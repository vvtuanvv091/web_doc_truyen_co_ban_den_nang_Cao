@model web_doc_truyen_Co_ban.Models.ChapterCommentModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chỉnh Sửa Bình Luận";
    ViewData["ActiveMenu"] = "ChapterComment";
}

@section Styles {
    <style>
        .card {
            background: #fff;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
            overflow: hidden;
        }

        .card-header {
            padding: 14px 18px;
            border-bottom: 1px solid #e2e8f0;
            background: #f8fafc;
            font-size: .95rem;
            font-weight: 700;
            color: #1e293b;
        }

        .card-body {
            padding: 20px;
        }

        .info-box {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 16px;
            margin-bottom: 18px;
        }

        .content {
            font-size: .9rem;
            line-height: 1.7;
            color: #374151;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: .78rem;
            font-weight: 700;
        }

        .b-show {
            background: #dcfce7;
            color: #15803d;
        }

        .b-hide {
            background: #fef3c7;
            color: #92400e;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 9px 16px;
            border: none;
            border-radius: 8px;
            text-decoration: none;
            font-size: .84rem;
            font-weight: 700;
            cursor: pointer;
            transition: .15s;
        }

        .btn-ok {
            background: #dcfce7;
            color: #15803d;
            border: 1px solid #bbf7d0;
        }

            .btn-ok:hover {
                background: #bbf7d0;
            }

        .btn-warn {
            background: #fef3c7;
            color: #92400e;
            border: 1px solid #fde68a;
        }

            .btn-warn:hover {
                background: #fde68a;
            }

        .btn-secondary {
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #e2e8f0;
        }

            .btn-secondary:hover {
                background: #e2e8f0;
            }

        .meta {
            display: grid;
            grid-template-columns: 140px 1fr;
            gap: 10px;
            font-size: .84rem;
            margin-bottom: 10px;
        }

            .meta label {
                color: #94a3b8;
                font-weight: 700;
            }

            .meta span {
                color: #1e293b;
                font-weight: 600;
            }
    </style>
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:10px">
    <h2 style="margin:0;font-size:1.2rem;font-weight:800;color:#1e293b">
        <i class="bi bi-pencil-square me-2"></i>Chỉnh Sửa Bình Luận
    </h2>

    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:#dcfce7;border:1px solid #bbf7d0;color:#15803d;padding:12px 14px;border-radius:8px;margin-bottom:16px;font-size:.84rem">
        <i class="bi bi-check-circle-fill me-1"></i>
        @TempData["Success"]
    </div>
}

<div class="card">
    <div class="card-header">
        <i class="bi bi-chat-left-text me-1"></i>
        Thông Tin Bình Luận
    </div>

    <div class="card-body">

        <div class="meta">
            <label>ID</label>
            <span>#@Model.Id</span>
        </div>

        <div class="meta">
            <label>Người dùng</label>
            <span>@Model.User?.Username</span>
        </div>
        <div class="meta">
            <label>Truyện</label>
            <span>@Model.Chapter.Story.Title</span>
        </div>
        <div class="meta">
            <label>Chương</label>
            <span>@Model.Chapter.Title</span>
        </div>

        <div class="meta">
            <label>Ngày tạo</label>
            <span>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
        </div>

        <div class="meta">
            <label>Trạng thái</label>
            <span>
                @if (Model.Status == 0)
                {
                    <span class="badge b-show">
                        <i class="bi bi-eye"></i> Hiển thị
                    </span>
                }
                else
                {
                    <span class="badge b-hide">
                        <i class="bi bi-eye-slash"></i> Đã ẩn
                    </span>
                }
            </span>
        </div>

        <div class="info-box">
            <div class="content">@Model.Content</div>
        </div>

        <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()

            <div style="display:flex;gap:10px;flex-wrap:wrap">

                @if (Model.Status == 0)
                {
                    <button type="submit" class="btn btn-warn">
                        <i class="bi bi-eye-slash"></i>
                        Ẩn bình luận
                    </button>
                }
                else
                {
                    <button type="submit" class="btn btn-ok">
                        <i class="bi bi-eye"></i>
                        Hiện bình luận
                    </button>
                }

                <a asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-secondary">
                    <i class="bi bi-arrow-left-circle"></i>
                    Chi tiết
                </a>

            </div>
        </form>

    </div>
</div>