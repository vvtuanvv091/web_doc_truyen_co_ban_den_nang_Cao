@model List<web_doc_truyen_Co_ban.Models.ChapterCommentModel>
@{
    ViewData["Title"] = "Quản lý Bình luận Chương";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    int page = (int)(ViewBag.Page ?? 1);
    int totalPages = (int)(ViewBag.TotalPages ?? 1);
    int total = (int)(ViewBag.Total ?? 0);
    int pageSize = (int)(ViewBag.PageSize ?? 15);
    string? search = ViewData["Search"] as string;
    string? storyId = ViewData["StoryId"] as string;
    string? chapterId = ViewData["ChapterId"] as string;
    int? statusFilter = ViewData["Status"] as int?;
}

@section Styles {
<style>
    :root {
        --ink: #0f1117;
        --ink-soft: #3a3d4a;
        --ink-muted: #7c8190;
        --surface: #ffffff;
        --surface-raised: #f8f9fc;
        --surface-sunken: #f0f2f7;
        --border: #e4e7ef;
        --border-strong: #c9cdd9;
        --accent: #4361ee;
        --accent-hover: #3451d1;
        --accent-soft: #eef1ff;
        --success: #22c55e;
        --success-soft: #f0fdf4;
        --warning: #f59e0b;
        --warning-soft: #fffbeb;
        --danger: #ef4444;
        --danger-soft: #fef2f2;
        --info: #06b6d4;
        --info-soft: #ecfeff;
        --radius: 10px;
        --radius-sm: 6px;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
        --shadow: 0 4px 12px rgba(0,0,0,.08);
        --shadow-lg: 0 8px 24px rgba(0,0,0,.1);
        --font-sans: 'Be Vietnam Pro', 'Segoe UI', system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
    }

    * { box-sizing: border-box; }

    body { font-family: var(--font-sans); color: var(--ink); background: var(--surface-raised); }

    /* ─── Page header ─── */
    .page-header {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding: 20px 24px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }
    .page-header h1 {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--ink);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .page-header h1 i { color: var(--accent); font-size: 1.4rem; }
    .breadcrumb-nav { font-size: .78rem; color: var(--ink-muted); margin-top: 3px; }
    .breadcrumb-nav a { color: var(--accent); text-decoration: none; }

    /* ─── Stat cards ─── */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }
    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: var(--shadow-sm);
        transition: box-shadow .2s, transform .2s;
    }
    .stat-card:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
    .stat-icon {
        width: 44px; height: 44px;
        border-radius: var(--radius-sm);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }
    .stat-icon.blue   { background: var(--accent-soft); color: var(--accent); }
    .stat-icon.green  { background: var(--success-soft); color: var(--success); }
    .stat-icon.yellow { background: var(--warning-soft); color: var(--warning); }
    .stat-icon.red    { background: var(--danger-soft); color: var(--danger); }
    .stat-label { font-size: .75rem; color: var(--ink-muted); margin-bottom: 2px; }
    .stat-value { font-size: 1.5rem; font-weight: 700; line-height: 1; color: var(--ink); }

    /* ─── Charts row ─── */
    .chart-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 24px;
    }
    @@media(max-width:768px) { .chart-grid { grid-template-columns: 1fr; } }
    .chart-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        box-shadow: var(--shadow-sm);
    }
    .chart-card h2 { font-size: .9rem; font-weight: 700; color: var(--ink); margin: 0 0 16px; display: flex; align-items: center; gap: 8px; }
    .chart-card h2 i { color: var(--accent); }

    /* ─── Filter card ─── */
    .filter-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px 20px;
        margin-bottom: 20px;
        box-shadow: var(--shadow-sm);
    }
    .filter-row { display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end; }
    .filter-group { display: flex; flex-direction: column; gap: 4px; flex: 1; min-width: 160px; }
    .filter-group label { font-size: .72rem; font-weight: 600; color: var(--ink-muted); text-transform: uppercase; letter-spacing: .04em; }
    .filter-group .form-control,
    .filter-group .form-select {
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-sm);
        font-size: .83rem;
        padding: 7px 10px;
        background: var(--surface);
        color: var(--ink);
        transition: border-color .15s, box-shadow .15s;
    }
    .filter-group .form-control:focus,
    .filter-group .form-select:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(67,97,238,.15);
    }

    /* ─── Table card ─── */
    .table-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        margin-bottom: 20px;
    }
    .table-card-header {
        padding: 14px 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }
    .table-card-header h3 { font-size: .9rem; font-weight: 700; margin: 0; color: var(--ink); display: flex; align-items: center; gap: 8px; }
    .table-card-header h3 i { color: var(--accent); }
    .badge-count {
        background: var(--accent);
        color: #fff;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: .72rem;
        font-weight: 700;
    }

    /* ─── Table ─── */
    .comment-table { width: 100%; border-collapse: collapse; font-size: .82rem; }
    .comment-table thead th {
        background: var(--surface-sunken);
        color: var(--ink-muted);
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        padding: 10px 14px;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
    }
    .comment-table tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background .12s;
    }
    .comment-table tbody tr:last-child { border-bottom: none; }
    .comment-table tbody tr:hover { background: var(--surface-raised); }
    .comment-table td { padding: 12px 14px; vertical-align: middle; }

    /* avatar */
    .user-cell { display: flex; align-items: center; gap: 10px; }
    .avatar {
        width: 34px; height: 34px;
        border-radius: 50%;
        background: var(--accent-soft);
        color: var(--accent);
        font-weight: 700; font-size: .85rem;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .user-name { font-weight: 600; color: var(--ink); line-height: 1.2; }
    .user-meta { font-size: .7rem; color: var(--ink-muted); }

    /* comment content preview */
    .comment-preview { max-width: 300px; }
    .comment-text {
        color: var(--ink-soft);
        line-height: 1.45;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .comment-meta-row { display: flex; gap: 6px; margin-top: 4px; align-items: center; flex-wrap: wrap; }

    /* chapter badge */
    .chapter-badge {
        display: inline-flex; align-items: center; gap: 4px;
        background: var(--accent-soft); color: var(--accent);
        border-radius: 4px; padding: 1px 7px;
        font-size: .68rem; font-weight: 600;
        white-space: nowrap;
        max-width: 200px; overflow: hidden; text-overflow: ellipsis;
    }
    .story-name { font-size: .7rem; color: var(--ink-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 160px; display: block; }

    /* status badge */
    .status-badge {
        display: inline-flex; align-items: center; gap: 5px;
        border-radius: 20px; padding: 3px 10px;
        font-size: .7rem; font-weight: 700;
        white-space: nowrap;
    }
    .status-badge.visible { background: var(--success-soft); color: var(--success); }
    .status-badge.hidden  { background: var(--warning-soft); color: var(--warning); }
    .status-badge.deleted { background: var(--danger-soft); color: var(--danger); }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

    /* replies chip */
    .replies-chip {
        display: inline-flex; align-items: center; gap: 4px;
        background: var(--surface-sunken); color: var(--ink-muted);
        border-radius: 12px; padding: 2px 8px;
        font-size: .7rem; font-weight: 600;
    }

    /* timestamp */
    .timestamp { font-size: .72rem; color: var(--ink-muted); white-space: nowrap; }

    /* ─── Action buttons ─── */
    .action-cell { display: flex; gap: 6px; align-items: center; }
    .btn-icon {
        width: 30px; height: 30px;
        border-radius: var(--radius-sm);
        display: inline-flex; align-items: center; justify-content: center;
        border: 1px solid transparent;
        cursor: pointer;
        font-size: .85rem;
        transition: all .15s;
        text-decoration: none;
    }
    .btn-icon.view   { background: var(--info-soft); color: var(--info); border-color: #a5f3fc; }
    .btn-icon.edit   { background: var(--accent-soft); color: var(--accent); border-color: #c7d2fe; }
    .btn-icon.toggle { background: var(--warning-soft); color: var(--warning); border-color: #fde68a; }
    .btn-icon.delete { background: var(--danger-soft); color: var(--danger); border-color: #fecaca; }
    .btn-icon:hover { filter: brightness(.9); transform: scale(1.08); }

    /* ─── Pagination ─── */
    .pagination-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 20px;
        border-top: 1px solid var(--border);
        font-size: .78rem;
        color: var(--ink-muted);
        flex-wrap: wrap;
        gap: 10px;
    }
    .pagination { display: flex; gap: 4px; list-style: none; margin: 0; padding: 0; }
    .pagination .page-item .page-link {
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--ink-soft);
        text-decoration: none;
        font-size: .78rem;
        transition: all .15s;
    }
    .pagination .page-item.active .page-link { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 700; }
    .pagination .page-item.disabled .page-link { opacity: .4; pointer-events: none; }
    .pagination .page-item .page-link:hover:not(.page-item.active .page-link) { background: var(--accent-soft); color: var(--accent); border-color: var(--accent); }

    /* ─── Empty state ─── */
    .empty-state { text-align: center; padding: 60px 20px; color: var(--ink-muted); }
    .empty-state i { font-size: 3rem; margin-bottom: 12px; opacity: .3; }
    .empty-state p { margin: 0; font-size: .9rem; }

    /* ─── Alert ─── */
    .toast-alert {
        border-radius: var(--radius-sm);
        padding: 10px 16px;
        font-size: .83rem;
        font-weight: 500;
        display: flex; align-items: center; gap: 8px;
        margin-bottom: 16px;
        border: 1px solid transparent;
    }
    .toast-alert.success { background: var(--success-soft); color: #15803d; border-color: #bbf7d0; }
    .toast-alert.error   { background: var(--danger-soft);  color: #b91c1c; border-color: #fecaca; }

    /* ─── Filter chip (active filter indicator) ─── */
    .filter-chips { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
    .filter-chip {
        background: var(--accent-soft); color: var(--accent);
        border-radius: 20px; padding: 2px 10px 2px 8px;
        font-size: .72rem; font-weight: 600;
        display: inline-flex; align-items: center; gap: 5px;
    }
    .filter-chip a { color: inherit; text-decoration: none; opacity: .6; }
    .filter-chip a:hover { opacity: 1; }

    /* ─── Spinner ─── */
    .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,.4); border-top-color: #fff; border-radius: 50%; animation: spin .6s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* ─── Responsive tweaks ─── */
    @@media(max-width:600px) {
        .comment-table thead th:nth-child(4),
        .comment-table tbody td:nth-child(4) { display: none; }
    }
</style>
}

<!-- ══════════════════════════════════════════════════════════════
     PAGE HEADER
═══════════════════════════════════════════════════════════════ -->
<div class="page-header">
    <div>
        <h1><i class="ti ti-message-dots"></i> Bình luận Chương</h1>
        <div class="breadcrumb-nav">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            <span class="mx-1">/</span>
            <span>Bình luận chương</span>
        </div>
    </div>
</div>

<div class="container-fluid px-3 pb-4">

    @if (TempData["Success"] != null)
    {
        <div class="toast-alert success" id="toastAlert">
            <i class="ti ti-circle-check"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-alert error" id="toastAlert">
            <i class="ti ti-alert-circle"></i> @TempData["Error"]
        </div>
    }

    <!-- ── STAT CARDS ── -->
    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-chat-dots-fill"></i></div>
            <div>
                <div class="stat-label">Tất cả</div>
                <div class="stat-value" id="statTotal">@ViewBag.TotalAll</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-eye-fill"></i></div>
            <div>
                <div class="stat-label">Hiển thị</div>
                <div class="stat-value" id="statVisible">@ViewBag.TotalVisible</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon yellow"><i class="bi bi-eye-slash-fill"></i></div>
            <div>
                <div class="stat-label">Đã ẩn</div>
                <div class="stat-value" id="statHidden">@ViewBag.TotalHidden</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-trash3-fill"></i></div>
            <div>
                <div class="stat-label">Đã xóa</div>
                <div class="stat-value" id="statDeleted">@ViewBag.TotalDeleted</div>
            </div>
        </div>
    </div>

    <!-- ── CHARTS ── -->
    <div class="chart-grid">
        <div class="chart-card">
            <h2><i class="ti ti-chart-bar"></i> Bình luận 7 ngày gần nhất</h2>
            <canvas id="chartWeekly" height="130"></canvas>
        </div>
        <div class="chart-card">
            <h2><i class="ti ti-chart-donut"></i> Top 5 chương nhiều bình luận</h2>
            <canvas id="chartTopChapters" height="130"></canvas>
        </div>
    </div>

    <!-- ── FILTER ── -->
    <div class="filter-card">
        <form method="get" asp-action="Index" id="filterForm">
            <div class="filter-row">
                <div class="filter-group" style="flex:2; min-width:200px;">
                    <label>Tìm kiếm</label>
                    <input type="text" name="search" value="@search" class="form-control"
                           placeholder="Nội dung hoặc tên người dùng…" />
                </div>
                <div class="filter-group">
                    <label>Truyện</label>
                    <select name="storyId" class="form-select" id="storyFilter">
                        <option value="">— Tất cả truyện —</option>
                        @foreach (var s in (ViewBag.Stories as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>()))
                        {
                            <option value="@s.Id" selected="@(storyId == s.Id.ToString() ? "selected" : "")">@s.Title</option>
                        }
                    </select>
                </div>
                <div class="filter-group">
                    <label>Chương</label>
                    <select name="chapterId" class="form-select" id="chapterFilter">
                        <option value="">— Tất cả chương —</option>
                        @foreach (var ch in (ViewBag.Chapters as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>()))
                        {
                            <option value="@ch.Id"
                                    data-story="@ch.StoryId" selected="@(chapterId == ch.Id.ToString() ? "selected" : "")"
                                    >@ch.Title</option>
                        }
                    </select>
                </div>
                <div class="filter-group" style="min-width:140px;">
                    <label>Trạng thái</label>
                    <select name="status" class="form-select">
                        <option value="">— Tất cả —</option>
                        <option value="0" selected="@statusFilter==1">Hiển thị</option>
                        <option value="1" selected="@statusFilter==2">Đã ẩn</option>
                        <option value="2" selected="@statusFilter==3">Đã xóa</option>
                    </select>
                </div>
                <div class="filter-group" style="flex:0; min-width:auto;">
                    <label>&nbsp;</label>
                    <div style="display:flex;gap:6px;">
                        <button type="submit" class="btn btn-primary btn-sm" style="border-radius:var(--radius-sm);padding:7px 14px;font-size:.82rem;white-space:nowrap;">
                            <i class="ti ti-search me-1"></i> Lọc
                        </button>
                        <a asp-action="Index" class="btn btn-sm" style="border:1px solid var(--border);border-radius:var(--radius-sm);padding:7px 10px;font-size:.82rem;color:var(--ink-muted);background:var(--surface);white-space:nowrap;">
                            <i class="ti ti-refresh"></i>
                        </a>
                    </div>
                </div>
            </div>

            @{
                var chips = new List<(string label, string removeParam)>();
                if (!string.IsNullOrWhiteSpace(search))    chips.Add(($"Từ khóa: {search}", "search"));
                if (!string.IsNullOrWhiteSpace(storyId))   chips.Add(("Truyện đã chọn", "storyId"));
                if (!string.IsNullOrWhiteSpace(chapterId)) chips.Add(("Chương đã chọn", "chapterId"));
                if (statusFilter.HasValue)                  chips.Add(($"Trạng thái: {(statusFilter == 0 ? "Hiển thị" : statusFilter == 1 ? "Đã ẩn" : "Đã xóa")}", "status"));
            }
            @if (chips.Any())
            {
                <div class="filter-chips">
                    @foreach (var chip in chips)
                    {
                        <span class="filter-chip">
                            @chip.label
                            <a href="@Url.Action("Index", new {
                                search     = chip.removeParam == "search"    ? null : search,
                                storyId    = chip.removeParam == "storyId"   ? null : storyId,
                                chapterId  = chip.removeParam == "chapterId" ? null : chapterId,
                                status     = chip.removeParam == "status"    ? (int?)null : statusFilter
                            })">✕</a>
                        </span>
                    }
                </div>
            }
        </form>
    </div>

    <!-- ── TABLE ── -->
    <div class="table-card">
        <div class="table-card-header">
            <h3><i class="ti ti-list-details"></i> Danh sách bình luận <span class="badge-count">@total</span></h3>
            <span style="font-size:.78rem;color:var(--ink-muted);">
                Trang @@page / @totalPages &nbsp;·&nbsp; Hiển thị @Math.Min(pageSize, Model.Count) / @total bản ghi
            </span>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <div><i class="ti ti-message-off"></i></div>
                <p>Không tìm thấy bình luận nào phù hợp với bộ lọc.</p>
            </div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="comment-table">
                    <thead>
                        <tr>
                            <th style="width:200px;">Người dùng</th>
                            <th>Nội dung</th>
                            <th style="width:180px;">Chương / Truyện</th>
                            <th style="width:110px;">Trạng thái</th>
                            <th style="width:110px;">Ngày tạo</th>
                            <th style="width:120px;text-align:center;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            string initials = c.User?.Username?.Length > 0
                                ? c.User.Username.Substring(0, 1).ToUpper()
                                : "?";
                            string statusClass = c.Status == 0 ? "visible" : c.Status == 1 ? "hidden" : "deleted";
                            string statusLabel = c.Status == 0 ? "Hiển thị" : c.Status == 1 ? "Đã ẩn" : "Đã xóa";
                            string statusIcon  = c.Status == 0 ? "ti-eye" : c.Status == 1 ? "ti-eye-off" : "ti-trash";
                            int replyCount = c.Replies?.Count ?? 0;

                            <tr>
                                <!-- User -->
                                <td>
                                    <div class="user-cell">
                                        <div class="avatar">@initials</div>
                                        <div>
                                            <div class="user-name">@(c.User?.Username ?? "Ẩn danh")</div>
                                            <div class="user-meta">@(c.User?.Email ?? "")</div>
                                        </div>
                                    </div>
                                </td>

                                <!-- Content -->
                                <td>
                                    <div class="comment-preview">
                                        @if (c.ParentId.HasValue)
                                        {
                                            <span style="font-size:.68rem;background:var(--surface-sunken);color:var(--ink-muted);border-radius:3px;padding:1px 6px;margin-bottom:4px;display:inline-block;">
                                                <i class="ti ti-corner-down-right"></i> Phản hồi
                                            </span>
                                        }
                                        <div class="comment-text" title="@c.Content">@c.Content</div>
                                        <div class="comment-meta-row">
                                            @if (replyCount > 0)
                                            {
                                                <span class="replies-chip">
                                                    <i class="ti ti-messages" style="font-size:.65rem;"></i> @replyCount trả lời
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </td>

                                <!-- Chapter / Story -->
                                <td>
                                    @if (c.Chapter != null)
                                    {
                                        <span class="chapter-badge" title="@c.Chapter.Title">
                                            <i class="ti ti-book" style="font-size:.65rem;"></i>
                                            @(c.Chapter.Title?.Length > 22 ? c.Chapter.Title.Substring(0, 22) + "…" : c.Chapter.Title)
                                        </span>
                                        @if (c.Chapter.Story != null)
                                        {
                                            <span class="story-name" title="@c.Chapter.Story.Title">@c.Chapter.Story.Title</span>
                                        }
                                    }
                                </td>

                                <!-- Status -->
                                <td>
                                    <span class="status-badge @statusClass">
                                        <span class="status-dot"></span> @statusLabel
                                    </span>
                                </td>

                                <!-- Date -->
                                <td class="timestamp">
                                    @c.CreatedAt.ToString("dd/MM/yyyy")<br />
                                    <span style="opacity:.6;">@c.CreatedAt.ToString("HH:mm")</span>
                                </td>

                                <!-- Actions -->
                                <td>
                                    <div class="action-cell" style="justify-content:center;">
                                        <!-- View detail -->
                                        <a asp-action="Detail" asp-route-id="@c.Id"
                                           class="btn-icon view" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <!-- Edit -->
                                        @if (c.Status != 2)
                                        {
                                            <a asp-action="Edit" asp-route-id="@c.Id"
                                               class="btn-icon edit" title="Chỉnh sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }

                                        <!-- Toggle hide/show -->
                                        @if (c.Status != 2)
                                        {
                                            <button type="button"
                                                    class="btn-icon toggle btn-toggle"
                                                    data-id="@c.Id"
                                                    data-status="@c.Status"
                                                    title="@(c.Status == 0 ? "Ẩn bình luận" : "Hiện bình luận")">
                                                <i class="bi @(c.Status == 0 ? "bi-eye-slash" : "bi-eye")"></i>
                                            </button>
                                        }

                                        <!-- Delete -->
                                        @if (c.Status != 2)
                                        {
                                            <a asp-action="Delete" asp-route-id="@c.Id"
                                               class="btn-icon delete" title="Xóa bình luận">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="pagination-row">
                    <span>
                        Hiển thị <strong>@((page - 1) * pageSize + 1)–@Math.Min(page * pageSize, total)</strong>
                        trong <strong>@total</strong> bình luận
                    </span>
                    <ul class="pagination">
                        <li class="page-item @(page <= 1 ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { search, storyId, chapterId, status = statusFilter, page = page - 1 })">
                                <i class="ti ti-chevron-left" style="font-size:.7rem;"></i>
                            </a>
                        </li>

                        @{
                            int startPage = Math.Max(1, page - 2);
                            int endPage   = Math.Min(totalPages, startPage + 4);
                            if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);
                        }

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { search, storyId, chapterId, status = statusFilter, page = 1 })">1</a>
                            </li>
                            @if (startPage > 2) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                        }

                        @for (int p = startPage; p <= endPage; p++)
                        {
                            <li class="page-item @(p == page ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { search, storyId, chapterId, status = statusFilter, page = p })">@p</a>
                            </li>
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { search, storyId, chapterId, status = statusFilter, page = totalPages })">@totalPages</a>
                            </li>
                        }

                        <li class="page-item @(page >= totalPages ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { search, storyId, chapterId, status = statusFilter, page = page + 1 })">
                                <i class="ti ti-chevron-right" style="font-size:.7rem;"></i>
                            </a>
                        </li>
                    </ul>
                </div>
            }
        }
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     CONFIRM DELETE MODAL
═══════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="border-radius:var(--radius);border:none;box-shadow:var(--shadow-lg);">
            <div class="modal-header" style="border-bottom:1px solid var(--border);padding:16px 20px;">
                <h5 class="modal-title" style="font-size:.95rem;font-weight:700;color:var(--danger);display:flex;align-items:center;gap:8px;">
                    <i class="ti ti-alert-triangle"></i> Xác nhận xóa
                </h5>
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:16px 20px;font-size:.85rem;color:var(--ink-soft);">
                Bạn có chắc muốn xóa bình luận này? Toàn bộ phản hồi cũng sẽ bị xóa theo.
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--border);padding:12px 16px;gap:8px;">
                <button class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger">
                        <i class="ti ti-trash me-1"></i> Xóa
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
// ── Auto-dismiss toast ──
const toast = document.getElementById('toastAlert');
if (toast) setTimeout(() => { toast.style.opacity = '0'; toast.style.transition = 'opacity .5s'; setTimeout(() => toast.remove(), 500); }, 4000);

// ── Chapter filter dependent on story ──
document.getElementById('storyFilter')?.addEventListener('change', function () {
    const sid = this.value;
    const cf = document.getElementById('chapterFilter');
    Array.from(cf.options).forEach(opt => {
        if (!opt.value) return;
        opt.hidden = sid ? opt.dataset.story !== sid : false;
    });
    cf.value = '';
});
// init on load
(function () {
    const sid = document.getElementById('storyFilter')?.value;
    if (sid) {
        const cf = document.getElementById('chapterFilter');
        Array.from(cf.options).forEach(opt => {
            if (!opt.value) return;
            opt.hidden = opt.dataset.story !== sid;
        });
    }
})();

// ── AJAX Toggle hide/show ──
document.querySelectorAll('.btn-toggle').forEach(btn => {
    btn.addEventListener('click', async function () {
        const id = this.dataset.id;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        const icon = this.querySelector('i');

        this.disabled = true;
        icon.className = 'spinner';

        try {
            const res = await fetch('@Url.Action("ToggleStatus")/' + id, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': token ?? '',
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'id=' + id
            });
            const data = await res.json();
            if (data.success) {
                const row = this.closest('tr');
                const statusCell = row.querySelector('.status-badge');
                const isVisible = data.newStatus === 0;

                statusCell.className = 'status-badge ' + (isVisible ? 'visible' : 'hidden');
                statusCell.innerHTML = '<span class="status-dot"></span>' + (isVisible ? 'Hiển thị' : 'Đã ẩn');
                icon.className = 'ti ' + (isVisible ? 'ti-eye-off' : 'ti-eye');
                this.title = isVisible ? 'Ẩn bình luận' : 'Hiện bình luận';
                this.dataset.status = data.newStatus;

                // Refresh stat cards
                refreshStats();
            }
        } catch (e) { console.error(e); icon.className = 'ti ti-refresh'; }

        this.disabled = false;
    });
});

async function refreshStats() {
    try {
        const res = await fetch('@Url.Action("Stats")');
        const d = await res.json();
        document.getElementById('statTotal').textContent   = d.total;
        document.getElementById('statVisible').textContent = d.visible;
        document.getElementById('statHidden').textContent  = d.hidden;
        document.getElementById('statDeleted').textContent = d.deleted;
    } catch {}
}

// ── Charts ──
const chartColors = {
    accent: '#4361ee',
    success: '#22c55e',
    warning: '#f59e0b',
    danger: '#ef4444',
    info: '#06b6d4',
    grid: '#e4e7ef',
    muted: '#7c8190'
};

const commonOptions = {
    responsive: true,
    maintainAspectRatio: true,
    plugins: { legend: { display: false }, tooltip: { boxPadding: 4, cornerRadius: 6 } }
};

// Weekly bar chart
(async function () {
    try {
        const res = await fetch('@Url.Action("ChartWeekly")');
        const data = await res.json();
        const ctx = document.getElementById('chartWeekly').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: data.map(d => d.date),
                datasets: [{
                    label: 'Bình luận',
                    data: data.map(d => d.count),
                    backgroundColor: 'rgba(67,97,238,.15)',
                    borderColor: chartColors.accent,
                    borderWidth: 2,
                    borderRadius: 6,
                    borderSkipped: false
                }]
            },
            options: {
                ...commonOptions,
                scales: {
                    x: { grid: { display: false }, ticks: { font: { size: 11 }, color: chartColors.muted } },
                    y: {
                        beginAtZero: true, grid: { color: chartColors.grid },
                        ticks: { precision: 0, font: { size: 11 }, color: chartColors.muted }
                    }
                }
            }
        });
    } catch (e) { console.error('Weekly chart error', e); }
})();

// Top chapters doughnut / horizontal bar
(async function () {
    try {
        const res = await fetch('@Url.Action("ChartTopChapters")');
        const data = await res.json();
        const ctx = document.getElementById('chartTopChapters').getContext('2d');
        const palette = [chartColors.accent, chartColors.success, chartColors.warning, chartColors.danger, chartColors.info];
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: data.map(d => d.title?.length > 24 ? d.title.substring(0, 24) + '…' : d.title),
                datasets: [{
                    label: 'Bình luận',
                    data: data.map(d => d.count),
                    backgroundColor: palette,
                    borderRadius: 6,
                    borderSkipped: false
                }]
            },
            options: {
                ...commonOptions,
                indexAxis: 'y',
                scales: {
                    x: {
                        beginAtZero: true, grid: { color: chartColors.grid },
                        ticks: { precision: 0, font: { size: 11 }, color: chartColors.muted }
                    },
                    y: { grid: { display: false }, ticks: { font: { size: 11 }, color: chartColors.muted } }
                }
            }
        });
    } catch (e) { console.error('Top chapters chart error', e); }
})();
</script>
}
