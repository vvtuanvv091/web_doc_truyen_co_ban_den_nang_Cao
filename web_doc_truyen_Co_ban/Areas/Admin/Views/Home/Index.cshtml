@model web_doc_truyen_Co_ban.Models.DashBoardModel

@{
    ViewData["Title"] = "Dashboard Tổng Quan";
    
}

<div class="container-fluid py-4 bg-light">
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm p-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted small fw-bold text-uppercase">Tổng User</div>
                        <h3 class="fw-bold my-1">@Model.TongUser.ToString("#,##0")</h3>
                        <span class="text-success small fw-bold">↑ +2% tháng trước</span>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary">
                        <i class="bi bi-people-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm p-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted small fw-bold text-uppercase">Tổng Xu Nạp</div>
                        <h3 class="fw-bold my-1">@Model.TongDonate.ToString("#,##0")</h3>
                        <span class="text-success small fw-bold">↑ +8% tháng trước</span>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-2 rounded-3 text-warning">
                        <i class="bi bi-coin fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm p-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted small fw-bold text-uppercase">Theo Dõi</div>
                        <h3 class="fw-bold my-1">@Model.TongTheoDoi.ToString("#,##0")</h3>
                        <span class="text-secondary small fw-bold">→ 0% tháng trước</span>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-2 rounded-3 text-danger">
                        <i class="bi bi-heart-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm p-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted small fw-bold text-uppercase">Bookmark</div>
                        <h3 class="fw-bold my-1">@Model.TongBookmark.ToString("#,##0")</h3>
                        <span class="text-success small fw-bold">↑ +4% tháng trước</span>
                    </div>
                    <div class="bg-info bg-opacity-10 p-2 rounded-3 text-info">
                        <i class="bi bi-bookmark-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm d-flex flex-row align-items-center p-3">
                <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3"><i class="bi bi-book fs-4"></i></div>
                <div>
                    
                    <h6 class="fw-bold mb-0">@Model.TongTruyen Truyện</h6>
                    <small class="text-muted">@Model.TongChuong.ToString("#,##0") chương đã đăng</small>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm d-flex flex-row align-items-center p-3">
                <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3"><i class="bi bi-chat-dots fs-4"></i></div>
                <div>
                    <h6 class="fw-bold mb-0">@Model.TongBinhLuan.ToString("#,##0") Bình luận</h6>
                    <small class="text-muted">@Model.TongDanhGia lượt đánh giá mời nhất</small>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm d-flex flex-row align-items-center p-3">
                <div class="bg-dark bg-opacity-10 p-3 rounded-3 me-3"><i class="bi bi-star-fill fs-4"></i></div>
                <div>
                    <h6 class="fw-bold mb-0">@Model.TongDanhGia.ToString("#,##0") Đánh giá</h6>
                    <small class="text-muted">Từ @Model.TongUser.ToString("#,##0") người đọc</small>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm d-flex flex-row align-items-center p-3">
                <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3"><i class="bi bi-heart-pulse fs-4"></i></div>
                <div>
                    <h6 class="fw-bold mb-0">@Model.TongTheoDoi.ToString("#,##0") Theo dõi</h6>
                    <small class="text-muted">@Model.TongBookmark.ToString("#,##0") bookmark</small>
                </div>
            </div>
        </div>
    </div>

