@model web_doc_truyen_Co_ban.Models.StoryModel

@* Xóa <head> CKEditor 5 — dùng CKEditor 4 thôi *@

<div class="container-fluid px-4">
    <h2 class="mt-4">Thêm truyện mới</h2>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-action="Index">Danh sách truyện</a></li>
        <li class="breadcrumb-item active">Thêm mới</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header"><i class="fas fa-book me-1"></i> Thông tin truyện</div>
        <div class="card-body">

            
            <form asp-area="Admin" asp-controller="Story" asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Title" class="form-label">Tiêu đề <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề truyện..." />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Slug" class="form-label">Slug <span class="text-danger">*</span></label>
                        <input asp-for="Slug" class="form-control" placeholder="ten-truyen-viet-khong-dau" />
                        <span asp-validation-for="Slug" class="text-danger"></span>
                        <div class="form-text">Để trống sẽ tự tạo từ tiêu đề.</div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryId" class="form-label">Danh mục <span class="text-danger">*</span></label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                            <option value="" disabled selected>-- Chọn danh mục --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Thẻ Tag <span class="text-danger">*</span></label>
                        <select name="selectedTags" asp-items="ViewBag.Tags" class="form-select" multiple>
                        </select>
                    </div>
                </div>
                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="OriginalAuthor" class="form-label">Tác giả gốc</label>
                        <input asp-for="OriginalAuthor" class="form-control" placeholder="Tên tác giả gốc..." />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Source" class="form-label">Nguồn dịch</label>
                        <input asp-for="Source" class="form-control" placeholder="Nguồn/nhóm dịch..." />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Mô tả</label>
                    <textarea asp-for="Description" id="Description" class="form-control" rows="4"></textarea>
                </div>

                <!-- Ảnh bìa -->
                <div class="mb-3">
                    <label class="form-label">Ảnh bìa</label>
                    <div class="btn-group mb-2 d-flex" style="max-width:300px">
                        <button type="button" class="btn btn-sm btn-primary" id="btnUrl" onclick="switchTab('url')">
                            🔗 Nhập URL
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="btnFile" onclick="switchTab('file')">
                            📁 Upload từ máy
                        </button>
                    </div>

                    <div id="tabUrl">
                        <input asp-for="CoverImageUrl" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="CoverImageUrl" class="text-danger"></span>
                    </div>

                    <div id="tabFile" style="display:none">
                        <input type="file" name="coverFile" id="fileUpload" accept="image/*"
                               class="form-control" onchange="previewAndFillUrl(this)" />
                        <div class="form-text">Hỗ trợ: JPG, PNG, WEBP. Tối đa 2MB.</div>
                    </div>

                    <div id="previewBox" class="mt-2" style="display:none">
                        <img id="previewImg" src="" alt="Preview"
                             style="max-height:180px; border-radius:8px; border:1px solid #dee2e6;" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label asp-for="Status" class="form-label">Trạng thái</label>
                        <select asp-for="Status" class="form-select">
                            <option value="0">Bản nháp</option>
                            <option value="1" selected>Đang ra</option>
                            <option value="2">Hoàn thành</option>
                            <option value="3">Tạm dừng</option>
                            <option value="4">Drop</option>
                        </select>
                    </div>
                    <div class="col-md-9 mb-3 d-flex align-items-end gap-4">
                        <div class="form-check">
                            <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                            <label asp-for="IsFeatured" class="form-check-label">⭐ Nổi bật</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="IsVip" class="form-check-input" type="checkbox" />
                            <label asp-for="IsVip" class="form-check-label">👑 VIP</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Is18Plus" class="form-check-input" type="checkbox" />
                            <label asp-for="Is18Plus" class="form-check-label">🔞 18+</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i> Lưu truyện
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

  
    @* <script src="https://cdn.ckeditor.com/4.25.1-lts/standard/ckeditor.js"></script> *@
    <script>
        // CKEditor 4
        // CKEDITOR.replace('Description');

        // Auto slug
        document.getElementById('Title').addEventListener('input', function () {
        const slugField = document.getElementById('Slug');
        if (!slugField.value) {
        slugField.value = this.value
        .toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9\s-]/g, '')
        .trim()
        .replace(/\s+/g, '-');
        }
        });
        
        
        function previewAndFillUrl(input) {
            const file = input.files[0];
            if (!file) return;

            if (file.size > 2 * 1024 * 1024) {
                alert('❌ File quá 2MB!');
                input.value = '';
                return;
            }

            // ✅ Xóa URL cũ đi để tránh conflict
            document.querySelector('input[name="CoverImageUrl"]').value = '';

            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('previewImg').src = e.target.result;
                document.getElementById('previewBox').style.display = 'block';
            };
            reader.readAsDataURL(file);
        }
        function switchTab(tab) {
        const isUrl = tab === 'url';
        document.getElementById('tabUrl').style.display  = isUrl ? 'block' : 'none';
        document.getElementById('tabFile').style.display = isUrl ? 'none'  : 'block';
        document.getElementById('btnUrl').className  = 'btn btn-sm ' + (isUrl ? 'btn-primary' : 'btn-outline-primary');
        document.getElementById('btnFile').className = 'btn btn-sm ' + (isUrl ? 'btn-outline-primary' : 'btn-primary');
        if (isUrl) {
        document.getElementById('fileUpload').value = '';
        document.getElementById('previewBox').style.display = 'none';
        }
        }

        function previewAndFillUrl(input) {
        const file = input.files[0];
        if (!file) return;

        if (file.size > 2 * 1024 * 1024) {
        alert('❌ File quá 2MB!');
        input.value = '';
        return;
        }

        // ✅ Chỉ preview, KHÔNG điền base64 nữa
        const reader = new FileReader();
        reader.onload = e => {
        document.getElementById('previewImg').src = e.target.result;
        document.getElementById('previewBox').style.display = 'block';
        };
        reader.readAsDataURL(file);
        }
    </script>
}