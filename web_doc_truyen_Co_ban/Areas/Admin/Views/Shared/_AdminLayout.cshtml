@{
    var adminDisplayName = Context.Session.GetString("Admin_DisplayName") ?? "Admin";
    var adminUsername = Context.Session.GetString("Admin_Username") ?? "admin";
    var adminAvatarUrl = Context.Session.GetString("Admin_AvatarUrl");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DASHMIN Admin</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <!-- Thêm vào <head> -->
    <link rel="stylesheet" 
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary:      #2563eb;
            --primary-light:#eff6ff;
            --sidebar-bg:   #ffffff;
            --sidebar-w:    240px;
            --topbar-h:     60px;
            --body-bg:      #f0f4f8;
            --text-main:    #1e293b;
            --text-muted:   #64748b;
            --border:       #e2e8f0;
            --card-shadow:  0 1px 4px rgba(0,0,0,.08);
            --radius:       10px;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Nunito', sans-serif;
            background: var(--body-bg);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
        }

        /* ─── SIDEBAR ──────────────────────────────────────── */
        #sidebar {
            width: var(--sidebar-w);
            height: 100vh;
            overflow-y: auto;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0;
            z-index: 1040;
            transition: transform .25s ease;
        }
        #sidebar::-webkit-scrollbar { width: 4px; }
        #sidebar::-webkit-scrollbar-track { background: transparent; }
        #sidebar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        #sidebar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        .sidebar-brand {
            height: var(--topbar-h);
            display: flex;
            align-items: center;
            padding: 0 20px;
            border-bottom: 1px solid var(--border);
            font-size: 1.25rem;
            font-weight: 800;
            color: var(--primary);
            text-decoration: none;
            letter-spacing: -.5px;
        }
        .sidebar-brand span { color: var(--text-muted); font-weight: 400; }

        .sidebar-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
        }
        .sidebar-user img {
            width: 38px; height: 38px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--primary);
        }
        .sidebar-user .name  { font-weight: 700; font-size: .85rem; line-height: 1.2; }
        .sidebar-user .role  { font-size: .72rem; color: var(--text-muted); }

        /* Role badge colour */
        .role-badge {
            display: inline-block;
            padding: 1px 8px;
            border-radius: 20px;
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
        }
        .role-admin     { background:#dbeafe; color:#1d4ed8; }
        .role-moderator { background:#dcfce7; color:#15803d; }
        .role-user      { background:#f3f4f6; color:#6b7280; }

        .sidebar-nav { flex: 1; padding: 12px 0; }

        .nav-section {
            padding: 6px 20px 4px;
            font-size: .65rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: #94a3b8;
        }

        .nav-link-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 20px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: .84rem;
            font-weight: 600;
            border-radius: 0;
            transition: all .15s;
            position: relative;
        }
        .nav-link-item:hover {
            color: var(--primary);
            background: var(--primary-light);
        }
        .nav-link-item.active {
            color: var(--primary);
            background: var(--primary-light);
            font-weight: 700;
        }
        .nav-link-item.active::before {
            content: '';
            position: absolute;
            left: 0; top: 4px; bottom: 4px;
            width: 3px;
            background: var(--primary);
            border-radius: 0 3px 3px 0;
        }
        .nav-link-item i { font-size: 1rem; width: 20px; text-align: center; }

        /* Collapsible sub-menu */
        .nav-has-sub .nav-arrow {
            margin-left: auto;
            font-size: .7rem;
            transition: transform .2s;
        }
        .nav-has-sub[aria-expanded="true"] .nav-arrow { transform: rotate(90deg); }
        .nav-sub { background: #f8fafc; }
        .nav-sub .nav-link-item { padding-left: 50px; font-size: .8rem; }

        /* ─── TOPBAR ────────────────────────────────────────── */
        #topbar {
            position: fixed;
            top: 0; left: var(--sidebar-w); right: 0;
            height: var(--topbar-h);
            background: #fff;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 24px;
            gap: 12px;
            z-index: 1030;
        }

        #sidebarToggle {
            background: none; border: none;
            color: var(--text-muted);
            font-size: 1.2rem;
            cursor: pointer;
            padding: 4px;
            display: none;
        }

        .topbar-search {
            flex: 1; max-width: 320px;
            position: relative;
        }
        .topbar-search input {
            width: 100%;
            padding: 7px 14px 7px 36px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--body-bg);
            font-family: inherit;
            font-size: .83rem;
            color: var(--text-main);
            outline: none;
            transition: border .15s;
        }
        .topbar-search input:focus { border-color: var(--primary); }
        .topbar-search i {
            position: absolute; left: 11px; top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted); font-size: .9rem;
        }

        .topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .topbar-btn {
            width: 36px; height: 36px;
            border: none;
            background: var(--body-bg);
            border-radius: 8px;
            color: var(--text-muted);
            font-size: 1rem;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            position: relative;
            transition: background .15s, color .15s;
        }
        .topbar-btn:hover { background: var(--primary-light); color: var(--primary); }

        .badge-dot {
            position: absolute;
            top: 5px; right: 5px;
            width: 8px; height: 8px;
            background: #ef4444;
            border-radius: 50%;
            border: 2px solid #fff;
        }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 4px 12px 4px 4px;
            border-radius: 8px;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            transition: background .15s;
        }
        .topbar-user:hover { background: var(--body-bg); }
        .topbar-user img {
            width: 32px; height: 32px;
            border-radius: 50%;
            object-fit: cover;
        }
        .topbar-user .uname { font-size: .83rem; font-weight: 700; }

        /* ─── MAIN CONTENT ──────────────────────────────────── */
        #main-wrapper {
            margin-left: var(--sidebar-w);
            padding-top: var(--topbar-h);
            flex: 1;
            min-height: 100vh;
        }

        #page-content {
            padding: 24px;
        }

        /* ─── RESPONSIVE ─────────────────────────────────────── */
        @@media (max-width: 768px) {
            #sidebarToggle { display: flex; }
            #sidebar { transform: translateX(-100%); }
            #sidebar.open { transform: translateX(0); }
            #topbar { left: 0; }
            #main-wrapper { margin-left: 0; }
            #sidebar-overlay {
                display: none;
                position: fixed; inset: 0;
                background: rgba(0,0,0,.4);
                z-index: 1039;
            }
            #sidebar-overlay.show { display: block; }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- ═══ SIDEBAR ═══════════════════════════════════════════ -->
<nav id="sidebar">

    <!-- Brand -->
    <a class="sidebar-brand" href="/Admin/Dashboard">
        <i class="bi bi-hash me-1"></i> DASHMIN <span class="ms-1">admin</span>
    </a>

    @{ var currentUser = User.Identity?.Name ?? "Admin"; }

    <div class="sidebar-user">
        <img src="@(string.IsNullOrEmpty(adminAvatarUrl) ? "/img/anh-27-meme-dang-yeu-didongmy.jpg" : adminAvatarUrl)" alt="avatar" />
        <div>
            <span class="uname d-none d-sm-inline">@adminUsername</span>
            <span class="role-badge role-admin">Admin</span>
        </div>
    </div>

    <!-- Navigation — hiện tất cả, không check role -->
    <div class="sidebar-nav">

        <div class="nav-section">Tổng quan</div>
        <a asp-area="Admin" asp-action="Index"asp-controller="Home" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "Dashboard" ? "active" : "")">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="nav-section">Nội dung</div>
        <a asp-area="Admin" asp-action="Index" asp-controller="Story" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "Story" ? "active" : "")">
            <i class="bi bi-book"></i> Truyện
        </a>
        <a asp-area="Admin" asp-action="Index" asp-controller="Chapter" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "Chapter" ? "active" : "")">
            <i class="bi bi-journal-text"></i> Chương
        </a>
        <a asp-area="Admin" asp-action="Index" asp-controller="Category" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "Category" ? "active" : "")">
            <i class="bi bi-tags"></i> Thể loại
        </a>
        <a asp-area="Admin" asp-action="Index" asp-controller="Tag" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "Tag" ? "active" : "")">
            <i class="bi bi-tag"></i> Tag
        </a>
        <a asp-area="Admin" asp-action="Index" asp-controller="ThaoLuanDanhMuc" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "ThaoLuanDanhMuc" ? "active" : "")">
            <i class="bi bi-chat-dots"></i> Thảo luận
        </a>

        <div class="nav-section">Tương tác</div>
        <a href="/Admin/StoryComment" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "StoryComment" ? "active" : "")">
            <i class="bi bi-chat-dots"></i> Bình luận truyện
        </a>
        <a asp-area="Admin" asp-action="Index" asp-controller="ChapterComment" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "ChapterComment" ? "active" : "")">
            <i class="bi bi-chat-left-text"></i> Bình luận chương
        </a>
        <a asp-area="Admin" asp-action="Index" asp-controller="StoryRating" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "StoryRating" ? "active" : "")">
            <i class="bi bi-star"></i> Đánh giá
        </a>
        <a asp-area="Admin" asp-action="Index" asp-controller="BookMark" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "BookMark" ? "active" : "")">
            <i class="bi bi-bookmark"></i> Bookmark
        </a>
        <a asp-area="Admin" asp-action="Index" asp-controller="Follow" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "Follow" ? "active" : "")">
            <i class="bi bi-heart"></i> Follow
        </a>
        <a asp-area="Admin" asp-action="Index" asp-controller="ReadHistory" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "ReadHistory" ? "active" : "")">
            <i class="bi bi-clock-history"></i> Lịch sử đọc
        </a>

        <div class="nav-section">Quản trị</div>
        <a class="nav-link-item nav-has-sub" data-bs-toggle="collapse" href="#submenu-user"
           aria-expanded="@(new[]{"User","Roles","UserSession"}.Contains(ViewData["ActiveMenu"]?.ToString()) ? "true" : "false")">
            <i class="bi bi-people"></i> Người dùng
            <i class="bi bi-chevron-right nav-arrow"></i>
        </a>
        <div class="collapse nav-sub @(new[]{"User","Roles","UserSession"}.Contains(ViewData["ActiveMenu"]?.ToString()) ? "show" : "")" id="submenu-user">
            <a asp-area="Admin" asp-controller="User" asp-action="Index" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "User" ? "active" : "")">
                <i class="bi bi-person"></i> Tài khoản
            </a>
            <a asp-area="Admin" asp-controller="Roles" asp-action="Index" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "Roles" ? "active" : "")">
                <i class="bi bi-shield-lock"></i> Phân quyền
            </a>
            <a asp-area="Admin" asp-action="Index" asp-controller="UserSession" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "UserSession" ? "active" : "")">
                <i class="bi bi-key"></i> Phiên đăng nhập
            </a>
        </div>
        <a asp-area="Admin" asp-action="Index" asp-controller="ErrorLog" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "ErrorLog" ? "active" : "")">
            <i class="bi bi-bug"></i> Nhật ký lỗi
        </a>
        @* <a href="/Admin/ChapterView" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "ChapterView" ? "active" : "")">
            <i class="bi bi-eye"></i> Lượt xem chương *@
        @* </a> *@
        <a asp-area="Admin" asp-controller="Import" asp-action="Index" class="nav-link-item @(ViewData["ActiveMenu"]?.ToString() == "Import" ? "active" : "")">
            <i class="bi bi-mask"></i> lấy truyện tự động
        </a>

    </div><!-- /sidebar-nav -->
</nav>
<!-- ═══ /SIDEBAR ══════════════════════════════════════════ -->

<!-- Overlay mobile -->
<div id="sidebar-overlay" onclick="closeSidebar()"></div>

<!-- ═══ TOPBAR ════════════════════════════════════════════ -->
<header id="topbar">
    <button id="sidebarToggle" onclick="toggleSidebar()">
        <i class="bi bi-list"></i>
    </button>

    <div class="topbar-search">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Tìm kiếm..." />
    </div>

    <div class="topbar-right">
        <!-- Thông báo -->
        @* <button class="topbar-btn" title="Thông báo">
            <i class="bi bi-bell"></i>
            <span class="badge-dot"></span>
        </button> *@
            <div style="position:relative;display:inline-block;" id="bell-wrapper">

                        <!-- Nút chuông -->
                        <button id="btn-bell"
                                style="width:36px;height:36px;border-radius:50%;border:1px solid #e0e0f0;
                            background:none;cursor:pointer;position:relative;display:flex;
                            align-items:center;justify-content:center;color:#555;">
                            <i class="fa fa-bell" style="font-size:15px;"></i>

                            <!-- Badge: ẩn mặc định, JS sẽ hiện khi > 0 -->
                            <span id="badge-thongbao"
                                  style="display:none;position:absolute;top:2px;right:2px;
                                min-width:16px;height:16px;padding:0 4px;
                                border-radius:8px;background:#e74c3c;border:2px solid #fff;
                                font-size:10px;font-weight:700;color:#fff;
                                line-height:12px;text-align:center;">
                            </span>
                        </button>

                        <!-- Dropdown thông báo -->
                        <div id="dropdown-thongbao"
                             style="display:none;position:absolute;top:44px;right:0;width:320px;
                            background:#fff;border:1px solid #e0e0f0;border-radius:10px;
                            box-shadow:0 4px 20px rgba(0,0,0,.12);z-index:9999;overflow:hidden;">

                            <!-- Header dropdown -->
                            <div style="display:flex;align-items:center;justify-content:space-between;
                                padding:12px 16px;border-bottom:1px solid #f0f0f0;">
                                <span style="font-weight:700;font-size:14px;color:#222;">Thông báo</span>
                                <button id="btn-doc-het"
                                        style="font-size:12px;color:#6c63ff;background:none;
                                    border:none;cursor:pointer;padding:0;">
                                    Đánh dấu đã đọc hết
                                </button>
                            </div>

                            <!-- Danh sách thông báo (JS render vào đây) -->
                            <div id="list-thongbao"
                                 style="max-height:360px;overflow-y:auto;">
                                <div style="padding:24px;text-align:center;color:#aaa;font-size:13px;">
                                    Đang tải...
                                </div>
                            </div>

                            <!-- Footer -->
                            <div style="padding:10px;text-align:center;border-top:1px solid #f0f0f0;">
                                <a href="/Admin/ThongBao/Index"
                                       style="font-size:13px;color:#6c63ff;text-decoration:none;">
                                    Xem tất cả thông báo
                                </a>
                            </div>
                        </div>
             </div>
        <!-- Tin nhắn -->
        <button class="topbar-btn" title="Tin nhắn">
            <i class="bi bi-envelope"></i>
        </button>

        <!-- User dropdown -->
        @* <div class="dropdown">
            <a class="topbar-user dropdown-toggle" href="#" data-bs-toggle="dropdown" style="text-decoration:none;">
                <img src="@(string.IsNullOrEmpty(adminAvatarUrl) ? "/img/anh-27-meme-dang-yeu-didongmy.jpg" : adminAvatarUrl)" alt="avatar" />
                <span class="uname d-none d-sm-inline">@adminUsername</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="min-width:180px; border-radius:10px; font-size:.84rem;">
                <li>
                    <span class="dropdown-item-text text-muted px-3 py-1" style="font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.8px;">
                        Admin
                    </span>
                </li>
                <li><hr class="dropdown-divider my-1" /></li>
                <li><a class="dropdown-item" href="/Admin/Profile"><i class="bi bi-person me-2"></i>Hồ sơ</a></li>
                <li><a class="dropdown-item" href="/Admin/Settings"><i class="bi bi-gear me-2"></i>Cài đặt</a></li>
                <li><hr class="dropdown-divider my-1" /></li>
                <li>
                    <a class="dropdown-item text-danger"asp-area="" asp-controller="Account" asp-action="LogoutGet">
                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                    </a>
                </li>
            </ul>
            </div> *@
             @if (User.Identity?.IsAuthenticated == true)
             {
                        <div class="nb-user-wrap" style="position:relative;">
                            <button class="nb-user-btn"
                                    style="display:flex;align-items:center;gap:8px;padding:4px 10px 4px 4px;
                                border-radius:20px;border:1px solid #e0e0f0;background:none;
                                cursor:pointer;transition:.2s;">

                                @{
                                    var _navAvatar = Context.Session.GetString("Admin_AvatarUrl");
                                }
                                @if (!string.IsNullOrEmpty(_navAvatar))
                                {
                                    <img src="@_navAvatar"
                                         style="width:28px;height:28px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                                }
                                else
                                {
                                    <div style="width:28px;height:28px;border-radius:50%;
                                        
                                        background: #525fe1;
                                        display:flex;align-items:center;justify-content:center;
                                        color:#fff;font-size:11px;font-weight:700;">
                                        @(User.Identity.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "U")
                                    </div>
                                }

                                <span style="font-size:13px;font-weight:600;color:#0b104a;
                                    max-width:90px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    @User.Identity.Name
                                </span>
                                <i class="fa fa-chevron-down" style="font-size:10px;color:#888;"></i>
                            </button>
                            <div class="nb-user-dropdown"
                                 style="position:absolute;top:calc(100% + 10px);right:0;
                                background:#fff;border:1px solid #ebebf5;border-radius:10px;
                                padding:6px;min-width:190px;opacity:0;visibility:hidden;
                                transition:.2s;z-index:9999;box-shadow:0 4px 20px rgba(0,0,0,.08);">

                                @{
                                    var avatarUrl = Context.Session.GetString("Admin_AvatarUrl");
                                }

                                <div style="padding:8px 10px 10px;border-bottom:1px solid #f0f0f8;margin-bottom:4px;display:flex;align-items:center;gap:10px;">
                                    @if (!string.IsNullOrEmpty(avatarUrl))
                                    {
                                        <img src="@avatarUrl" style="width:36px;height:36px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                                    }
                                    else
                                    {
                                        <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#a855f7);display:flex;align-items:center;justify-content:center;color:#fff;font-size:13px;font-weight:700;flex-shrink:0;">
                                            @(User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "U")
                                        </div>
                                    }
                                    <div>
                                        <div style="font-size:13px;font-weight:600;color:#0b104a;">@User.Identity.Name</div>
                                        <div style="font-size:11px;color:#888;">@User.Identity.Name</div>
                                    </div>
                                </div>
                                <a asp-area="Admin" asp-action="Index" asp-controller="Profile"
                                       style="display:flex;align-items:center;gap:8px;padding:8px 10px;
                                    border-radius:6px;font-size:13px;color:#333;text-decoration:none;transition:.15s;">
                                    <i class="fa fa-user" style="font-size:13px;color:#525fe1;width:16px;"></i> Hồ sơ
                                </a>
                                <a href="#"
                                       style="display:flex;align-items:center;gap:8px;padding:8px 10px;
                                    border-radius:6px;font-size:13px;color:#333;text-decoration:none;transition:.15s;">
                                    <i class="fa fa-cog" style="font-size:13px;color:#525fe1;width:16px;"></i> Cài đặt
                                </a>
                                <div style="height:1px;background:#f0f0f8;margin:4px 0;"></div>
                                <a asp-action="LogoutGet" asp-controller="Account"
                                       style="display:flex;align-items:center;gap:8px;padding:8px 10px;
                                    border-radius:6px;font-size:13px;color:#e74c3c;text-decoration:none;transition:.15s;">
                                    <i class="fa fa-sign-out" style="font-size:13px;width:16px;"></i> Đăng xuất
                                </a>
                            </div>
                        </div>
              }
              else
              {
                        <a asp-action="Login" asp-controller="Account" class="header-btn">Đăng nhập</a>
                        <a asp-action="Register" asp-controller="Account" class="btn_one">Đăng ký</a>
              }

    </div>
</header>
