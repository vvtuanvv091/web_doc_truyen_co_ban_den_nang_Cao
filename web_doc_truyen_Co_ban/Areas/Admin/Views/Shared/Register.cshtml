@{
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
    ViewData["Title"] = "Đăng ký";
}

<form asp-action="Register" asp-controller="Auth" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Họ và tên</label>
        <input type="text" name="FullName" class="form-control" placeholder="Nhập họ và tên" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Tên đăng nhập</label>
        <input type="text" name="Username" class="form-control" placeholder="Nhập tên đăng nhập" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" name="Email" class="form-control" placeholder="Nhập email" required />
    </div>

    <div class="mb-4">
        <label class="form-label">Mật khẩu</label>
        <input type="password" name="Password" class="form-control" placeholder="Nhập mật khẩu" required />
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger py-2 px-3 mb-3" style="font-size:.83rem; border-radius:8px;">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]
        </div>
    }

    <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-person-plus me-1"></i> Đăng ký
    </button>

    <div class="auth-footer">
        Đã có tài khoản? <a href="/Auth/Login">Đăng nhập</a>
    </div>
</form>
