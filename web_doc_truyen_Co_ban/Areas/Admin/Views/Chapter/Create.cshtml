@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.3/tinymce.min.js"></script>
    <script>
        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

        tinymce.init({
        selector: '#contentEditor',
        height: 600,
        menubar: false,
        branding: false,
        resize: true,
        plugins: [
        'advlist', 'autolink', 'lists', 'link', 'image',
        'charmap', 'searchreplace', 'visualblocks', 'code',
        'fullscreen', 'table', 'wordcount', 'emoticons',
        'media'          // ← thêm plugin media (YouTube / Vimeo / link video)
        ],
        toolbar:
        'undo redo | bold italic underline | forecolor | ' +
        'alignleft aligncenter alignright | ' +
        'bullist numlist | image uploadimg | media uploadvideo | emoticons | fullscreen',
        //                                   ^^^^^^^^^^^^^^^^^^^
        //  media   = dialog chèn YouTube/Vimeo qua link
        //  uploadvideo = nút custom upload video từ máy

        // ── Cấu hình plugin media ─────────────────────────────
        media_live_embeds: true,   // xem trước video ngay trong editor
        media_alt_source: false,   // ẩn ô "Alternate source" cho gọn
        media_poster: false,       // ẩn ô "Poster" cho gọn

        // ── Ảnh: bật tab chỉnh width/height ──────────────────
        paste_data_images: true,
        automatic_uploads: false,
        image_title: false,
        image_advtab: true,
        image_dimensions: true,
        file_picker_types: 'image',
        file_picker_callback: function (callback, value, meta) {
        if (meta.filetype !== 'image') return;
        const inp = document.createElement('input');
        inp.type = 'file';
        inp.accept = 'image/png,image/jpeg,image/gif,image/webp';
        inp.onchange = function () {
        const file = inp.files[0];
        if (!file) return;
        if (file.size > 5 * 1024 * 1024) {
        alert('Ảnh quá lớn! Vui lòng chọn ảnh nhỏ hơn 5 MB.'); return;
        }
        const reader = new FileReader();
        reader.onload = e => callback(e.target.result, { title: file.name });
        reader.readAsDataURL(file);
        };
        inp.click();
        },

        content_style: `
        body {
        font-family: Georgia, serif;
        font-size: 15px; line-height: 1.9;
        color: #1e1208; padding: 10px 16px;
        }
        p { margin: 0 0 0.9em; }
        img { max-width: 100%; height: auto; }
        video { max-width: 100%; height: auto; }
        `,

        setup: function (editor) {

        // ── Nút upload ảnh từ máy (nhiều file, base64) ────
        editor.ui.registry.addButton('uploadimg', {
        icon: 'gallery',
        tooltip: 'Tải ảnh từ máy lên',
        onAction: function () {
        const inp = document.createElement('input');
        inp.type = 'file';
        inp.accept = 'image/png,image/jpeg,image/gif,image/webp';
        inp.multiple = true;
        inp.onchange = function () {
        Array.from(inp.files).forEach(file => {
        if (file.size > 5 * 1024 * 1024) {
        alert(file.name + ' quá lớn (> 5 MB), bỏ qua.'); return;
        }
        const reader = new FileReader();
        reader.onload = e => {
        editor.insertContent(
        `<img src="${e.target.result}" alt="${file.name}" style="max-width:100%;" />`
        );
        };
        reader.readAsDataURL(file);
        });
        };
        inp.click();
        }
        });

        // ── Nút upload video từ máy (blob URL) ───────────
        editor.ui.registry.addButton('uploadvideo', {
        icon: 'embed',
        tooltip: 'Tải video từ máy lên (mp4, webm, ogg)',
        onAction: function () {
        const inp = document.createElement('input');
        inp.type = 'file';
        inp.accept = 'video/mp4,video/webm,video/ogg';
        inp.multiple = true;
        inp.onchange = function () {
        Array.from(inp.files).forEach(file => {
        if (file.size > 200 * 1024 * 1024) {
        alert(file.name + ' quá lớn (> 100 MB), bỏ qua.'); return;
        }
        // Dùng blob URL – video phát ngay trong editor.
        // LƯU Ý: blob URL chỉ tồn tại trong tab hiện tại.
        // Nếu cần lưu lâu dài, hãy upload lên server và
        // thay blob URL bằng đường dẫn server trả về.
        const blobUrl = URL.createObjectURL(file);
        editor.insertContent(
        `<video controls style="max-width:100%; height:auto;">` +
        `<source src="${blobUrl}" type="${file.type}">` +
        `Trình duyệt không hỗ trợ thẻ video.` +
        `</video>`
        );
        });
        };
        inp.click();
        }
        });

        // ── Word count ────────────────────────────────────
        const wcDisplay = document.getElementById('wordCountDisplay');
        const wcInput   = document.getElementById('wordCountInput');
        function updateWc() {
        const wc = editor.plugins.wordcount;
        if (!wc || !wcDisplay) return;
        const count = wc.body.getWordCount();
        wcDisplay.textContent = count.toLocaleString('vi-VN');
        if (wcInput) wcInput.value = count;
        }
        editor.on('init', updateWc);
        editor.on('input keyup change', updateWc);
        }
        });

        // Sync TinyMCE → textarea trước khi submit
        document.getElementById('chapterForm').addEventListener('submit', function () {
        tinymce.triggerSave();
        });

        // Lock toggle
        const toggle         = document.getElementById('isLockedToggle');
        const lockPriceGroup = document.getElementById('lockPriceGroup');
        const unlockPrice    = document.getElementById('unlockPriceInput');

        function syncLockPrice() {
        const locked = toggle.checked;
        lockPriceGroup.style.display = locked ? 'block' : 'none';
        unlockPrice.required = locked;
        if (!locked) unlockPrice.value = 0;
        }
        toggle.addEventListener('change', syncLockPrice);
        syncLockPrice();

    </script>
    <script>
        document.getElementById('StoryId').addEventListener('change', function () {
        loadVolumes(this.value);
        });

        window.addEventListener('DOMContentLoaded', function () {
        const storyId = document.getElementById('StoryId').value;
        if (storyId) loadVolumes(storyId);
        });

        function loadVolumes(storyId) {
        if (!storyId) return;
        fetch(`/Admin/Chapter/GetVolumes?storyId=${storyId}`)
        .then(r => r.json())
        .then(volumes => {
        const datalist = document.getElementById('volumeList');
        datalist.innerHTML = '';
        volumes.forEach(v => {
        const option = document.createElement('option');
        option.value = v;
        datalist.appendChild(option);
        });
        });
        }
    </script>
    <script>
        new TomSelect('#storySelect', {
            placeholder: 'Gõ để tìm truyện...',
            searchField: ['text'],   // tìm theo tên hiển thị
            maxOptions: 50,          // chỉ hiện tối đa 50 kết quả
            create: false
        });
    </script>
}
}
