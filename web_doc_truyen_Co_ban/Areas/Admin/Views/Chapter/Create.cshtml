            <form asp-area="Admin"
                  asp-controller="Chapter"
                  asp-action="Create"
                  method="post"
                  id="chapterForm">

                @Html.AntiForgeryToken()

                <!-- Story -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="StoryId" class="form-label fw-semibold">
                            Thuộc Truyện <span class="text-danger">*</span>
                        </label>
                        <select asp-for="StoryId"
                                asp-items="@((SelectList)ViewBag.Stories)"
