@model web_doc_truyen_Co_ban.Models.StoryCommentModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi Tiết Bình Luận";
    ViewData["ActiveMenu"] = "StoryComment";
    var replies = Model.Replies?.Where(r => r.Status != 2).OrderBy(r => r.CreatedAt).ToList() ?? new();
}

@section Styles {
<style>
    .card{background:#fff;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 4px rgba(0,0,0,.06);margin-bottom:20px}
    .card-header{padding:12px 18px;border-bottom:1px solid #e2e8f0;font-weight:700;font-size:.88rem;color:#1e293b;background:#f8fafc;border-radius:12px 12px 0 0;display:flex;align-items:center;justify-content:space-between}
    .card-body{padding:20px}
    .badge{display:inline-flex;align-items:center;gap:4px;font-size:.76rem;font-weight:700;padding:3px 10px;border-radius:20px}
    .b-show{background:#dcfce7;color:#16a34a} .b-hide{background:#fef9c3;color:#92400e} .b-del{background:#fee2e2;color:#dc2626}
    .meta{font-size:.8rem;color:#94a3b8}
    .content-box{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:14px 16px;font-size:.88rem;color:#374151;line-height:1.7;white-space:pre-wrap;word-break:break-word}
    .reply-item{border:1px solid #e2e8f0;border-radius:8px;padding:12px 14px;margin-bottom:8px;background:#fff}
    .reply-item.hidden{opacity:.5;background:#f9fafb}
    .btn{display:inline-flex;align-items:center;gap:5px;padding:6px 14px;border-radius:7px;font-weight:700;font-size:.8rem;cursor:pointer;border:none;text-decoration:none;transition:all .15s}
    .btn-primary{background:#2563eb;color:#fff} .btn-primary:hover{background:#1d4ed8;color:#fff}
    .btn-secondary{background:#f1f5f9;color:#475569;border:1px solid #e2e8f0}
    .btn-warn{background:#fef9c3;color:#92400e;border:1px solid #fde68a}
    .btn-ok{background:#dcfce7;color:#15803d;border:1px solid #bbf7d0}
    .btn-danger{background:#fee2e2;color:#dc2626;border:1px solid #fecaca}
    .spinner{display:inline-block;width:12px;height:12px;border:2px solid currentColor;border-top-color:transparent;border-radius:50%;animation:spin .6s linear infinite}
    @@keyframes spin{to{transform:rotate(360deg)}}
    .info-row{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #f1f5f9;font-size:.83rem}
    .info-row:last-child{border:none}
    .info-row label{color:#94a3b8;font-weight:600}
    .info-row span{color:#1e293b;font-weight:700;text-align:right}
</style>
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px">
    <h1 style="font-size:1.2rem;font-weight:800;color:#1e293b;margin:0">
        <i class="bi bi-chat-left-text me-2"></i>Chi Tiết Bình Luận
    </h1>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
        @if (Model.Status != 2)
        {
            <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@Url.Action("Detail", new { id = Model.Id })" />
                <button type="submit" class="btn @(Model.Status == 0 ? "btn-warn" : "btn-ok")">
                    <i class="bi @(Model.Status == 0 ? "bi-eye-slash" : "bi-eye")"></i>
                    @(Model.Status == 0 ? "Ẩn" : "Hiện")
                </button>
            </form>
        }
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Sửa</a>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:#dcfce7;border:1px solid #bbf7d0;border-radius:8px;padding:10px 14px;font-size:.84rem;color:#15803d;margin-bottom:16px">
        <i class="bi bi-check-circle-fill me-1"></i>@TempData["Success"]
    </div>
}

<div style="display:grid;grid-template-columns:1fr 290px;gap:18px;align-items:start">

    <div>
        <!-- Nội dung -->
        <div class="card">
            <div class="card-header">
                <span><i class="bi bi-chat-quote me-1"></i>Nội Dung</span>
                <div style="display:flex;gap:6px;align-items:center">
                    @{ var bc = Model.Status==0?"b-show":Model.Status==1?"b-hide":"b-del";
                       var bt = Model.Status==0?"Hiển thị":Model.Status==1?"Đã ẩn":"Đã xóa"; }
                    <span class="badge @bc"><i class="bi @(Model.Status==0?"bi-eye":Model.Status==1?"bi-eye-slash":"bi-trash")"></i> @bt</span>
                    <span style="font-size:.78rem;color:#ef4444;font-weight:700">❤️ @Model.LikeCount</span>
                </div>
            </div>
            <div class="card-body">
                @if (Model.ParentId.HasValue && Model.Parent != null)
                {
                    <div style="background:#eff6ff;border-left:3px solid #2563eb;border-radius:0 8px 8px 0;padding:8px 12px;margin-bottom:12px;font-size:.8rem;color:#1d4ed8">
                        <i class="bi bi-reply-all me-1"></i><strong>Trả lời:</strong>
                        @Model.Parent.Content.Substring(0, Math.Min(80, Model.Parent.Content.Length))@(Model.Parent.Content.Length > 80 ? "…" : "")
                    </div>
                }
                <div class="content-box">@Model.Content</div>
            </div>
        </div>

        <!-- Replies -->
        <div class="card">
            <div class="card-header">
                <span>
                    <i class="bi bi-chat-right-dots me-1"></i>Trả Lời
                    <span style="background:#e2e8f0;color:#475569;border-radius:20px;padding:2px 8px;font-size:.74rem;font-weight:700;margin-left:4px">@replies.Count</span>
                </span>
            </div>
            <div class="card-body" style="padding:14px">
                @if (!replies.Any())
                {
                    <p style="text-align:center;color:#94a3b8;font-size:.84rem;padding:16px 0;margin:0">
                        <i class="bi bi-chat-right d-block mb-1" style="font-size:1.5rem"></i>Chưa có trả lời nào.
                    </p>
                }
                else
                {
                    @foreach (var r in replies)
                    {
                        <div class="reply-item @(r.Status==1?"hidden":"")" id="reply-@r.Id">
                            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:6px">
                                <span style="font-size:.82rem;font-weight:700;color:#1e293b"><i class="bi bi-person-circle me-1" style="color:#94a3b8"></i>@r.User?.Username</span>
                                <span class="meta">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                <span class="badge @(r.Status==0?"b-show":"b-hide") rbadge-@r.Id">
                                    <i class="bi @(r.Status==0?"bi-eye":"bi-eye-slash")"></i> @(r.Status==0?"Hiển thị":"Đã ẩn")
                                </span>
                                <span style="font-size:.75rem;color:#ef4444;font-weight:700">❤️ @r.LikeCount</span>
                            </div>
                            <div style="font-size:.84rem;color:#374151;line-height:1.6;margin-bottom:8px">@r.Content</div>
                            <div style="display:flex;gap:6px">
                                <button type="button" class="btn @(r.Status==0?"btn-warn":"btn-ok") toggle-btn" data-id="@r.Id" data-status="@r.Status">
                                    <i class="bi @(r.Status==0?"bi-eye-slash":"bi-eye")"></i>
                                    <span>@(r.Status==0?"Ẩn":"Hiện")</span>
                                </button>
                                <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-secondary"><i class="bi bi-pencil"></i> Sửa</a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Cột phải -->
    <div>
        <div class="card">
            <div class="card-header"><span><i class="bi bi-info-circle me-1"></i>Thông Tin</span></div>
            <div class="card-body" style="padding:14px 18px">
                <div class="info-row"><label>Truyện</label><span>@Model.Story?.Title</span></div>
                <div class="info-row"><label>Người dùng</label><span>@Model.User?.Username</span></div>
                <div class="info-row"><label>Loại</label><span>@(Model.ParentId.HasValue ? "↩ Reply" : "💬 Gốc")</span></div>
                <div class="info-row"><label>Lượt thích</label><span>❤️ @Model.LikeCount</span></div>
                <div class="info-row"><label>Số replies</label><span>💬 @replies.Count</span></div>
                <div class="info-row"><label>Ngày tạo</label><span>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span></div>
                <div class="info-row"><label>Cập nhật</label><span>@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</span></div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><span><i class="bi bi-lightning me-1"></i>Thao Tác</span></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px;padding:14px">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary" style="justify-content:center"><i class="bi bi-pencil-square"></i> Chỉnh sửa</a>
                @if (Model.Status != 2)
                {
                    <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@Url.Action("Detail", new { id = Model.Id })" />
                        <button type="submit" class="btn @(Model.Status==0?"btn-warn":"btn-ok")" style="width:100%;justify-content:center">
                            <i class="bi @(Model.Status==0?"bi-eye-slash":"bi-eye")"></i>
                            @(Model.Status==0 ? "Ẩn bình luận" : "Hiện bình luận")
                        </button>
                    </form>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger" style="justify-content:center"><i class="bi bi-trash"></i> Xóa</a>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    document.querySelectorAll('.toggle-btn').forEach(btn => {
        btn.addEventListener('click', async function () {
            const id = this.dataset.id, orig = this.innerHTML;
            this.disabled = true;
            this.innerHTML = '<span class="spinner"></span>';
            try {
                const res  = await fetch('/Admin/StoryComment/ToggleStatus', {
                    method: 'POST',
                    headers: {'Content-Type':'application/x-www-form-urlencoded','X-Requested-With':'XMLHttpRequest','RequestVerificationToken':token},
                    body: `id=${id}`
                });
                const data = await res.json();
                if (!data.success) { this.innerHTML = orig; return; }
                const h = data.newStatus === 1;
                const item  = document.getElementById('reply-' + id);
                const badge = item.querySelector('.rbadge-' + id);
                item.classList.toggle('hidden', h);
                badge.className = `badge ${h?'b-hide':'b-show'} rbadge-${id}`;
                badge.innerHTML = `<i class="bi ${h?'bi-eye-slash':'bi-eye'}"></i> ${h?'Đã ẩn':'Hiển thị'}`;
                this.className  = `btn ${h?'btn-ok':'btn-warn'} toggle-btn`;
                this.dataset.status = data.newStatus;
                this.innerHTML  = `<i class="bi ${h?'bi-eye':'bi-eye-slash'}"></i> <span>${h?'Hiện':'Ẩn'}</span>`;
            } catch { this.innerHTML = orig; }
            finally  { this.disabled = false; }
        });
    });
</script>
}
