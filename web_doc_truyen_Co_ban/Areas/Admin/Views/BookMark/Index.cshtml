@model IEnumerable<web_doc_truyen_Co_ban.Models.BookmarkModel>

@{
    ViewData["Title"] = "Phân tích Bookmark";
    int page      = (int)ViewBag.Page;
    int totalPages = (int)ViewBag.TotalPages;
    int total      = (int)ViewBag.ToTal;

    string? search    = ViewData["Search"]    as string;
    string? storyId   = ViewData["StoryId"]   as string;
    string? chapterId = ViewData["ChapterId"] as string;
}

@section Styles{
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    :root {
        --bg: #f0f2f8;
        --card: #fff;
        --border: #e8ecf4;
        --text: #1a202c;
        --muted: #718096;
        --blue: #4f63d2;
        --blue-light: #eef2ff;
        --green: #059669;
        --green-light: #ecfdf5;
        --amber: #d97706;
        --amber-light: #fffbeb;
        --red: #dc2626;
        --red-light: #fef2f2;
        --radius: 12px;
        --shadow: 0 1px 4px rgba(0,0,0,.06);
    }

    *, *::before, *::after { box-sizing: border-box; }
    body { background: var(--bg); font-family: 'Segoe UI', system-ui, sans-serif; }

    .bm-wrap { padding: 24px; min-height: 100vh; }

    /* ── PAGE TITLE ── */
    .bm-title {
        font-size: 20px; font-weight: 700; color: var(--text);
        margin-bottom: 4px; display: flex; align-items: center; gap: 8px;
    }
    .bm-sub { font-size: 13px; color: var(--muted); margin-bottom: 20px; }

    /* ── TOP STAT BAR ── */
    .stat-bar {
        display: grid; grid-template-columns: repeat(4, 1fr);
        background: var(--card); border-radius: var(--radius);
        box-shadow: var(--shadow); overflow: hidden; margin-bottom: 16px;
    }
    .stat-bar-cell {
        padding: 14px 18px; border-right: 1px solid var(--border);
        display: flex; align-items: center; gap: 12px;
    }
    .stat-bar-cell:last-child { border-right: none; }
    .sbc-icon {
        width: 42px; height: 42px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; flex-shrink: 0;
    }
    .sbc-val { font-size: 22px; font-weight: 700; color: var(--text); line-height: 1; }
    .sbc-lbl { font-size: 11px; color: var(--muted); margin-top: 3px; text-transform: uppercase; letter-spacing: .04em; }

    /* ── MAIN GRID ── */
    .main-grid { display: grid; grid-template-columns: 1fr 260px; gap: 16px; margin-bottom: 16px; }

    /* ── CARD ── */
    .card { background: var(--card); border-radius: var(--radius); box-shadow: var(--shadow); padding: 18px 20px; }
    .card-title {
        font-size: 13px; font-weight: 700; color: var(--text);
        display: flex; align-items: center; gap: 6px; margin-bottom: 14px;
    }

    /* ── TAB ── */
    .tab-row {
        display: flex; gap: 0; margin-bottom: 14px;
        border: 1px solid var(--border); border-radius: 8px;
        overflow: hidden; width: fit-content;
    }
    .tab-btn {
        padding: 5px 16px; font-size: 12px; font-weight: 600;
        border: none; background: transparent; color: var(--muted); cursor: pointer; transition: background .15s;
    }
    .tab-btn.active { background: var(--blue); color: #fff; }

    /* ── RIGHT PANELS ── */
    .right-col { display: flex; flex-direction: column; gap: 16px; }
    .panel-green {
        background: var(--green); border-radius: var(--radius);
        padding: 16px 18px; display: flex; align-items: center; gap: 14px; color: #fff;
    }
    .panel-blue {
        background: var(--blue); border-radius: var(--radius);
        padding: 16px 18px; display: flex; align-items: center; gap: 14px; color: #fff;
    }
    .panel-icon {
        width: 44px; height: 44px; border-radius: 10px;
        background: rgba(255,255,255,.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; flex-shrink: 0;
    }
    .panel-big { font-size: 24px; font-weight: 700; line-height: 1; }
    .panel-sub { font-size: 12px; opacity: .85; margin-top: 3px; }

    .mini-stats { background: var(--card); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; flex: 1; }
    .mini-stat-row { display: grid; grid-template-columns: 1fr 1fr; border-bottom: 1px solid var(--border); }
    .mini-stat-row:last-child { border-bottom: none; }
    .mini-cell { padding: 12px 14px; border-right: 1px solid var(--border); }
    .mini-cell:last-child { border-right: none; }
    .mc-lbl { font-size: 11px; color: var(--muted); }
    .mc-val { font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 4px; margin-top: 2px; }
    .mc-val .up { color: var(--green); font-size: 12px; }
    .mc-sub { font-size: 10px; color: var(--muted); margin-top: 2px; }

    /* ── CHART ROW 2 ── */
    .chart-row2 { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 16px; }

    /* ── MEMBER LIST ── */
    .member-list {
        background: var(--card); border-radius: var(--radius);
        box-shadow: var(--shadow); overflow: hidden; margin-bottom: 16px;
    }
    .member-head {
        display: flex; justify-content: space-between; align-items: center;
        padding: 14px 18px; border-bottom: 1px solid var(--border);
    }
    .member-head span { font-size: 14px; font-weight: 700; color: var(--text); }
    .member-row {
        display: flex; align-items: center; gap: 12px;
        padding: 11px 18px; border-bottom: 1px solid var(--border); transition: background .12s;
    }
    .member-row:last-child { border-bottom: none; }
    .member-row:hover { background: #f8faff; }
    .avatar {
        width: 36px; height: 36px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 12px; flex-shrink: 0; overflow: hidden;
    }
    .avatar img { width: 100%; height: 100%; object-fit: cover; }
    .member-info { flex: 1; min-width: 0; }
    .member-info .name { font-size: 13px; font-weight: 700; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .member-info .role { font-size: 11px; color: var(--muted); }
    .member-reads { font-size: 13px; font-weight: 600; color: var(--text); display: flex; align-items: center; gap: 4px; }
    .reads-up { color: var(--green); font-size: 12px; }

    /* ── PROGRESS ROW ── */
    .prog-row {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
        background: var(--card); border-radius: var(--radius);
        box-shadow: var(--shadow); overflow: hidden; margin-bottom: 16px;
    }
    .prog-cell { padding: 14px 18px; border-right: 1px solid var(--border); }
    .prog-cell:last-child { border-right: none; }
    .pc-lbl { font-size: 11px; color: var(--muted); margin-bottom: 4px; }
    .pc-val { font-size: 18px; font-weight: 700; color: var(--text); }
    .pc-chg { font-size: 12px; margin-left: 4px; }
    .pc-chg.up { color: var(--green); }
    .prog-bar { height: 5px; background: var(--border); border-radius: 99px; margin-top: 10px; }
    .prog-fill { height: 100%; border-radius: 99px; position: relative; }
    .prog-fill::after {
        content: ''; position: absolute; right: -1px; top: 50%;
        transform: translateY(-50%); width: 10px; height: 10px;
        border-radius: 50%; background: inherit;
    }

    /* ── FILTER BAR ── */
    .filter-bar {
        background: var(--card); border-radius: var(--radius);
        box-shadow: var(--shadow); padding: 14px 18px; margin-bottom: 16px;
        display: flex; gap: 10px; flex-wrap: wrap; align-items: center;
    }
    .filter-bar input,
    .filter-bar select {
        height: 38px; border: 1px solid var(--border); border-radius: 8px;
        padding: 0 12px; background: #fff; font-size: 13px; outline: none; color: var(--text);
    }
    .filter-bar input { width: 220px; }
    .btn-main {
        height: 38px; border: none; border-radius: 8px;
        background: var(--blue); color: #fff; font-weight: 700;
        padding: 0 18px; cursor: pointer; display: flex; align-items: center; gap: 6px;
    }
    .btn-main:hover { opacity: .9; }

    /* ── TABLE ── */
    .table-card { background: var(--card); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
    .table-head {
        padding: 16px 18px; border-bottom: 1px solid var(--border);
        display: flex; justify-content: space-between; align-items: center;
    }
    .table-head h3 { margin: 0; font-size: 15px; font-weight: 700; color: var(--text); }
    table { width: 100%; border-collapse: collapse; }
    thead { background: #f8fafc; }
    th {
        padding: 11px 14px; font-size: 11px; text-transform: uppercase;
        color: var(--muted); text-align: left; letter-spacing: .05em; font-weight: 700;
    }
    td { padding: 12px 14px; border-top: 1px solid var(--border); font-size: 13px; vertical-align: middle; }
    tbody tr:hover { background: #fafcff; }
    .story-name { font-weight: 700; color: var(--blue); }
    .chapter-badge {
        display: inline-flex; align-items: center; gap: 5px;
        background: var(--amber-light); color: var(--amber);
        padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 700;
    }
    .action-btn {
        width: 30px; height: 30px; border-radius: 7px; border: none;
        background: var(--blue-light); color: var(--blue);
        display: inline-flex; align-items: center; justify-content: center;
        text-decoration: none; font-size: 14px;
    }
    .action-btn:hover { background: var(--blue); color: #fff; }

    /* ── PAGINATION ── */
    .pagination-wrap {
        padding: 14px 18px; border-top: 1px solid var(--border);
        display: flex; justify-content: space-between; align-items: center;
    }
    .pagination-btns { display: flex; gap: 5px; flex-wrap: wrap; }
    .p-btn {
        min-width: 32px; height: 32px; border-radius: 7px;
        border: 1px solid var(--border); background: #fff;
        font-size: 13px; cursor: pointer; color: var(--text);
    }
    .p-btn.active { background: var(--blue); color: #fff; border-color: var(--blue); font-weight: 700; }
    .p-btn:hover:not(.active) { background: var(--blue-light); }

    @@media (max-width: 1100px) {
        .main-grid { grid-template-columns: 1fr; }
        .chart-row2 { grid-template-columns: 1fr; }
        .stat-bar { grid-template-columns: repeat(2, 1fr); }
        .prog-row { grid-template-columns: repeat(2, 1fr); }
    }
</style>
}

<div class="bm-wrap">

    <!-- TITLE -->
    <div class="bm-title">
        <i class="bi bi-bookmark-heart-fill" style="color:var(--blue)"></i>
        Phân tích Bookmark
    </div>
    <div class="bm-sub">Theo dõi hành vi đánh dấu truyện của người dùng</div>

    <!-- TOP STAT BAR -->
    <div class="stat-bar">
        <div class="stat-bar-cell">
            <div class="sbc-icon" style="background:var(--blue-light);color:var(--blue)">
                <i class="bi bi-bookmarks-fill"></i>
            </div>
            <div>
                <div class="sbc-val">@ViewBag.ToTalReading</div>
                <div class="sbc-lbl">Tổng bookmark</div>
            </div>
        </div>
        <div class="stat-bar-cell">
            <div class="sbc-icon" style="background:var(--green-light);color:var(--green)">
                <i class="bi bi-people-fill"></i>
            </div>
            <div>
                <div class="sbc-val">@ViewBag.ToTalUser</div>
                <div class="sbc-lbl">User đã bookmark</div>
            </div>
        </div>
        <div class="stat-bar-cell">
            <div class="sbc-icon" style="background:var(--amber-light);color:var(--amber)">
                <i class="bi bi-book-fill"></i>
            </div>
            <div>
                <div class="sbc-val">@ViewBag.ToTal</div>
                <div class="sbc-lbl">Bookmark hiển thị</div>
            </div>
        </div>
        <div class="stat-bar-cell">
            <div class="sbc-icon" style="background:var(--red-light);color:var(--red)">
                <i class="bi bi-fire"></i>
            </div>
            <div>
                <div class="sbc-val">@ViewBag.ToTalRead</div>
                <div class="sbc-lbl">Bookmark hôm nay</div>
            </div>
        </div>
    </div>

    <!-- MAIN GRID: trend chart + right col -->
    <div class="main-grid">

        <!-- TREND CHART -->
        <div class="card">
            <div class="card-title">
                <i class="bi bi-graph-up-arrow"></i>
                Xu hướng bookmark
            </div>
            <div class="tab-row">
                <button class="tab-btn active" onclick="switchTrend('week', this)">Tuần</button>
                <button class="tab-btn" onclick="switchTrend('month', this)">Tháng</button>
            </div>
            <div style="position:relative;width:100%;height:180px">
                <canvas id="trendChart" role="img" aria-label="Biểu đồ xu hướng bookmark"></canvas>
            </div>
        </div>

        <!-- RIGHT COLUMN -->
        <div class="right-col">

            <div class="panel-green">
                <div class="panel-icon"><i class="bi bi-bookmarks-fill"></i></div>
                <div>
                    <div class="panel-big">@ViewBag.ToTalReading</div>
                    <div class="panel-sub">Tổng bookmark</div>
                </div>
            </div>

            <div class="panel-blue">
                <div class="panel-icon"><i class="bi bi-people-fill"></i></div>
                <div>
                    <div class="panel-big">@ViewBag.ToTalUser</div>
                    <div class="panel-sub">User đã bookmark</div>
                </div>
            </div>

            <div class="mini-stats">
                <div class="mini-stat-row">
                    <div class="mini-cell">
                        <div class="mc-lbl">Hôm nay</div>
                        <div class="mc-val">
                            <i class="bi bi-arrow-up up"></i>@ViewBag.ToTalRead
                        </div>
                        <div class="mc-sub">Bookmark mới hôm nay</div>
                    </div>
                    <div class="mini-cell">
                        <div class="mc-lbl">Hiển thị</div>
                        <div class="mc-val">
                            <i class="bi bi-arrow-up up"></i>@ViewBag.ToTal
                        </div>
                        <div class="mc-sub">Kết quả hiện tại</div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- CHART ROW 2: top stories + giờ cao điểm -->
    <div class="chart-row2">

        <div class="card">
            <div class="card-title">
                <i class="bi bi-trophy-fill"></i>
                Top truyện được bookmark nhiều
            </div>
            <div style="position:relative;width:100%;height:200px">
                <canvas id="storyChart" role="img" aria-label="Biểu đồ top truyện được bookmark nhiều nhất"></canvas>
            </div>
        </div>

        <div class="card">
            <div class="card-title">
                <i class="bi bi-clock-history"></i>
                Giờ bookmark cao điểm
            </div>
            <div style="position:relative;width:100%;height:200px">
                <canvas id="heatChart" role="img" aria-label="Biểu đồ giờ bookmark cao điểm trong ngày"></canvas>
            </div>
        </div>

    </div>

    <!-- MEMBER LIST + TOP USER DONUT -->
    <div style="display:grid;grid-template-columns:1fr 300px;gap:16px;margin-bottom:16px">

        <div class="member-list">
            <div class="member-head">
                <span><i class="bi bi-people"></i> Top user bookmark nhiều</span>
            </div>
            <div id="topUserList">
                <div style="padding:20px;text-align:center;color:var(--muted);font-size:13px">
                    Đang tải...
                </div>
            </div>
        </div>

        <div class="card" style="display:flex;flex-direction:column">
            <div class="card-title">
                <i class="bi bi-person-fill"></i>
                Phân bổ user bookmark
            </div>
            <div style="position:relative;width:100%;flex:1;min-height:180px">
                <canvas id="userChart" role="img" aria-label="Biểu đồ phân bổ top user bookmark nhiều nhất"></canvas>
            </div>
        </div>

    </div>

    <!-- TOP CHAPTERS -->
    <div class="card" style="margin-bottom:16px">
        <div class="card-title">
            <i class="bi bi-bookmark-star-fill"></i>
            Top chapter được bookmark nhiều
        </div>
        <div style="position:relative;width:100%;height:200px">
            <canvas id="chapterChart" role="img" aria-label="Biểu đồ top chapter được bookmark nhiều nhất"></canvas>
        </div>
    </div>

    <!-- PROGRESS ROW -->
    <div class="prog-row">
        <div class="prog-cell">
            <div class="pc-lbl">Tổng bookmark</div>
            <div class="pc-val">@ViewBag.ToTalReading <span class="pc-chg up">↑</span></div>
            <div class="prog-bar"><div class="prog-fill" style="width:72%;background:var(--blue)"></div></div>
        </div>
        <div class="prog-cell">
            <div class="pc-lbl">User đã bookmark</div>
            <div class="pc-val">@ViewBag.ToTalUser <span class="pc-chg up">↑</span></div>
            <div class="prog-bar"><div class="prog-fill" style="width:60%;background:var(--green)"></div></div>
        </div>
        <div class="prog-cell">
            <div class="pc-lbl">Kết quả lọc</div>
            <div class="pc-val">@ViewBag.ToTal <span class="pc-chg up">↑</span></div>
            <div class="prog-bar"><div class="prog-fill" style="width:85%;background:var(--amber)"></div></div>
        </div>
        <div class="prog-cell">
            <div class="pc-lbl">Bookmark hôm nay</div>
            <div class="pc-val">@ViewBag.ToTalRead <span class="pc-chg up">↑</span></div>
            <div class="prog-bar"><div class="prog-fill" style="width:40%;background:var(--red)"></div></div>
        </div>
    </div>

    <!-- FILTER -->
    <div class="filter-bar">
        <form method="get" asp-action="Index"
              style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
            <input type="text" name="searach" value="@search" placeholder="Tìm username..." />
            <select name="storyid">
                <option value="">Tất cả truyện</option>
                @foreach (var s in ViewBag.Storiesbag)
                {
                    if (storyId == s.Id.ToString())
                    {
                        <option value="@s.Id" selected>@s.Title</option>
                    }
                    else
                    {
                        <option value="@s.Id">@s.Title</option>
                    }
                }
            </select>
            <button type="submit" class="btn-main">
                <i class="bi bi-funnel-fill"></i> Lọc dữ liệu
            </button>
        </form>
    </div>

    <!-- TABLE -->
    <div class="table-card">
        <div class="table-head">
            <h3>Danh sách Bookmark gần đây</h3>
            <div style="font-size:13px;color:var(--muted)">@total bookmark</div>
        </div>

        <div style="overflow-x:auto">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Người dùng</th>
                        <th>Truyện</th>
                        <th>Chapter</th>
                        <th>Cập nhật lúc</th>
                        <th>Xem</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int row = (page - 1) * 10; }
                    @foreach (var item in Model)
                    {
                        row++;
                        var initials = string.Join("",
                            item.User.Username
                                .Split(' ')
                                .TakeLast(2)
                                .Select(x => x[0].ToString().ToUpper()));

                        var avatarBgs = new[] {
                            "#dbeafe;color:#1e40af",
                            "#fce7f3;color:#9d174d",
                            "#fef3c7;color:#92400e",
                            "#d1fae5;color:#065f46",
                            "#ede9fe;color:#5b21b6"
                        };
                        var avatarStyle = avatarBgs[Math.Abs(item.User.Username.GetHashCode()) % avatarBgs.Length];

                        // Lấy avatar từ ViewBag.ingAvatarUrl nếu có
                        var avatarDict = ViewBag.ingAvatarUrl as List<KeyValuePair<Guid, string>>;
                        var avatarUrl  = avatarDict?.FirstOrDefault(a => a.Key == item.UserId).Value;

                        <tr>
                            <td style="color:var(--muted)">@row</td>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px">
                                    <div class="avatar" style="background:@avatarStyle">
                                        @if (!string.IsNullOrEmpty(avatarUrl))
                                        {
                                            <img src="@avatarUrl" alt="avatar" />
                                        }
                                        else
                                        {
                                            @initials
                                        }
                                    </div>
                                    <div>
                                        <div style="font-weight:700">@item.User.Username</div>
                                        <div style="font-size:11px;color:var(--muted)">@item.User.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td><div class="story-name">@item.Story.Title</div></td>
                            <td>
                                @if (item.Chapter != null)
                                {
                                    <span class="chapter-badge">
                                        <i class="bi bi-bookmark-fill"></i>
                                        Chương @item.Chapter.ChapterNumber
                                    </span>
                                }
                                else
                                {
                                    <span style="color:var(--muted)">Không rõ</span>
                                }
                            </td>
                            <td>
                                <div style="font-weight:600">@item.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy")</div>
                                <div style="font-size:11px;color:var(--muted)">@item.UpdatedAt.ToLocalTime().ToString("HH:mm")</div>
                            </td>
                            <td>
                                <div style="display:flex;gap:6px">
                                    <a asp-action="UserDetail" asp-route-id="@item.UserId"
                                       class="action-btn" title="Xem user">
                                        <i class="bi bi-person"></i>
                                    </a>
                                    <a asp-action="StoryDetail" asp-route-id="@item.StoryId"
                                       class="action-btn" title="Xem truyện">
                                        <i class="bi bi-book"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-wrap">
            <div style="font-size:13px;color:var(--muted)">Trang @@page / @totalPages</div>
            <div class="pagination-btns">
                @for (int p = 1; p <= totalPages; p++)
                {
                    <button type="button"
                            class="p-btn @(p == page ? "active" : "")"
                            onclick="goPage(@p)">@p</button>
                }
            </div>
        </div>
    </div>

</div>

@section Scripts{
<script>

    function goPage(p) {
        const url = new URL(window.location.href);
        url.searchParams.set("page", p);
        window.location.href = url.toString();
    }

    const COLORS = ['#4f63d2','#059669','#d97706','#dc2626','#8b5cf6','#0891b2','#db2777'];
    const GRID   = 'rgba(0,0,0,0.06)';
    const TICK   = '#718096';

    const baseOpts = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { color: GRID }, ticks: { color: TICK, font: { size: 11 } }, border: { display: false } },
            y: { grid: { color: GRID }, ticks: { color: TICK, font: { size: 11 }, maxTicksLimit: 5 }, border: { display: false } }
        }
    };

    /* ─── TREND ─── */
    let trendChart;
    let trendRaw = [];

    async function loadTrend() {
        const res = await fetch('/Admin/BookMark/ChartBookmarkTrend');
        trendRaw  = await res.json();
        renderTrend('week');
    }

    function renderTrend(mode) {
        let labels, values;

        if (mode === 'month') {
            const map = {};
            trendRaw.forEach(x => {
                const d = new Date(x.date);
                const key = `${d.getMonth() + 1}/${d.getFullYear()}`;
                map[key] = (map[key] || 0) + x.count;
            });
            labels = Object.keys(map);
            values = Object.values(map);
        } else {
            const slice = trendRaw.slice(-7);
            labels = slice.map(x => new Date(x.date).toLocaleDateString('vi-VN', { weekday: 'short', day: '2-digit', month: '2-digit' }));
            values = slice.map(x => x.count);
        }

        const ctx = document.getElementById('trendChart');
        if (trendChart) trendChart.destroy();

        trendChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels,
                datasets: [{
                    label: 'Lượt bookmark',
                    data: values,
                    borderColor: '#4f63d2',
                    backgroundColor: 'rgba(79,99,210,0.08)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#4f63d2',
                    borderWidth: 2
                }]
            },
            options: { ...baseOpts,
                scales: {
                    x: { ...baseOpts.scales.x, ticks: { ...baseOpts.scales.x.ticks, maxRotation: 40 } },
                    y: baseOpts.scales.y
                }
            }
        });
    }

    function switchTrend(mode, btn) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderTrend(mode);
    }

    /* ─── TOP STORIES ─── */
    async function loadTopStories() {
        const res  = await fetch('/Admin/BookMark/ChartTopStories');
        const data = await res.json();

        new Chart(document.getElementById('storyChart'), {
            type: 'bar',
            data: {
                labels: data.map(x => x.title.length > 20 ? x.title.slice(0, 20) + '…' : x.title),
                datasets: [{
                    label: 'Lượt bookmark',
                    data: data.map(x => x.count),
                    backgroundColor: data.map((_, i) => COLORS[i % COLORS.length] + 'cc'),
                    borderColor:     data.map((_, i) => COLORS[i % COLORS.length]),
                    borderWidth: 1,
                    borderRadius: 6
                }]
            },
            options: { ...baseOpts }
        });
    }

    /* ─── TOP USERS ─── */
    const USER_AVATARS = [
        '#dbeafe;color:#1e40af','#fce7f3;color:#9d174d',
        '#fef3c7;color:#92400e','#d1fae5;color:#065f46','#ede9fe;color:#5b21b6'
    ];

    async function loadTopUsers() {
        const res  = await fetch('/Admin/BookMark/ChartTopUsers');
        const data = await res.json();

        new Chart(document.getElementById('userChart'), {
            type: 'doughnut',
            data: {
                labels: data.map(x => x.username),
                datasets: [{
                    data: data.map(x => x.count),
                    backgroundColor: COLORS.slice(0, data.length),
                    borderWidth: 2,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '62%',
                plugins: {
                    legend: {
                        display: true,
                        position: 'bottom',
                        labels: { color: TICK, font: { size: 11 }, boxWidth: 10, padding: 8 }
                    }
                }
            }
        });

        const list = document.getElementById('topUserList');
        list.innerHTML = data.map((u, i) => {
            const initials = u.username.split(' ').slice(-2).map(w => w[0].toUpperCase()).join('');
            const parts    = USER_AVATARS[i % USER_AVATARS.length].split(';');
            const bg       = parts[0];
            const col      = parts[1] || '';
            return `
            <div class="member-row">
                <div class="avatar" style="background:${bg};${col}">
                    ${initials}
                </div>
                <div class="member-info">
                    <div class="name">${u.username}</div>
                    <div class="role">Độc giả</div>
                </div>
                <div class="member-reads">
                    ${u.count} bookmark
                    <span class="reads-up"><i class="bi bi-arrow-up"></i></span>
                </div>
            </div>`;
        }).join('');
    }

    /* ─── HEATMAP ─── */
    async function loadHeat() {
        const res  = await fetch('/Admin/BookMark/Heatmap');
        const data = await res.json();

        new Chart(document.getElementById('heatChart'), {
            type: 'polarArea',
            data: {
                labels: data.map(x => x.hour + ':00'),
                datasets: [{
                    data: data.map(x => x.count),
                    backgroundColor: data.map((_, i) => COLORS[i % COLORS.length] + '99'),
                    borderColor:     data.map((_, i) => COLORS[i % COLORS.length]),
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    r: {
                        ticks: { color: TICK, font: { size: 10 }, backdropColor: 'transparent' },
                        grid:  { color: GRID }
                    }
                }
            }
        });
    }

    /* ─── TOP CHAPTERS ─── */
    async function loadTopChapters() {
        const res  = await fetch('/Admin/BookMark/ChartTopChapters');
        const data = await res.json();

        new Chart(document.getElementById('chapterChart'), {
            type: 'bar',
            data: {
                labels: data.map(x => {
                    const label = `${x.story} - Ch.${x.chapter}`;
                    return label.length > 28 ? label.slice(0, 28) + '…' : label;
                }),
                datasets: [{
                    label: 'Lượt bookmark',
                    data: data.map(x => x.count),
                    backgroundColor: data.map((_, i) => COLORS[i % COLORS.length] + 'bb'),
                    borderColor:     data.map((_, i) => COLORS[i % COLORS.length]),
                    borderWidth: 1,
                    borderRadius: 6
                }]
            },
            options: {
                ...baseOpts,
                indexAxis: 'y',
                scales: {
                    x: baseOpts.scales.y,
                    y: { ...baseOpts.scales.x, ticks: { ...baseOpts.scales.x.ticks, maxRotation: 0 } }
                }
            }
        });
    }

    /* ─── INIT ─── */
    loadTrend();
    loadTopStories();
    loadTopUsers();
    loadHeat();
    loadTopChapters();

</script>
}
