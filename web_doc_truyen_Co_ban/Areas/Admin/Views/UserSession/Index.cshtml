@model IEnumerable<web_doc_truyen_Co_ban.Models.UserSessionViewModel>
@{
    ViewData["Title"] = "Quản lý Phiên Đăng Nhập";
    int    totalCount  = ViewBag.TotalCount;
    int    currentPage = ViewBag.CurrentPage;
    int    pageSize    = ViewBag.PageSize;
    int    totalPages  = ViewBag.TotalPages;
    Guid?  filterUserId = ViewBag.UserId;
    string search      = ViewBag.Search      ?? "";
    string deviceFilter= ViewBag.DeviceFilter ?? "";
    string statusFilter= ViewBag.StatusFilter ?? "";
}

<style>
    .ss-wrap { background:#fff; border:1.5px solid #e5e7eb; border-radius:14px; overflow:hidden; }
    .ss-head { padding:18px 24px; border-bottom:1px solid #f3f4f6;
               display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
    .ss-title { margin:0; font-size:17px; font-weight:700; color:#111827;
                display:flex; align-items:center; gap:8px; }
    .ss-title .cnt { font-size:13px; font-weight:400; color:#6b7280; }

    .ss-filters { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .s-box { display:flex; align-items:center; gap:6px;
             border:1.5px solid #e5e7eb; border-radius:9px; padding:5px 11px; background:#fff; }
    .s-box input { border:none; outline:none; font-size:13px; color:#111827;
                   background:transparent; width:190px; }
    .s-box input::placeholder { color:#9ca3af; }
    .s-sel { height:36px; border:1.5px solid #e5e7eb; border-radius:9px;
             padding:0 10px; font-size:13px; color:#374151; background:#fff;
             outline:none; cursor:pointer; }
    .s-btn { height:36px; padding:0 16px; background:#2563eb; color:#fff;
             border:none; border-radius:9px; font-size:13px; font-weight:600;
             cursor:pointer; display:flex; align-items:center; gap:5px; }
    .s-btn:hover { background:#1d4ed8; }
    .s-btn-danger { height:36px; padding:0 14px; background:#fee2e2; color:#991b1b;
                    border:1.5px solid #fca5a5; border-radius:9px; font-size:13px;
                    font-weight:600; cursor:pointer; display:flex; align-items:center; gap:5px; }
    .s-btn-danger:hover { background:#fecaca; }

    .ss-table { width:100%; border-collapse:collapse; }
    .ss-table th { font-size:11px; font-weight:700; letter-spacing:.07em; color:#6b7280;
                   padding:10px 14px; border-bottom:1.5px solid #e5e7eb; white-space:nowrap;
                   text-transform:uppercase; }
    .ss-table td { padding:12px 14px; font-size:13px; color:#111827;
                   border-bottom:1px solid #f3f4f6; vertical-align:middle; }
    .ss-table tbody tr:hover { background:#f9fafb; }

    .avatar { width:32px; height:32px; border-radius:50%; background:#dbeafe;
              color:#1d4ed8; display:inline-flex; align-items:center; justify-content:center;
              font-weight:700; font-size:12px; flex-shrink:0; }

    .badge { display:inline-flex; align-items:center; gap:4px;
             padding:3px 9px; border-radius:20px; font-size:11px; font-weight:600; }
    .badge-ok  { background:#d1fae5; color:#065f46; }
    .badge-exp { background:#fee2e2; color:#991b1b; }

    .dev-pill { display:inline-flex; align-items:center; gap:5px;
                background:#f3f4f6; padding:3px 9px; border-radius:20px;
                font-size:11px; font-weight:600; color:#374151; }

    .ip-code { font-size:11px; background:#f3f4f6; padding:2px 7px;
               border-radius:5px; color:#374151; font-family:monospace; }

    .act-btn { border:none; background:transparent; cursor:pointer;
               padding:5px 6px; border-radius:6px; transition:background .15s; }
    .act-btn:hover            { background:#f3f4f6; }
    .act-btn.del:hover        { background:#fee2e2; }

    .pg-bar { display:flex; align-items:center; justify-content:space-between;
              padding:14px 24px; border-top:1px solid #f3f4f6; }
    .pg-info { font-size:12px; color:#6b7280; }
    .pg-btns { display:flex; gap:5px; }
    .pg-btn  { min-width:32px; height:32px; border-radius:7px; border:1px solid #e5e7eb;
               background:#fff; cursor:pointer; font-size:12px; font-weight:600;
               display:inline-flex; align-items:center; justify-content:center;
               color:#374151; transition:all .15s; text-decoration:none; }
    .pg-btn:hover:not(.disabled) { background:#f3f4f6; }
    .pg-btn.active { background:#2563eb; color:#fff; border-color:#2563eb; }
    .pg-btn.disabled { opacity:.4; pointer-events:none; }

    .alert-ok { margin:10px 24px; padding:10px 14px; background:#d1fae5;
                color:#065f46; border-radius:8px; font-size:13px; font-weight:500; }
    .empty-row td { text-align:center; padding:48px 0; color:#9ca3af; font-size:14px; }
</style>

<div class="ss-wrap">
    <div class="ss-head">
        <h4 class="ss-title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5" y="2" width="14" height="20" rx="2"/>
                <line x1="12" y1="18" x2="12" y2="18.01"/>
            </svg>
            Quản lý Phiên Đăng Nhập
            <span class="cnt">(@totalCount)</span>
        </h4>

        <form method="get" action="@Url.Action("Index","UserSession")"
              class="ss-filters">

            @if (filterUserId.HasValue)
            {
                <input type="hidden" name="userId" value="@filterUserId" />
            }

            <div class="s-box">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="#9ca3af" stroke-width="2.5" stroke-linecap="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" name="search" placeholder="Tên, email, IP..."
                       value="@search" />
            </div>

            <select name="deviceType" class="s-sel">
                <option value="">Tất cả thiết bị</option>
                <option value="desktop" selected="@(deviceFilter == "desktop"  ? "selected" : null)">Desktop</option>
                <option value="mobile"  selected="@(deviceFilter == "mobile"   ? "selected" : null)">Mobile</option>
                <option value="tablet"  selected="@(deviceFilter == "tablet"   ? "selected" : null)">Tablet</option>
                <option value="bot"     selected="@(deviceFilter == "bot"      ? "selected" : null)">Bot</option>
            </select>

            <select name="status" class="s-sel">
                <option value="">Tất cả trạng thái</option>
                <option value="active"  selected="@(statusFilter == "active"   ? "selected" : null)">Còn hiệu lực</option>
                <option value="expired" selected="@(statusFilter == "expired"  ? "selected" : null)">Đã hết hạn</option>
            </select>

            <button type="submit" class="s-btn">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                Tìm kiếm
            </button>
        </form>
            <form method="post" action="@Url.Action("RevokeAllByUser","UserSession")"
                  onsubmit="return confirm('Thu hồi toàn bộ phiên của người dùng này?')">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@filterUserId" />
                <button type="submit" class="s-btn-danger">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14H6L5 6"/>
                        <path d="M9 6V4h6v2"/>
                    </svg>
                    Thu hồi tất cả
                </button>
            </form>
        @if (filterUserId.HasValue)
        {
            <form method="post" action="@Url.Action("RevokeAllByUser","UserSession")"
                  onsubmit="return confirm('Thu hồi toàn bộ phiên của người dùng này?')">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@filterUserId" />
                <button type="submit" class="s-btn-danger">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14H6L5 6"/>
                        <path d="M9 6V4h6v2"/>
                    </svg>
                    Thu hồi tất cả
                </button>
            </form>
        }
    </div>
    @if (TempData["Success"] != null)
    {
        <div class="alert-ok">✓ @TempData["Success"]</div>
    }
    <div style="overflow-x:auto;">
        <table class="ss-table">
            <thead>
                <tr>
                    <th>Người dùng</th>
                    <th>Địa chỉ IP</th>
                    <th>Thiết bị</th>
                    <th>Trình duyệt / HĐH</th>
                    <th>Trạng thái</th>
                    <th>Tạo lúc</th>
                    <th>Hết hạn</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr class="empty-row">
                    <td colspan="8">Không tìm thấy phiên đăng nhập nào.</td>
                </tr>
            }
            else
            {
                foreach (var s in Model)
                {
                    var init = s.Username.Length > 0
                        ? s.Username.Substring(0,1).ToUpper() : "?";

                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:9px;">
                                <div class="avatar">@init</div>
                                <div>
                                    <div style="font-weight:600;">@s.Username</div>
                                    <div style="font-size:11px;color:#6b7280;">@s.Email</div>
                                </div>
                            </div>
                        </td>
                        <td><span class="ip-code">@s.IpAddress</span></td>
                        <td>
                            <span class="dev-pill">
                                @switch (s.DeviceInfo.DeviceType)
                                {
                                    case "mobile":
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                            <rect x="5" y="2" width="14" height="20" rx="2"/>
                                            <line x1="12" y1="18" x2="12" y2="18.01"/>
                                        </svg>
                                        @: Mobile
                                        break;
                                    case "tablet":
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                            <rect x="4" y="2" width="16" height="20" rx="2"/>
                                            <line x1="12" y1="18" x2="12" y2="18.01"/>
                                        </svg>
                                        @: Tablet
                                        break;
                                    case "bot":
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                            <rect x="3" y="11" width="18" height="10" rx="2"/>
                                            <path d="M12 11V7"/><circle cx="12" cy="5" r="2"/>
                                        </svg>
                                        @: Bot
                                        break;
                                    default:
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                            <rect x="2" y="3" width="20" height="14" rx="2"/>
                                            <path d="M8 21h8M12 17v4"/>
                                        </svg>
                                        @: Desktop
                                        break;
                                }
                            </span>
                            <div style="font-size:11px;color:#9ca3af;margin-top:2px;">
                                @s.DeviceInfo.DeviceFamily
                            </div>
                        </td>
                        <td>
                            <div style="font-weight:600;font-size:12px;">@s.DeviceInfo.Browser</div>
                            <div style="font-size:11px;color:#6b7280;">@s.DeviceInfo.Os</div>
                        </td>
                        <td>
                            @if (s.IsExpired)
                            {
                                <span class="badge badge-exp">
                                    <svg width="9" height="9" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="3" stroke-linecap="round">
                                        <line x1="18" y1="6" x2="6" y2="18"/>
                                        <line x1="6" y1="6" x2="18" y2="18"/>
                                    </svg>
                                    Hết hạn
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-ok">
                                    <svg width="9" height="9" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="3" stroke-linecap="round">
                                        <polyline points="20 6 9 17 4 12"/>
                                    </svg>
                                    Hoạt động
                                </span>
                            }
                        </td>
                        <td style="white-space:nowrap;color:#374151;">
                            @s.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td style="white-space:nowrap;color:@(s.IsExpired ? "#ef4444" : "#374151");">
                            @s.ExpiresAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td>
                            <div style="display:flex;gap:4px;">
                                

                                <form method="post" action="@Url.Action("Revoke","UserSession")"
                                      onsubmit="return confirm('Thu hồi phiên này?')"
                                      style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <button type="submit" class="act-btn del" title="Thu hồi">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                             stroke="#ef4444" stroke-width="2" stroke-linecap="round">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6l-1 14H6L5 6"/>
                                            <path d="M9 6V4h6v2"/>
                                        </svg>
                                    </button>
                                </form>

                                
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="pg-bar">
            <span class="pg-info">
                Hiển thị @((currentPage-1)*pageSize+1)–@(Math.Min(currentPage*pageSize, totalCount))
                trong @totalCount phiên
            </span>
            <div class="pg-btns">
                <a class="pg-btn @(currentPage<=1 ? "disabled":"")"
                   href="@Url.Action("Index","UserSession", new{ page=currentPage-1, pageSize, userId=filterUserId, search, deviceType=deviceFilter, status=statusFilter })">
                    ‹
                </a>
                @for (int p = Math.Max(1, currentPage-2); p <= Math.Min(totalPages, currentPage+2); p++)
                {
                    <a class="pg-btn @(p==currentPage ? "active":"")"
                       href="@Url.Action("Index","UserSession", new{ page=p, pageSize, userId=filterUserId, search, deviceType=deviceFilter, status=statusFilter })">
                        @p
                    </a>
                }
                <a class="pg-btn @(currentPage>=totalPages ? "disabled":"")"
                   href="@Url.Action("Index","UserSession", new{ page=currentPage+1, pageSize, userId=filterUserId, search, deviceType=deviceFilter, status=statusFilter })">
                    ›
                </a>
            </div>
        </div>
    }

</div>
