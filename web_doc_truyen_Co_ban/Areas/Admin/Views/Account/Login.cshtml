@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
@model web_doc_truyen_Co_ban.Areas.Admin.Controllers.AdminLoginDto
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Nhập</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='48' fill='%236366f1'/><text x='50' y='68' font-size='60' text-anchor='middle' fill='white' font-family='system-ui,sans-serif'>L</text></svg>">
    <style>
        /* ===== RESET & BASE ===== */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --clr-bg-1: #0f0c29;
            --clr-bg-2: #302b63;
            --clr-bg-3: #24243e;
            --clr-accent-1: #a78bfa;
            --clr-accent-2: #f472b6;
            --clr-accent-3: #38bdf8;
            --glass-bg: rgba(255,255,255,0.07);
            --glass-border: rgba(255,255,255,0.15);
            --glass-hover: rgba(255,255,255,0.12);
            --text-primary: #f1f5f9;
            --text-muted: rgba(241,245,249,0.55);
            --input-bg: rgba(255,255,255,0.06);
            --input-focus: rgba(167,139,250,0.18);
            --radius: 20px;
            --radius-sm: 12px;
            --divider: rgba(255,255,255,0.18);
        }

        html, body { height: 100%; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            /* background-image: url('/img/anhdong.jpg');   */
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            line-height: 1.6;
            overflow: hidden;
            position: relative;
        }

        /* ===== ANIMATED BACKGROUND WAVES ===== */
        .wave-container {
            position: fixed; inset: 0;
            overflow: hidden; pointer-events: none; z-index: 0;
        }
        .wave {
            position: absolute;
            border-radius: 40%;
            animation: waveRotate linear infinite;
            opacity: 0.04;
        }
        .wave-1 { width: 200%; height: 200%; top: -50%; left: -50%; background: radial-gradient(ellipse, var(--clr-accent-1), transparent 70%); animation-duration: 18s; }
        .wave-2 { width: 180%; height: 180%; top: -40%; left: -40%; background: radial-gradient(ellipse, var(--clr-accent-2), transparent 70%); animation-duration: 24s; animation-direction: reverse; }
        .wave-3 { width: 160%; height: 160%; bottom: -50%; right: -50%; background: radial-gradient(ellipse, var(--clr-accent-3), transparent 70%); animation-duration: 30s; }
        .wave-4 { width: 140%; height: 140%; bottom: -40%; right: -40%; background: radial-gradient(ellipse, var(--clr-accent-1), transparent 70%); animation-duration: 20s; animation-direction: reverse; opacity: 0.03; }
        @@keyframes waveRotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

        /* ===== PARTICLES ===== */
        .gradient-particles { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
        .particle {
            position: absolute;
            border-radius: 50%;
            animation: particleDrift linear infinite;
        }
        .particle:nth-child(1) { width:6px;height:6px; background:var(--clr-accent-1); left:15%; top:20%; animation-duration:12s; animation-delay:-2s; }
        .particle:nth-child(2) { width:4px;height:4px; background:var(--clr-accent-2); left:75%; top:60%; animation-duration:16s; animation-delay:-5s; }
        .particle:nth-child(3) { width:8px;height:8px; background:var(--clr-accent-3); left:40%; top:80%; animation-duration:10s; animation-delay:-3s; }
        .particle:nth-child(4) { width:5px;height:5px; background:var(--clr-accent-1); left:85%; top:15%; animation-duration:14s; animation-delay:-7s; }
        .particle:nth-child(5) { width:3px;height:3px; background:var(--clr-accent-2); left:25%; top:50%; animation-duration:18s; animation-delay:-1s; }
        .particle:nth-child(6) { width:7px;height:7px; background:var(--clr-accent-3); left:60%; top:30%; animation-duration:22s; animation-delay:-9s; }
        @@keyframes particleDrift {
            0%   { transform: translateY(0) translateX(0) scale(1); opacity: 0.6; }
            33%  { transform: translateY(-40px) translateX(20px) scale(1.2); opacity: 1; }
            66%  { transform: translateY(-80px) translateX(-15px) scale(0.8); opacity: 0.4; }
            100% { transform: translateY(-120px) translateX(10px) scale(1); opacity: 0; }
        }

        /* ===== MAIN CARD ===== */
        .login-container {
            position: relative; z-index: 10;
            width: 100%; max-width: 900px;
            padding: 24px;
        }

        .login-card {
            display: flex;
            border-radius: var(--radius);
            overflow: hidden;
            backdrop-filter: blur(28px) saturate(180%);
            -webkit-backdrop-filter: blur(28px) saturate(180%);
            background: rgba(15, 12, 41, 0.55);
            border: 1px solid var(--glass-border);
            box-shadow:
                0 32px 80px rgba(0,0,0,0.5),
                0 0 0 1px rgba(255,255,255,0.06) inset,
                0 1px 0 rgba(255,255,255,0.12) inset;
            animation: cardReveal 0.8s cubic-bezier(0.34,1.56,0.64,1) both;
        }
        @@keyframes cardReveal {
            from { opacity:0; transform: translateY(32px) scale(0.96); }
            to   { opacity:1; transform: translateY(0) scale(1); }
        }

        /* ===== GLOW ===== */
        .card-glow {
            position: absolute; inset: -2px;
            border-radius: inherit;
            background: conic-gradient(from 180deg, var(--clr-accent-1), var(--clr-accent-2), var(--clr-accent-3), var(--clr-accent-1));
            opacity: 0;
            transition: opacity 0.6s;
            pointer-events: none;
            z-index: -1;
            filter: blur(20px);
        }
        .login-card:hover .card-glow { opacity: 0.18; }

        /* ===== SPLIT PANES ===== */
        .pane-left {
            flex: 1 1 0;
            padding: 48px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-width: 0;
        }

        .pane-divider {
            width: 1px;
            background: linear-gradient(to bottom, transparent 5%, var(--divider) 30%, var(--divider) 70%, transparent 95%);
            flex-shrink: 0;
            position: relative;
        }
        .pane-divider::after {
            content: 'HOẶC';
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(15,12,41,0.85);
            color: var(--text-muted);
            font-size: 10px;
            letter-spacing: 2px;
            padding: 8px 4px;
            font-weight: 600;
            writing-mode: vertical-lr;
            text-orientation: mixed;
        }

        .pane-right {
            flex: 0 0 280px;
            padding: 48px 36px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 16px;
            background: rgba(255,255,255,0.025);
        }

        /* ===== HEADER ===== */
        .login-header { text-align: center; margin-bottom: 32px; }
        .gradient-icon {
            width: 52px; height: 52px;
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 16px;
            background: linear-gradient(135deg, var(--clr-accent-1), var(--clr-accent-2));
            position: relative; overflow: hidden;
            box-shadow: 0 8px 24px rgba(167,139,250,0.35);
        }
        .gradient-icon svg { width: 24px; height: 24px; color: white; position: relative; z-index: 1; }
        .icon-wave {
            position: absolute; inset: 0;
            background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.2));
            animation: iconShimmer 3s ease-in-out infinite;
        }
        @@keyframes iconShimmer {
            0%,100% { opacity: 0; } 50% { opacity: 1; }
        }
        .login-header h2 { font-size: 26px; font-weight: 700; color: var(--text-primary); letter-spacing: -0.5px; margin-bottom: 6px; }
        .login-header p  { font-size: 13px; color: var(--text-muted); letter-spacing: 0.3px; }

        /* ===== FORM ===== */
        .login-form { display: flex; flex-direction: column; gap: 16px; }
        .form-group { display: flex; flex-direction: column; gap: 5px; }

        .input-container {
            position: relative; border-radius: var(--radius-sm); overflow: hidden;
        }
        .input-bg {
            position: absolute; inset: 0;
            background: var(--input-bg);
            border: 1px solid var(--glass-border);
            border-radius: inherit;
            transition: background 0.3s, border-color 0.3s;
        }
        .input-container:focus-within .input-bg {
            background: var(--input-focus);
            border-color: var(--clr-accent-1);
        }
        .input-container input {
            position: relative; z-index: 1;
            width: 100%; padding: 15px 16px 6px;
            background: transparent;
            border: none; outline: none;
            color: var(--text-primary);
            font-size: 14px;
            font-family: inherit;
        }
        .input-container label {
            position: absolute; left: 16px; top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted); font-size: 13px;
            pointer-events: none; z-index: 2;
            transition: 0.25s cubic-bezier(0.4,0,0.2,1);
        }
        .input-container input:focus + label,
        .input-container input:not(:placeholder-shown) + label {
            top: 10px; transform: none; font-size: 10px;
            color: var(--clr-accent-1); letter-spacing: 0.5px;
        }
        .input-wave {
            position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
            background: linear-gradient(90deg, var(--clr-accent-1), var(--clr-accent-2), var(--clr-accent-3));
            transform: scaleX(0); transform-origin: left;
            transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
        }
        .input-container:focus-within .input-wave { transform: scaleX(1); }

        .password-container { }
        .password-toggle {
            position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
            background: none; border: none; cursor: pointer; z-index: 3; padding: 4px;
            color: var(--text-muted); transition: color 0.2s;
        }
        .password-toggle:hover { color: var(--clr-accent-1); }
        .toggle-bg {
            position: absolute; inset: 0; border-radius: 6px;
            background: rgba(255,255,255,0.06);
            opacity: 0; transition: opacity 0.2s;
        }
        .password-toggle:hover .toggle-bg { opacity: 1; }
        .eye-closed { display: none; }
        .password-toggle.active .eye-open  { display: none; }
        .password-toggle.active .eye-closed { display: block; }
        .toggle-icon svg { width: 16px; height: 16px; display: block; }

        .error-message { font-size: 11px; color: #f87171; padding-left: 4px; min-height: 16px; }

        /* ===== OPTIONS ===== */
        .form-options {
            display: flex; align-items: center; justify-content: space-between;
        }
        .checkbox-container { display: flex; align-items: center; gap: 8px; }
        .checkbox-container input[type="checkbox"] { display: none; }
        .checkbox-label {
            display: flex; align-items: center; gap: 8px;
            cursor: pointer; color: var(--text-muted); font-size: 12px; user-select: none;
        }
        .gradient-checkbox {
            width: 18px; height: 18px; border-radius: 5px;
            position: relative; flex-shrink: 0; overflow: hidden;
        }
        .checkbox-bg {
            position: absolute; inset: 0;
            border: 1.5px solid var(--glass-border);
            border-radius: inherit;
            background: var(--input-bg);
            transition: all 0.25s;
        }
        .gradient-checkbox svg {
            position: absolute; inset: 0;
            width: 100%; height: 100%;
            color: white; opacity: 0; transition: opacity 0.2s;
            padding: 2px;
        }
        .checkbox-container input:checked ~ .checkbox-label .checkbox-bg {
            background: linear-gradient(135deg, var(--clr-accent-1), var(--clr-accent-2));
            border-color: transparent;
        }
        .checkbox-container input:checked ~ .checkbox-label .gradient-checkbox svg { opacity: 1; }

        .forgot-link {
            font-size: 12px; color: var(--clr-accent-1);
            text-decoration: none; transition: color 0.2s, opacity 0.2s;
            opacity: 0.8;
        }
        .forgot-link:hover { opacity: 1; color: var(--clr-accent-2); }

        /* ===== SUBMIT BUTTON ===== */
        .gradient-button {
            position: relative; width: 100%;
            padding: 14px; border: none; cursor: pointer;
            border-radius: var(--radius-sm); overflow: hidden;
            font-family: inherit; font-size: 14px; font-weight: 600;
            color: white; letter-spacing: 0.3px;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .gradient-button:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(167,139,250,0.4); }
        .gradient-button:active { transform: translateY(0); }
        .button-bg {
            position: absolute; inset: 0;
            background: linear-gradient(135deg, var(--clr-accent-1) 0%, var(--clr-accent-2) 50%, var(--clr-accent-3) 100%);
            background-size: 200% 200%;
            animation: gradShift 4s ease infinite;
        }
        @@keyframes gradShift {
            0%,100% { background-position: 0% 50%; }
            50%      { background-position: 100% 50%; }
        }
        .button-content { position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-loader { display: none; gap: 4px; align-items: center; }
        .btn-loader.active { display: flex; }
        .btn-text.hidden { display: none; }
        .loader-wave {
            width: 4px; height: 14px; border-radius: 2px;
            background: white; animation: loaderPulse 0.8s ease-in-out infinite;
        }
        .loader-wave:nth-child(2) { animation-delay: 0.15s; }
        .loader-wave:nth-child(3) { animation-delay: 0.30s; }
        @@keyframes loaderPulse {
            0%,100% { transform: scaleY(0.4); opacity: 0.5; }
            50%      { transform: scaleY(1); opacity: 1; }
        }
        .button-ripple {
            position: absolute; inset: 0; pointer-events: none;
        }

        /* ===== RIGHT PANE ===== */
        .social-header { text-align: center; margin-bottom: 8px; }
        .social-header h3 { font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 4px; }
        .social-header p  { font-size: 12px; color: var(--text-muted); }

        .social-btn {
            position: relative; width: 100%;
            display: flex; align-items: center; gap: 14px;
            padding: 13px 18px; border: none; cursor: pointer;
            border-radius: var(--radius-sm); overflow: hidden;
            font-family: inherit; font-size: 13px; font-weight: 500;
            color: var(--text-primary); text-align: left;
            transition: transform 0.2s;
        }
        .social-btn:hover { transform: translateX(3px); }
        .social-bg {
            position: absolute; inset: 0;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: inherit;
            transition: background 0.25s, border-color 0.25s;
        }
        .social-btn:hover .social-bg {
            background: var(--glass-hover);
            border-color: rgba(255,255,255,0.25);
        }
        .social-btn svg { width: 20px; height: 20px; flex-shrink: 0; position: relative; z-index: 1; }
        .social-btn span { position: relative; z-index: 1; }

        .signup-link {
            margin-top: 4px; text-align: center;
            font-size: 12px; color: var(--text-muted);
        }
        .signup-link a { color: var(--clr-accent-1); text-decoration: none; font-weight: 500; }
        .signup-link a:hover { color: var(--clr-accent-2); }

        /* ===== SUCCESS OVERLAY ===== */
        .success-message {
            display: none; position: absolute; inset: 0;
            border-radius: var(--radius);
            align-items: center; justify-content: center;
            flex-direction: column; gap: 12px;
            backdrop-filter: blur(20px);
            background: rgba(15,12,41,0.8);
            z-index: 20;
            animation: fadeIn 0.4s ease;
        }
        .success-message.active { display: flex; }
        @@keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
        .success-wave {
            position: absolute; inset: 0; border-radius: inherit;
            background: linear-gradient(135deg, rgba(167,139,250,0.1), rgba(244,114,182,0.1));
            animation: successPulse 2s ease-in-out infinite;
        }
        @@keyframes successPulse {
            0%,100% { opacity: 0.5; } 50% { opacity: 1; }
        }
        .success-content { position: relative; z-index: 1; text-align: center; }
        .success-icon {
            width: 60px; height: 60px; border-radius: 50%;
            background: linear-gradient(135deg, var(--clr-accent-1), var(--clr-accent-2));
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 16px;
            box-shadow: 0 0 40px rgba(167,139,250,0.5);
            animation: successBounce 0.6s cubic-bezier(0.34,1.56,0.64,1) both;
        }
        @@keyframes successBounce {
            from { transform: scale(0); opacity: 0; }
            to   { transform: scale(1); opacity: 1; }
        }
        .success-icon svg { width: 28px; height: 28px; color: white; }
        .success-content h3 { font-size: 22px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
        .success-content p  { font-size: 13px; color: var(--text-muted); }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 640px) {
            .login-card { flex-direction: column; }
            .pane-divider {
                width: auto; height: 1px;
                background: linear-gradient(to right, transparent 5%, var(--divider) 30%, var(--divider) 70%, transparent 95%);
            }
            .pane-divider::after {
                writing-mode: horizontal-tb;
                padding: 4px 10px;
                top: 50%; left: 50%;
            }
            .pane-right { flex: none; padding: 28px 36px 40px; }
            .social-btn { padding: 12px 14px; }
        }
    </style>
</head>
<body>
    <div class="wave-container">
        <div class="wave wave-1"></div>
        <div class="wave wave-2"></div>
        <div class="wave wave-3"></div>
        <div class="wave wave-4"></div>
    </div>

    <div class="gradient-particles">
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
    </div>

    <div class="login-container">
        <div class="login-card">
            <div class="card-glow"></div>

            <!-- ========== LEFT PANE: FORM ========== -->
            <div class="pane-left">
                <div class="login-header">
                    <div class="gradient-icon">
                        <div class="icon-wave"></div>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                            <path d="M2 17l10 5 10-5"/>
                            <path d="M2 12l10 5 10-5"/>
                        </svg>
                    </div>
                    <h2>Chào Mừng</h2>
                    <p>Vui Lòng Tiếp Tục Đăng Nhập</p>
                </div>

                <form asp-action="Login" asp-controller="Account" class="login-form" id="loginForm" novalidate>
                    @Html.AntiForgeryToken();

                    <div class="form-group">
                        <div class="input-container">
                            <div class="input-bg"></div>
                            <input name="Email" 
                                   type="email" 
                                   required 
                                   autocomplete="email" 
                                   placeholder=" ">
                            <label for="emailInput">Địa Chỉ Email</label>
                            <div class="input-wave"></div>
                        </div>
                        <span class="error-message" id="emailError"></span>
                    </div>

                    <div class="form-group">
                        <div class="input-container password-container">
                            <div class="input-bg"></div>
                            <input name="Password" 
                                   type="password" 
                                   id="passwordInput" 
                                   required 
                                   autocomplete="current-password" 
                                   placeholder=" ">
                            <label for="passwordInput">Mật Khẩu</label>
                            <button type="button" class="password-toggle" id="passwordToggle" aria-label="Toggle password visibility">
                                <span id="eyeIcon">👁</span>
                            </button>
                            <div class="input-wave"></div>
                        </div>
                        <span class="error-message" id="passwordError"></span>
                    </div>

                    <div class="form-options">
                        <div class="checkbox-container">
                            <input type="checkbox" id="rememberMe" name="RememberMe" value="true">
                            <label for="rememberMe" class="checkbox-label">
                                <div class="gradient-checkbox">
                                    <div class="checkbox-bg"></div>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                        <polyline points="20 6 9 17 4 12"/>
                                    </svg>
                                </div>
                                Ghi Nhớ Đăng Nhập
                            </label>
                        </div>
                        <a href="#" class="forgot-link">Quên Mật Khẩu?</a>
                    </div>

                    <button type="submit" class="gradient-button">
                        <div class="button-bg"></div>
                        <div class="button-content">
                            <span class="btn-text">Đăng Nhập</span>
                            <div class="btn-loader">
                                <div class="loader-wave"></div>
                                <div class="loader-wave"></div>
                                <div class="loader-wave"></div>
                            </div>
                        </div>
                        <div class="button-ripple"></div>
                    </button>
                </form>
            </div>

            <!-- ========== DIVIDER ========== -->
            <div class="pane-divider"></div>

            <!-- ========== RIGHT PANE: SOCIAL ========== -->
            <div class="pane-right">
                <div class="social-header">
                    <h3>Đăng Nhập Nhanh</h3>
                    <p>Tiếp tục với tài khoản của bạn</p>
                </div>

                <button type="button" class="social-btn">
                    <div class="social-bg"></div>
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    <span style="color:dodgerblue">Tiếp tục với Google</span>
                </button>

                <button type="button" class="social-btn">
                    <div class="social-bg"></div>
                    <svg viewBox="0 0 24 24" fill="#1877F2">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                    <span style="color:dodgerblue">Tiếp tục với Facebook</span>
                </button>

                <button type="button" class="social-btn">
                    <div class="social-bg"></div>
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                    </svg>
                    <span style="color:dodgerblue">Tiếp tục với Apple</span>
                </button>

                <div class="signup-link">
                    <p>Chưa có tài khoản? <a asp-action="Register" asp-controller="Account">Đăng Ký</a></p>
                </div>
            </div>

            <!-- SUCCESS OVERLAY -->
            <div class="success-message" id="successMessage">
                <div class="success-wave"></div>
                <div class="success-content">
                    <div class="success-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    </div>
                    <h3>Chào Mừng Bạn!</h3>
                    <p>Chúc Bạn Đọc Tuyện Thật Vui Vẻ...</p>
                </div>
            </div>
        </div>
    </div>

<script>
        document.addEventListener("DOMContentLoaded", function () {

            // Toggle password
            document.getElementById("passwordToggle").onclick = function() {
                var input = document.getElementById("passwordInput");
                var icon  = document.getElementById("eyeIcon");
                input.type = input.type === "password" ? "text" : "password";
                icon.textContent = input.type === "password" ? "👁" : "🙈";
            };

            // Submit AJAX
            document.getElementById("loginForm").addEventListener("submit", async function(e) {
                e.preventDefault();

                var form      = this;
                var btnText   = form.querySelector(".btn-text");
                var btnLoader = form.querySelector(".btn-loader");
                var submitBtn = form.querySelector(".gradient-button");

                btnText.classList.add("hidden");
                btnLoader.classList.add("active");
                submitBtn.disabled = true;

                document.getElementById("emailError").textContent    = "";
                document.getElementById("passwordError").textContent = "";

                try {
                    var response = await fetch(form.action, {
                        method: "POST",
                        body: new FormData(form)
                    });
                    var result = await response.json();

                    if (result.success) {
                        document.getElementById("successMessage").classList.add("active");
                        setTimeout(function() {
                            window.location.href = result.redirectUrl || "/";
                        }, 1500);
                    } else {
                        var msg = (result.message || "").toLowerCase();
                        if (msg.includes("mật khẩu") || msg.includes("email"))
                            document.getElementById("emailError").textContent = result.message;
                        else
                            document.getElementById("emailError").textContent = result.message;

                        btnText.classList.remove("hidden");
                        btnLoader.classList.remove("active");
                        submitBtn.disabled = false;
                    }
                } catch(err) {
                    document.getElementById("emailError").textContent = "Có lỗi xảy ra.";
                    btnText.classList.remove("hidden");
                    btnLoader.classList.remove("active");
                    submitBtn.disabled = false;
                }
            });
        });
    </script>

</body>
</html>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
        @RenderSection("Scripts", required: false)
    }
}