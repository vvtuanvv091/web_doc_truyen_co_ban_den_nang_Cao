@model List<web_doc_truyen_Co_ban.Areas.Admin.Service.MangaDexResult>
@{
    ViewData["Title"] = "Kết quả tìm kiếm MangaDex";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Kết quả tìm kiếm</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/Admin/Home">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Admin/Import">Import MangaDex</a></li>
        <li class="breadcrumb-item active">Kết quả</li>
    </ol>

    <div class="mb-3">
        <a href="/Admin/Import" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Tìm lại
        </a>
        <span class="ms-3 text-muted">
            Tìm từ khoá: <strong>"@ViewData["SearchTitle"]"</strong> —
            Tìm thấy <strong>@Model.Count</strong> kết quả
        </span>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">Không tìm thấy truyện nào. Thử từ khoá khác.</div>
    }
    else
    {
        <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-3">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(item.CoverUrl))
                        {
                            <img src="@item.CoverUrl"
                                 class="card-img-top"
                                 alt="@item.Title"
                                 style="height:220px; object-fit:cover;"
                                 onerror="this.src='/img/no-cover.png'" />
                        }
                        else
                        {
                            <div class="bg-secondary text-white d-flex align-items-center justify-content-center"
                                 style="height:220px; font-size:0.75rem;">
                                Không có ảnh
                            </div>
                        }
                        <div class="card-body p-2">
                            <p class="card-title fw-semibold mb-1" style="font-size:0.85rem; line-height:1.3;">
                                @item.Title
                            </p>
                            <p class="text-muted mb-1" style="font-size:0.75rem;">
                                @(item.AuthorName ?? "—")
                            </p>
                            <div class="d-flex gap-1 flex-wrap mb-2">
                                @if (!string.IsNullOrEmpty(item.Status))
                                {
                                    <span class="badge bg-info" style="font-size:0.7rem;">@item.Status</span>
                                }
                                @if (item.Year.HasValue)
                                {
                                    <span class="badge bg-secondary" style="font-size:0.7rem;">@item.Year</span>
                                }
                                @if (item.ContentRating is "erotica" or "pornographic")
                                {
                                    <span class="badge bg-danger" style="font-size:0.7rem;">18+</span>
                                }
                            </div>
                        </div>
                        <div class="card-footer p-2">
                            <a asp-action="Preview"
                                   asp-route-mangaDexId="@item.MangaDexId"
                                   class="btn btn-primary btn-sm w-100">
                                <i class="fas fa-eye"></i> Xem & Import
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
