@model IEnumerable<web_doc_truyen_Co_ban.Models.UsersModel>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Người Dùng";
    ViewData["ActiveMenu"] = "User";

    int page       = (int)(ViewBag.Page ?? 1);
    int totalPages = (int)(ViewBag.TotalPages ?? 1);
    int total      = (int)(ViewBag.Total ?? 0);
    string search  = ViewData["Search"]?.ToString() ?? "";

    var allRoles   = ViewBag.AllRoles as List<web_doc_truyen_Co_ban.Models.RolesModel> ?? new();
    Guid? roleFilter = ViewBag.RoleFilter as Guid?;
    // var _navAvatar = Context.Session.GetString("AvatarUrl");

}

@section Styles {
<style>
    .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px}
    .page-title{font-size:1.25rem;font-weight:800;color:#1e293b;margin:0}
    .card{background:#fff;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 4px rgba(0,0,0,.06)}
    .search-box{position:relative;max-width:260px;flex:1}
    .search-box input{width:100%;padding:8px 14px 8px 36px;border:1px solid #e2e8f0;border-radius:8px;font-size:.84rem;outline:none;transition:border .15s}
    .search-box input:focus{border-color:#2563eb}
    .search-box i{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#94a3b8}
    .btn-add{display:inline-flex;align-items:center;gap:6px;background:#2563eb;color:#fff;border:none;padding:9px 18px;border-radius:8px;font-weight:700;font-size:.84rem;cursor:pointer;text-decoration:none;transition:background .15s}
    .btn-add:hover{background:#1d4ed8;color:#fff}
    select.filter-select{padding:8px 12px;border:1px solid #e2e8f0;border-radius:8px;font-size:.84rem;outline:none;background:#fff;cursor:pointer}
    select.filter-select:focus{border-color:#2563eb}
    table{width:100%;border-collapse:collapse}
    thead th{padding:10px 14px;font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:#64748b;border-bottom:2px solid #e2e8f0;white-space:nowrap}
    tbody td{padding:11px 14px;border-bottom:1px solid #f1f5f9;font-size:.84rem;vertical-align:middle}
    tbody tr:hover{background:#f8fafc}
    tbody tr:last-child td{border-bottom:none}
    .badge{padding:3px 10px;border-radius:20px;font-size:.71rem;font-weight:700;white-space:nowrap}
    .action-btns{display:flex;gap:6px}
    .btn-icon{width:32px;height:32px;border:none;border-radius:7px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.85rem;text-decoration:none;transition:all .15s}
    .btn-edit{background:#eff6ff;color:#2563eb}.btn-edit:hover{background:#dbeafe}
    .btn-del{background:#fef2f2;color:#ef4444}.btn-del:hover{background:#fee2e2}
    .pagination{display:flex;gap:6px;align-items:center;margin-top:0;justify-content:flex-end}
    .page-btn{width:34px;height:34px;border:1px solid #e2e8f0;border-radius:7px;background:#fff;display:flex;align-items:center;justify-content:center;font-size:.82rem;font-weight:600;color:#475569;text-decoration:none;transition:all .15s}
    .page-btn:hover,.page-btn.active{background:#2563eb;color:#fff;border-color:#2563eb}
    .page-btn.disabled{pointer-events:none;opacity:.4}
    .info-bar{font-size:.8rem;color:#64748b}
    .empty-state{text-align:center;padding:60px 20px;color:#94a3b8}
    .empty-state i{font-size:3rem;display:block;margin-bottom:12px}
    .avatar-sm{width:34px;height:34px;border-radius:50%;object-fit:cover;background:#e2e8f0;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.82rem;color:#64748b;flex-shrink:0}
    .user-cell{display:flex;align-items:center;gap:10px}
    .toast-wrap{position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px}
    .toast-msg{background:#fff;border-radius:10px;padding:14px 18px;box-shadow:0 4px 20px rgba(0,0,0,.12);border-left:4px solid #22c55e;display:flex;align-items:center;gap:10px;font-size:.84rem;font-weight:600;animation:slideIn .3s ease;min-width:260px}
    .toast-err{border-left-color:#ef4444}
    @@keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:none;opacity:1}}

    /* Dropdown role inline */
    .role-select{padding:4px 8px;border:1px solid #e2e8f0;border-radius:6px;font-size:.78rem;font-weight:600;background:#f8fafc;cursor:pointer;outline:none;transition:border .15s}
    .role-select:focus{border-color:#2563eb}
</style>
}

@if (TempData["Success"] != null)
{
    <div class="toast-wrap" id="toastWrap">
        <div class="toast-msg"><i class="bi bi-check-circle-fill text-success"></i> @TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="toast-wrap" id="toastWrap">
        <div class="toast-msg toast-err"><i class="bi bi-x-circle-fill text-danger"></i> @TempData["Error"]</div>
    </div>
}

<!-- Page Header -->
<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-people me-2"></i>Quản lý Người Dùng
        <span style="font-size:.85rem;color:#64748b;font-weight:600">(@total)</span>
    </h1>
    <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
        <form method="get" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
            <!-- Search -->
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input name="search" value="@search" placeholder="Tên, email..." />
            </div>

            <!-- Filter role -->
            <select name="roleFilter" class="filter-select" onchange="this.form.submit()">
                <option value="">Tất cả quyền</option>
                @foreach (var r in allRoles)
                {
                    @if (roleFilter == r.Id)
                    {
                        <option value="@r.Id" selected>@r.Name</option>
                    }
                    else
                    {
                        <option value="@r.Id">@r.Name</option>
                    }
                }
            </select>

            <button type="submit" class="btn-add" style="padding:8px 14px">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(search) || roleFilter.HasValue)
            {
                <a href="@Url.Action("Index")" class="btn-add" style="background:#64748b;padding:8px 12px">
                    <i class="bi bi-x"></i>
                </a>
            }
        </form>

        <a asp-area="Admin" asp-controller="User" asp-action="Create" class="btn-add">
            <i class="bi bi-person-plus"></i> Thêm người dùng
        </a>
    </div>
</div>

<!-- Table -->
<div class="card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-people"></i>
            <p>Chưa có người dùng nào.</p>
        </div>
    }
    else
    {
    <table>
        <thead>
            <tr>
                <th>Người dùng</th>
                <th>Email</th>
                <th>Quyền</th>
                <th>Trạng thái</th>
                <th>Đăng nhập cuối</th>
                <th>Ngày tạo</th>
                <th style="width:100px;text-align:center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <!-- Avatar + Username -->
                <td>
                    <div class="user-cell">
                        @if (!string.IsNullOrEmpty(u.AvatarUrl))
                        {
                                    <img src="@u.AvatarUrl"
                                    style="width:28px;height:28px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                        }
                        else
                        {
                            <div class="avatar-sm">
                                @u.Username.Substring(0, 1).ToUpper()
                            </div>
                        }
                        <div>
                            <div style="font-weight:700;color:#1e293b">@u.Username</div>
                            @if (!string.IsNullOrEmpty(u.DisplayName) && u.DisplayName != u.Username)
                            {
                                <div style="font-size:.75rem;color:#94a3b8">@u.DisplayName</div>
                            }
                        </div>
                    </div>
                </td>

                <!-- Email -->
                <td style="color:#475569;font-size:.82rem">
                    @u.Email
                    @if (u.EmailVerified)
                    {
                        <i class="bi bi-patch-check-fill text-success ms-1" title="Đã xác minh" style="font-size:.75rem"></i>
                    }
                </td>
                <!-- Role — dropdown inline -->
                <td>
                    <select class="role-select"
                            onchange="assignRole('@u.Id', this.value, this)"
                            title="Đổi quyền nhanh">
                        @foreach (var r in allRoles)
                        {
                            @if (u.RoleId == r.Id)
                            {
                                <option value="@r.Id" selected>@r.Name</option>
                            }
                            else
                            {
                                <option value="@r.Id">@r.Name</option>
                            }
                        }
                    </select>
                </td>

                <!-- Status -->
                <td>
                    @{
                        var (statusLabel, statusClass) = u.Status switch
                        {
                            0 => ("Chưa xác minh", "bg-warning bg-opacity-10 text-warning"),
                            1 => ("Hoạt động",     "bg-success bg-opacity-10 text-success"),
                            2 => ("Tạm khóa",      "bg-warning bg-opacity-10 text-warning"),
                            3 => ("Đã cấm",        "bg-danger  bg-opacity-10 text-danger"),
                            _ => ("Không rõ",      "bg-secondary bg-opacity-10 text-secondary")
                        };
                    }
                    <div style="display:flex;align-items:center;gap:6px">
                        <span class="badge @statusClass">@statusLabel</span>
                        <!-- Nút đổi status nhanh -->
                        <div style="display:flex;gap:3px">
                            @if (u.Status != 1)
                            {
                                <button class="btn-icon" style="background:#dcfce7;color:#16a34a;width:26px;height:26px;font-size:.75rem"
                                        onclick="setStatus('@u.Id', 1)" title="Mở khóa">
                                    <i class="bi bi-unlock"></i>
                                </button>
                            }
                            @if (u.Status != 2)
                            {
                                <button class="btn-icon" style="background:#fef9c3;color:#ca8a04;width:26px;height:26px;font-size:.75rem"
                                        onclick="setStatus('@u.Id', 2)" title="Tạm khóa">
                                    <i class="bi bi-lock"></i>
                                </button>
                            }
                            @if (u.Status != 3)
                            {
                                <button class="btn-icon" style="background:#fef2f2;color:#ef4444;width:26px;height:26px;font-size:.75rem"
                                        onclick="setStatus('@u.Id', 3)" title="Cấm vĩnh viễn">
                                    <i class="bi bi-slash-circle"></i>
                                </button>
                            }
                        </div>
                    </div>
                </td>

                <!-- Last login -->
                <td style="font-size:.78rem;color:#64748b;white-space:nowrap">
                    @(u.LastLoginAt.HasValue ? u.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm") : "—")
                </td>

                <!-- Created -->
                <td style="font-size:.78rem;color:#64748b;white-space:nowrap">
                    @u.CreatedAt.ToString("dd/MM/yyyy")
                </td>

                <!-- Actions -->
                <td>
                    <div class="action-btns" style="justify-content:center">
                        <a asp-area="Admin" asp-controller="User" asp-action="Edit"
                           asp-route-id="@u.Id" class="btn-icon btn-edit" title="Sửa">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <button class="btn-icon btn-del" title="Xóa"
                                onclick="confirmDelete('@u.Id', '@u.Username')">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <!-- Pagination -->
    <div style="padding:14px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;border-top:1px solid #f1f5f9">
        <span class="info-bar">
            Hiển thị @((page-1)*ViewBag.PageSize+1)–@Math.Min(page*ViewBag.PageSize, total) / @total người dùng
        </span>
        @if (totalPages > 1)
        {
        <div class="pagination">
            <a href="?page=@(page-1)&search=@search&roleFilter=@roleFilter"
               class="page-btn @(page<=1 ? "disabled" : "")">
                <i class="bi bi-chevron-left"></i>
            </a>
            @for (int i = Math.Max(1, page-2); i <= Math.Min(totalPages, page+2); i++)
            {
                <a href="?page=@i&search=@search&roleFilter=@roleFilter"
                   class="page-btn @(i==page ? "active" : "")">@i</a>
            }
            <a href="?page=@(page+1)&search=@search&roleFilter=@roleFilter"
               class="page-btn @(page>=totalPages ? "disabled" : "")">
                <i class="bi bi-chevron-right"></i>
            </a>
        </div>
        }
    </div>
    }
</div>

<!-- Modal xóa -->
<div id="deleteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9998;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:14px;padding:28px 32px;max-width:420px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.2)">
        <div style="font-size:2.5rem;margin-bottom:12px">🗑️</div>
        <h5 style="font-weight:800;margin-bottom:8px">Xác nhận xóa</h5>
        <p style="color:#64748b;font-size:.88rem;margin-bottom:24px">
            Bạn có chắc muốn xóa tài khoản <strong id="deleteTitle"></strong>?<br>
            <span style="color:#ef4444;font-size:.82rem">Toàn bộ session và dữ liệu liên quan sẽ bị xóa.</span>
        </p>
        <form id="deleteForm" method="post">
            @Html.AntiForgeryToken()
            <div style="display:flex;gap:10px;justify-content:center">
                <button type="button" onclick="closeModal()"
                    style="padding:9px 24px;border:1px solid #e2e8f0;border-radius:8px;background:#fff;font-weight:600;cursor:pointer">
                    Hủy
                </button>
                <button type="submit"
                    style="padding:9px 24px;border:none;border-radius:8px;background:#ef4444;color:#fff;font-weight:700;cursor:pointer">
                    Xóa
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Toast động (JS) -->
<div id="jsToastWrap" class="toast-wrap" style="display:none"></div>

@section Scripts {
<script>
    // Toast tĩnh (TempData)
    const tw = document.getElementById('toastWrap');
    if (tw) setTimeout(() => { tw.style.transition='opacity .4s'; tw.style.opacity='0'; }, 3000);

    // Toast động
    function showToast(msg, isError = false) {
        const wrap = document.getElementById('jsToastWrap');
        wrap.style.display = 'flex';
        wrap.innerHTML = `<div class="toast-msg ${isError ? 'toast-err' : ''}">
            <i class="bi bi-${isError ? 'x-circle-fill text-danger' : 'check-circle-fill text-success'}"></i> ${msg}
        </div>`;
        setTimeout(() => { wrap.style.opacity='0'; wrap.style.transition='opacity .4s'; }, 3000);
    }

    // Xóa user
    function confirmDelete(id, name) {
        document.getElementById('deleteTitle').textContent = name;
        document.getElementById('deleteForm').action = '/Admin/User/Delete/' + id;
        document.getElementById('deleteModal').style.display = 'flex';
    }
    function closeModal() {
        document.getElementById('deleteModal').style.display = 'none';
    }
    document.getElementById('deleteModal').addEventListener('click', function(e) {
        if (e.target === this) closeModal();
    });

    // Đổi role inline
    async function assignRole(userId, roleId, el) {
        if (!roleId) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        try {
            const res  = await fetch('/Admin/User/AssignRole', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `userId=${userId}&roleId=${roleId}&__RequestVerificationToken=${encodeURIComponent(token)}`
            });
            const data = await res.json();
            showToast(data.message, !data.success);
        } catch {
            showToast('Lỗi kết nối.', true);
        }
    }

    // Đổi status inline
    async function setStatus(userId, status) {
        const labels = { 1: 'mở khóa', 2: 'tạm khóa', 3: 'cấm vĩnh viễn' };
        if (!confirm(`Xác nhận ${labels[status]} tài khoản này?`)) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        try {
            const res  = await fetch('/Admin/User/SetStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${userId}&status=${status}&__RequestVerificationToken=${encodeURIComponent(token)}`
            });
            const data = await res.json();
            showToast(data.message, !data.success);
            if (data.success) setTimeout(() => location.reload(), 800);
        } catch {
            showToast('Lỗi kết nối.', true);
        }
    }
</script>
}
