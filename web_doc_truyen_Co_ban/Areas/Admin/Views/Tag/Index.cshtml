@model IEnumerable<web_doc_truyen_Co_ban.Models.TagModel>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Tag";
    ViewData["ActiveMenu"] = "Tag";

    int page       = (int)(ViewBag.Page ?? 1);
    int totalPages = (int)(ViewBag.TotalPages ?? 1);
    int total      = (int)(ViewBag.Total ?? 0);
    string search  = ViewData["Search"]?.ToString() ?? "";
}

@section Styles {
<style>
    .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px}
    .page-title{font-size:1.25rem;font-weight:800;color:#1e293b;margin:0}
    .card{background:#fff;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 4px rgba(0,0,0,.06)}
    .search-box{position:relative;max-width:300px;flex:1}
    .search-box input{width:100%;padding:8px 14px 8px 36px;border:1px solid #e2e8f0;border-radius:8px;font-size:.84rem;outline:none;transition:border .15s}
    .search-box input:focus{border-color:#2563eb}
    .search-box i{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#94a3b8}
    .btn-add{display:inline-flex;align-items:center;gap:6px;background:#2563eb;color:#fff;border:none;padding:9px 18px;border-radius:8px;font-weight:700;font-size:.84rem;cursor:pointer;text-decoration:none;transition:background .15s}
    .btn-add:hover{background:#1d4ed8;color:#fff}
    table{width:100%;border-collapse:collapse}
    thead th{padding:10px 14px;font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:#64748b;border-bottom:2px solid #e2e8f0;white-space:nowrap}
    tbody td{padding:12px 14px;border-bottom:1px solid #f1f5f9;font-size:.84rem;vertical-align:middle}
    tbody tr:hover{background:#f8fafc}
    tbody tr:last-child td{border-bottom:none}
    .badge{padding:3px 10px;border-radius:20px;font-size:.71rem;font-weight:700}
    .action-btns{display:flex;gap:6px}
    .btn-icon{width:32px;height:32px;border:none;border-radius:7px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.85rem;text-decoration:none;transition:all .15s}
    .btn-edit{background:#eff6ff;color:#2563eb}.btn-edit:hover{background:#dbeafe}
    .btn-del{background:#fef2f2;color:#ef4444}.btn-del:hover{background:#fee2e2}
    .pagination{display:flex;gap:6px;align-items:center;margin-top:16px;justify-content:flex-end}
    .page-btn{width:34px;height:34px;border:1px solid #e2e8f0;border-radius:7px;background:#fff;display:flex;align-items:center;justify-content:center;font-size:.82rem;font-weight:600;color:#475569;text-decoration:none;transition:all .15s}
    .page-btn:hover,.page-btn.active{background:#2563eb;color:#fff;border-color:#2563eb}
    .page-btn.disabled{pointer-events:none;opacity:.4}
    .info-bar{font-size:.8rem;color:#64748b;margin-top:10px}
    .empty-state{text-align:center;padding:60px 20px;color:#94a3b8}
    .empty-state i{font-size:3rem;display:block;margin-bottom:12px}
    .toast-wrap{position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px}
    .toast-msg{background:#fff;border-radius:10px;padding:14px 18px;box-shadow:0 4px 20px rgba(0,0,0,.12);border-left:4px solid #22c55e;display:flex;align-items:center;gap:10px;font-size:.84rem;font-weight:600;animation:slideIn .3s ease;min-width:260px}
    @@keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:none;opacity:1}}
</style>
}

@if (TempData["Success"] != null)
{
    <div class="toast-wrap" id="toastWrap">
        <div class="toast-msg"><i class="bi bi-check-circle-fill text-success"></i> @TempData["Success"]</div>
    </div>
}

<!-- Page Header -->
<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-hash me-2"></i>Quản lý Tag
        <span style="font-size:.85rem;color:#64748b;font-weight:600">(@total)</span>
    </h1>
    <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
        <form method="get" style="display:flex;gap:8px;align-items:center">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input name="search" value="@search" placeholder="Tìm tên tag, slug..." />
            </div>
            <button type="submit" class="btn-add" style="padding:8px 14px">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(search))
            {
                <a href="" class="btn-add" style="background:#64748b;padding:8px 12px">
                    <i class="bi bi-x"></i>
                </a>
            }
        </form>
        <a asp-area="Admin" asp-controller="Tag" asp-action="Create" class="btn-add">
            <i class="bi bi-plus-lg"></i> Thêm tag
        </a>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div style="padding:0">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-hash"></i>
                <p>Chưa có tag nào.
                    <a asp-area="Admin" asp-controller="Tag" asp-action="Create">Thêm ngay</a>
                </p>
            </div>
        }
        else
        {
        <table>
            <thead>
                <tr>
                    <th>Tên Tag</th>
                    <th>Slug</th>
                    <th>Số Truyện</th>
                    <th>Ngày tạo</th>
                    <th style="width:90px;text-align:center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td style="font-weight:700;color:#1e293b">
                        @t.Name
                    </td>
                    <td>
                        <span style="font-size:.82rem;color:#64748b;font-family:monospace">@t.Slug</span>
                    </td>
                    <td>
                        <span class="badge bg-primary bg-opacity-10 text-primary">@t.StoryCount</span>
                    </td>
                    <td style="white-space:nowrap;font-size:.78rem;color:#64748b">
                        @t.CreatedAt.ToString("dd/MM/yyyy")
                    </td>
                    <td>
                        <div class="action-btns" style="justify-content:center">
                            <a asp-area="Admin" asp-controller="Tag" asp-action="Edit" asp-route-id="@t.Id"
                               class="btn-icon btn-edit" title="Sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button class="btn-icon btn-del" title="Xóa"
                                    onclick="confirmDelete('@t.Id', '@t.Name')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <!-- Pagination -->
        <div style="padding:14px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;border-top:1px solid #f1f5f9">
            <span class="info-bar">
                Hiển thị @((page-1)*ViewBag.PageSize+1)–@Math.Min(page*ViewBag.PageSize,total) / @total tag
            </span>
            @if (totalPages > 1)
            {
            <div class="pagination">
                <a href="?page=@(page-1)&search=@search" class="page-btn @(page<=1?"disabled":"")">
                    <i class="bi bi-chevron-left"></i>
                </a>
                @for (int i = Math.Max(1,page-2); i <= Math.Min(totalPages,page+2); i++)
                {
                    <a href="?page=@i&search=@search" class="page-btn @(i==page?"active":"")">@i</a>
                }
                <a href="?page=@(page+1)&search=@search" class="page-btn @(page>=totalPages?"disabled":"")">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </div>
            }
        </div>
        }
    </div>
</div>

<!-- Modal xóa -->
<div id="deleteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9998;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:14px;padding:28px 32px;max-width:420px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.2)">
        <div style="font-size:2.5rem;margin-bottom:12px">🗑️</div>
        <h5 style="font-weight:800;margin-bottom:8px">Xác nhận xóa</h5>
        <p style="color:#64748b;font-size:.88rem;margin-bottom:24px">
            Bạn có chắc muốn xóa tag <strong id="deleteTitle"></strong>? Hành động này không thể hoàn tác.
        </p>
        <form id="deleteForm" method="post">
            @Html.AntiForgeryToken()
            <div style="display:flex;gap:10px;justify-content:center">
                <button type="button" onclick="closeModal()"
                    style="padding:9px 24px;border:1px solid #e2e8f0;border-radius:8px;background:#fff;font-weight:600;cursor:pointer">
                    Hủy
                </button>
                <button type="submit"
                    style="padding:9px 24px;border:none;border-radius:8px;background:#ef4444;color:#fff;font-weight:700;cursor:pointer">
                    Xóa
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const tw = document.getElementById('toastWrap');
    if (tw) setTimeout(() => tw.style.opacity = '0', 3000);

    function confirmDelete(id, name) {
        document.getElementById('deleteTitle').textContent = name;
        document.getElementById('deleteForm').action = '/Admin/Tag/Delete/' + id;
        document.getElementById('deleteModal').style.display = 'flex';
    }
    function closeModal() {
        document.getElementById('deleteModal').style.display = 'none';
    }
    document.getElementById('deleteModal').addEventListener('click', function(e) {
        if (e.target === this) closeModal();
    });
</script>
}
