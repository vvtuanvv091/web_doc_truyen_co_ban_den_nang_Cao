@* ══════════════════════════════════════════════════════════════
   SCRIPT – Hero Slider
══════════════════════════════════════════════════════════════ *@
<script>
(function(){
  var INTERVAL = 4500;
  var slides   = Array.from(document.querySelectorAll('#heroTrack .hero-slide'));
  var dotsWrap = document.getElementById('heroDots');
  var prog     = document.getElementById('heroProgress');
  var total    = slides.length;
  var cur      = 0, timer = null;

  /* Tạo dots */
  slides.forEach(function(_,i){
    var d = document.createElement('button');
    d.className = 'hero-dot' + (i===0?' active':'');
    d.setAttribute('aria-label','Slide '+(i+1));
    d.addEventListener('click', function(){ goTo(i); });
    dotsWrap.appendChild(d);
  });

  function pos(idx){
    var diff = ((idx-cur)%total+total)%total;
    if(diff===0)         return 'pos-active';
    if(diff===1)         return 'pos-next';
    if(diff===total-1)   return 'pos-prev';
    if(diff===2)         return 'pos-next2';
    if(diff===total-2)   return 'pos-prev2';
    return 'pos-hidden';
  }

  function render(){
    slides.forEach(function(sl,i){ sl.className='hero-slide '+pos(i); });
    dotsWrap.querySelectorAll('.hero-dot').forEach(function(d,i){
      d.classList.toggle('active', i===cur);
    });
  }

  function startProg(){
    prog.style.transition='none'; prog.style.width='0%';
    void prog.offsetWidth;
    prog.style.transition='width '+INTERVAL+'ms linear';
    prog.style.width='100%';
  }

  function startAuto(){
    clearInterval(timer);
    startProg();
    timer=setInterval(function(){
      cur=(cur+1)%total; render(); startProg();
    },INTERVAL);
  }

  function goTo(idx){
    cur=((idx%total)+total)%total;
    render(); startAuto();
  }

  document.getElementById('heroPrevBtn').addEventListener('click',function(){ goTo(cur-1); });
  document.getElementById('heroNextBtn').addEventListener('click',function(){ goTo(cur+1); });

  slides.forEach(function(sl,i){
    sl.addEventListener('click',function(){
      if(!sl.classList.contains('pos-active')) goTo(i);
    });
  });

  /* Swipe */
  var tx=null, banner=document.getElementById('heroBanner');
  banner.addEventListener('touchstart',function(e){ tx=e.touches[0].clientX; },{passive:true});
  banner.addEventListener('touchend',function(e){
    if(tx===null) return;
    var dx=e.changedTouches[0].clientX-tx;
    if(Math.abs(dx)>40) goTo(dx<0?cur+1:cur-1);
    tx=null;
  });

  /* Pause hover */
  banner.addEventListener('mouseenter',function(){ clearInterval(timer); prog.style.transition='none'; });
  banner.addEventListener('mouseleave',function(){ startAuto(); });

  render(); startAuto();
})();
</script>

