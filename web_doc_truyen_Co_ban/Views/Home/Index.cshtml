          string rc    = i == 0 ? "r1" : i == 1 ? "r2" : i == 2 ? "r3" : "rn";
          int    rc2   = s.Ratings?.Count ?? 0;
          double ravg  = rc2 > 0 ? (double)s.RatingSum / rc2 : 0;
          <a href="/Story/Detail/@s.Id" class="rank-row">
