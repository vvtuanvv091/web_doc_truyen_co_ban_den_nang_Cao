@functions {
    public string GetImage(string? url)
    {
        if (string.IsNullOrEmpty(url))
            return Url.Content("~/img/cat1.jpg");

        // ảnh online
        if (url.StartsWith("http"))
            return url;

        // nếu đã là path tuyệt đối
        if (url.StartsWith("/"))
            return url;

        // file local trong wwwroot/img
        return Url.Content("~/img/" + url);
    }
}