@model web_doc_truyen_Co_ban.Models.MembershipViewModel
@{
    ViewData["Title"] = "Hội viên";
    var cardColors  = new[] { "#F3F0EB", "#E8F4F0", "#FFF6E8", "#EEF0FF" };
    var cardAccents = new[] { "#C9B99A", "#7DBFAA", "#F0B860", "#8B95E0" };
    var tierLabels  = new[] { "Miễn phí", "Cơ bản", "Phổ biến nhất ✦", "Cao cấp nhất ◈" };
    int i = 0;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
    --ink:      #1c1917;
    --ink-2:    #44403c;
    --ink-3:    #78716c;
    --ink-4:    #a8a29e;
    --paper:    #faf8f5;
    --rule:     #e7e4df;
    --white:    #ffffff;
    --r:        14px;
}

body { background: var(--paper) !important; }

.mp {
    font-family: 'Outfit', sans-serif;
    color: var(--ink);
    max-width: 1140px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
}

/* ─── HERO ─────────────────────────────── */
.mp-hero {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 2rem;
    padding-bottom: 2.5rem;
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--rule);
}

.mp-hero-left {}

.mp-label {
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: .9rem;
}

.mp-hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.8rem, 5.5vw, 4.4rem);
    font-weight: 600;
    line-height: 1.08;
    color: var(--ink);
    margin-bottom: .8rem;
    letter-spacing: -.01em;
}

.mp-hero h1 em {
    font-style: italic;
    color: var(--ink-2);
}

.mp-hero-sub {
    font-size: 14px;
    color: var(--ink-3);
    line-height: 1.65;
    max-width: 380px;
    font-weight: 300;
}

.mp-active-pill {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    background: var(--ink);
    color: #fff;
    padding: 18px 24px;
    border-radius: var(--r);
    white-space: nowrap;
    min-width: 200px;
}

.mp-active-pill .pill-plan {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1;
}

.mp-active-pill .pill-exp {
    font-size: 11.5px;
    color: rgba(255,255,255,.55);
    font-weight: 300;
    letter-spacing: .04em;
}

/* ─── SECTION HEAD ──────────────────────── */
.mp-sh {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.4rem;
}

.mp-sh-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.55rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -.01em;
}

.mp-sh-rule {
    flex: 1;
    height: 1px;
    background: var(--rule);
}

/* ─── PLAN GRID ─────────────────────────── */
.mp-plans {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 14px;
    margin-bottom: 3.5rem;
}

.mp-card {
    border-radius: var(--r);
    padding: 1.6rem 1.4rem 1.4rem;
    display: flex;
    flex-direction: column;
    min-height: 360px;
    position: relative;
    border: 1.5px solid transparent;
    transition: transform .16s ease, box-shadow .16s ease;
}

.mp-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 36px rgba(0,0,0,.08);
}

.mp-card-tier {
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 4px;
}

.mp-card-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: .9rem;
    line-height: 1.1;
}

.mp-price {
    display: flex;
    align-items: baseline;
    gap: 2px;
    margin-bottom: 2px;
}

.mp-price-n {
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -.03em;
    line-height: 1;
}

.mp-price-u {
    font-size: 13px;
    color: var(--ink-3);
    font-weight: 400;
}

.mp-dur {
    font-size: 12px;
    color: var(--ink-4);
    margin-bottom: 1rem;
}

.mp-desc {
    font-size: 12.5px;
    color: var(--ink-2);
    margin-bottom: .9rem;
    line-height: 1.55;
    font-weight: 300;
}

.mp-feats {
    list-style: none;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 1.3rem;
}

.mp-feats li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12.5px;
    color: var(--ink);
    font-weight: 400;
}

.fi {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 10px;
    font-weight: 700;
    color: #fff;
}

.mp-btn {
    display: block;
    width: 100%;
    padding: 11px 0;
    border-radius: 99px;
    font-size: 13px;
    font-weight: 600;
    text-align: center;
    cursor: pointer;
    background: var(--ink);
    color: #fff;
    border: none;
    text-decoration: none;
    letter-spacing: .03em;
    font-family: 'Outfit', sans-serif;
    transition: opacity .13s;
}

.mp-btn:hover { opacity: .72; color: #fff; text-decoration: none; }

.mp-btn.mp-btn-ghost {
    background: rgba(0,0,0,.07);
    color: var(--ink-3);
    cursor: default;
}

.mp-btn.mp-btn-active {
    background: #e9f7ef;
    color: #1a6640;
}

.mp-hot {
    position: absolute;
    top: 12px;
    right: 12px;
    background: var(--ink);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 99px;
    letter-spacing: .06em;
}

/* ─── COMPARE ───────────────────────────── */
.mp-cmp {
    background: var(--white);
    border: 1px solid var(--rule);
    border-radius: var(--r);
    padding: 1.8rem 1.8rem 1.4rem;
    margin-bottom: 3.5rem;
    overflow-x: auto;
}

.mp-tbl {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    min-width: 480px;
}

.mp-tbl th {
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-3);
    text-align: center;
    padding: 7px 8px 12px;
    border-bottom: 1.5px solid var(--rule);
    letter-spacing: .02em;
}

.mp-tbl th:first-child { text-align: left; }

.mp-tbl td {
    padding: 11px 8px;
    border-bottom: 1px solid #f0ede8;
    text-align: center;
    color: var(--ink);
    font-weight: 300;
}

.mp-tbl td:first-child {
    text-align: left;
    color: var(--ink-2);
    font-size: 12.5px;
}

.mp-tbl tr:last-child td { border-bottom: none; }

.ic-y { color: #1a6640; font-size: 14px; font-weight: 700; }
.ic-n  { color: var(--rule); font-size: 16px; line-height: 1; }

/* ─── HISTORY ───────────────────────────── */
.mp-hist {
    background: var(--white);
    border: 1px solid var(--rule);
    border-radius: var(--r);
    overflow: hidden;
    margin-bottom: 2rem;
}

.mp-hist-head {
    padding: 1.3rem 1.8rem;
    border-bottom: 1px solid var(--rule);
    display: flex;
    align-items: center;
    gap: 8px;
}

.mp-hist-empty {
    padding: 3rem 2rem;
    text-align: center;
    color: var(--ink-4);
    font-size: 13.5px;
    font-weight: 300;
}

.mp-htbl {
    width: 100%;
    border-collapse: collapse;
    font-size: 12.5px;
}

.mp-htbl thead tr { background: #f8f6f2; }

.mp-htbl th {
    padding: 10px 16px;
    text-align: left;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--ink-3);
    border-bottom: 1px solid var(--rule);
}

.mp-htbl td {
    padding: 12px 16px;
    border-bottom: 1px solid #f2f0ec;
    color: var(--ink);
    vertical-align: middle;
    font-weight: 300;
}

.mp-htbl tr:last-child td { border-bottom: none; }
.mp-htbl tr:hover td { background: #faf9f6; }

.ocode {
    font-family: 'Courier New', monospace;
    font-size: 11.5px;
    background: #f0ede8;
    padding: 3px 8px;
    border-radius: 6px;
    color: var(--ink-3);
    letter-spacing: .04em;
}

.badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    border-radius: 99px;
    font-size: 11px;
    font-weight: 600;
}

.badge-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }

.b-paid      { background: #e9f7ef; color: #1a6640; }
.b-paid      .badge-dot { background: #1a6640; }
.b-pending   { background: #fff8e6; color: #9a6800; }
.b-pending   .badge-dot { background: #b07a10; }
.b-expired   { background: #f4f4f4; color: #888; }
.b-expired   .badge-dot { background: #aaa; }
.b-failed    { background: #fdecea; color: #b83232; }
.b-failed    .badge-dot { background: #c0392b; }
.b-cancelled { background: #f0f0f0; color: #999; }
.b-cancelled .badge-dot { background: #bbb; }

.cancel-form button {
    background: none;
    border: 1px solid var(--rule);
    color: var(--ink-3);
    font-size: 11.5px;
    padding: 4px 11px;
    border-radius: 8px;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    transition: background .12s, color .12s, border-color .12s;
}

.cancel-form button:hover {
    background: #fdecea;
    color: #b83232;
    border-color: #f5bbb8;
}

.pay-link {
    font-size: 12px;
    color: #3b6fd4;
    text-decoration: none;
    font-weight: 600;
    transition: opacity .12s;
}

.pay-link:hover { opacity: .7; }

.mp-foot {
    text-align: center;
    font-size: 12px;
    color: var(--ink-4);
    margin-top: 2.5rem;
    font-weight: 300;
}

.mp-foot a { color: var(--ink-3); text-decoration: none; border-bottom: 1px solid var(--rule); }
.mp-foot a:hover { color: var(--ink); }

@@media (max-width: 760px) {
    .mp-hero { grid-template-columns: 1fr; }
    .mp-active-pill { align-items: flex-start; width: fit-content; }
}

@@media (max-width: 600px) {
    .mp-htbl thead { display: none; }
    .mp-htbl td    { display: block; padding: 5px 16px; }
    .mp-htbl td::before {
        content: attr(data-label) ": ";
        font-weight: 600;
        color: var(--ink-3);
        font-size: 10.5px;
        text-transform: uppercase;
        letter-spacing: .05em;
    }
    .mp-htbl tr { display: block; border-bottom: 1px solid var(--rule); padding: 8px 0; }
    .mp-htbl tr:last-child { border-bottom: none; }
}
</style>

<div class="mp">

    <!-- HERO -->
    <div class="mp-hero">
        <div class="mp-hero-left">
            @if (Model.HasActiveMembership)
            {
                <div class="mp-label">Hội viên đang hoạt động</div>
                <h1>Chào mừng trở lại,<br><em>độc giả thân mến.</em></h1>
                <p class="mp-hero-sub">Gói của bạn đang hoạt động đầy đủ. Tận hưởng trải nghiệm đọc trọn vẹn nhất.</p>
            }
            else
            {
                <div class="mp-label">Hội viên</div>
                <h1>Đặc quyền dành<br><em>riêng cho bạn.</em></h1>
                <p class="mp-hero-sub">Đọc không giới hạn, không quảng cáo, truy cập sớm chương mới nhất — tất cả trong một gói hội viên.</p>
            }
        </div>

        @if (Model.HasActiveMembership)
        {
            <div class="mp-active-pill">
                <span class="pill-plan">@Model.CurrentMembership!.Plan!.Name</span>
                <span class="pill-exp">Hết hạn @Model.CurrentMembership.EndDate.ToString("dd/MM/yyyy")</span>
            </div>
        }
    </div>

    <!-- PLANS -->
    <div class="mp-sh">
        <span class="mp-sh-title">Chọn gói phù hợp</span>
        <div class="mp-sh-rule"></div>
    </div>

    <div class="mp-plans">
        @foreach (var plan in Model.Plans)
        {
            var bg        = cardColors[i % cardColors.Length];
            var accent    = cardAccents[i % cardAccents.Length];
            var tier      = tierLabels[i % tierLabels.Length];
            var isCurrent = Model.HasActiveMembership && Model.CurrentMembership!.MembershipPlanId == plan.Id;
            var isFree    = plan.Price == 0;
            i++;

            <div class="mp-card" style="background:@bg;">
                @if (plan.EarlyAccess)
                {
                    <div class="mp-hot">HOT</div>
                }

                <div class="mp-card-tier" style="color:@accent;">@tier</div>
                <div class="mp-card-name">@plan.Name</div>

                <div class="mp-price">
                    <span class="mp-price-n">@plan.Price.ToString("N0")</span>
                    <span class="mp-price-u">đ</span>
                </div>
                <div class="mp-dur">/ @plan.DurationDays ngày</div>

                @if (!string.IsNullOrEmpty(plan.Description))
                {
                    <div class="mp-desc">@plan.Description</div>
                }

                <ul class="mp-feats">
                    <li>
                        <span class="fi" style="background:@accent;">✓</span>
                        Đọc không giới hạn
                    </li>
                    @if (plan.NoAds)
                    {
                        <li>
                            <span class="fi" style="background:@accent;">✓</span>
                            Không có quảng cáo
                        </li>
                    }
                    @if (plan.EarlyAccess)
                    {
                        <li>
                            <span class="fi" style="background:@accent;">★</span>
                            Đọc sớm chương mới
                        </li>
                    }
                    @if (plan.ChapterUnlockPerDay == 0)
                    {
                        <li>
                            <span class="fi" style="background:@accent;">✓</span>
                            Mở khoá không giới hạn
                        </li>
                    }
                </ul>

                @if (isCurrent)
                {
                    <span class="mp-btn mp-btn-active">✓ Đang sử dụng</span>
                }
                else if (isFree && !Model.HasActiveMembership)
                {
                    <span class="mp-btn mp-btn-ghost">Đang sử dụng</span>
                }
                else if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-action="CreateOrder" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PlanId" value="@plan.Id" />
                        <button type="submit" class="mp-btn">Đăng ký ngay →</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login"
                       asp-route-returnUrl="/MembershipPlan/Index"
                       class="mp-btn">
                        Đăng nhập để đăng ký
                    </a>
                }
            </div>
        }
    </div>

    <!-- COMPARE -->
    <div class="mp-sh">
        <span class="mp-sh-title">So sánh các gói</span>
        <div class="mp-sh-rule"></div>
    </div>

    <div class="mp-cmp">
        <table class="mp-tbl">
            <thead>
                <tr>
                    <th>Tính năng</th>
                    @foreach (var plan in Model.Plans)
                    {
                        <th>@plan.Name</th>
                    }
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Đọc không giới hạn</td>
                    @foreach (var plan in Model.Plans)
                    {
                        <td><span class="ic-y">✓</span></td>
                    }
                </tr>
                <tr>
                    <td>Không quảng cáo</td>
                    @foreach (var plan in Model.Plans)
                    {
                        <td>
                            @if (plan.NoAds) { <span class="ic-y">✓</span> }
                            else             { <span class="ic-n">—</span>  }
                        </td>
                    }
                </tr>
                <tr>
                    <td>Đọc sớm chương mới</td>
                    @foreach (var plan in Model.Plans)
                    {
                        <td>
                            @if (plan.EarlyAccess) { <span class="ic-y">✓</span> }
                            else                   { <span class="ic-n">—</span>  }
                        </td>
                    }
                </tr>
            </tbody>
        </table>
    </div>

    <!-- ORDER HISTORY -->
    @if (User.Identity?.IsAuthenticated == true && ViewBag.Orders != null)
    {
        var orders = ViewBag.Orders as List<web_doc_truyen_Co_ban.Models.MembershipOrder>;

        <div class="mp-sh">
            <span class="mp-sh-title">Lịch sử đơn hàng</span>
            <div class="mp-sh-rule"></div>
        </div>

        <div class="mp-hist">
            @if (orders == null || !orders.Any())
            {
                <div class="mp-hist-empty">Bạn chưa có đơn hàng nào.</div>
            }
            else
            {
                <table class="mp-htbl">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Gói</th>
                            <th>Số tiền</th>
                            <th>Ngày tạo</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in orders)
                        {
                            var (bCls, bTxt, bDot) = order.Status switch
                            {
                                web_doc_truyen_Co_ban.Models.OrderStatus.Paid      => ("b-paid",      "Đã thanh toán", "#1a6640"),
                                web_doc_truyen_Co_ban.Models.OrderStatus.Pending   => ("b-pending",   "Chờ thanh toán","#b07a10"),
                                web_doc_truyen_Co_ban.Models.OrderStatus.Expired   => ("b-expired",   "Hết hạn",       "#aaa"),
                                web_doc_truyen_Co_ban.Models.OrderStatus.Failed    => ("b-failed",    "Thất bại",      "#c0392b"),
                                web_doc_truyen_Co_ban.Models.OrderStatus.Cancelled => ("b-cancelled", "Đã huỷ",        "#bbb"),
                                _ => ("b-expired", order.Status.ToString(), "#aaa")
                            };

                            <tr>
                                <td data-label="Mã đơn">
                                    <span class="ocode">@order.OrderCode</span>
                                </td>
                                <td data-label="Gói">@(order.Plan?.Name ?? "—")</td>
                                <td data-label="Số tiền">@order.Amount.ToString("N0") đ</td>
                                <td data-label="Ngày tạo">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td data-label="Trạng thái">
                                    <span class="badge @bCls">
                                        <span class="badge-dot" style="background:@bDot;"></span>
                                        @bTxt
                                    </span>
                                </td>
                                <td data-label="">
                                    @if (order.Status == web_doc_truyen_Co_ban.Models.OrderStatus.Pending)
                                    {
                                        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                                            <a asp-action="Payment" asp-route-orderCode="@order.OrderCode" class="pay-link">
                                                Thanh toán →
                                            </a>
                                            <form asp-action="CancelPending" method="post" class="cancel-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="orderCode" value="@order.OrderCode" />
                                                <button type="submit" onclick="return confirm('Huỷ đơn hàng này?')">Huỷ</button>
                                            </form>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    <div class="mp-foot">
        Có thắc mắc? <a href="/Contact">Liên hệ hỗ trợ</a> &nbsp;·&nbsp; Thanh toán an toàn qua SePay / VietQR
    </div>

</div>
