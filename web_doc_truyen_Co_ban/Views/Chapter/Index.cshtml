@using System.Security.Claims
@model web_doc_truyen_Co_ban.Models.ChapterModel
<head>

    <meta charset="UTF-8" />

    <meta http-equiv="X-UA-Compatible"
          content="IE=edge" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"]</title>

    <!-- Quill CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css"
          rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
          <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
</head>

<style>
    :root {
        
        --text: #2c1a0e;
        --accent: #c0712a;
        --accent-light: #e8a85a;
        --card: #fff8f0;
        --border: #e8d5b7;
        --btn-prev: #b0c4a0;
        --btn-next: #4a7c59;
        --btn-menu: #4a7c59;
                    --ink: #1a1714;
            --ink-mid: #5a5550;
            --ink-lt: #9a9490;
            --paper: #faf8f5;
            --line: #e8e4de;
            --radius: 18px;
    }
    body {
        background: ;
    }
    body {
        background: var(--paper) !important;
        color: var(--text);
        font-family: 'Times New Roman', serif;
    }

    .chapter-wrapper {
        max-width: 820px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
    }

    /* ── Header ── */
    .chapter-header {
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border);
    }

    .story-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        text-decoration: none;
    }

    .story-title:hover { text-decoration: underline; color: var(--accent); }

    .chapter-subtitle {
        margin-top: 0.35rem;
        font-size: 0.95rem;
        color: var(--muted);
        font-style: italic;
    }

    .ornament {
        display: block;
        text-align: center;
        font-size: 1.4rem;
        color: var(--border);
        margin: 0.75rem 0;
        letter-spacing: 0.5em;
    }

    /* ── Nav buttons ── */
    .chapter-nav {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin: 1rem 0;
        flex-wrap: wrap;
    }

    .btn-nav {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1.2rem;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: opacity .18s, transform .12s;
        font-family: inherit;
    }

    .btn-nav:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-nav:active { transform: translateY(0); }

    .btn-prev {
        background: var(--btn-next);
        color: #fff;
    }

    .btn-next {
        background: var(--btn-next);
        color: #fff;
    }

    .btn-menu {
        background: var(--btn-menu);
        color: #fff;
        padding: 0.5rem 0.85rem;
    }

    .btn-disabled {
        background: #d0c8bc !important;
        opacity: 0.6;
        cursor: default;
        pointer-events: none;
    }

    .btn-ebook {
        background: var(--btn-next);
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 0.45rem 1.1rem;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-family: inherit;
        transition: opacity .18s;
    }

    .btn-ebook:hover { opacity: 0.85; }

    /* ── Content ── */
    .chapter-content {
        font-size: 1.08rem;
        line-height: 1.95;
        color: var(--text);
        margin: 2.5rem 0;
    }

    .chapter-content p {
        margin-bottom: 1.1em;
        text-indent: 0;
    }

    .chapter-content p:empty { display: none; }

    /* ── Meta bar ── */
    .chapter-meta {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        font-size: 0.82rem;
        color: var(--muted);
        margin-bottom: 1rem;
    }

    .chapter-meta span { display: flex; align-items: center; gap: 0.3rem; }

    /* ── Keyboard hint ── */
    .keyboard-hint {
        text-align: center;
        font-size: 0.8rem;
        color: var(--muted);
        border: 1px dashed var(--border);
        border-radius: 6px;
        padding: 0.45rem 1rem;
        display: inline-block;
        margin: 0.75rem auto;
    }

    /* ── Action buttons ── */
    .action-bar {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 0.45rem 1.3rem;
        border-radius: 20px;
        border: none;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: opacity .18s;
    }

    .btn-report { background: #f0a030; color: #fff; }
    .btn-comment { background: #c0712a; color: #fff; }
    .btn-action:hover { opacity: 0.85; }

    /* ── Comment section ── */
    .comment-section {
        margin-top: 3rem;
        border-top: 1px solid var(--border);
        padding-top: 1.5rem;
    }

    .comment-section h3 {
        font-size: 1rem;
        color: var(--accent);
        margin-bottom: 1rem;
    }

    .comment-item {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 0.75rem;
        font-size: 0.9rem;
    }

    .comment-author {
        font-weight: 700;
        color: var(--accent);
        font-size: 0.82rem;
        margin-bottom: 0.25rem;
    }

    /* ── Modal danh sách chương ── */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1000;
        justify-content: center;
        align-items: center;
    }

    .modal-overlay.open {
        display: flex;
    }

    .modal-box {
        background: #fff;
        border-radius: 10px;
        width: min(560px, 92vw);
        max-height: 75vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--border);
        font-weight: 700;
        font-size: 1rem;
        color: var(--accent);
        flex-shrink: 0;
    }

    .modal-close {
        background: none;
        border: none;
        font-size: 1.3rem;
        cursor: pointer;
        color: var(--muted);
        line-height: 1;
        padding: 0 0.25rem;
    }

    .modal-close:hover { color: var(--text); }

    .modal-list {
        overflow-y: auto;
        padding: 0.5rem 0;
        flex: 1;
    }

    .modal-chapter-link {
        display: block;
        padding: 0.6rem 1.25rem;
        color: var(--text);
        text-decoration: none;
        font-size: 0.93rem;
        border-left: 3px solid transparent;
        transition: background .14s;
    }

    .modal-chapter-link:hover {
        background: var(--bg);
        border-left-color: var(--accent-light);
        color: var(--text);
        text-decoration: none;
    }

    .modal-chapter-link.active {
        color: var(--accent);
        font-weight: 700;
        border-left-color: var(--accent);
        background: #fff5ea;
    }
    .chapter-content {
        font-size: 22px;
        line-height: 1.9;
        font-family: "Merriweather", "Times New Roman", serif;
    }

    .chapter-content p {
        margin-bottom: 18px;
    }
    .comment-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
    }

    .comment-author {
        font-weight: 700;
        color: var(--accent);
        font-size: 0.85rem;
        margin-bottom: 0.25rem;
    }

    .comment-time {
        font-size: 0.78rem;
        color: var(--muted);
        margin-top: 0.25rem;
    }

    .reply-item {
        background: #fff;
        border-left: 3px solid var(--accent-light);
        border-radius: 6px;
        padding: 0.5rem 0.75rem;
        margin-top: 0.5rem;
        margin-left: 1.5rem;
        font-size: 0.85rem;
    }
    .cmt-avatar { border-radius: 50%; object-fit: cover; flex-shrink: 0; }
    .cmt-avatar-letter {
        border-radius: 50%;
        background: var(--accent, #3b82f6);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 0.9rem; flex-shrink: 0;
    }
    .cmt-item { padding: 12px 0; border-bottom: 1px solid var(--border, #e2e8f0); }
    .cmt-reply { padding: 8px 0 0 12px; border-left: 2px solid var(--border, #e2e8f0); margin-top: 8px; }
    .cmt-name { font-weight: 600; font-size: 0.88rem; color: var(--accent, #3b82f6); }
    .cmt-time { font-size: 0.78rem; color: var(--muted, #94a3b8); }
    .cmt-text { font-size: 0.88rem; line-height: 1.6; margin-top: 2px; }
    .btn-cmt-sm {
        background: none; border: none; padding: 0;
        font-size: 0.8rem; color: var(--muted, #94a3b8);
        cursor: pointer; transition: color .15s;
    }
    .btn-cmt-sm:hover { color: var(--accent, #3b82f6); }
    .btn-cmt-sm:disabled { opacity: .5; cursor: not-allowed; }
</style>

<div class="chapter-wrapper">

    <!-- Header -->
    <div class="chapter-header">
        <a class="story-title" asp-controller="Story" asp-action="Detail" asp-route-id="@Model.StoryId">
            @Model.Story?.Title
        </a>
        <p class="chapter-subtitle">
            Volumn @Model.VolumeTitle
        </p>
        <p class="chapter-subtitle">
            Chương @Model.ChapterNumber@(string.IsNullOrWhiteSpace(Model.Title) ? "" : $": {Model.Title}")
        </p>
        <span class="ornament">~ ~ ~</span>

        <!-- Nav top -->
        <div class="chapter-nav">
            @{
                var prevChapter = ViewBag.PrevChapter_Id as Guid?;
                var nextChapter = ViewBag.NextChapter_Id as Guid?;
            }

            @if (prevChapter.HasValue)
            {
                <a class="btn-nav btn-prev"
                   asp-controller="Chapter" asp-action="Index" asp-route-id="@prevChapter">
                    ❮ Chương trước
                </a>
            }
            else
            {
                <span class="btn-nav btn-prev btn-disabled">❮ Chương trước</span>
            }
            <button class="btn-nav btn-menu" onclick="openChapterModal()" title="Danh sách chương">☰</button>

            @if (nextChapter.HasValue)
            {
                <a class="btn-nav btn-next"
                   asp-controller="Chapter" asp-action="Index" asp-route-id="@nextChapter">
                    Chương tiếp ❯
                </a>
            }
            else
            {
                <span class="btn-nav btn-next btn-disabled">Chương tiếp ❯</span>
            }
        </div>

        <div>
            <button class="btn-ebook" id="btn-bm" onclick="saveBookmark()">
                🔖 Bookmark chương này
            </button>
            @Html.AntiForgeryToken()
        </div>

        <span class="ornament" style="font-size:1rem;">❧ ✦ ❧</span>
    </div>

    <!-- Meta -->
    <div class="chapter-meta">
        <span>👁 @Model.ViewCount.ToString("N0") lượt xem</span>
        <span>📝 @Model.WordCount.ToString("N0") từ</span>
        @if (Model.PublishedAt.HasValue)
        {
            <span>📅 @Model.PublishedAt.Value.ToString("dd/MM/yyyy")</span>
        }
    </div>

    <!-- Content -->
    <div class="chapter-content" id="chapterContent">
        @if (string.IsNullOrWhiteSpace(Model.Content))
        {
            <p style="color: var(--muted); font-style: italic; text-align:center;">
                Chương này chưa có nội dung.
            </p>
        }
        else
        {
            @Html.Raw(Model.Content)
        }
    </div>

    <!-- Nav bottom -->
    <div class="chapter-nav">
        @if (prevChapter.HasValue)
        {
            <a class="btn-nav btn-prev"
               asp-controller="Chapter" asp-action="Index" asp-route-id="@prevChapter">
                ❮ Chương trước
            </a>
        }
        else
        {
            <span class="btn-nav btn-prev btn-disabled">❮ Chương trước</span>
        }
        <button class="btn-nav btn-menu" onclick="openChapterModal()" title="Danh sách chương">☰</button>

        @if (nextChapter.HasValue)
        {
            <a class="btn-nav btn-next"
               asp-controller="Chapter" asp-action="Index" asp-route-id="@nextChapter">
                Chương tiếp ❯
            </a>
        }
        else
        {
            <span class="btn-nav btn-next btn-disabled">Chương tiếp ❯</span>
        }
    </div>

    <div style="text-align:center;">
        <span class="keyboard-hint">
            Bạn có thể dùng phím mũi tên ← → hoặc WASD để lùi/sang chương.
        </span>
    </div>


    <!-- Comments -->
     <!-- Action bar -->
<!-- Action bar -->
    <div class="action-bar">
        <button class="btn-action btn-report" onclick="alert('Cảm ơn bạn đã báo lỗi!')">Báo lỗi</button>
        <button class="btn-action btn-comment"
                onclick="document.getElementById('commentSection').scrollIntoView({behavior:'smooth'})">
            Bình luận <span id="commentCountBtn">(0)</span>
        </button>
    </div>
    
    <!-- Comment Section -->
    <div class="comment-section" id="commentSection">
        <h3>💬 Bình luận (<span id="total-count">0</span>)</h3>

        @if (User.Identity.IsAuthenticated)
        {
            <div class="mb-3">
                <textarea id="commentInput" class="form-control" rows="3"
                          placeholder="Viết bình luận..."
                          style="border-color:var(--border);border-radius:8px;font-family:inherit"></textarea>
                <button onclick="postComment()" class="btn-action btn-comment mt-2">
                    Gửi bình luận
                </button>
            </div>
        }
        else
        {
            <p style="font-size:0.9rem;color:var(--muted)">
                <a href="/Account/Login" style="color:var(--accent)">Đăng nhập</a> để bình luận.
            </p>
        }

        <div id="comment-list"></div>

        <div class="text-center mt-3" id="load-more-wrapper" style="display:none">
            <button class="btn-action btn-comment" id="btn-load-more">
                Xem thêm bình luận ↓
            </button>
        </div>

        <div class="text-center mt-2" id="all-loaded"
             style="display:none;font-size:0.85rem;color:var(--muted)">
            ✓ Đã hiển thị tất cả bình luận
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════
     MODAL DANH SÁCH CHƯƠNG
     ═══════════════════════════════════════ -->
<div class="modal-overlay" id="chapterListModal" onclick="if(event.target===this)closeChapterModal()">
    <div class="modal-box">
        <div class="modal-header">
            📖 Danh sách chương
            <button class="modal-close" onclick="closeChapterModal()">✕</button>
        </div>
        <div class="modal-list" id="chapterModalList">
            @if (ViewBag.AllChapters != null)
            {
                foreach (var ch in (IEnumerable<dynamic>)ViewBag.AllChapters)
                {
                    bool isActive = ch.Id == Model.Id;
                    string label = $"Chương {ch.ChapterNumber}" +
                                   (string.IsNullOrWhiteSpace((string)ch.Title) ? "" : $": {ch.Title}");
                    <a class="modal-chapter-link @(isActive ? "active" : "")"
                       id="chlink-@ch.Id"
                       asp-controller="Chapter" asp-action="Index" asp-route-id="@ch.Id">
                        @label
                    </a>
                }
            }
            else
            {
                <p style="padding:1rem;color:var(--muted);font-style:italic;">
                    Không có dữ liệu chương. Vui lòng kiểm tra ViewBag.AllChapters trong Controller.
                </p>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Mở / đóng modal ──
    function openChapterModal() {
        document.getElementById('chapterListModal').classList.add('open');
        // Scroll đến chương đang đọc
        setTimeout(function () {
            var active = document.querySelector('.modal-chapter-link.active');
            if (active) active.scrollIntoView({ block: 'center', behavior: 'smooth' });
        }, 60);
    }

    function closeChapterModal() {
        document.getElementById('chapterListModal').classList.remove('open');
    }

    // Đóng modal bằng phím Escape
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeChapterModal();

        // Keyboard navigation (chỉ khi modal đóng)
        if (document.getElementById('chapterListModal').classList.contains('open')) return;

        // 
    });

    // ── Tải nội dung dạng text ──
    function downloadText() {
        const title = "@(Model.Story?.Title ?? "Truyen") - Chuong @Model.ChapterNumber";
        const content = document.getElementById('chapterContent').innerText;
        const blob = new Blob([title + '\n\n' + content], { type: 'text/plain;charset=utf-8' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = title.replace(/[^a-zA-Z0-9]/g, '_') + '.txt';
        a.click();
    }
    // ── Mở / đóng modal ──
    function openChapterModal() {
        document.getElementById('chapterListModal').classList.add('open');
        setTimeout(function () {
            var active = document.querySelector('.modal-chapter-link.active');
            if (active) active.scrollIntoView({ block: 'center', behavior: 'smooth' });
        }, 60);
    }
    function closeChapterModal() {
        document.getElementById('chapterListModal').classList.remove('open');
    }
    function downloadText() {
        const title   = "@(Model.Story?.Title ?? "Truyen") - Chuong @Model.ChapterNumber";
        const content = document.getElementById('chapterContent').innerText;
        // const blob    = new Blob([title + '\n\n' + content], { type: 'text/plain;charset=utf-8' });
        const blob = new Blob(
            ['\uFEFF' + title + '\n\n' + content],
            { type: 'text/plain;charset=utf-8' }
        );
        const a       = document.createElement('a');
        a.href        = URL.createObjectURL(blob);
        a.download    = title.replace(/[^a-zA-Z0-9]/g, '_') + '.txt';
        a.click();
    }
    
</script>

<script>
(function () {
    let currentPage = 1;
    const pageSize = 5;
    const chapterId = '@Model.Id';
    const isAuth = @(User.Identity.IsAuthenticated ? "true" : "false");
    let totalLoaded = 0;
    let grandTotal = 0;

    // ── Avatar helper ──
    function avatarHtml(avatar, userName, size = 36) {
        if (avatar)
            return `<img src="${avatar}" class="cmt-avatar" width="${size}" height="${size}" style="border-radius:50%;object-fit:cover">`;
        const letter = (userName || '?').charAt(0).toUpperCase();
        return `<div class="cmt-avatar cmt-avatar-letter" style="width:${size}px;height:${size}px">${letter}</div>`;
    }

    function formatDate(d) {
        return new Date(d).toLocaleString('vi-VN');
    }

    // ── Render 1 comment ──
    function renderComment(c, prepend = false) {
        const replies = (c.replies ?? []).map(r => `
            <div class="cmt-reply">
                <div class="d-flex gap-2 align-items-start">
                    ${avatarHtml(r.avatar, r.userName, 28)}
                    <div>
                        <span class="cmt-name">↩ ${r.userName ?? 'Ẩn danh'}</span>
                        <span class="cmt-time ms-2">${formatDate(r.createdAt)}</span>
                        <div class="cmt-text">${r.content}</div>
                    </div>
                </div>
            </div>`).join('');

        const replyBox = isAuth ? `
            <div id="replyBox-${c.id}" style="display:none" class="mt-2">
                <textarea id="replyInput-${c.id}" class="form-control form-control-sm" rows="2"
                          placeholder="Trả lời..."></textarea>
                <button onclick="postReply('${c.id}')" class="btn-action btn-comment mt-1 btn-sm">Gửi</button>
            </div>` : '';

        const html = `
        <div class="cmt-item" id="cmt-${c.id}">
            <div class="d-flex gap-2 align-items-start">
                ${avatarHtml(c.avatar, c.userName)}
                <div class="flex-grow-1">
                    <span class="cmt-name">${c.userName ?? 'Ẩn danh'}</span>
                    <span class="cmt-time ms-2">${formatDate(c.createdAt)}</span>
                    <div class="cmt-text mt-1">${c.content}</div>
                    <div class="d-flex gap-3 mt-1 align-items-center">
                        <button class="btn-cmt-sm" onclick="likeComment('${c.id}', this)">
                            👍 <span class="like-count">${c.likeCount ?? 0}</span>
                        </button>
                        ${isAuth ? `<button class="btn-cmt-sm" onclick="toggleReply('${c.id}')">↩ Trả lời</button>` : ''}
                    </div>
                    ${replyBox}
                    <div class="replies-wrap">${replies}</div>
                </div>
            </div>
        </div>`;

        const list = document.getElementById('comment-list');
        if (prepend) list.insertAdjacentHTML('afterbegin', html);
        else list.insertAdjacentHTML('beforeend', html);
    }

    // ── Load comments ──
    async function loadComments(page) {
        const res = await fetch(`/Chapter/GetComments?chapterId=${chapterId}&page=${page}&pageSize=${pageSize}`);
        const data = await res.json();

        grandTotal = data.total;
        document.getElementById('total-count').textContent = grandTotal;
        document.getElementById('commentCountBtn').textContent = `(${grandTotal})`;

        if (page === 1) document.getElementById('comment-list').innerHTML = '';

        data.comments.forEach(c => renderComment(c));
        totalLoaded += data.comments.length;

        const hasMore = totalLoaded < grandTotal;
        document.getElementById('load-more-wrapper').style.display = hasMore ? 'block' : 'none';
        document.getElementById('all-loaded').style.display = (!hasMore && grandTotal > 0) ? 'block' : 'none';
    }

    // ── Post comment ──
    window.postComment = async function () {
        const input = document.getElementById('commentInput');
        const content = input.value.trim();
        if (!content) return;

        const res = await fetch('/Chapter/PostComment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ chapterId, content })
        });

        if (res.ok) {
            const c = await res.json();
            input.value = '';
            renderComment({ ...c, likeCount: 0, replies: [] }, true);
            grandTotal++;
            document.getElementById('total-count').textContent = grandTotal;
            document.getElementById('commentCountBtn').textContent = `(${grandTotal})`;
        } else {
            alert('Gửi thất bại, vui lòng thử lại!');
        }
    };

    // ── Reply ──
    window.toggleReply = function (id) {
        const box = document.getElementById(`replyBox-${id}`);
        if (box) box.style.display = box.style.display === 'none' ? 'block' : 'none';
    };

    window.postReply = async function (parentId) {
        const input = document.getElementById(`replyInput-${parentId}`);
        const content = input?.value.trim();
        if (!content) return;

        const res = await fetch('/Chapter/PostComment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ chapterId, content, parentId })
        });

        if (res.ok) {
            const r = await res.json();
            input.value = '';
            document.getElementById(`replyBox-${parentId}`).style.display = 'none';

            const wrap = document.querySelector(`#cmt-${parentId} .replies-wrap`);
            if (wrap) wrap.insertAdjacentHTML('beforeend', `
                <div class="cmt-reply">
                    <div class="d-flex gap-2 align-items-start">
                        ${avatarHtml(r.avatar, r.userName, 28)}
                        <div>
                            <span class="cmt-name">↩ ${r.userName ?? 'Ẩn danh'}</span>
                            <span class="cmt-time ms-2">${formatDate(r.createdAt)}</span>
                            <div class="cmt-text">${r.content}</div>
                        </div>
                    </div>
                </div>`);
        } else {
            alert('Gửi thất bại!');
        }
    };

    // ── Like ──
    window.likeComment = async function (id, btn) {
        const res = await fetch(`/Chapter/LikeComment?id=${id}`, { method: 'POST' });
        if (res.ok) {
            const data = await res.json();
            const span = btn.querySelector('.like-count');
            span.textContent = data.likeCount;
            // Toggle UI
            if (data.liked) {
                btn.style.color = 'var(--accent, #3b82f6)';
                btn.title = 'Bỏ thích';
            } else {
                btn.style.color = '';
                btn.title = 'Thích';
            }
        }
    };

    // ── Load more ──
    document.getElementById('btn-load-more')?.addEventListener('click', () => {
        currentPage++;
        loadComments(currentPage);
    });

    loadComments(1);
})();

///lưu trang 

    async function saveBookmark() {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const btn   = document.getElementById('btn-bm');

        btn.disabled = true;
        btn.innerHTML = '⏳ Đang lưu...';

        const res  = await fetch('/BookMark/CreateBookMark', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `storieid=@Model.StoryId&chapterid=@Model.Id&__RequestVerificationToken=${encodeURIComponent(token)}`
        });
        const data = await res.json();

        if (data.success) {
            btn.innerHTML = '✅ Đã bookmark!';
            btn.style.background = '#2ecc71';
        } else {
            btn.innerHTML = '⚠️ ' + data.message;
        }

        setTimeout(() => {
            btn.disabled    = false;
            btn.innerHTML   = '🔖 Bookmark chương này';
            btn.style.background = '';
        }, 2000);
    }
</script>


