@using System.Security.Claims
@model web_doc_truyen_Co_ban.Models.ChapterModel
<head>

    <meta charset="UTF-8" />

    <meta http-equiv="X-UA-Compatible"
          content="IE=edge" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"]</title>

    <!-- Quill CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css"
          rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
          <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
</head>

<style>
    :root {
        
        --text: #2c1a0e;
        --accent: #c0712a;
        --accent-light: #e8a85a;
        --card: #fff8f0;
        --border: #e8d5b7;
        --btn-prev: #b0c4a0;
        --btn-next: #4a7c59;
        --btn-menu: #4a7c59;
                    --ink: #1a1714;
            --ink-mid: #5a5550;
            --ink-lt: #9a9490;
            --paper: #faf8f5;
            --line: #e8e4de;
            --radius: 18px;
    }
    body {
        background: ;
    }
    body {
        background: var(--paper) !important;
        color: var(--text);
        font-family: 'Times New Roman', serif;
    }

    .chapter-wrapper {
        max-width: 820px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
    }

    /* ── Header ── */
    .chapter-header {
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border);
    }

    .story-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        text-decoration: none;
    }

    .story-title:hover { text-decoration: underline; color: var(--accent); }

    .chapter-subtitle {
        margin-top: 0.35rem;
        font-size: 0.95rem;
        color: var(--muted);
        font-style: italic;
    }
    /* Modal danh sách chương */
    #chapterListModal .modal-chapter-link {
        font-family: 'Segoe UI', 'Be Vietnam Pro', sans-serif;
        font-size: 14px;
        font-weight: 400;
        color: #334155;
        line-height: 1.5;
        padding: 10px 16px;
        border-radius: 8px;
        display: block;
        text-decoration: none;
        transition: background .15s;
    }

    #chapterListModal .modal-chapter-link:hover {
        background: #f1f5f9;
        color: #525fe1;
    }

    #chapterListModal .modal-chapter-link.active {
        background: #fff3e6;
        color: #e07b00;
        font-weight: 600;
    }
    .ornament {
        display: block;
        text-align: center;
        font-size: 1.4rem;
        color: var(--border);
        margin: 0.75rem 0;
        letter-spacing: 0.5em;
    }

    /* ── Nav buttons ── */
    .chapter-nav {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin: 1rem 0;
        flex-wrap: wrap;
    }

    .btn-nav {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1.2rem;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: opacity .18s, transform .12s;
        font-family: inherit;
    }

    .btn-nav:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-nav:active { transform: translateY(0); }

    .btn-prev {
        background: var(--btn-next);
        color: #fff;
    }

    .btn-next {
        background: var(--btn-next);
        color: #fff;
    }

    .btn-menu {
        background: var(--btn-menu);
        color: #fff;
        padding: 0.5rem 0.85rem;
    }

    .btn-disabled {
        background: #d0c8bc !important;
        opacity: 0.6;
        cursor: default;
        pointer-events: none;
    }

    .btn-ebook {
        background: var(--btn-next);
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 0.45rem 1.1rem;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-family: inherit;
        transition: opacity .18s;
    }

    .btn-ebook:hover { opacity: 0.85; }

    /* ── Content ── */
    .chapter-content {
        font-size: 1.08rem;
        line-height: 1.95;
        color: var(--text);
        margin: 2.5rem 0;
    }

    .chapter-content p {
        margin-bottom: 1.1em;
        text-indent: 0;
    }

    .chapter-content p:empty { display: none; }

    /* ── Meta bar ── */
    .chapter-meta {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        font-size: 0.82rem;
        color: var(--muted);
        margin-bottom: 1rem;
    }

    .chapter-meta span { display: flex; align-items: center; gap: 0.3rem; }

    /* ── Keyboard hint ── */
    .keyboard-hint {
        text-align: center;
        font-size: 0.8rem;
        color: var(--muted);
        border: 1px dashed var(--border);
        border-radius: 6px;
        padding: 0.45rem 1rem;
        display: inline-block;
        margin: 0.75rem auto;
    }

    /* ── Action buttons ── */
    .action-bar {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 0.45rem 1.3rem;
        border-radius: 20px;
        border: none;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: opacity .18s;
    }

    .btn-report { background: #f0a030; color: #fff; }
    .btn-comment { background: #c0712a; color: #fff; }
    .btn-action:hover { opacity: 0.85; }

    /* ── Comment section ── */
    .comment-section {
        margin-top: 3rem;
        border-top: 1px solid var(--border);
        padding-top: 1.5rem;
    }

    .comment-section h3 {
        font-size: 1rem;
        color: var(--accent);
        margin-bottom: 1rem;
    }

    .comment-item {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 0.75rem;
        font-size: 0.9rem;
    }

    .comment-author {
        font-weight: 700;
        color: var(--accent);
        font-size: 0.82rem;
        margin-bottom: 0.25rem;
    }

    /* ── Modal danh sách chương ── */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1000;
        justify-content: center;
        align-items: center;
    }

    .modal-overlay.open {
        display: flex;
    }

    .modal-box {
        background: #fff;
        border-radius: 10px;
        width: min(560px, 92vw);
        max-height: 75vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--border);
        font-weight: 700;
        font-size: 1rem;
        color: var(--accent);
        flex-shrink: 0;
    }

    .modal-close {
        background: none;
        border: none;
        font-size: 1.3rem;
        cursor: pointer;
        color: var(--muted);
        line-height: 1;
        padding: 0 0.25rem;
    }

    .modal-close:hover { color: var(--text); }

    .modal-list {
        overflow-y: auto;
        padding: 0.5rem 0;
        flex: 1;
    }

    .modal-chapter-link {
        display: block;
        padding: 0.6rem 1.25rem;
        color: var(--text);
        text-decoration: none;
        font-size: 0.93rem;
        border-left: 3px solid transparent;
        transition: background .14s;
    }

    .modal-chapter-link:hover {
        background: var(--bg);
        border-left-color: var(--accent-light);
        color: var(--text);
        text-decoration: none;
    }

    .modal-chapter-link.active {
        color: var(--accent);
        font-weight: 700;
        border-left-color: var(--accent);
        background: #fff5ea;
    }
    .chapter-content {
        font-size: 22px;
        line-height: 1.9;
        font-family: "Merriweather", "Times New Roman", serif;
    }

    .chapter-content p {
        margin-bottom: 18px;
    }
    .comment-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
    }

    .comment-author {
        font-weight: 700;
        color: var(--accent);
        font-size: 0.85rem;
        margin-bottom: 0.25rem;
    }

    .comment-time {
        font-size: 0.78rem;
        color: var(--muted);
        margin-top: 0.25rem;
    }

    .reply-item {
        background: #fff;
        border-left: 3px solid var(--accent-light);
        border-radius: 6px;
        padding: 0.5rem 0.75rem;
        margin-top: 0.5rem;
        margin-left: 1.5rem;
        font-size: 0.85rem;
    }
    .cmt-avatar { border-radius: 50%; object-fit: cover; flex-shrink: 0; }
    .cmt-avatar-letter {
        border-radius: 50%;
        background: var(--accent, #3b82f6);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 0.9rem; flex-shrink: 0;
    }
    .cmt-item { padding: 12px 0; border-bottom: 1px solid var(--border, #e2e8f0); }
    .cmt-reply { padding: 8px 0 0 12px; border-left: 2px solid var(--border, #e2e8f0); margin-top: 8px; }
    .cmt-name { font-weight: 600; font-size: 0.88rem; color: var(--accent, #3b82f6); }
    .cmt-time { font-size: 0.78rem; color: var(--muted, #94a3b8); }
    .cmt-text { font-size: 0.88rem; line-height: 1.6; margin-top: 2px; }
    .btn-cmt-sm {
        background: none; border: none; padding: 0;
        font-size: 0.8rem; color: var(--muted, #94a3b8);
        cursor: pointer; transition: color .15s;
    }
    .btn-cmt-sm:hover { color: var(--accent, #3b82f6); }
    .btn-cmt-sm:disabled { opacity: .5; cursor: not-allowed; }
    .cmt-menu-wrap { position: relative; display: inline-block; }
    .cmt-menu-item {
        display: block; width: 100%; padding: 8px 16px;
        background: none; border: none; text-align: left;
        font-size: 13px; cursor: pointer; color: #334155;
    }
    .cmt-menu-item:hover { background: #f1f5f9; }
</style>

<div class="chapter-wrapper">

    <!-- Header -->
    <div class="chapter-header">
        <a class="story-title" asp-controller="Story" asp-action="Detail" asp-route-id="@Model.StoryId">
            @Model.Story?.Title
        </a>
        <p class="chapter-subtitle">
            Volumn @Model.VolumeTitle
        </p>
        <p class="chapter-subtitle">
            Chương @Model.ChapterNumber@(string.IsNullOrWhiteSpace(Model.Title) ? "" : $": {Model.Title}")
        </p>
        <span class="ornament">~ ~ ~</span>

        <!-- Nav top -->
        <div class="chapter-nav">
            @{
                var prevChapter = ViewBag.PrevChapter_Id as Guid?;
                var nextChapter = ViewBag.NextChapter_Id as Guid?;
            }

            @if (prevChapter.HasValue)
            {
                <a class="btn-nav btn-prev"
                   asp-controller="Chapter" asp-action="Index" asp-route-id="@prevChapter">
                    ❮ Chương trước
                </a>
            }
            else
            {
                <span class="btn-nav btn-prev btn-disabled">❮ Chương trước</span>
            }
            <button class="btn-nav btn-menu" onclick="openChapterModal()" title="Danh sách chương">☰</button>

            @if (nextChapter.HasValue)
            {
                <a class="btn-nav btn-next"
                   asp-controller="Chapter" asp-action="Index" asp-route-id="@nextChapter">
                    Chương tiếp ❯
                </a>
            }
            else
            {
                <span class="btn-nav btn-next btn-disabled">Chương tiếp ❯</span>
            }
        </div>

        <div>
            <button class="btn-ebook" id="btn-bm" onclick="saveBookmark()">
                🔖 Bookmark chương này
            </button>
            @Html.AntiForgeryToken()
        </div>

        <span class="ornament" style="font-size:1rem;">❧ ✦ ❧</span>
    </div>

    <!-- Meta -->
    <div class="chapter-meta">
        <span>👁 @Model.ViewCount.ToString("N0") lượt xem</span>
        <span>📝 @Model.WordCount.ToString("N0") từ</span>
        @if (Model.PublishedAt.HasValue)
        {
            <span>📅 @Model.PublishedAt.Value.ToString("dd/MM/yyyy")</span>
        }
    </div>

    <!-- Content -->
    <div class="chapter-content" id="chapterContent">
        @if (string.IsNullOrWhiteSpace(Model.Content))
        {
            <p style="color: var(--muted); font-style: italic; text-align:center;">
                Chương này chưa có nội dung.
            </p>
        }
        else
        {
            @Html.Raw(Model.Content)
        }
    </div>

    <!-- Nav bottom -->
    <div class="chapter-nav">
        @if (prevChapter.HasValue)
        {
            <a class="btn-nav btn-prev"
               asp-controller="Chapter" asp-action="Index" asp-route-id="@prevChapter">
                ❮ Chương trước
            </a>
        }
        else
        {
            <span class="btn-nav btn-prev btn-disabled">❮ Chương trước</span>
        }
        <button class="btn-nav btn-menu" onclick="openChapterModal()" title="Danh sách chương">☰</button>

        @if (nextChapter.HasValue)
        {
            <a class="btn-nav btn-next"
               asp-controller="Chapter" asp-action="Index" asp-route-id="@nextChapter">
                Chương tiếp ❯
            </a>
        }
        else
        {
            <span class="btn-nav btn-next btn-disabled">Chương tiếp ❯</span>
        }
    </div>

    <div style="text-align:center;">
        <span class="keyboard-hint">
            Bạn có thể dùng phím mũi tên ← → hoặc WASD để lùi/sang chương.
        </span>
    </div>


