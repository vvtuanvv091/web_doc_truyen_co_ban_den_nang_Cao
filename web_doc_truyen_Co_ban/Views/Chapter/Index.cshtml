<!-- ═══════════════════════════════════════
     MODAL DANH SÁCH CHƯƠNG
     ═══════════════════════════════════════ -->
<div class="modal-overlay" id="chapterListModal" onclick="if(event.target===this)closeChapterModal()">
    <div class="modal-box">
        <div class="modal-header">
            📖 Danh sách chương
            <button class="modal-close" onclick="closeChapterModal()">✕</button>
        </div>
        <div class="modal-list" id="chapterModalList">
            @if (ViewBag.AllChapters != null)
            {
                foreach (var ch in (IEnumerable<dynamic>)ViewBag.AllChapters)
                {
                    bool isActive = ch.Id == Model.Id;
                    double num = (double)ch.ChapterNumber;
                    string numStr = num == Math.Floor(num) 
                        ? ((int)num).ToString()        // 3.00 → "3"
                        : num.ToString("0.##");        // 3.50 → "3.5"

                    string label = $"Chương {numStr}" +
                                   (string.IsNullOrWhiteSpace((string)ch.Title) ? "" : $": {ch.Title}");
                    <a class="modal-chapter-link @(isActive ? "active" : "")"
                       id="chlink-@ch.Id"
                       asp-controller="Chapter" asp-action="Index" asp-route-id="@ch.Id">
                        @label
                    </a>
                }
            }
            else
            {
                <p style="padding:1rem;color:var(--muted);font-style:italic;">
                    Không có dữ liệu chương. Vui lòng kiểm tra ViewBag.AllChapters trong Controller.
                </p>
            }
        </div>
    </div>
</div>
@await Html.PartialAsync("_PopupReport")
@section Scripts {
<script>

    function openChapterModal() {
        document.getElementById('chapterListModal').classList.add('open');
        setTimeout(function () {
            var active = document.querySelector('.modal-chapter-link.active');
            if (active) active.scrollIntoView({ block: 'center', behavior: 'smooth' });
        }, 60);
    }

    function closeChapterModal() {
        document.getElementById('chapterListModal').classList.remove('open');
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeChapterModal();
    });

    function downloadText() {
        const title = "@(Model.Story?.Title ?? "Truyen") - Chuong @Model.ChapterNumber";  // ✅ bỏ comment
        const content = document.getElementById('chapterContent').innerText;
        const blob = new Blob(
            ['\uFEFF' + title + '\n\n' + content],
            { type: 'text/plain;charset=utf-8' }
        );
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = title.replace(/[^a-zA-Z0-9]/g, '_') + '.txt';
        a.click();
    }
    
</script>

<script>
    const chapterId   = document.getElementById('currentChapterId').value;
    const currentUid  = document.getElementById('currentUserId').value;
    const isAuth      = document.getElementById('isAuthenticated').value === 'true';
    const aftToken    = document.getElementById('aftToken').value;

    let page = 1;
    const pageSize = 10;
    let totalLoaded = 0;

    // ── Đóng menu khi click ra ngoài ────────────────────────
    document.addEventListener('click', e => {
        if (!e.target.closest('.cmt-menu-wrap')) {
            document.querySelectorAll('.cmt-dropdown').forEach(m => m.style.display = 'none');
        }
    });

    // ── Toggle menu 3 chấm ──────────────────────────────────
    function toggleCmtMenu(id) {
        const menu = document.getElementById('menu-' + id);
        const isVisible = menu.style.display === 'block';
        document.querySelectorAll('.cmt-dropdown').forEach(m => m.style.display = 'none');
        menu.style.display = isVisible ? 'none' : 'block';
    }

    // ── Render 1 comment (hoặc reply) ───────────────────────
    function renderComment(cmt, isReply = false) {
        const isOwner = currentUid && cmt.userId === currentUid;
        const avatar = cmt.avatarUrl
            ? `<img src="${cmt.avatarUrl}"
                    style="width:${isReply?32:42}px;height:${isReply?32:42}px;border-radius:50%;
                           object-fit:cover;flex-shrink:0;" />`
            : `<div style="width:${isReply?32:42}px;height:${isReply?32:42}px;border-radius:50%;
                           background:linear-gradient(135deg,#6c63ff,#a78bfa);
                           display:flex;align-items:center;justify-content:center;
                           color:#fff;font-weight:700;font-size:${isReply?13:16}px;flex-shrink:0;">
                   ${(cmt.displayName||'?')[0].toUpperCase()}
               </div>`;

        const menuItems = isAuth ? `
            <div class="cmt-menu-wrap">
                <button onclick="toggleCmtMenu('${cmt.id}')"
                        style="background:none;border:none;cursor:pointer;
                               color:#94a3b8;padding:4px 8px;border-radius:6px;
                               font-size:16px;line-height:1;">···</button>
                <div id="menu-${cmt.id}" class="cmt-dropdown"
                     style="display:none;position:absolute;right:0;top:100%;
                            background:#fff;border:1px solid #e2e8f0;
                            border-radius:10px;box-shadow:0 4px 16px rgba(0,0,0,.1);
                            z-index:99;min-width:150px;overflow:hidden;">
                    ${!isReply ? `
                    <button onclick="openReply('${cmt.id}','${escHtml(cmt.displayName)}')"
                            class="cmt-menu-item">
                        <i class="fa fa-reply"></i> Trả lời
                    </button>` : ''}
                    ${isOwner ? `
                    <button onclick="openEdit('${cmt.id}', \`${escJs(cmt.content)}\`)"
                            class="cmt-menu-item">
                        <i class="fa fa-pencil"></i> Chỉnh sửa
                    </button>
                    <button onclick="xoaBinhLuan('${cmt.id}')"
                            class="cmt-menu-item" style="color:#e74c3c;">
                        <i class="fa fa-trash"></i> Xóa
                    </button>` : ''}
                    <button onclick="openBaoCao('comment','${cmt.id}','Bình luận của ${escHtml(cmt.displayName)}')"
                            class="cmt-menu-item" style="color:#e74c3c;">
                        <i class="fa fa-flag"></i> Báo cáo
                    </button>
                </div>
            </div>` : '';

        const likeBtn = isAuth
            ? `<button onclick="likeCmt('${cmt.id}')"
                       style="border:1px solid #fecdd3;background:#fff5f5;
                              color:#e74c3c;font-size:12px;padding:4px 12px;
                              border-radius:20px;cursor:pointer;
                              display:inline-flex;align-items:center;gap:4px;">
                   <i class="fa fa-heart"></i>
                   <span id="like-count-${cmt.id}">${cmt.likeCount}</span>
               </button>`
            : `<span style="border:1px solid #fecdd3;background:#fff5f5;
                            color:#e74c3c;font-size:12px;padding:4px 12px;
                            border-radius:20px;display:inline-flex;align-items:center;gap:4px;">
                   <i class="fa fa-heart"></i> ${cmt.likeCount}
               </span>`;

        const editForm = `
            <div id="edit-${cmt.id}" style="display:none;margin-bottom:10px;">
                <textarea id="edit-text-${cmt.id}" rows="2"
                          style="width:100%;padding:8px 12px;border:1px solid #e2e8f0;
                                 border-radius:8px;font-size:14px;resize:vertical;
                                 font-family:inherit;box-sizing:border-box;"></textarea>
                <div style="display:flex;gap:8px;margin-top:6px;justify-content:flex-end;">
                    <button onclick="cancelEdit('${cmt.id}')"
                            style="padding:6px 14px;border:1px solid #ddd;border-radius:8px;
                                   background:none;cursor:pointer;font-size:13px;color:#666;">Hủy</button>
                    <button onclick="luuSua('${cmt.id}')"
                            style="padding:6px 14px;border:none;border-radius:8px;
                                   background:#525fe1;color:#fff;cursor:pointer;font-size:13px;">Lưu</button>
                </div>
            </div>`;

        const replyForm = !isReply ? `
            <div id="reply-${cmt.id}" style="display:none;margin:8px 0 10px;">
                <div style="font-size:12px;color:#94a3b8;margin-bottom:4px;">
                    Đang trả lời <strong id="reply-name-${cmt.id}"></strong>
                </div>
                <textarea id="reply-text-${cmt.id}" rows="2" placeholder="Viết trả lời..."
                          style="width:100%;padding:8px 12px;border:1px solid #e2e8f0;
                                 border-radius:8px;font-size:14px;resize:vertical;
                                 font-family:inherit;box-sizing:border-box;"></textarea>
                <div style="display:flex;gap:8px;margin-top:6px;justify-content:flex-end;">
                    <button onclick="cancelReply('${cmt.id}')"
                            style="padding:6px 14px;border:1px solid #ddd;border-radius:8px;
                                   background:none;cursor:pointer;font-size:13px;color:#666;">Hủy</button>
                    <button onclick="guiReply('${cmt.id}')"
                            style="padding:6px 14px;border:none;border-radius:8px;
                                   background:#525fe1;color:#fff;cursor:pointer;font-size:13px;">Gửi</button>
                </div>
            </div>` : '';

        const repliesContainer = !isReply
            ? `<div id="replies-${cmt.id}" style="margin-top:10px;"></div>` : '';

        const wrapStyle = isReply
            ? `display:flex;gap:10px;padding:10px 0;padding-left:16px;border-left:3px solid #e2e8f0;`
            : `display:flex;gap:12px;padding:16px 0;border-bottom:1px solid #f1f5f9;`;

        return `
            <div style="${wrapStyle}" id="cmt-${cmt.id}">
                ${avatar}
                <div style="flex:1;min-width:0;">
                    <div style="display:flex;align-items:center;justify-content:space-between;
                                gap:8px;flex-wrap:wrap;">
                        <div style="display:flex;align-items:center;gap:8px;">
                            <span style="font-weight:700;font-size:${isReply?13:14}px;color:#1e293b;">
                                ${escHtml(cmt.displayName || 'Ẩn danh')}
                            </span>
                            <span style="font-size:11px;color:#94a3b8;">${cmt.createdAt}</span>
                        </div>
                        ${menuItems}
                    </div>
                    <p id="content-${cmt.id}"
                       style="margin:${isReply?'4px 0 0':'6px 0 10px'};font-size:14px;
                              color:#334155;line-height:1.6;word-break:break-word;">
                        ${escHtml(cmt.content)}
                    </p>
                    ${editForm}
                    ${replyForm}
                    ${likeBtn}
                    ${repliesContainer}
                </div>
            </div>`;
    }

    // ── Load comments ────────────────────────────────────────
    async function loadComments(reset = false) {
        if (reset) { page = 1; totalLoaded = 0; document.getElementById('comment-list').innerHTML = ''; }

        const res = await fetch(`/ChapterComment/GetList?chapterId=${chapterId}&page=${page}&pageSize=${pageSize}`);
        const data = await res.json();

        document.getElementById('total-count').textContent = data.total;
        totalLoaded += data.comments.length;

        const list = document.getElementById('comment-list');
        data.comments.forEach(cmt => {
            list.insertAdjacentHTML('beforeend', renderComment(cmt));
            if (cmt.replies?.length) {
                const repliesEl = document.getElementById('replies-' + cmt.id);
                cmt.replies.forEach(r => repliesEl.insertAdjacentHTML('beforeend', renderComment(r, true)));
            }
        });

        const hasMore = totalLoaded < data.total;
        document.getElementById('load-more-wrapper').style.display = hasMore ? 'block' : 'none';
        document.getElementById('all-loaded').style.display = !hasMore && totalLoaded > 0 ? 'block' : 'none';
        page++;
    }

    function loadMore() { loadComments(); }

    // ── Gửi comment mới ─────────────────────────────────────
    async function postComment() {
        const content = document.getElementById('commentInput').value.trim();
        if (!content) return;

        await fetch('/ChapterComment/Add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ chapterId, content, __RequestVerificationToken: aftToken })
        });

        document.getElementById('commentInput').value = '';
        loadComments(true);
    }

    // ── Like ─────────────────────────────────────────────────
    async function likeCmt(commentId) {
        await fetch('/ChapterComment/Like', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ commentId, chapterId, __RequestVerificationToken: aftToken })
        });
        // Cập nhật số like không cần reload
        const res = await fetch(`/ChapterComment/GetLikeCount?commentId=${commentId}`);
        const data = await res.json();
        const el = document.getElementById('like-count-' + commentId);
        if (el) el.textContent = data.count;
    }

    // ── Reply ────────────────────────────────────────────────
    function openReply(id, name) {
        document.getElementById('reply-' + id).style.display = 'block';
        document.getElementById('reply-name-' + id).textContent = name;
        toggleCmtMenu(id);
    }
    function cancelReply(id) { document.getElementById('reply-' + id).style.display = 'none'; }

    async function guiReply(parentId) {
        const content = document.getElementById('reply-text-' + parentId).value.trim();
        if (!content) return;

        await fetch('/ChapterComment/Add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ chapterId, content, parentId, __RequestVerificationToken: aftToken })
        });

        cancelReply(parentId);
        loadComments(true);
    }

    // ── Edit ─────────────────────────────────────────────────
    function openEdit(id, content) {
        document.getElementById('content-' + id).style.display = 'none';
        document.getElementById('edit-' + id).style.display = 'block';
        document.getElementById('edit-text-' + id).value = content;
        toggleCmtMenu(id);
    }
    function cancelEdit(id) {
        document.getElementById('edit-' + id).style.display = 'none';
        document.getElementById('content-' + id).style.display = 'block';
    }
    async function luuSua(id) {
        const content = document.getElementById('edit-text-' + id).value.trim();
        if (!content) return;

        await fetch('/ChapterComment/Edit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ id, chapterId, content, __RequestVerificationToken: aftToken })
        });

        document.getElementById('content-' + id).textContent = content;
        cancelEdit(id);
    }

    // ── Xóa ─────────────────────────────────────────────────
    async function xoaBinhLuan(id) {
        if (!confirm('Xóa bình luận này?')) return;

        await fetch('/ChapterComment/Delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ id, chapterId, __RequestVerificationToken: aftToken })
        });

        document.getElementById('cmt-' + id)?.remove();
        const count = document.getElementById('total-count');
        count.textContent = Math.max(0, parseInt(count.textContent) - 1);
    }

    // ── Escape helpers ───────────────────────────────────────
    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;')
                        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function escJs(s) { return String(s).replace(/\\/g,'\\\\').replace(/`/g,'\\`'); }

    // ── Init ─────────────────────────────────────────────────
    loadComments();
</script>
<script>
    async function saveBookmark() {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? "";
    
    const res = await fetch('/Bookmark/CreateBookMark', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': token
        },
        body: new URLSearchParams({
            storieid: '@Model.StoryId',  
            chapterid: '@Model.Id'         
        })
    });

    const data = await res.json();
    
    if (data.success) {
        alert('✅ ' + data.message);
    } else {
        alert('⚠️ ' + data.message);
    }
}
</script>


