@model List<web_doc_truyen_Co_ban.Models.FollowModel>
@{
    ViewData["Title"] = "Truyện đang theo dõi";
    var hotStories = ViewBag.HotStories as List<StoryModel> ?? new();
    var newStories = ViewBag.NewStories as List<StoryModel> ?? new();
}

@functions {
    public string GetImage(string? url)
    {
        if (string.IsNullOrEmpty(url)) return Url.Content("~/img/cat1.jpg");
        if (url.StartsWith("http")) return url;
        if (url.StartsWith("/")) return url;  // ✅ path tuyệt đối → giữ nguyên
        return Url.Content("~/img/" + url);         // chỉ ghép nếu là tên file thuần
    }
}

<div class="container-fluid px-lg-5 px-3 py-4">
    <div class="row g-4 align-items-start">

        @* ── MAIN ── *@
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4">

                    <h5 class="fw-bold mb-3">
                        <i class="fas fa-heart text-danger me-2"></i>Truyện đang theo dõi
                        <span class="badge bg-danger ms-2" style="font-size:.75rem;">@(Model?.Count ?? 0)</span>
                    </h5>
                    <hr class="mt-0">

                    @if (Model == null || !Model.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fas fa-book-open fa-3x mb-3 opacity-25"></i>
                            <p class="fw-bold">Bạn chưa theo dõi truyện nào</p>
                            <a asp-controller="Category" asp-action="Index" class="btn btn-primary btn-sm rounded-pill">
                                Khám phá ngay
                            </a>
                        </div>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <div class="d-flex gap-3 py-3 border-bottom align-items-start">
                                <a asp-controller="Story" asp-action="Details" asp-route-id="@item.Story.Id" class="flex-shrink-0">
                                    <img src="@GetImage(item.Story?.CoverImageUrl)"
                                         style="width:70px;height:95px;object-fit:cover;border-radius:8px;"
                                         alt="@item.Story?.Title" />
                                </a>
                                <div class="flex-grow-1">
                                    <a asp-controller="Story" asp-action="Details" asp-route-id="@item.Story.Id"
                                           class="fw-bold text-dark text-decoration-none d-block mb-1"
                                           style="font-size:.95rem;">
                                        @item.Story?.Title
                                    </a>
                                    <div class="text-muted small mb-1">
                                        <i class="fa fa-tag me-1"></i>@(item.Story?.Category?.Name ?? "Chưa phân loại")
                                    </div>
                                    <div class="d-flex gap-3 text-muted small">
                                        <span><i class="fa fa-eye me-1"></i>@item.Story?.TotalViews lượt xem</span>
                                        <span><i class="fa fa-clock me-1"></i>@item.CreatedAt.ToString("dd/MM/yyyy")</span>
                                    </div>
                                </div>
                                <form asp-controller="Follow" asp-action="RemoveFollow" method="post" class="flex-shrink-0">
                                    <input type="hidden" name="storyId" value="@item.StoryId" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill"
                                            title="Bỏ theo dõi"
                                            onclick="return confirm('Bỏ theo dõi truyện này?')">
                                        <i class="fas fa-heart-broken"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        @* ── SIDEBAR ── *@
        <div class="col-lg-3">

            @* HOT *@
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-3">
                        <i class="fas fa-fire text-danger me-2"></i>Truyện HOT
                    </h6>
                    @foreach (var hot in hotStories.Take(5))
                    {
                        <div class="d-flex gap-2 mb-3 align-items-start">
                            <img src="@GetImage(hot.CoverImageUrl)"
                                 style="width:48px;height:64px;object-fit:cover;border-radius:6px;flex-shrink:0;"
                                 alt="@hot.Title" />
                            <div>
                                <a asp-controller="Story" asp-action="Details" asp-route-id="@hot.Id"
                                       class="text-dark text-decoration-none fw-semibold"
                                       style="font-size:.82rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                    @hot.Title
                                </a>
                                <div class="text-muted mt-1" style="font-size:.75rem;">
                                    <i class="fa fa-eye me-1"></i>@hot.TotalViews
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @* NEW *@
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-3">
                        <i class="fas fa-bolt text-warning me-2"></i>Mới cập nhật
                    </h6>
                    @foreach (var n in newStories.Take(5))
                    {
                        <div class="d-flex gap-2 mb-3 align-items-start">
                            <img src="@GetImage(n.CoverImageUrl)"
                                 style="width:48px;height:64px;object-fit:cover;border-radius:6px;flex-shrink:0;"
                                 alt="@n.Title" />
                            <div>
                                <a asp-controller="Story" asp-action="Details" asp-route-id="@n.Id"
                                       class="text-dark text-decoration-none fw-semibold"
                                       style="font-size:.82rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                    @n.Title
                                </a>
                                <div class="text-muted mt-1" style="font-size:.75rem;">
                                    <i class="fa fa-calendar me-1"></i>@n.UpdatedAt.ToString("dd/MM/yyyy")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>
