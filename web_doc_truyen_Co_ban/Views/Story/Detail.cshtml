</html>

@section Scripts {
    <script>
    // ===== BÌNH LUẬN =====
        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        }

        function toggleCmtMenu(id) {
            document.querySelectorAll('[id^="menu-"]').forEach(m => {
                if (m.id !== 'menu-' + id) m.style.display = 'none';
            });
            const m = document.getElementById('menu-' + id);
            m.style.display = m.style.display === 'block' ? 'none' : 'block';
        }

        document.addEventListener('click', e => {
            if (!e.target.closest('.cmt-menu-wrap'))
                document.querySelectorAll('[id^="menu-"]').forEach(m => m.style.display = 'none');
        });

        function openReply(id, name) {
            document.getElementById('menu-' + id).style.display = 'none';
            document.getElementById('reply-name-' + id).textContent = name;
            document.getElementById('reply-' + id).style.display = 'block';
            document.getElementById('reply-text-' + id).focus();
        }
        function cancelReply(id) {
            document.getElementById('reply-' + id).style.display = 'none';
            document.getElementById('reply-text-' + id).value = '';
        }
        async function guiReply(parentId) {
            const content = document.getElementById('reply-text-' + parentId).value.trim();
            if (!content) return;
            const res = await fetch('/Story/AddComment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    storyId: '@Model.Id',
                    content,
                    parentId,
                    __RequestVerificationToken: getToken()
                })
            });
            if (res.ok) location.reload();
        }

        function openEdit(id, content) {
            document.getElementById('menu-' + id).style.display = 'none';
            document.getElementById('content-' + id).style.display = 'none';
            document.getElementById('edit-text-' + id).value = content;
            document.getElementById('edit-' + id).style.display = 'block';
        }
        function cancelEdit(id) {
            document.getElementById('edit-' + id).style.display = 'none';
            document.getElementById('content-' + id).style.display = 'block';
        }
        async function luuSua(id) {
            const content = document.getElementById('edit-text-' + id).value.trim();
            if (!content) return;
            const res = await fetch('/Story/EditComment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    commentId: id,
                    content,
                    __RequestVerificationToken: getToken()
                })
            });
            const data = await res.json();
            if (data.success) {
                document.getElementById('content-' + id).textContent = content;
                cancelEdit(id);
            }
        }

        async function xoaBinhLuan(id) {
            if (!confirm('Xóa bình luận này?')) return;
            const res = await fetch('/Story/DeleteComment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    commentId: id,
                    __RequestVerificationToken: getToken()
                })
            });
            const data = await res.json();
            if (data.success) document.getElementById('cmt-' + id).remove();
        }

    (function () {

   
        var box = document.getElementById('user-rating-box');
        if (!box) return;

        var storyId   = box.dataset.story;
        var userScore = parseInt(box.dataset.userScore) || 0;
        var stars     = box.querySelectorAll('.star-pick');
        var msgEl     = document.getElementById('rate-msg');

        if (!stars.length) return;

        function highlight(upTo) {
            stars.forEach(function(s) {
                s.style.color = parseInt(s.dataset.score) <= upTo ? '#ffa500' : '#ccc';
            });
        }

        stars.forEach(function(star) {
            star.addEventListener('mouseenter', function() { highlight(parseInt(this.dataset.score)); });
            star.addEventListener('mouseleave', function() { highlight(userScore); });
            star.addEventListener('click',      function() { sendRating(parseInt(this.dataset.score)); });
        });

        function getToken() {
            var el = document.querySelector('input[name="__RequestVerificationToken"]');
            return el ? el.value : '';
        }

        function sendRating(score) {
            if (msgEl) msgEl.innerHTML = '<span class="text-muted">Đang gửi...</span>';

            fetch('/Story/Rate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'storyId=' + storyId
                    + '&score=' + score
                    + '&__RequestVerificationToken=' + encodeURIComponent(getToken())
            })
            .then(function(res) { return res.json(); })
            .then(function(data) {
                if (data.success) {
                    userScore = data.userScore;
                    highlight(userScore);
                    box.dataset.userScore = userScore;

                    var avg = parseFloat(data.avgRating).toFixed(2);
                    var e1 = document.getElementById('avg-display');
                    var e2 = document.getElementById('count-display');
                    var e3 = document.getElementById('rating-text');
                    if (e1) e1.textContent = avg;
                    if (e2) e2.textContent = data.ratingCount;
                    if (e3) e3.textContent = avg + ' / 5 (' + data.ratingCount + ' đánh giá)';

                    refreshStaticStars(data.avgRating);
                    if (msgEl) msgEl.innerHTML = '<span class="text-success"><i class="fa fa-check"></i> Đã lưu ' + userScore + '★</span>';
                } else {
                    if (msgEl) msgEl.innerHTML = '<span class="text-danger">' + (data.message || 'Lỗi.') + '</span>';
                }
                setTimeout(function() { if (msgEl) msgEl.innerHTML = ''; }, 3000);
            })
            .catch(function() {
                if (msgEl) msgEl.innerHTML = '<span class="text-danger">Lỗi kết nối.</span>';
            });
        }

        function refreshStaticStars(avg) {
            var container = document.getElementById('stars-display');
            if (!container) return;
            var span = container.querySelector('span');
            container.querySelectorAll('i').forEach(function(el) { el.remove(); });
            for (var i = 1; i <= 5; i++) {
                var icon = document.createElement('i');
                if      (i <= Math.floor(avg))           { icon.className = 'fa fa-star';        icon.style.color = '#ffa500'; }
                else if (avg > i-1 && avg < i)           { icon.className = 'fa fa-star-half-o'; icon.style.color = '#ffa500'; }
                else                                     { icon.className = 'fa fa-star-o';      icon.style.color = '#ccc'; }
                container.insertBefore(icon, span);
            }
        }
    })();

    //thêm  xổ danh sách phần bôkmark
    const STORY_ID = '@Model.Id';
    let bmOpen = false;

    async function toggleBookmark() {
        bmOpen = !bmOpen;
        document.getElementById('bookmark-dropdown').style.display = bmOpen ? 'block' : 'none';
        document.getElementById('bm-chevron').style.transform = bmOpen ? 'rotate(180deg)' : 'rotate(0deg)';
        if (bmOpen) await loadBookmarks();
    }

    async function loadBookmarks() {
        const listEl = document.getElementById('bm-list');
        listEl.innerHTML = '<div style="padding:20px;text-align:center;color:#aaa;font-size:13px;">Đang tải...</div>';
        try {
            const res  = await fetch(`/BookMark/GetByStory?storyId=${STORY_ID}`);
            const data = await res.json();

            document.getElementById('bm-count').textContent = data.length;

            if (!data.length) {
                listEl.innerHTML = '<div style="padding:20px;text-align:center;color:#aaa;font-size:13px;">Chưa có bookmark nào.</div>';
                return;
            }

            listEl.innerHTML = data.map(b => `
                <div style="display:flex;align-items:center;justify-content:space-between;
                            padding:9px 12px;border-bottom:1px solid #f1f5f9;cursor:pointer;"
                     onclick="window.location.href='/Chapter/Index/${b.chapterId}'">
                    <div style="display:flex;align-items:center;gap:8px;">
                        <i class="fa fa-bookmark" style="color:#534AB7;font-size:13px;"></i>
                        <div>
                            <div style="font-size:13px;font-weight:600;color:#1e293b;">
                                Chương ${parseFloat(b.chapterNumber).toFixed(2)}
                            </div>
                            <div style="font-size:11px;color:#94a3b8;">${b.updatedAt ?? ''}</div>
                        </div>
                    </div>
                    <button onclick="event.stopPropagation(); removeBookmark('${b.id}')"
                            style="background:none;border:none;cursor:pointer;
                                   color:#94a3b8;padding:2px 6px;border-radius:4px;">
                        <i class="fa fa-times"></i>
                    </button>
                </div>
            `).join('');

        } catch {
            listEl.innerHTML = '<div style="padding:20px;text-align:center;color:#e74c3c;font-size:13px;">Lỗi tải dữ liệu.</div>';
        }
    }

    async function removeBookmark(id) {
        await fetch(`/BookMark/Remove`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `bookmarkid=${id}&__RequestVerificationToken=${getToken()}`
        });
        await loadBookmarks();
    }

    async function removeAllBookmark() {
        await fetch(`/BookMark/RemoveAll`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `storyId=${STORY_ID}&__RequestVerificationToken=${getToken()}`
        });
        await loadBookmarks();
    }

    // Đóng dropdown khi click ngoài
    document.addEventListener('click', (e) => {
        const wrap = document.getElementById('btn-bookmark')?.parentElement;
        if (wrap && !wrap.contains(e.target)) {
            bmOpen = false;
            document.getElementById('bookmark-dropdown').style.display = 'none';
            document.getElementById('bm-chevron').style.transform = 'rotate(0deg)';
        }
    });

    // Load count ban đầu
    fetch(`/BookMark/GetByStory?storyId=${STORY_ID}`)
        .then(r => r.json())
        .then(d => document.getElementById('bm-count').textContent = d.length)
        .catch(() => {});

    function getToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    }



    //chọn load luyuw trang

    </script>
}