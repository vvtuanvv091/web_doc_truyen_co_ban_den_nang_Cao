@model web_doc_truyen_Co_ban.Models.StoryModel
@{
    ViewData["Title"] = Model.Title;
    var avgRating = (Model.Ratings != null && Model.Ratings.Any())
        ? Math.Round(Model.Ratings.Average(r => r.Score), 1)
        : 0.0;
    var ratingCount  = Model.Ratings?.Count ?? 0;
    var chapterCount = Model.Chapters?.Count ?? 0;
    var commentCount = Model.StoryComments?.Count ?? 0;
}

