<body data-spy="scroll" data-offset="80">

    <!-- MAIN -->
    <section class="our_event section-padding">
        @Html.AntiForgeryToken()
        <div class="container-fluid px-lg-5 px-3">
            <div class="row">

                <!-- ========== CỘT TRÁI ========== -->
                <div class="col-lg-8 col-sm-8 col-xs-12">

                    <!-- HEADER TRUYỆN -->
                    <div class="single_event_single">
                        <div class="story-header-wrap">

                            <!-- Ảnh bìa -->
                            <div class="story-cover-box">
                                @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                                {
                                    <img src="@GetImage(Model.CoverImageUrl)" alt="@Model.Title" />
                                }
                                else
                                {
                                    <div class="story-cover-placeholder">
                                        <i class="fa fa-book"></i>
                                    </div>
                                }
                            </div>


                            <!-- Thông tin -->
                            <div class="story-info-box single_event_text_single">
                                <h4>@Model.Title</h4>

                                <span class="story-badge">@GetStatusText(Model.Status)</span>

                                <div class="story-stats">
                                    <span><i class="fa fa-eye"></i>@(Model.TotalViews.ToString("N0"))</span>
                                    <span><i class="fa fa-heart"></i>@Model.TotalFollows</span>
                                    <span><i class="fa fa-book"></i>@chapterCount chương</span>
                                    @{
                                        var avgRating   = (decimal)Model.RatingAvg;
                                        var ratingCount = Model.RatingCount;
                                        var userScore   = (byte)(ViewBag.UserScore ?? 0);
                                    }
                                    <span>
                                        <i class="fa fa-star" style="color:#ffa500;"></i>
                                        <span id="avg-display">@avgRating.ToString("0.00")</span>
                                        (<span id="count-display">@ratingCount</span> đánh giá)
                                    </span>
                                </div>

                                <div class="story-stars" id="stars-display">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Floor((double)avgRating))
                                            { <i class="fa fa-star" style="color:#ffa500;"></i> }
                                        else if (avgRating > i - 1 && avgRating < i)
                                            { <i class="fa fa-star-half-o" style="color:#ffa500;"></i> }
                                        else
                                            { <i class="fa fa-star-o" style="color:#ccc;"></i> }
                                    }
                                    <span class="rating-text" id="rating-text">
                                        @avgRating.ToString("0.00") / 5 (@ratingCount đánh giá)
                                    </span>
                                </div>

                                <div id="user-rating-box" data-story="@Model.Id" data-user-score="@userScore" class="mt-2">
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <div class="d-flex align-items-center gap-1">
                                            <span class="text-muted me-1" style="font-size:.85rem;">Đánh giá của bạn:</span>
                                            @for (byte i = 1; i <= 5; i++)
                                            {
                                                <i class="fa fa-star star-pick"
                                                   data-score="@i"
                                                   style="font-size:1.5rem; cursor:pointer; color:@(i <= userScore ? "#ffa500" : "#ccc");"></i>
                                            }
                                            @if (userScore > 0)
                                            {
                                                <span class="text-muted ms-1" style="font-size:.82rem;">(@userScore★)</span>
                                            }
                                        </div>
                                        <div id="rate-msg" class="small mt-1" style="min-height:1.2em;"></div>
                                    }
                                    else
                                    {
                                        <p class="text-muted small mt-1 mb-0">
                                            <a href="/Account/Login">Đăng nhập</a> để đánh giá.
                                        </p>
                                    }
                                </div>

                                
                            </div>

                        </div>
                    </div>
                    <!-- Nút hành động -->
                                <div class="details-buttons-area" style="margin-top:0;">
                                    @if (Model.Chapters != null && Model.Chapters.Any())
                                    {
                                        var firstChap    = Model.Chapters.OrderBy(c => c.ChapterNumber).First();
                                        <a href="@Url.Action("Index","Chapter",new{id=firstChap.Id})"
                                           class="custom-button">
                                            <i class="fa fa-book-open"></i> Đọc truyện

                                        </a>
                                    }
                                    @{
                                        var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                        bool isFollowed = Model.Follows != null &&
                                                          Model.Follows.Any(x => x.UserId.ToString() == userId);
                                    }

                                    @if (User.Identity.IsAuthenticated)
                                    {
                                        @if (isFollowed)
                                        {
                                            <form asp-action="RemoveFollow" asp-controller="Follow" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="storyId" value="@Model.Id" />
                                                <button type="submit" class="custom-button" style="background:#e11d48;color:white;">
                                                    <i class="fa fa-heart-broken"></i> Bỏ theo dõi
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="AddFollow" asp-controller="Follow" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="storyId" value="@Model.Id" />
                                                <button type="submit" class="custom-button">
                                                    <i class="fa fa-heart"></i> Theo dõi
                                                </button>
                                            </form>
                                        }
                                    }
                                    else
                                    {
                                        <a asp-controller="Account" asp-action="Login" class="custom-button">
                                            <i class="fa fa-lock"></i> Đăng nhập để theo dõi
                                        </a>
                                    }
                                    @* <button class="custom-button" onclick="openBaoCao('story', '@Model.Id', '@Model.Title')">
                                        <i class="bi bi-flag"></i> Báo cáo truyện
                                    </button> *@
                                    <button class="custom-button" onclick="openBaoCao('story', '@Model.Id', '@Model.Title')">
                                        <i class="bi bi-flag"></i> Báo cáo truyện
                                    </button>
                                    @if (User.Identity.IsAuthenticated)
                                    {
                                        <div style="position:relative; display:inline-block;">
                                            <button class="custom-button" id="btn-bookmark"
                                                    onclick="toggleBookmark()"
                                                    style="display:flex; align-items:center; gap:8px;
                                                           
                                                             color:#fff;
                                                           font-size:14px; font-weight:600; cursor:pointer;">
                                                <i class="fa fa-bookmark"></i> Bookmark
                                                <span id="bm-count"
                                                       border-radius:99px;
                                                             font-size:11px; padding:1px 7px;">0</span>
                                                <i class="fa fa-chevron-down" id="bm-chevron"
                                                   style="font-size:11px; transition:transform 0.2s;"></i>
                                            </button>

                                            <div id="bookmark-dropdown"
                                                 style="display:none; position:absolute; top:calc(100% + 6px); left:0;
                                                        min-width:240px; background:#fff; border:1px solid #e2e8f0;
                                                        border-radius:12px; z-index:999; box-shadow:0 8px 24px rgba(0,0,0,0.12);
                                                        overflow:hidden;">

                                                <div style="padding:8px 12px; font-size:11px; color:#94a3b8;
                                                            border-bottom:1px solid #f1f5f9; font-weight:600;
                                                            letter-spacing:0.04em;">
                                                    CHƯƠNG ĐÃ LƯU
                                                </div>

                                                <div id="bm-list" style="max-height:260px; overflow-y:auto;">
                                                    <div style="padding:20px; text-align:center; color:#aaa; font-size:13px;">
                                                        Đang tải...
                                                    </div>
                                                </div>

                                                <div style="padding:8px 10px; border-top:1px solid #f1f5f9;">
                                                    <button onclick="removeAllBookmark()"
                                                            style="width:100%; padding:7px; border-radius:8px;
                                                                   background:none; border:1px dashed #e2e8f0;
                                                                   color:#94a3b8; font-size:12px; cursor:pointer;
                                                                   display:flex; align-items:center; justify-content:center; gap:5px;">
                                                        <i class="fa fa-trash"></i> Xóa tất cả
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>

                    <!-- END HEADER TRUYỆN -->

                    <!-- VIP BANNER -->
                    <div class="vip-banner">
                        <div class="vip-banner__header">
                            <i class="fa fa-crown"></i>
                            <h5>MUA GÓI HỘI VIÊN</h5>
                        </div>
                        <div class="vip-banner__body">
                            <div class="vip-item">
                                <i class="fa fa-check-circle"></i>
                                <span>Đăng ký <strong>miễn phí</strong>: đọc full trừ 50 chương mới nhất + 10 chương/ngày mở bằng điểm</span>
                            </div>
                            <div class="vip-item">
                                <i class="fa fa-star"></i>
                                <span>Nâng cấp <strong>VIP</strong>: đọc full tất cả truyện, nghe audio không giới hạn</span>
                            </div>
                            <div class="vip-item">
                                <i class="fa fa-tag"></i>
                                <span>Chỉ từ <strong>49.000đ</strong>, áp dụng ưu đãi bất kỳ lúc nào</span>
                            </div>
                        </div>
                        <a href="#" class="vip-banner__btn">
                            <i class="fa fa-credit-card"></i> MUA NGAY
                        </a>
                    </div>

                    <!-- TABS -->
                    <div class="course-details-content section-bg">
                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item">
                                <a href="#thongtin" class="nav-link active" data-bs-toggle="tab">
                                    <i class="fa fa-info-circle"></i> Thông tin truyện
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="#danhsachchap" class="nav-link" data-bs-toggle="tab">
                                    <i class="fa fa-list"></i> Chap (@chapterCount)
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="#binhluan" class="nav-link" data-bs-toggle="tab">
                                    <i class="fa fa-comments"></i> Bình luận (@commentCount)
                                </a>
                            </li>
                        </ul>

                        <div class="tab-content" id="storyTabContent">

                            <!-- ── TAB 1: THÔNG TIN ── -->
                            <div class="tab-pane show fade active" id="thongtin">
                                <div class="overview">
                                    <h5 style="margin-bottom:12px;font-size:1rem;">Giới thiệu</h5>
                                    <p style="line-height:1.8;">
                                        @Html.Raw(Model.Description ?? "Chưa có mô tả.")
                                    </p>

                                    <table class="info-tbl">
                                        <tr>
                                            <td class="info-lbl">Thể loại</td>
                                            <td>
                                                @if (Model.Category != null)
                                                {
                                                    <a href="@Url.Action("ListByCategory","Category",new{slug=Model.Category.Slug})"
                                                       style="color:#e85d04;">@Model.Category.Name</a>
                                                }
                                                else { <span style="color:#666;">—</span> }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="info-lbl">Trạng thái</td>
                                            <td>@GetStatusText(Model.Status)</td>
                                        </tr>
                                        <tr>
                                            <td class="info-lbl">Số chương</td>
                                            <td>@chapterCount chương</td>
                                        </tr>
                                        <tr>
                                            <td class="info-lbl">Lượt xem</td>
                                            <td>@Model.TotalViews.ToString("N0")</td>
                                        </tr>
                                        <tr>
                                            <td class="info-lbl">Ngày đăng</td>
                                            <td>@Model.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    </table>

                                    @if (Model.Tags != null && Model.Tags.Any())
                                    {
                                        <div style="margin-top:14px;">
                                            <span style="font-size:13px;margin-right:4px;">Tags:</span>
                                            @foreach (var tag in Model.Tags)
                                            {
                                                <a href="/Tag/@tag.Slug" class="tag-chip">@tag.Name</a>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- ── TAB 2: DANH SÁCH CHƯƠNG ── -->
                            <div class="tab-pane fade" id="danhsachchap">
                                <div class="overview" style="padding:0;">
                                    @if (Model.Chapters != null && Model.Chapters.Any())
                                    {
                                        <div style="max-height:540px;overflow-y:auto;">
                                            <table class="chap-table">
                                                <thead>
                                                    <tr>
                                                        <th style="text-align:left">Volumn</th>
                                                        <th style="text-align:left">Chương</th>
                                                        <th style="text-align:left">Tên chương</th>
                                                        <th style="text-align:right">Ngày cập nhật</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var chapter in Model.Chapters.OrderBy(c => c.ChapterNumber))
                                                    {
                                                        <tr>
                                                            <td>@(chapter.VolumeTitle ?? "—")</td>
                                                            <td>
                                                                @* ✅ Đúng: IsLocked || Status==2 *@
                                                                @if (chapter.IsLocked && chapter.Status == 2)
                                                                {
                                                                    <a href="@Url.Action("Confirm","UnlockChapter", new { id = chapter.Id })">
                                                                        Chương @chapter.ChapterNumber
                                                                    </a>
                                                                    <span class="badge badge-vip">VIP</span>
                                                                    @if (chapter.UnlockPrice > 0)
                                                                    {
                                                                        <span class="badge badge-lock">🔒 @chapter.UnlockPrice xu</span>
                                                                    }
                                                                }
                                                                else if (chapter.Status == 1 && !chapter.IsLocked)
                                                                {
                                                                    <a href="@Url.Action("Index","Chapter", new { id = chapter.Id })">
                                                                        Chương @chapter.ChapterNumber
                                                                    </a>
                                                                    <span class="badge badge-published">Đã đăng</span>
                                                                }
                                                                else if (chapter.Status == 0)
                                                                {
                                                                    <span style="color:#aaa">Chương @chapter.ChapterNumber</span>
                                                                    <span class="badge badge-draft">Bản nháp</span>
                                                                }
                                                            </td>
                                                            <td>
                                                                @if (!string.IsNullOrEmpty(chapter.Title))
                                                                {
                                                                    @chapter.Title
                                                                }
                                                                else
                                                                {
                                                                    <span style="color:#999">—</span>
                                                                }
                                                            </td>
                                                            <td style="text-align:right; color:#888; font-size:13px;">
                                                                @chapter.UpdatedAt.ToString("dd/MM/yyyy")
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="text-align:center;color:#666;padding:48px 0;">
                                            <i class="fa fa-book" style="font-size:40px;display:block;margin-bottom:12px;"></i>
                                            Chưa có chương nào.
                                        </div>
                                    }
                                </div>
                            </div>

                           <!-- ── TAB 3: BÌNH LUẬN ── -->
                            <div class="tab-pane fade" id="binhluan">
                                <div style="padding: 24px 0;">

                                    <!-- Header -->
                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
                                        <h5 style="margin:0;font-weight:700;color:#1e293b;">
                                            💬 Bình luận 
                                            <span style="background:#6c63ff;color:#fff;border-radius:20px;
                                                         padding:2px 10px;font-size:13px;margin-left:6px;">
                                                @Model.StoryComments.Count
                                            </span>
                                        </h5>
                                    </div>
                                    @* //xem lại nha code ai render *@
                                    <!-- Danh sách bình luận -->
                                    @if (Model.StoryComments != null && Model.StoryComments.Any())
                                    {
                                        @foreach (var cmt in Model.StoryComments
                                            .Where(c => c.ParentId == null && c.Status == 0)
                                            .OrderByDescending(c => c.CreatedAt)
                                            .Take(20))
                                        {
                                            var isOwner = userId != null && cmt.UserId.ToString() == userId;

                                            <div style="display:flex;gap:12px;padding:16px 0;
                                                        border-bottom:1px solid #f1f5f9;" id="cmt-@cmt.Id">

                                                <!-- Avatar -->
                                                @if (!string.IsNullOrEmpty(cmt.User?.AvatarUrl))
                                                {
                                                    <img src="@cmt.User.AvatarUrl"
                                                         style="width:42px;height:42px;border-radius:50%;
                                                                object-fit:cover;flex-shrink:0;" />
                                                }
                                                else
                                                {
                                                    <div style="width:42px;height:42px;border-radius:50%;
                                                                background:linear-gradient(135deg,#6c63ff,#a78bfa);
                                                                display:flex;align-items:center;justify-content:center;
                                                                color:#fff;font-weight:700;font-size:16px;flex-shrink:0;">
                                                        @((cmt.User?.DisplayName ?? "?").Substring(0,1).ToUpper())
                                                    </div>
                                                }

                                                <!-- Nội dung -->
                                                <div style="flex:1;min-width:0;">
                                                    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;">
                                                        <div style="display:flex;align-items:center;gap:8px;">
                                                            <span style="font-weight:700;font-size:14px;color:#1e293b;">
                                                                @(cmt.User?.DisplayName ?? "Ẩn danh")
                                                            </span>
                                                            <span style="font-size:11px;color:#94a3b8;">
                                                                @cmt.CreatedAt.ToString("HH:mm · dd/MM/yyyy")
                                                            </span>
                                                        </div>

                                                        <!-- 3 chấm menu -->
                                                        @if (User.Identity.IsAuthenticated)
                                                        {
                                                            <div style="position:relative;" class="cmt-menu-wrap">
                                                                <button onclick="toggleCmtMenu('@cmt.Id')"
                                                                        style="background:none;border:none;cursor:pointer;
                                                                               color:#94a3b8;padding:4px 8px;border-radius:6px;
                                                                               font-size:16px;line-height:1;"
                                                                        title="Tùy chọn">
                                                                    ···
                                                                </button>
                                                                <div id="menu-@cmt.Id"
                                                                     style="display:none;position:absolute;right:0;top:100%;
                                                                            background:#fff;border:1px solid #e2e8f0;
                                                                            border-radius:10px;box-shadow:0 4px 16px rgba(0,0,0,.1);
                                                                            z-index:99;min-width:150px;overflow:hidden;">

                                                                    <!-- Trả lời — ai cũng thấy -->
                                                                    <button onclick="openReply('@cmt.Id', '@(cmt.User?.DisplayName ?? "Ẩn danh")')"
                                                                            class="cmt-menu-item">
                                                                        <i class="fa fa-reply"></i> Trả lời
                                                                    </button>

                                                                    @if (isOwner)
                                                                    {
                                                                        <!-- Sửa -->
                                                                        <button onclick="openEdit('@cmt.Id', `@Html.Raw(cmt.Content.Replace("`","\\`"))`)"
                                                                                class="cmt-menu-item">
                                                                            <i class="fa fa-pencil"></i> Chỉnh sửa
                                                                        </button>
                                                                        <!-- Xóa -->
                                                                        <button onclick="xoaBinhLuan('@cmt.Id')"
                                                                                class="cmt-menu-item" style="color:#e74c3c;">
                                                                            <i class="fa fa-trash"></i> Xóa
                                                                        </button>
                                                                        <button onclick="openBaoCao('comment','@cmt.Id','Bình luận của @(cmt.User?.DisplayName ?? "Ẩn danh")')"
                                                                                class="cmt-menu-item" style="color:#e74c3c;">
                                                                            <i class="fa fa-flag"></i> Báo cáo
                                                                        </button>
                                                                    }
                                                                    else
                                                                    {
                                                                        <button onclick="openBaoCao('comment','@cmt.Id','Bình luận của @(cmt.User?.DisplayName ?? "Ẩn danh")')"
                                                                                class="cmt-menu-item" style="color:#e74c3c;">
                                                                            <i class="fa fa-flag"></i> Báo cáo
                                                                        </button>
                                                                    }
                                                                    </div>
                                                            </div>
                                                        }
                                                    </div>

                                                    <!-- Nội dung bình luận (có thể edit) -->
                                                    <p id="content-@cmt.Id"
                                                       style="margin:6px 0 10px;font-size:14px;color:#334155;
                                                              line-height:1.6;word-break:break-word;">
                                                        @cmt.Content
                                                    </p>

                                                    <!-- Form sửa (ẩn mặc định) -->
                                                    <div id="edit-@cmt.Id" style="display:none;margin-bottom:10px;">
                                                        <textarea id="edit-text-@cmt.Id" rows="2"
                                                                  style="width:100%;padding:8px 12px;border:1px solid #e2e8f0;
                                                                         border-radius:8px;font-size:14px;resize:vertical;
                                                                         font-family:inherit;box-sizing:border-box;"></textarea>
                                                        <div style="display:flex;gap:8px;margin-top:6px;justify-content:flex-end;">
                                                            <button onclick="cancelEdit('@cmt.Id')"
                                                                    style="padding:6px 14px;border:1px solid #ddd;border-radius:8px;
                                                                           background:none;cursor:pointer;font-size:13px;color:#666;">
                                                                Hủy
                                                            </button>
                                                            <button onclick="luuSua('@cmt.Id')"
                                                                    style="padding:6px 14px;border:none;border-radius:8px;
                                                                           background:#525fe1;color:#fff;cursor:pointer;font-size:13px;">
                                                                Lưu
                                                            </button>
                                                        </div>
                                                    </div>

                                                    <!-- Form reply (ẩn mặc định) -->
                                                    <div id="reply-@cmt.Id" style="display:none;margin:8px 0 10px;">
                                                        <div style="font-size:12px;color:#94a3b8;margin-bottom:4px;">
                                                            Đang trả lời <strong id="reply-name-@cmt.Id"></strong>
                                                        </div>
                                                        <textarea id="reply-text-@cmt.Id" rows="2"
                                                                  placeholder="Viết trả lời..."
                                                                  style="width:100%;padding:8px 12px;border:1px solid #e2e8f0;
                                                                         border-radius:8px;font-size:14px;resize:vertical;
                                                                         font-family:inherit;box-sizing:border-box;"></textarea>
                                                        <div style="display:flex;gap:8px;margin-top:6px;justify-content:flex-end;">
                                                            <button onclick="cancelReply('@cmt.Id')"
                                                                    style="padding:6px 14px;border:1px solid #ddd;border-radius:8px;
                                                                           background:none;cursor:pointer;font-size:13px;color:#666;">
                                                                Hủy
                                                            </button>
                                                            <button onclick="guiReply('@cmt.Id')"
                                                                    style="padding:6px 14px;border:none;border-radius:8px;
                                                                           background:#525fe1;color:#fff;cursor:pointer;font-size:13px;">
                                                                Gửi
                                                            </button>
                                                        </div>
                                                    </div>

                                                    <!-- Like -->
                                                    @if (User.Identity.IsAuthenticated)
                                                    {
                                                        <form method="post" asp-action="LikeComment" asp-controller="Story"
                                                              style="display:inline;">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="commentId" value="@cmt.Id" />
                                                            <input type="hidden" name="storyId" value="@Model.Id" />
                                                            <button type="submit"
                                                                    style="border:1px solid #fecdd3;background:#fff5f5;
                                                                           color:#e74c3c;font-size:12px;padding:4px 12px;
                                                                           border-radius:20px;cursor:pointer;
                                                                           display:inline-flex;align-items:center;gap:4px;">
                                                                <i class="fa fa-heart"></i>
                                                                <span>@cmt.LikeCount</span>
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <span style="border:1px solid #fecdd3;background:#fff5f5;
                                                                     color:#e74c3c;font-size:12px;padding:4px 12px;
                                                                     border-radius:20px;display:inline-flex;align-items:center;gap:4px;">
                                                            <i class="fa fa-heart"></i> @cmt.LikeCount
                                                        </span>
                                                    }
                                                    <div id="replies-@cmt.Id" style="margin-top:10px;">
                                                        @foreach (var reply in Model.StoryComments
                                                            .Where(r => r.ParentId == cmt.Id && r.Status == 0)
                                                            .OrderBy(r => r.CreatedAt))
                                                        {
                                                            <div style="display:flex;gap:10px;padding:10px 0;
                                                                        padding-left:16px;border-left:3px solid #e2e8f0;"
                                                                 id="cmt-@reply.Id">
                                                                <!-- Avatar reply -->
                                                                @if (!string.IsNullOrEmpty(reply.User?.AvatarUrl))
                                                                {
                                                                    <img src="@reply.User.AvatarUrl"
                                                                         style="width:32px;height:32px;border-radius:50%;
                                                                                object-fit:cover;flex-shrink:0;" />
                                                                }
                                                                else
                                                                {
                                                                    <div style="width:32px;height:32px;border-radius:50%;
                                                                                background:linear-gradient(135deg,#6c63ff,#a78bfa);
                                                                                display:flex;align-items:center;justify-content:center;
                                                                                color:#fff;font-weight:700;font-size:13px;flex-shrink:0;">
                                                                        @((reply.User?.DisplayName ?? "?").Substring(0,1).ToUpper())
                                                                    </div>
                                                                }
                                                                <!-- Nội dung reply -->
                                                                <div style="flex:1;">
                                                                    <span style="font-weight:700;font-size:13px;color:#1e293b;">
                                                                        @(reply.User?.DisplayName ?? "Ẩn danh")
                                                                    </span>
                                                                    <span style="font-size:11px;color:#94a3b8;margin-left:6px;">
                                                                        @reply.CreatedAt.ToString("HH:mm · dd/MM/yyyy")
                                                                    </span>
                                                                    <p id="content-@reply.Id"
                                                                       style="margin:4px 0 0;font-size:14px;color:#334155;
                                                                              line-height:1.6;word-break:break-word;">
                                                                        @reply.Content
                                                                    </p>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        
                                    }
                                    else
                                    {
                                        <div style="text-align:center;padding:40px 0;color:#94a3b8;">
                                            <i class="fa fa-comments" style="font-size:40px;display:block;
                                                                              margin-bottom:12px;color:#cbd5e1;"></i>
                                            <p style="font-size:14px;">Chưa có bình luận. Hãy là người đầu tiên!</p>
                                        </div>
                                    }

                                    <!-- Form thêm bình luận -->
                                    <div style="margin-top:28px;">
                                        @if (User.Identity.IsAuthenticated)
                                        {
                                            <h6 style="font-weight:700;color:#1e293b;margin-bottom:14px;">
                                                ✍️ Thêm bình luận
                                            </h6>
                                            <form method="post" asp-action="AddComment" asp-controller="Story">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="storyId" value="@Model.Id" />

                                                <textarea name="content" rows="3"
                                                          placeholder="Viết bình luận của bạn..."
                                                          maxlength="2000" required
                                                          style="width:100%;padding:12px 16px;border:1px solid #e2e8f0;
                                                                 border-radius:12px;font-size:14px;resize:vertical;
                                                                 font-family:inherit;outline:none;
                                                                 transition:border-color .2s;
                                                                 background:#f8fafc;color:#1e293b;"
                                                          onfocus="this.style.borderColor='#6c63ff';this.style.background='#fff'"
                                                          onblur="this.style.borderColor='#e2e8f0';this.style.background='#f8fafc'">
                                                </textarea>

                                                <div style="text-align:right;margin-top:10px;">
                                                    <button type="submit"
                                                            style=" background: #525fe1;;
                                                                   color:#fff;border:none;padding:10px 24px;
                                                                   border-radius:10px;font-size:14px;font-weight:600;
                                                                   cursor:pointer;display:inline-flex;align-items:center;
                                                                   gap:8px;transition:opacity .2s;"
                                                            onmouseover="this.style.opacity='.85'"
                                                            onmouseout="this.style.opacity='1'">
                                                        <i class="fa fa-paper-plane"></i> Gửi bình luận
                                                    </button>
                                                </div>
                                            </form>
                                        }
                                        else
                                        {
                                            <div style="text-align:center;padding:20px;background:#f8fafc;
                                                        border-radius:12px;border:1px dashed #e2e8f0;">
                                                <i class="fa fa-lock" style="color:#94a3b8;font-size:20px;
                                                                              display:block;margin-bottom:8px;"></i>
                                                <p style="margin:0;font-size:14px;color:#64748b;">
                                                    Bạn cần 
                                                    <a asp-action="Login" asp-controller="Account"
                                                       style="color:#6c63ff;font-weight:600;">đăng nhập</a>
                                                    để bình luận.
                                                </p>
                                            </div>
                                        }
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>
                    <!-- END TABS -->

                </div>
                <!-- END CỘT TRÁI -->

                <!-- ========== CỘT PHẢI (SIDEBAR) ========== -->
                <div class="col-lg-4 col-sm-4 col-xs-12">

                    <!-- Thông tin nhanh -->
                    <div class="course_features">
                        <h3>Thông tin</h3>
                        <ul>
                            <li><i class="fa fa-list"></i> Số chương <b>@chapterCount</b></li>
                            <li><i class="fa fa-eye"></i> Lượt xem <b>@Model.TotalViews.ToString("N0")</b></li>
                            <li><i class="fa fa-heart"></i> Theo dõi <b>@Model.TotalFollows</b></li>
                            <li><i class="fa fa-star"></i> Đánh giá <b>@avgRating / 5</b></li>
                            <li><i class="fa fa-tag"></i> Thể loại <b>@(Model.Category?.Name ?? "—")</b></li>
                            <li><i class="fa fa-calendar"></i> Ngày đăng <b>@Model.CreatedAt.ToString("dd/MM/yy")</b></li>
                        </ul>
                    </div>

                    <!-- Nút đọc -->
                    <div class="event_info_price">
                        <h4><i class="fa fa-book-open" ></i> Truyện chữ</h4>
                    </div>
                    <div class="event_info_register">
                        @if (Model.Chapters != null && Model.Chapters.Any())
                        {
                            var firstChap    = Model.Chapters.OrderBy(c => c.ChapterNumber).First();
                            var lastChap     = Model.Chapters.OrderBy(c => c.ChapterNumber).Last();
                            var continueId   = ViewBag.ContinueChapterId as Guid?;
                            var continueNum  = ViewBag.ContinueChapterNumber;

                            @* ── Nút thông minh: Đọc tiếp nếu đã đọc, Đọc từ đầu nếu chưa ── *@
                            @if (continueId.HasValue)
                            {
                                <a class="sidebar-read-btn"
                                   href="@Url.Action("Index","Chapter",new{id=continueId.Value})">
                                    <i class="fa fa-forward"></i> Đọc tiếp - Chương @continueNum
                                </a>
                            }
                            else
                            {
                                <a class="sidebar-read-btn"
                                   href="@Url.Action("Index","Chapter",new{id=firstChap.Id})">
                                    <i class="fa fa-play"></i> Đọc từ đầu
                                </a>
                            }

                            @* ── Nút đọc mới nhất luôn hiện ── *@
                            <a class="btn-vip"
                               href="@Url.Action("Index","Chapter",new{id=lastChap.Id})">
                                <i class="fa fa-fast-forward"></i> Đọc mới nhất
                            </a>
                        }
                        else
                        {
                            <span class="btn_one sidebar-read-btn" style="opacity:0.5;cursor:default;">
                                Chưa có chương
                            </span>
                        }
                    </div>

                    <!-- Truyện liên quan -->
                    @if (ViewBag.RelatedStories != null)
                    {
                        <div class="related_course">
                            <h3>Truyện liên quan</h3>
                            @foreach (var rel in (IEnumerable<web_doc_truyen_Co_ban.Models.StoryModel>)ViewBag.RelatedStories)
                            {
                                <div class="single_rc">
                                    <div class="rc_img">
                                        <img src="@(string.IsNullOrEmpty(rel.CoverImageUrl) ? "/assets/img/rc-1.png" : rel.CoverImageUrl)"
                                             alt="@rel.Title" />
                                    </div>
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <i class="fa fa-star" style="color:@(s <= 4 ? "#ffa500" : "#555");"></i>
                                    }
                                    <h4>
                                        <a href="@Url.Action("Detail","Story",new{id=rel.Id})">@rel.Title</a>
                                    </h4>
                                    <span>@(rel.Category?.Name ?? "")</span>
                                </div>
                            }
                        </div>
                    }

                    <!-- Thể loại -->
                    @if (ViewBag.Categories != null)
                    {
                        <div class="sidebar-post">
                            <div class="sidebar_title"><h4>THỂ LOẠI</h4></div>
                            <div class="single_category">
                                <ul>
                                    @foreach (var cat in (IEnumerable<web_doc_truyen_Co_ban.Models.CategoryModel>)ViewBag.Categories)
                                    {
                                        <li>
                                            <a href="@Url.Action("ListByCategory","Category",new{slug=cat.Slug})">
                                                @cat.Name <sup>@cat.StoryCount</sup>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }

                </div>
                <!-- END CỘT PHẢI -->

            </div>
        </div>
    </section>

