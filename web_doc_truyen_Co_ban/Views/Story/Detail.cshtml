@model web_doc_truyen_Co_ban.Models.StoryModel
@{
    ViewData["Title"] = Model.Title;
    var avgRating = (Model.Ratings != null && Model.Ratings.Any())
        ? Math.Round(Model.Ratings.Average(r => r.Score), 1)
        : 0.0;
    var ratingCount  = Model.Ratings?.Count ?? 0;
    var chapterCount = Model.Chapters?.Count ?? 0;
    var commentCount = Model.StoryComments?.Count ?? 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@Model.Title - Đọc Truyện</title>

  @*   <link rel="stylesheet" href="~/assets/bootstrap/css/bootstrap.min.css"> *@
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="~/assets/fonts/font-awesome.min.css">
    <link rel="stylesheet" href="~/assets/fonts/themify-icons.css"> 
    <link rel="stylesheet" href="~/assets/owlcarousel/css/owl.carousel.css">
    <link rel="stylesheet" href="~/assets/owlcarousel/css/owl.theme.css">
    <link rel="stylesheet" href="~/assets/css/jquery-simple-mobilemenu.css">
    <link rel="stylesheet" href="~/assets/css/magnific-popup.css">
    <link rel="stylesheet" href="~/assets/css/animate.css">
    <link rel="stylesheet" href="~/assets/css/style.css">

    <style>
    :root{
            --ink: #1a1714;
            --ink-mid: #5a5550;
            --ink-lt: #9a9490;
            --paper: #faf8f5;
            --line: #e8e4de;
            --radius: 18px;
    }
    body {
        background: var(--paper) !important;
    }
        }
        /* ===== FIX layout header truyện ===== */
        .story-header-wrap {
            display: flex;
            gap: 24px;
            align-items: flex-start;
        }
        .story-cover-box {
            flex-shrink: 0;
            width: 150px;
        }
        .story-cover-box img,
        .story-cover-placeholder {
            width: 150px;
            height: 210px;
            object-fit: cover;
            border-radius: 8px;
            box-shadow: 0 6px 20px rgba(0,0,0,0.5);
            display: block;
        }
        .story-cover-placeholder {
            background: #2a2a2a;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            color: #555;
        }
        .story-info-box {
            flex: 1;
            min-width: 0;
        }
        .story-info-box h4 {
            font-size: 1.35rem;
            font-weight: 700;
            margin-bottom: 10px;
            line-height: 1.4;
        }
        .story-badge {
            display: inline-block;
            padding: 3px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            background: rgba(46,204,113,0.15);
            color: #2ecc71;
            border: 1px solid rgba(46,204,113,0.3);
            margin-bottom: 10px;
        }
        .story-stats {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            font-size: 13px;
            color: #aaa;
            margin-bottom: 10px;
        }
        .story-stats span i { margin-right: 4px; }
        .story-stars {
            display: flex;
            align-items: center;
            gap: 4px;
            margin-bottom: 14px;
            font-size: 15px;
        }
        .story-stars .rating-text {
            font-size: 13px;
            color: #999;
            margin-left: 4px;
        }
        /* ===== VIP banner ===== */
     .vip-banner {
        background: #525fe1;
        border-radius: 12px;
        padding: 20px 24px;
        margin: 16px 0;
        color: #fff;
        box-shadow: 0 4px 18px rgba(91,63,212,0.25);
    }

    .vip-banner__header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 14px;
        border-bottom: 1px solid rgba(255,255,255,0.2);
        padding-bottom: 10px;
    }

    .vip-banner__header i {
        color: #ffd700;
        font-size: 18px;
    }

    .vip-banner__header h5 {
        margin: 0;
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 1px;
        color: #fff;
    }

    .vip-banner__body {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 16px;
    }

    .vip-item {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        font-size: 13.5px;
        line-height: 1.5;
    }

    .vip-item i {
        margin-top: 2px;
        flex-shrink: 0;
    }

    .vip-item .fa-check-circle { color: #69f0ae; }
    .vip-item .fa-star          { color: #ffd700; }
    .vip-item .fa-tag           { color: #ff8a65; }

    .vip-banner__btn {
        display: block;
        text-align: center;
        background: linear-gradient(90deg, #ffd700, #ffaa00);
        color: #2d1f6e;
        font-weight: 700;
        font-size: 14px;
        letter-spacing: 1px;
        padding: 10px 0;
        border-radius: 8px;
        text-decoration: none;
        transition: opacity 0.2s;
    }

    .vip-banner__btn:hover {
        opacity: 0.88;
        color: #2d1f6e;
        text-decoration: none;
    }
        /* ===== Tabs fix ===== */
        .course-details-content .nav-tabs { border-bottom: 1px solid #2a2a2a; }
        .course-details-content .nav-tabs .nav-link {
            font-size: 14px;
            padding: 12px 18px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        /* ===== Chapter table ===== */
        .chap-table { width: 100%; border-collapse: collapse; font-size: 14px; }
        .chap-table thead tr { border-bottom: 1px solid #333; }
        .chap-table thead th { padding: 10px 8px; color: #999; font-weight: 500; }
        .chap-table tbody tr { border-bottom: 1px solid #1e1e1e; transition: background .15s; }
        .chap-table tbody tr:hover { background: #f1f5f9; }
        .chap-table tbody td { padding: 10px 8px; }
        .chap-num { color: #e85d04; font-weight: 600; white-space: nowrap; }
        .chap-date { text-align: right; color: #666; font-size: 12px; white-space: nowrap; }
        .chap-table tbody tr {
             transition: all 0.2s ease;
        }

        .chap-table tbody tr:hover {
            background: #cbd5e1;
            box-shadow: inset 4px 0 0 #2563eb;
        }

        .chap-title a {
            color: #1e293b;
            text-decoration: none;
            transition: color 0.2s;
        }

        .chap-table tbody tr:hover .chap-title a {
            color: #2563eb;
        }
        /* ===== Sidebar ===== */
        .sidebar-read-btn {
            display: block;
            width: 100%;
            text-align: center;
            margin-bottom: 8px;
        }
        /* ===== Info table ===== */
        .info-tbl { width: 100%; border-collapse: collapse; font-size: 14px; margin-top: 14px; }
        .info-tbl td { padding: 9px 0; border-bottom: 1px solid #0B104A; }
        .info-tbl tr:last-child td { border-bottom: none; }
        .info-lbl {width: 130px; }
        /* ===== Tag chips ===== */
        .tag-chip {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 12px;
            background: #2a2a2a;
            border: 1px solid #444;
            margin: 2px;
            color: #ccc;
            text-decoration: none;
        }
        .tag-chip:hover { border-color: #e85d04; color: #e85d04; }
        .sidebar-read-btn,
        .btn-vip {
            display: block;
            width: 100%;
            padding: 12px 16px;
            border-radius: 12px;
            text-align: center;
            font-weight: 600;
            border: 2px solid transparent;
            transition: all 0.3s ease;
        }

        /* Nút đọc từ đầu */
        .sidebar-read-btn {
            background: linear-gradient(135deg, #5B5BD6, #7A7AFF);
            color: #fff;
            border: 2px solid #5B5BD6;
        }

        .sidebar-read-btn:hover {
            background: #fff;
            color: #5B5BD6;
            border: 2px solid #5B5BD6;
        }

        /* Nút đọc mới nhất */
        .btn-vip {
            background:linear-gradient(135deg, #5B5BD6, #7A7AFF);
            color: #fff;
            border: 2px solid #444;
            margin-top: 8px;
        }

        .btn-vip:hover {
            background: #fff;
            color: #444;
            border: 2px solid #444;
        }

        /* Icon spacing */
        .sidebar-read-btn i,
        .btn-vip i {
            margin-right: 6px;
        }
        .event_info_price h4
        {

            padding:12px 16px;
            border-radius: 12px;
            text-align: center;
            font-weight: 600;
            border: 2px solid transparent;

        }
        .course_features h3{
            margin-bottom:20px
            padding:12px 16px;
            border-radius: 12px;
            text-align: center;
            font-weight: 600;
            border: 2px solid transparent;
        }
        .story-header-wrap {
            display: flex;
            align-items: flex-start;
            gap: 1.5rem;
        }

        .story-cover-box {
            flex-shrink: 0;
            width: 160px;
        }

        .story-cover-box img {
            width: 100%;
            border-radius: 10px;
            display: block;
            box-shadow: 0 4px 16px rgba(0,0,0,.18);
        }

        .story-cover-placeholder {
            width: 160px;
            height: 220px;
            background: #eee;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            color: #aaa;
        }

        .story-info-box {
            flex: 1;
            min-width: 0;
        }
    .details-buttons-area {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        justify-content: flex-start; /* hoặc bỏ dòng này vì đây là default */
        margin: 0 -5px -5px;
    }
    .badge-vip    { background: #ffc107; color: #000; padding: 2px 8px; border-radius: 4px; font-size: 12px; }
    .badge-lock   { background: #ff9800; color: #fff; padding: 2px 8px; border-radius: 4px; font-size: 12px; }
    .badge-published { background: #28a745; color: #fff; padding: 2px 8px; border-radius: 4px; font-size: 12px; }
    .badge-draft  { background: #6c757d; color: #fff; padding: 2px 8px; border-radius: 4px; font-size: 12px; }
    </style>
</head>

<body data-spy="scroll" data-offset="80">

    @* @await Html.PartialAsync("_Navbar")

    @* <!-- SECTION TOP -->
    <section class="section-top">
        <div class="container">
            <div class="col-lg-10 offset-lg-1 text-center">
                <div class="section-top-title wow fadeInRight"
                     data-wow-duration="1s" data-wow-delay="0.3s" data-wow-offset="0">
                    <h1>Chi tiết truyện</h1>
                    <ul>
                        <li><a href="/">Trang chủ</a></li>
                        <li> / @Model.Title</li>
                    </ul>
                </div>
            </div>
        </div>
    </section> *@

    <!-- MAIN -->
    <section class="our_event section-padding">
        <div class="container-fluid px-lg-5 px-3">
            <div class="row">

                <!-- ========== CỘT TRÁI ========== -->
                <div class="col-lg-8 col-sm-8 col-xs-12">

                    <!-- HEADER TRUYỆN -->
                    <div class="single_event_single">
                        <div class="story-header-wrap">

                            <!-- Ảnh bìa -->
                            <div class="story-cover-box">
                                @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                                {
                                    <img src="@GetImage(Model.CoverImageUrl)" alt="@Model.Title" />
                                }
                                else
                                {
                                    <div class="story-cover-placeholder">
                                        <i class="fa fa-book"></i>
                                    </div>
                                }
                            </div>


                            <!-- Thông tin -->
                            <div class="story-info-box single_event_text_single">
                                <h4>@Model.Title</h4>

                                <span class="story-badge">@GetStatusText(Model.Status)</span>

                                <div class="story-stats">
                                    <span><i class="fa fa-eye"></i>@(Model.TotalViews.ToString("N0"))</span>
                                    <span><i class="fa fa-heart"></i>@Model.TotalFollows</span>
                                    <span><i class="fa fa-book"></i>@chapterCount chương</span>
                                    @{
                                        var avgRating   = (decimal)Model.RatingAvg;
                                        var ratingCount = Model.RatingCount;
                                        var userScore   = (byte)(ViewBag.UserScore ?? 0);
                                    }
                                    <span>
                                        <i class="fa fa-star" style="color:#ffa500;"></i>
                                        <span id="avg-display">@avgRating.ToString("0.00")</span>
                                        (<span id="count-display">@ratingCount</span> đánh giá)
                                    </span>
                                </div>

                                <div class="story-stars" id="stars-display">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Floor((double)avgRating))
                                            { <i class="fa fa-star" style="color:#ffa500;"></i> }
                                        else if (avgRating > i - 1 && avgRating < i)
                                            { <i class="fa fa-star-half-o" style="color:#ffa500;"></i> }
                                        else
                                            { <i class="fa fa-star-o" style="color:#ccc;"></i> }
                                    }
                                    <span class="rating-text" id="rating-text">
                                        @avgRating.ToString("0.00") / 5 (@ratingCount đánh giá)
                                    </span>
                                </div>

                                <div id="user-rating-box" data-story="@Model.Id" data-user-score="@userScore" class="mt-2">
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <div class="d-flex align-items-center gap-1">
                                            <span class="text-muted me-1" style="font-size:.85rem;">Đánh giá của bạn:</span>
                                            @for (byte i = 1; i <= 5; i++)
                                            {
                                                <i class="fa fa-star star-pick"
                                                   data-score="@i"
                                                   style="font-size:1.5rem; cursor:pointer; color:@(i <= userScore ? "#ffa500" : "#ccc");"></i>
                                            }
                                            @if (userScore > 0)
                                            {
                                                <span class="text-muted ms-1" style="font-size:.82rem;">(@userScore★)</span>
                                            }
                                        </div>
                                        <div id="rate-msg" class="small mt-1" style="min-height:1.2em;"></div>
                                    }
                                    else
                                    {
                                        <p class="text-muted small mt-1 mb-0">
                                            <a href="/Account/Login">Đăng nhập</a> để đánh giá.
                                        </p>
                                    }
                                </div>

                                
                            </div>

                        </div>
                    </div>
                    <!-- Nút hành động -->
                                <div class="details-buttons-area" style="margin-top:0;">
                                    @if (Model.Chapters != null && Model.Chapters.Any())
                                    {
                                        var firstChap    = Model.Chapters.OrderBy(c => c.ChapterNumber).First();
                                        <a href="@Url.Action("Index","Chapter",new{id=firstChap.Id})"
                                           class="custom-button">
                                            <i class="fa fa-book-open"></i> Đọc truyện

                                        </a>
                                    }
                                    @{
                                        var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                        bool isFollowed = Model.Follows != null &&
                                                          Model.Follows.Any(x => x.UserId.ToString() == userId);
                                    }

                                    @if (User.Identity.IsAuthenticated)
                                    {
                                        @if (isFollowed)
                                        {
                                            <form asp-action="RemoveFollow" asp-controller="Follow" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="storyId" value="@Model.Id" />
                                                <button type="submit" class="custom-button" style="background:#e11d48;color:white;">
                                                    <i class="fa fa-heart-broken"></i> Bỏ theo dõi
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="AddFollow" asp-controller="Follow" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="storyId" value="@Model.Id" />
                                                <button type="submit" class="custom-button">
                                                    <i class="fa fa-heart"></i> Theo dõi
                                                </button>
                                            </form>
                                        }
                                    }
                                    else
                                    {
                                        <a asp-controller="Account" asp-action="Login" class="custom-button">
                                            <i class="fa fa-lock"></i> Đăng nhập để theo dõi
                                        </a>
                                    }
                                    <a href="#" class="custom-button">
                                        <i class="fa fa-thumbs-up"></i> Đề cử
                                    </a>
                                    @if (User.Identity.IsAuthenticated)
                                    {
                                        <div style="position:relative; display:inline-block;">
                                            <button class="custom-button" id="btn-bookmark"
                                                    onclick="toggleBookmark()"
                                                    style="display:flex; align-items:center; gap:8px;
                                                           
                                                             color:#fff;
                                                           font-size:14px; font-weight:600; cursor:pointer;">
                                                <i class="fa fa-bookmark"></i> Bookmark
                                                <span id="bm-count"
                                                       border-radius:99px;
                                                             font-size:11px; padding:1px 7px;">0</span>
                                                <i class="fa fa-chevron-down" id="bm-chevron"
                                                   style="font-size:11px; transition:transform 0.2s;"></i>
                                            </button>

                                            <div id="bookmark-dropdown"
                                                 style="display:none; position:absolute; top:calc(100% + 6px); left:0;
                                                        min-width:240px; background:#fff; border:1px solid #e2e8f0;
                                                        border-radius:12px; z-index:999; box-shadow:0 8px 24px rgba(0,0,0,0.12);
                                                        overflow:hidden;">

                                                <div style="padding:8px 12px; font-size:11px; color:#94a3b8;
                                                            border-bottom:1px solid #f1f5f9; font-weight:600;
                                                            letter-spacing:0.04em;">
                                                    CHƯƠNG ĐÃ LƯU
                                                </div>

                                                <div id="bm-list" style="max-height:260px; overflow-y:auto;">
                                                    <div style="padding:20px; text-align:center; color:#aaa; font-size:13px;">
                                                        Đang tải...
                                                    </div>
                                                </div>

                                                <div style="padding:8px 10px; border-top:1px solid #f1f5f9;">
                                                    <button onclick="removeAllBookmark()"
                                                            style="width:100%; padding:7px; border-radius:8px;
                                                                   background:none; border:1px dashed #e2e8f0;
                                                                   color:#94a3b8; font-size:12px; cursor:pointer;
                                                                   display:flex; align-items:center; justify-content:center; gap:5px;">
                                                        <i class="fa fa-trash"></i> Xóa tất cả
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>

                    <!-- END HEADER TRUYỆN -->

                    <!-- VIP BANNER -->
                    <div class="vip-banner">
                        <div class="vip-banner__header">
                            <i class="fa fa-crown"></i>
                            <h5>MUA GÓI HỘI VIÊN</h5>
                        </div>
                        <div class="vip-banner__body">
                            <div class="vip-item">
                                <i class="fa fa-check-circle"></i>
                                <span>Đăng ký <strong>miễn phí</strong>: đọc full trừ 50 chương mới nhất + 10 chương/ngày mở bằng điểm</span>
                            </div>
                            <div class="vip-item">
                                <i class="fa fa-star"></i>
                                <span>Nâng cấp <strong>VIP</strong>: đọc full tất cả truyện, nghe audio không giới hạn</span>
                            </div>
                            <div class="vip-item">
                                <i class="fa fa-tag"></i>
                                <span>Chỉ từ <strong>49.000đ</strong>, áp dụng ưu đãi bất kỳ lúc nào</span>
                            </div>
                        </div>
                        <a href="#" class="vip-banner__btn">
                            <i class="fa fa-credit-card"></i> MUA NGAY
                        </a>
                    </div>

                    <!-- TABS -->
                    <div class="course-details-content section-bg">
                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item">
                                <a href="#thongtin" class="nav-link active" data-bs-toggle="tab">
                                    <i class="fa fa-info-circle"></i> Thông tin truyện
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="#danhsachchap" class="nav-link" data-bs-toggle="tab">
                                    <i class="fa fa-list"></i> Chap (@chapterCount)
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="#binhluan" class="nav-link" data-bs-toggle="tab">
                                    <i class="fa fa-comments"></i> Bình luận (@commentCount)
                                </a>
                            </li>
                        </ul>

                        <div class="tab-content" id="storyTabContent">

                            <!-- ── TAB 1: THÔNG TIN ── -->
                            <div class="tab-pane show fade active" id="thongtin">
                                <div class="overview">
                                    <h5 style="margin-bottom:12px;font-size:1rem;">Giới thiệu</h5>
                                    <p style="line-height:1.8;">
                                        @Html.Raw(Model.Description ?? "Chưa có mô tả.")
                                    </p>

                                    <table class="info-tbl">
                                        <tr>
                                            <td class="info-lbl">Thể loại</td>
                                            <td>
                                                @if (Model.Category != null)
                                                {
                                                    <a href="@Url.Action("ListByCategory","Category",new{slug=Model.Category.Slug})"
                                                       style="color:#e85d04;">@Model.Category.Name</a>
                                                }
                                                else { <span style="color:#666;">—</span> }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="info-lbl">Trạng thái</td>
                                            <td>@GetStatusText(Model.Status)</td>
                                        </tr>
                                        <tr>
                                            <td class="info-lbl">Số chương</td>
                                            <td>@chapterCount chương</td>
                                        </tr>
                                        <tr>
                                            <td class="info-lbl">Lượt xem</td>
                                            <td>@Model.TotalViews.ToString("N0")</td>
                                        </tr>
                                        <tr>
                                            <td class="info-lbl">Ngày đăng</td>
                                            <td>@Model.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    </table>

                                    @if (Model.Tags != null && Model.Tags.Any())
                                    {
                                        <div style="margin-top:14px;">
                                            <span style="font-size:13px;margin-right:4px;">Tags:</span>
                                            @foreach (var tag in Model.Tags)
                                            {
                                                <a href="/Tag/@tag.Slug" class="tag-chip">@tag.Name</a>
                                            }
                                        </div>
                                    }
                                </div>
