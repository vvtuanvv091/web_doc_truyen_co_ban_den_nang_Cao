          <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

</head> *@
<div class="container-fluid px-lg-5 px-3">

    <!-- Header -->
    <div class="bc-header">
        <div>
            <div class="bc-title">
                <i class="fa fa-flag"></i> Lịch Sử Báo Cáo
            </div>
            <div class="bc-count">
                Tổng @Model.Count báo cáo &nbsp;·&nbsp;
                Đang chờ: <strong style="color:#f39c12;">@Model.Count(r => r.Status == "pending")</strong>
            </div>
        </div>
    </div>

    <!-- Filter -->
    <div class="bc-filters">
        <button class="bc-filter-btn active" onclick="filter('all', this)">Tất cả</button>
        <button class="bc-filter-btn" onclick="filter('pending', this)">Đang chờ</button>
        <button class="bc-filter-btn" onclick="filter('approved', this)">Đã duyệt</button>
        <button class="bc-filter-btn" onclick="filter('rejected', this)">Bị từ chối</button>
    </div>

    <!-- Table -->
    <div class="bc-table-wrap">
        <div class="bc-thead">
            <div>Loại</div>
            <div>Lý do</div>
            <div>Ngày gửi</div>
            <div>Xử lý lúc</div>
            <div>Trạng thái</div>
        </div>

        @if (!Model.Any())
        {
            <div class="bc-empty">
                <i class="fa fa-inbox"></i>
                <p>Bạn chưa gửi báo cáo nào.</p>
            </div>
        }

        @foreach (var r in Model)
        {
            var typeLabel = r.TargetType switch {
                "comment" => ("fa-comment",  "comment",  "Bình luận"),
                "story"   => ("fa-book",     "story",    "Truyện"),
                "chapter" => ("fa-list",     "chapter",  "Chương"),
                "user"    => ("fa-user",     "user",     "Người dùng"),
                _         => ("fa-flag",     "story",    r.TargetType)
            };

            var (statusClass, statusText) = r.Status switch {
                "approved" => ("s-approved", "Đã duyệt"),
                "rejected" => ("s-rejected", "Từ chối"),
                _          => ("s-pending",  "Đang chờ")
            };

            <div class="bc-row" data-status="@r.Status">
                <!-- Loại -->
                <div>
                    <span class="type-badge type-@typeLabel.Item2">
                        <i class="fa @typeLabel.Item1" style="font-size:11px;"></i>
                        @typeLabel.Item3
                    </span>
                </div>

                <!-- Lý do -->
                <div class="bc-reason" title="@r.Reason">@r.Reason</div>

                <!-- Ngày gửi -->
                <div class="bc-time">
                    <i class="fa fa-clock-o" style="margin-right:4px;"></i>
                    @r.CreatedAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy")
                </div>

                <!-- Xử lý lúc -->
                <div class="bc-time">
                    @if (r.ProcessedAt.HasValue)
                    {
                        <span>
                            <i class="fa fa-check-circle" style="margin-right:4px;color:#27ae60;"></i>
                            @r.ProcessedAt.Value.ToLocalTime().ToString("HH:mm dd/MM/yyyy")
                        </span>
                    }
                    else
                    {
                        <span style="color:#ddd;">—</span>
                    }
                </div>

                <!-- Trạng thái -->
                <div>
                    <span class="status-badge @statusClass">@statusText</span>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    function filter(status, btn) {
        document.querySelectorAll('.bc-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        document.querySelectorAll('.bc-row').forEach(row => {
            row.style.display = (status === 'all' || row.dataset.status === status)
                ? 'grid' : 'none';
        });
    }
</script>
}
