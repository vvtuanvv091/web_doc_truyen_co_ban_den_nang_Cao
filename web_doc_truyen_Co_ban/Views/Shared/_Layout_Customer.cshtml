    <style>


        /* ===== MOBILE NAV ===== */
        @@media (max-width: 991px) {
            .col-10  { width: auto !important; }
            .col-60  { display: none !important; }   /* ẩn menu ngang */
            .col-30  { display: none !important; }   /* ẩn user/search */
            
            .mobile-toggle {
                display: flex !important;
                margin-left: auto;
                align-items: center;
                gap: 10px;
            }

            /* Drawer menu */
            .mobile-menu {
                display: none;
                position: fixed;
                top: 64px; left: 0; right: 0; bottom: 0;
                background: #fff;
                z-index: 9999;
                overflow-y: auto;
                padding: 16px 0;
                border-top: 1px solid #eee;
            }
            .mobile-menu.open { display: block; }

            .mobile-menu ul { list-style: none; margin: 0; padding: 0; }
            .mobile-menu ul li a {
                display: block; padding: 13px 20px;
                font-size: 15px; color: #0b104a;
                border-bottom: 1px solid #f5f5f5;
                text-decoration: none; font-weight: 500;
            }
            .mobile-menu ul li a:hover { background: #f8f8fc; color: #525fe1; }

            /* Sub menu mobile */
            .mobile-menu .sub-menu { padding-left: 16px; background: #f9f9ff; }
            .mobile-menu .sub-menu a { font-size: 14px; color: #555; }

            /* User + login buttons mobile */
            .mobile-user-row {
                display: flex; align-items: center; gap: 10px;
                padding: 14px 20px; border-top: 2px solid #f0f0f0; margin-top: 8px;
            }
            .mobile-user-row a {
                flex: 1; text-align: center; padding: 9px;
                border-radius: 8px; font-size: 14px; font-weight: 600;
                text-decoration: none;
            }
            .mobile-login  { background: #f0f0ff; color: #525fe1; }
            .mobile-signup { background: #525fe1; color: #fff; }
        }

        .mobile-toggle { display: none; }  /* ẩn trên desktop */
            /* Ẩn submenu cấp 3 cho đến khi hover đúng vào item cha */
            .menu-item-has-children .menu-item-has-children > ul {
                display: none;
                position: absolute;
                left: 100%;
                top: 0;
            }

            .menu-item-has-children .menu-item-has-children:hover > ul {
                display: block;
            }
            .col-10 {
                width: 10%;
            }

            .col-60 {
                width: 60%;
            }

            .col-30 {
                width: 30%;
            }

           /*  web dodooir sangtoi app full */
          
        /* ══════════════════════════════════
           DARK MODE — toàn bộ site
        ══════════════════════════════════ */

        /* Biến light (mặc định) */
        :root {
          --dm-bg       : #faf8f5;
          --dm-surface  : #ffffff;
          --dm-surface2 : #f4f4f8;
          --dm-border   : #e2e6f0;
          --dm-text     : #1a1c2e;
          --dm-muted    : #6b7080;
          --dm-dim      : #adb2c3;
          --dm-input-bg : #f8f8fc;
          --dm-badge-bg : #eef1f8;
          --dm-nav-bg   : #ffffff;
          --dm-dropdown : #ffffff;
          --dm-shadow   : rgba(0,0,0,.08);
        }

        /* Biến dark */
        body.dark-mode {
          --dm-bg       : #0f1117;
          --dm-surface  : #181c27;
          --dm-surface2 : #1e2235;
          --dm-border   : #2a2f4a;
          --dm-text     : #e8eaf6;
          --dm-muted    : #8b90aa;
          --dm-dim      : #555a7a;
          --dm-input-bg : #1e2235;
          --dm-badge-bg : #252840;
          --dm-nav-bg   : #181c27;
          --dm-dropdown : #1e2235;
          --dm-shadow   : rgba(0,0,0,.4);

          /* Các biến dùng trong Home CSS */
          --paper       : #0f1117;
          --bg-primary  : #0f1117;
          --bg-card     : #181c27;
          --bg-hover    : #252840;
          --border      : #2a2f4a;
          --border-strong:#3a3f66;
          --text-main   : #e8eaf6;
          --text-muted  : #8b90aa;
          --text-dim    : #555a7a;
          --tag-bg      : #252840;
          --ink         : #e8eaf6;
          --ink-mid     : #8b90aa;
          --ink-lt      : #555a7a;
          --line        : #2a2f4a;
          --shadow-sm   : 0 1px 4px rgba(0,0,0,.4);
          --shadow-md   : 0 4px 16px rgba(0,0,0,.5);
          --shadow-hover: 0 8px 28px rgba(232,84,26,.25);
          --accent-light: rgba(232,84,26,.15);
        }

        /* ── Base ── */
        body {
          background : var(--dm-bg)   !important;
          color      : var(--dm-text) !important;
          transition : background .3s ease, color .3s ease;
        }

        /* ── Navbar ── */
        body.dark-mode #navigation,
        body.dark-mode .site-navigation {
          background : var(--dm-nav-bg)  !important;
          border-color:var(--dm-border)  !important;
        }
        body.dark-mode #navigation a,
        body.dark-mode #main-menu a {
          color: var(--dm-text) !important;
        }
        body.dark-mode #main-menu ul {
          background: var(--dm-surface) !important;
          border-color:var(--dm-border) !important;
        }

        /* ── Input search navbar ── */
        body.dark-mode #nb-search-input {
          background  : var(--dm-input-bg) !important;
          color       : var(--dm-text)     !important;
          border-color: var(--dm-border)   !important;
        }
        body.dark-mode #nb-search-input::placeholder { color: var(--dm-muted) !important; }
        body.dark-mode #search-results {
          background  : var(--dm-dropdown) !important;
          border-color: var(--dm-border)   !important;
          color       : var(--dm-text)     !important;
        }

        /* ── Dropdown thông báo & user ── */
        body.dark-mode #dropdown-thongbao,
        body.dark-mode .nb-user-dropdown {
          background  : var(--dm-dropdown) !important;
          border-color: var(--dm-border)   !important;
        }
        body.dark-mode #dropdown-thongbao *,
        body.dark-mode .nb-user-dropdown a { color: var(--dm-text) !important; }
        body.dark-mode .nb-user-btn {
          border-color: var(--dm-border) !important;
          color       : var(--dm-text)  !important;
        }
        body.dark-mode .nb-user-btn span { color: var(--dm-text) !important; }
        body.dark-mode #btn-bell {
          border-color: var(--dm-border) !important;
          color       : var(--dm-muted) !important;
        }

        /* ── Mobile menu ── */
        body.dark-mode .mobile-menu {
          background  : var(--dm-surface) !important;
          border-color: var(--dm-border)  !important;
        }
        body.dark-mode .mobile-menu ul li a { color: var(--dm-text) !important; }
        body.dark-mode .mobile-menu ul li a:hover { background: var(--dm-surface2) !important; }

        /* ── Bootstrap utility overrides ── */
        body.dark-mode .text-dark            { color: var(--dm-text)     !important; }
        body.dark-mode .text-muted           { color: var(--dm-muted)    !important; }
        body.dark-mode .bg-light,
        body.dark-mode .bg-white,
        body.dark-mode .bg-faded            { background: var(--dm-surface) !important; }
        body.dark-mode .border,
        body.dark-mode .border-secondary,
        body.dark-mode .border-top,
        body.dark-mode .border-bottom       { border-color: var(--dm-border) !important; }
        body.dark-mode .badge.bg-light       {
          background: var(--dm-badge-bg) !important;
          color     : var(--dm-muted)    !important;
        }
        body.dark-mode .card,
        /* body.dark-mode .rounded, */
        body.dark-mode .shadow-sm {
          background  : var(--dm-surface) !important;
          border-color: var(--dm-border)  !important;
        }

        /* ── Input / Select / Textarea toàn site ── */
        body.dark-mode input:not([type=submit]):not([type=button]):not([type=checkbox]):not([type=radio]),
        body.dark-mode select,
        body.dark-mode textarea,
        body.dark-mode .form-control,
        body.dark-mode .input-group-text {
          background  : var(--dm-input-bg) !important;
          color       : var(--dm-text)     !important;
          border-color: var(--dm-border)   !important;
        }
        body.dark-mode input::placeholder,
        body.dark-mode textarea::placeholder { color: var(--dm-muted) !important; }

        /* ── Home page cards ── */
        body.dark-mode .hcard,
        body.dark-mode .story-card,
        body.dark-mode .rank-row,
        body.dark-mode .filter-bar,
        body.dark-mode .sdb-box,
        body.dark-mode .sbr-item {
          background  : var(--dm-surface) !important;
          border-color: var(--dm-border)  !important;
        }
        body.dark-mode .hcard-title,
        body.dark-mode .card-title,
        body.dark-mode .rtitle,
        body.dark-mode .sbr-title,
        body.dark-mode .sec-title,
        body.dark-mode .sdb-hd              { color: var(--dm-text)  !important; }
        body.dark-mode .hcard-time,
        body.dark-mode .card-meta,
        body.dark-mode .rmeta,
        body.dark-mode .sbr-sub             { color: var(--dm-muted) !important; }
        body.dark-mode .gitem {
          background  : rgba(255,255,255,.04) !important;
          border-color: var(--dm-border)      !important;
          color       : var(--dm-text)        !important;
        }
        body.dark-mode .ftab:not(.active) {
          color       : var(--dm-muted) !important;
          border-color: var(--dm-border) !important;
        }

        /* ── Category page (style_2.css) ── */
        body.dark-mode .product-item-inner,
        body.dark-mode .product-item-add {
          background  : var(--dm-surface) !important;
          border-color: var(--dm-border)  !important;
        }
        body.dark-mode .product-item-inner h6,
        body.dark-mode .product-item-inner a.text-dark,
        body.dark-mode .product-item-inner .fw-bold { color: var(--dm-text) !important; }

        /* ── Footer ── */
        body.dark-mode footer,
        body.dark-mode .footer,
        body.dark-mode [class*="footer"] {
          background  : var(--dm-surface) !important;
          border-color: var(--dm-border)  !important;
          color       : var(--dm-muted)   !important;
        }
        body.dark-mode footer a,
        body.dark-mode .footer a             { color: var(--dm-muted) ; }
        body.dark-mode .footer a .tnt-logo{
            margin-right: 5px; font-weight:800; font-size:18px;
                            color:#525fe1 !important; letter-spacing:1px; font-family:'Jost',sans-serif;
        }

        /* //lịch sử trang */
        /* ══ Lịch sử đọc (ReadingHistory) ══ */

        /* Header bar "Lịch sử đọc" */
        body.dark-mode .history-section > .container-fluid > div:first-child {
          background  : var(--dm-surface)  !important;
          border-color: var(--dm-border)   !important;
          box-shadow  : none                   !important;
        }
        body.dark-mode .history-section h4 {
          color: var(--dm-text) !important;
        }

        /* Từng row lịch sử */
        body.dark-mode .history-section [style*="background:#fff"] {
          background  : var(--dm-surface)  !important;
          border-color: var(--dm-border)   !important;
          box-shadow  : none                   !important;
        }

        /* Tên truyện */
        body.dark-mode .history-section a[style*="color:#1a1a1a"] {
          color: var(--dm-text) !important;
        }

        /* "Đang đọc: Chương X" */
        body.dark-mode .history-section span[style*="color:#555"] {
          color: var(--dm-muted) !important;
        }
        body.dark-mode .history-section span[style*="color:#888"] {
          color: var(--dm-dim) !important;
        }
        body.dark-mode .history-section strong {
          color: var(--dm-text) !important;
        }

        /* Timestamp "Đọc lần cuối" */
        body.dark-mode .history-section div[style*="color:#aaa"] {
          color: var(--dm-dim) !important;
        }

        /* Badge thể loại tím */
        body.dark-mode .history-section span[style*="background:#f0eeff"] {
          background: #252840 !important;
          color     : #a78bfa !important;
        }

        /* Nút "Đọc tiếp" — giữ màu accent, không đổi */
        body.dark-mode .history-section a[style*="background:#6c63ff"] {
          background: #e8541a !important; /* đổi sang accent cam của site */
          color     : #fff     !important;
        }

        /* Nút "Xóa" từng item */
        body.dark-mode .history-section button[style*="color:#aaa"] {
          background  : transparent       !important;
          border-color: var(--dm-border)  !important;
          color       : var(--dm-dim)     !important;
        }

        /* Nút "Xóa tất cả" */
        body.dark-mode .history-section button[style*="color:#e74c3c"] {
          background  : transparent !important;
          border-color: #e74c3c    !important;
          color       : #e74c3c    !important;
        }

        /* Ảnh placeholder khi không có cover */
        body.dark-mode .history-section div[style*="background:#f0f0f0"] {
          background: var(--dm-surface2) !important;
        }

        /* Trạng thái trống */
        body.dark-mode .history-section div[style*="color:#888"] {
          color: var(--dm-muted) !important;
        }
        body.dark-mode .history-section a[style*="color:#6c63ff"] {
          color: #a78bfa !important;
        }

        /* trang doc truyên */
        body.dark-mode span,p{
            color: var(--dm-text) !important;
        }
/* ══ Rating page fix ══ */

    /* Row nền tối */
    body.dark-mode .table tbody tr {
      background: var(--dm-surface) !important;
    }
    body.dark-mode .table-hover tbody tr:hover {
      background: var(--dm-surface2) !important;
    }

    /* Chữ tên truyện đang bị mờ */
    body.dark-mode .table td a,
    body.dark-mode .table td a.text-dark,
    body.dark-mode .table td .fw-semibold,
    body.dark-mode .table td {
      color: var(--dm-text) !important;
    }

    /* thead */
    body.dark-mode .table thead tr,
    body.dark-mode .table-light {
      background: var(--dm-surface2) !important;
    }
    body.dark-mode .table thead th {
      color       : var(--dm-muted)   !important;
      border-color: var(--dm-border)  !important;
    }

    /* Badge thể loại — đang tím Bootstrap */
    body.dark-mode .badge.bg-primary,
    body.dark-mode .table .badge {
      background: #2a2f4a !important;
      color     : #a78bfa !important;
      border    : none    !important;
    }

    /* Badge số "3" màu warning giữ vàng */
    body.dark-mode .badge.bg-warning {
      background: #b8860b  !important;
      color     : #fff     !important;
    }
    /* ══ Fix cứng Bootstrap bg-white trong card-header ══ */
    body.dark-mode .card-header.bg-white,
    body.dark-mode .card-header[class*="bg-white"] {
      background: var(--dm-surface2) !important;
      color      : var(--dm-text)    !important;
      border-color: var(--dm-border) !important;
    }

    /* Table toàn bộ */
    body.dark-mode .table,
    body.dark-mode .table > :not(caption) > * > * {
      background-color: var(--dm-surface)  !important;
      color           : var(--dm-text)     !important;
      border-color    : var(--dm-border)   !important;
    }

    body.dark-mode .table-light > tr,
    body.dark-mode .table > thead.table-light > tr > th,
    body.dark-mode thead.table-light {
      background-color: var(--dm-surface2) !important;
      color           : var(--dm-muted)    !important;
    }

    body.dark-mode .table-hover > tbody > tr:hover > * {
      background-color: var(--dm-surface2) !important;
      color           : var(--dm-text)     !important;
    }

    /* Link trong table */
    body.dark-mode .table a { color: var(--dm-text) !important; }

    body.dark-mode span .fa.fa-star.fa-xs{
        color: #b8860b  !important;
    }
    body.dark-mode .bc-title {
      color: var(--dm-text) !important;
    }

    body.dark-mode .bc-title i {
      color: #a78bfa !important;
    }

    body.dark-mode .bc-count {
      color: var(--dm-muted) !important;
    }

    body.dark-mode .bc-filter-btn {
      background: var(--dm-surface) !important;
      color: var(--dm-muted) !important;
      border-color: var(--dm-border) !important;
    }

    body.dark-mode .bc-filter-btn.active {
      background: #534AB7 !important;
      color: #fff !important;
      border-color: #534AB7 !important;
    }
    body.dark-mode .bc-table-wrap {
      background: var(--dm-surface) !important;
      border-color: var(--dm-border) !important;
      box-shadow: 0 2px 12px rgba(0, 0, 0, .25) !important;
    }

    body.dark-mode .bc-thead {
      background: var(--dm-surface2) !important;
      border-color: var(--dm-border) !important;
      color: var(--dm-muted) !important;
    }
    body.dark-mode .bc-row {
      border-color: var(--dm-border) !important;
    }

    body.dark-mode .bc-row:hover {
      background: var(--dm-surface2) !important;
    }

    body.dark-mode .bc-reason {
      color: var(--dm-text) !important;
    }
    body.dark-mode .bc-time {
      color: var(--dm-muted) !important;
    }
    body.dark-mode .type-comment {
      background: #2a2545 !important;
      color: #a78bfa !important;
    }

    body.dark-mode .type-story {
      background: #0d2233 !important;
      color: #5dade2 !important;
    }

    body.dark-mode .type-chapter {
      background: #2b1f0a !important;
      color: #f0a500 !important;
    }

    body.dark-mode .type-user {
      background: #2b0f0f !important;
      color: #e57373 !important;
    }

    body.dark-mode .s-pending {
      background: #2b2000 !important;
      color: #f0c040 !important;
    }

    body.dark-mode .s-approved {
      background: #0d2b17 !important;
      color: #4caf7d !important;
    }

    body.dark-mode .s-rejected {
      background: #2b0f0f !important;
      color: #e57373 !important;
    }
    body.dark-mode .bc-empty {
      color: var(--dm-muted) !important;
    }
    body.dark-mode .bc-empty i {
      color: var(--dm-border) !important;
    }
    body.dark-mode .pw{
        color: var(--dm-border) !important;
        background:#0f1117 !important;
    }
   /*  trang hô fso */


    </style>
</head>

