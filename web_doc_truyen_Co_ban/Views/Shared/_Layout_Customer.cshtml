    @* mobile *@
    <script>
        var hamburger   = document.getElementById('hamburger');
        var mobileMenu  = document.getElementById('mobileMenu');
        var isOpen      = false;

        hamburger.addEventListener('click', function () {
            isOpen = !isOpen;
            mobileMenu.classList.toggle('open', isOpen);
            // Đổi icon
            hamburger.innerHTML = isOpen
                ? '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0b104a" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'
                : '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0b104a" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
        });

        // Đóng khi bấm ra ngoài
        document.addEventListener('click', function (e) {
            if (isOpen && !mobileMenu.contains(e.target) && !hamburger.contains(e.target)) {
                isOpen = false;
                mobileMenu.classList.remove('open');
            }
        });
    </script>


    <script>
            // Dropdown user toggle
            const userBtn = document.querySelector('.nb-user-btn');
            const userDrop = document.querySelector('.nb-user-dropdown');
            if (userBtn && userDrop) {
                userBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const isOpen = userDrop.style.opacity === '1';
                    userDrop.style.opacity = isOpen ? '0' : '1';
                    userDrop.style.visibility = isOpen ? 'hidden' : 'visible';
                });
                document.addEventListener('click', () => {
                    if (userDrop) {
                        userDrop.style.opacity = '0';
                        userDrop.style.visibility = 'hidden';
                    }
                });
            }
    </script>
    <script>
                    (function () {
                const btnBell   = document.getElementById("btn-bell");
                const dropdown  = document.getElementById("dropdown-thongbao");
                const badge     = document.getElementById("badge-thongbao");
                const listEl    = document.getElementById("list-thongbao");
                const btnDocHet = document.getElementById("btn-doc-het");

                const userId = "@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value";
                if (!userId) return;

                // ── Icon map cho USER ──────────────────────────────────
                const iconMap = {
                    reply       : { ico: "fa-comment",  color: "#6c63ff" },
                    new_chapter : { ico: "fa-book",     color: "#27ae60" },
                    like        : { ico: "fa-heart",    color: "#e74c3c" },
                    follow      : { ico: "fa-user-plus",color: "#f39c12" },
                };

                // ── Badge ──────────────────────────────────────────────
                function capNhatBadge(count) {
                    if (count > 0) {
                        badge.textContent = count > 99 ? "99+" : count;
                        badge.style.display = "inline-block";
                    } else {
                        badge.style.display = "none";
                    }
                }

                // ── Fetch lại số chính xác từ server ──────────────────
                function refreshBadge() {
                    fetch("/ThongBao/SoThongBaoChuaDoc")
                        .then(r => r.json())
                        .then(d => capNhatBadge(d.count));
                }

                // ── Toast góc phải ─────────────────────────────────────
                function hienToast(type, message) {
                    const color = (iconMap[type] ?? { color: "#6c63ff" }).color;
                    const toast = document.createElement("div");
                    toast.style.cssText = `
                        position:fixed;bottom:24px;right:24px;
                        background:#fff;border-left:4px solid ${color};
                        border-radius:8px;padding:12px 16px;
                        box-shadow:0 4px 16px rgba(0,0,0,.12);
                        font-size:13px;color:#222;max-width:300px;
                        z-index:99999;animation:tbSlideIn .3s ease;
                    `;
                    toast.textContent = message;
                    document.body.appendChild(toast);
                    setTimeout(() => toast.remove(), 4000);
                }

                // ── Render 1 item ──────────────────────────────────────
                function renderItem(tb) {
                    const { ico, color } = iconMap[tb.type] ?? { ico: "fa-bell", color: "#888" };
                    const div = document.createElement("div");
                    div.style.cssText = `
                        display:flex;align-items:flex-start;gap:10px;padding:12px 16px;
                        cursor:pointer;transition:background .15s;
                        background:${tb.isRead ? "#fff" : "#f5f4ff"};
                        border-bottom:1px solid #f5f5f5;
                    `;
                    div.innerHTML = `
                        <div style="width:34px;height:34px;border-radius:50%;
                                    background:${color}22;flex-shrink:0;
                                    display:flex;align-items:center;justify-content:center;">
                            <i class="fa ${ico}" style="color:${color};font-size:14px;"></i>
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:13px;color:#222;line-height:1.4;
                                        word-break:break-word;">${tb.message}</div>
                            <div style="font-size:11px;color:#aaa;margin-top:4px;">${tb.time}</div>
                        </div>
                        ${!tb.isRead
                            ? `<span style="width:8px;height:8px;border-radius:50%;
                                           background:#6c63ff;flex-shrink:0;margin-top:4px;"></span>`
                            : ""}
                    `;
                    div.addEventListener("click", async () => {
                        await fetch(`/ThongBao/DanhDauDaDoc/${tb.id}`, {
                            method: "POST",
                            headers: { "RequestVerificationToken": getToken() }
                        });
                        if (tb.link) window.location.href = tb.link;
                    });
                    return div;
                }

                // ── Load danh sách ─────────────────────────────────────
                async function loadThongBao() {
                    listEl.innerHTML = `<div style="padding:24px;text-align:center;color:#aaa;font-size:13px;">Đang tải...</div>`;
                    try {
                        const res  = await fetch("/ThongBao/DanhSach");
                        const data = await res.json();
                        listEl.innerHTML = "";
                        if (!data.length) {
                            listEl.innerHTML = `<div style="padding:24px;text-align:center;color:#aaa;font-size:13px;">Chưa có thông báo nào.</div>`;
                            return;
                        }
                        data.forEach(tb => listEl.appendChild(renderItem(tb)));
                    } catch {
                        listEl.innerHTML = `<div style="padding:24px;text-align:center;color:#e74c3c;font-size:13px;">Lỗi tải thông báo.</div>`;
                    }
                }

                // ── Toggle dropdown ────────────────────────────────────
                btnBell.addEventListener("click", (e) => {
                    e.stopPropagation();
                    const isOpen = dropdown.style.display === "block";
                    dropdown.style.display = isOpen ? "none" : "block";
                    if (!isOpen) loadThongBao();
                });

                document.addEventListener("click", (e) => {
                    if (!document.getElementById("bell-wrapper").contains(e.target))
                        dropdown.style.display = "none";
                });

                // ── Đọc hết ───────────────────────────────────────────
                btnDocHet.addEventListener("click", async () => {
                    await fetch("/ThongBao/DanhDauTatCaDaDoc", {
                        method: "POST",
                        headers: { "RequestVerificationToken": getToken() }
                    });
                    capNhatBadge(0);
                    loadThongBao();
                });

                function getToken() {
                    return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? "";
                }

                // ── SignalR ────────────────────────────────────────────
                (async () => {
                    // Badge ban đầu
                    refreshBadge();

                    const connection = new signalR.HubConnectionBuilder()
                        .withUrl("/notificationHub")
                        .withAutomaticReconnect()
                        .build();

                    connection.on("NhanThongBaoMoi", (data) => {
                        // ✅ Fetch lại từ server thay vì tin vào data.soMoi
                        refreshBadge();
                        if (dropdown.style.display === "block") loadThongBao();
                        hienToast(data.type, data.message);
                    });

                    connection.on("CapNhatSoThongBao", (soMoi) => {
                        capNhatBadge(soMoi);
                    });

                    await connection.start();
                    await connection.invoke("JoinUserGroup", userId);
                })();
            })();
        ///đang lỗi role userBtn tạm fll 
            (function () {
                const btn  = document.getElementById('themeToggle');
                const knob = document.getElementById('themeKnob');
                if (!btn || !knob) return;
                    const sun  = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                    <path d="M14.828 14.828a4 4 0 1 0 -5.656 -5.656a4 4 0 0 0 5.656 5.656"/>
                                    <path d="M6.343 17.657l-1.414 1.414"/><path d="M6.343 6.343l-1.414 -1.414"/>
                                    <path d="M17.657 6.343l1.414 -1.414"/><path d="M17.657 17.657l1.414 1.414"/>
                                    <path d="M4 12h-2"/><path d="M12 4v-2"/><path d="M20 12h2"/><path d="M12 20v2"/>
                                </svg>`;
                    const moon =`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-moon-stars">
	                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
	                                <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454l0 .008" />
	                                <path d="M17 4a2 2 0 0 0 2 2a2 2 0 0 0 -2 2a2 2 0 0 0 -2 -2a2 2 0 0 0 2 -2" />
	                                <path d="M19 11h2m-1 -1v2" />
                                </svg>`
                function applyTheme(dark) {
                    document.body.classList.toggle('dark-mode', dark);
                     btn.style.background  = dark ? '#3b3b5c' : '#e0e0ee';
                    knob.style.left       = dark ? '25px'    : '3px';
                    knob.style.background = dark ? '#1e2235' : '#fff';
                    // knob.textContent      = dark ? sun      : moon;
                    knob.innerHTML      = dark ? sun      : moon;
                    localStorage.setItem('theme', dark ? 'dark' : 'light');
                }

                const saved      = localStorage.getItem('theme');
                const preferDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                applyTheme(saved ? saved === 'dark' : preferDark);

                btn.addEventListener('click', () => {
                    applyTheme(!document.body.classList.contains('dark-mode'));
                });
            })();
    </script>
    <script src="https:cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        document.getElementById("nb-search-input")
        .addEventListener("keydown", function (e) {

        if (e.key === "Enter") {

        let keyword = this.value.trim();

        if (keyword !== "") {

        window.location.href =
        "/Category/Index?keyword=" +
        encodeURIComponent(keyword);

        }

        }

        });
    </script>
