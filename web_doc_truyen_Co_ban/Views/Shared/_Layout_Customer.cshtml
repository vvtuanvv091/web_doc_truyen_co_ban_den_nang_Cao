    <script>
            // Dropdown user toggle
            const userBtn = document.querySelector('.nb-user-btn');
            const userDrop = document.querySelector('.nb-user-dropdown');
            if (userBtn && userDrop) {
                userBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const isOpen = userDrop.style.opacity === '1';
                    userDrop.style.opacity = isOpen ? '0' : '1';
                    userDrop.style.visibility = isOpen ? 'hidden' : 'visible';
                });
                document.addEventListener('click', () => {
                    if (userDrop) {
                        userDrop.style.opacity = '0';
                        userDrop.style.visibility = 'hidden';
                    }
                });
            }
    </script>
    <script>
            (function () {
                const btn  = document.getElementById('themeToggle');
                const knob = document.getElementById('themeKnob');
                if (!btn || !knob) return;

                function applyTheme(dark) {
                    document.body.classList.toggle('dark-mode', dark);
                     btn.style.background  = dark ? '#3b3b5c' : '#e0e0ee';
                    knob.style.left       = dark ? '25px'    : '3px';
                    // knob.style.background = dark ? '#1e2235' : '#fff';
                    knob.textContent      = dark ? '🌙'      : '☀️';
                    localStorage.setItem('theme', dark ? 'dark' : 'light');
                }

                const saved      = localStorage.getItem('theme');
                const preferDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                applyTheme(saved ? saved === 'dark' : preferDark);

                btn.addEventListener('click', () => {
                    applyTheme(!document.body.classList.contains('dark-mode'));
                });
            })();
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        (function () {
        // ── Elements ───────────────────────────────────────────
        const btnBell    = document.getElementById("btn-bell");
        const dropdown   = document.getElementById("dropdown-thongbao");
        const badge      = document.getElementById("badge-thongbao");
        const listEl     = document.getElementById("list-thongbao");
        const btnDocHet  = document.getElementById("btn-doc-het");

        // Lấy userId từ Razor (chỉ chạy nếu đã login)
        const userId = "@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value";
        if (!userId) return;

        // ── Badge helper ───────────────────────────────────────
        function capNhatBadge(count) {
        if (count > 0) {
        badge.textContent = count > 99 ? "99+" : count;
        badge.style.display = "inline-block";
        } else {
        badge.style.display = "none";
        }
        }

        // ── Render 1 item thông báo ────────────────────────────
        function renderItem(tb) {
        const div = document.createElement("div");
        div.style.cssText = `
        display:flex;align-items:flex-start;gap:10px;padding:12px 16px;
        cursor:pointer;transition:background .15s;
        background:${tb.isRead ? "#fff" : "#f5f4ff"};
        border-bottom:1px solid #f5f5f5;
        `;
        div.dataset.id = tb.id;

        // Icon type
        const iconMap = {
        reply       : { ico: "fa-comment",   color: "#6c63ff" },
        new_chapter : { ico: "fa-book",       color: "#27ae60" },
        like        : { ico: "fa-heart",      color: "#e74c3c" },
        follow      : { ico: "fa-user-plus",  color: "#f39c12" },
        };
        const { ico, color } = iconMap[tb.type] ?? { ico: "fa-bell", color: "#888" };

        div.innerHTML = `
        <div style="width:34px;height:34px;border-radius:50%;background:${color}22;
        flex-shrink:0;display:flex;align-items:center;justify-content:center;">
        <i class="fa ${ico}" style="color:${color};font-size:14px;"></i>
        </div>
        <div style="flex:1;min-width:0;">
        <div style="font-size:13px;color:#222;line-height:1.4;
        white-space:normal;word-break:break-word;">
        ${tb.message}
        </div>
        <div style="font-size:11px;color:#aaa;margin-top:4px;">${tb.time}</div>
        </div>
        ${!tb.isRead
        ? `<span style="width:8px;height:8px;border-radius:50%;
        background:#6c63ff;flex-shrink:0;margin-top:4px;"></span>`
        : ""}
        `;

        // Click → đánh dấu đã đọc + điều hướng
        div.addEventListener("click", async () => {
        await fetch(`/ThongBao/DanhDauDaDoc/${tb.id}`, {
        method: "POST",
        headers: { "RequestVerificationToken": getAntiForgeryToken() }
        });
        if (tb.link) window.location.href = tb.link;
        });

        return div;
        }

        // ── Load danh sách thông báo từ server ─────────────────
        async function loadThongBao() {
        listEl.innerHTML = `<div style="padding:24px;text-align:center;color:#aaa;font-size:13px;">Đang tải...</div>`;
        try {
        const res  = await fetch("/ThongBao/DanhSach");
        const data = await res.json(); // [{ id, type, message, link, time, isRead }]

        listEl.innerHTML = "";
        if (!data.length) {
        listEl.innerHTML = `<div style="padding:24px;text-align:center;color:#aaa;font-size:13px;">Chưa có thông báo nào.</div>`;
        return;
        }
        data.forEach(tb => listEl.appendChild(renderItem(tb)));
        } catch {
        listEl.innerHTML = `<div style="padding:24px;text-align:center;color:#e74c3c;font-size:13px;">Lỗi tải thông báo.</div>`;
        }
        }

        // ── Toggle dropdown ────────────────────────────────────
        btnBell.addEventListener("click", (e) => {
        e.stopPropagation();
        const isOpen = dropdown.style.display === "block";
        dropdown.style.display = isOpen ? "none" : "block";
        if (!isOpen) loadThongBao();
        });

        // Click ngoài → đóng dropdown
        document.addEventListener("click", (e) => {
        if (!document.getElementById("bell-wrapper").contains(e.target)) {
        dropdown.style.display = "none";
        }
        });

        // ── Đánh dấu đọc hết ──────────────────────────────────
        btnDocHet.addEventListener("click", async () => {
        await fetch("/ThongBao/DanhDauTatCaDaDoc", {
        method: "POST",
        headers: { "RequestVerificationToken": getAntiForgeryToken() }
        });
        capNhatBadge(0);
        loadThongBao(); // reload lại list để bỏ highlight
        });

        // ── Anti-forgery token helper ──────────────────────────
        function getAntiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? "";
        }

        // ── SignalR: lấy badge ban đầu + lắng nghe realtime ───
        (async () => {
        // Lấy số chưa đọc khi load trang
        const res = await fetch("/ThongBao/SoThongBaoChuaDoc");
        const { count } = await res.json();
        capNhatBadge(count);

        // Kết nối hub
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/notificationHub")
        .withAutomaticReconnect()
        .build();

        // Nhận thông báo mới → cập nhật badge, nếu dropdown đang mở thì reload list
        connection.on("NhanThongBaoMoi", (data) => {
        capNhatBadge(data.soMoi);

        if (dropdown.style.display === "block") {
        loadThongBao();
        }
        });

        // Server reset badge (sau DanhDauTatCaDaDoc)
        connection.on("CapNhatSoThongBao", (soMoi) => {
        capNhatBadge(soMoi);
        });

        await connection.start();
        await connection.invoke("JoinUserGroup", userId);
        })();
        })();
    </script>


    <script>
        document.getElementById("nb-search-input")
        .addEventListener("keydown", function (e) {

        if (e.key === "Enter") {

        let keyword = this.value.trim();

        if (keyword !== "") {

        window.location.href =
        "/Category/Index?keyword=" +
        encodeURIComponent(keyword);

        }

        }

        });
    </script>
</body>
