@* Views/Shared/_SlidebarPartial.cshtml *@
@{
    var currentSort = Context.Request.Query["sort"].ToString();
    var currentStatus = Context.Request.Query["status"].ToString();
    var currentAudio = Context.Request.Query["audio"].ToString();
    var currentMinChap = Context.Request.Query["minchap"].ToString();

    if (string.IsNullOrEmpty(currentSort)) currentSort = "new";
    if (string.IsNullOrEmpty(currentMinChap)) currentMinChap = "0";
}

<div class="col-lg-3 ps-0 pe-3">
    <aside class="fp">

        <div class="fp-head">
            <span><i class="fas fa-sliders-h me-2"></i>Bộ lọc</span>
            <a href="@Url.Action("Index", "Category")" class="fp-clear">
                <i class="fas fa-times me-1"></i>Xóa lọc
            </a>
        </div>

        <div class="fp-group">
            <div class="fp-group-title" data-target="g-sort">
                <span><i class="fas fa-sort-amount-down me-2"></i>Sắp xếp theo</span>
                <i class="fas fa-chevron-down fp-arrow"></i>
            </div>
            <div class="fp-group-body open" id="g-sort">
                <div class="fp-btns" data-single="sort">
                    <button class="fb @(currentSort == "new" ? "on" : "")" data-val="new">Mới cập nhật</button>
                    <button class="fb @(currentSort == "view" ? "on" : "")" data-val="view">Xem nhiều</button>
                    <button class="fb @(currentSort == "nominate" ? "on" : "")" data-val="nominate">Đề cử</button>
                    <button class="fb @(currentSort == "rating" ? "on" : "")" data-val="rating">Đánh giá cao</button>
                </div>
            </div>
        </div>

        <div class="fp-group">
            <div class="fp-group-title" data-target="g-status">
                <span><i class="fas fa-circle me-2"></i>Tình trạng</span>
                <i class="fas fa-chevron-down fp-arrow"></i>
            </div>
            <div class="fp-group-body open" id="g-status">
                <div class="fp-btns" data-single="status">
                    <button class="fb @(currentStatus == "1" ? "on" : "")" data-val="1">Đang ra</button>
                    <button class="fb @(currentStatus == "3" ? "on" : "")" data-val="3">Tạm dừng</button>
                    <button class="fb @(currentStatus == "2" ? "on" : "")" data-val="2">Hoàn thành</button>
                </div>
            </div>
        </div>

        <div class="fp-group">
            <div class="fp-group-title" data-target="g-audio">
                <span><i class="fas fa-headphones me-2"></i>Bản audio</span>
                <i class="fas fa-chevron-down fp-arrow"></i>
            </div>
            <div class="fp-group-body open" id="g-audio">
                <div class="fp-btns" data-single="audio">
                    <button class="fb @(currentAudio == "1" ? "on" : "")" data-val="1">Có audio</button>
                </div>
            </div>
        </div>

        <div class="fp-group">
            <div class="fp-group-title" data-target="g-chap">
                <span><i class="fas fa-list-ol me-2"></i>Số chương tối thiểu</span>
                <i class="fas fa-chevron-down fp-arrow"></i>
            </div>
            <div class="fp-group-body open" id="g-chap">
                <div class="fp-btns" data-single="minchap">
                    <button class="fb @(currentMinChap == "0" ? "on" : "")" data-val="0">Tất cả</button>
                    <button class="fb @(currentMinChap == "10" ? "on" : "")" data-val="10">10+</button>
                    <button class="fb @(currentMinChap == "50" ? "on" : "")" data-val="50">50+</button>
                    <button class="fb @(currentMinChap == "100" ? "on" : "")" data-val="100">100+</button>
                    <button class="fb @(currentMinChap == "200" ? "on" : "")" data-val="200">200+</button>
                </div>
            </div>
        </div>

        <div class="fp-group">
            <div class="fp-group-title" data-target="g-cat">
                <span><i class="fas fa-bookmark me-2"></i>Thể loại</span>
                <i class="fas fa-chevron-down fp-arrow"></i>
            </div>
            <div class="fp-group-body" id="g-cat">
                <div class="fp-btns fp-btns--vc fp-btns--cat">
                    <vc:categories></vc:categories>
                </div>
            </div>
        </div>

        <div class="fp-group">
            <div class="fp-group-title" data-target="g-tag">
                <span><i class="fas fa-tags me-2"></i>Tags</span>
                <i class="fas fa-chevron-down fp-arrow"></i>
            </div>
            <div class="fp-group-body" id="g-tag">
                <div class="fp-btns fp-btns--vc fp-btns--tag">
                    <vc:tags></vc:tags>
                </div>
            </div>
        </div>

        <button class="fp-submit" id="btnFilter">
            <i class="fas fa-search me-2"></i>Tìm kiếm
        </button>

    </aside>
</div>
<style>
/* ══ Panel ══ */
.fp {
    background: #ffffff;
    border-radius: 14px;
    overflow: hidden;
    font-size: 0.82rem;
    border: 1px solid #e2e8f0;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}

/* ══ Header ══ */
.fp-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    background: #f8fafc;
    font-weight: 700;
    font-size: 0.88rem;
    color: #1e293b;
    border-bottom: 1px solid #e2e8f0;
}
.fp-head i { color: #3b82f6; }

.fp-clear {
    font-size: 0.73rem;
    color: #ef4444;
    text-decoration: none;
    transition: .2s;
    display: flex;
    align-items: center;
    gap: 3px;
}
.fp-clear:hover { color: #dc2626; opacity: .8; }

/* ══ Group ══ */
.fp-group {
    border-bottom: 1px solid #f1f5f9;
}

/* ══ Title ══ */
.fp-group-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 16px;
    cursor: pointer;
    color: #64748b;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    user-select: none;
    transition: all .2s;
}
.fp-group-title:hover {
    color: #1e293b;
    background: #f8fafc;
}
.fp-group-title.is-open { color: #1e293b; }

.fp-arrow {
    font-size: 0.65rem;
    transition: transform .25s ease;
    color: #cbd5e1;
}
.fp-group-title.is-open .fp-arrow {
    transform: rotate(180deg);
    color: #3b82f6;
}

/* ══ Body ══ */
.fp-group-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height .3s ease, padding .3s ease;
    padding: 0 16px;
}
.fp-group-body.open {
    max-height: 300px;
    padding: 0 16px 12px;
}

/* ══ Buttons ══ */
.fp-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding-top: 8px;
}

.fb {
    padding: 5px 12px;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    color: #475569;
    font-size: 0.77rem;
    font-weight: 500;
    cursor: pointer;
    transition: all .18s ease;
    white-space: nowrap;
    line-height: 1.5;
}
.fb:hover {
    border-color: #93c5fd;
    background: #eff6ff;
    color: #1d4ed8;
    transform: translateY(-1px);
}
.fb.on {
    background: #3b82f6;
    border-color: #3b82f6;
    color: #fff;
    font-weight: 600;
    box-shadow: 0 3px 10px rgba(59,130,246,.25);
}

/* ══ VC buttons ══ */
.fp-btns--vc a {
    display: inline-flex;
    align-items: center;
    padding: 5px 12px;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    color: #475569 !important;
    font-size: 0.77rem;
    font-weight: 500;
    text-decoration: none !important;
    transition: all .18s ease;
    white-space: nowrap;
    line-height: 1.5;
}
.fp-btns--vc a:hover {
    border-color: #93c5fd;
    background: #eff6ff;
    color: #1d4ed8 !important;
    transform: translateY(-1px);
}
.fp-btns--vc a.on {
    background: #3b82f6 !important;
    border-color: #3b82f6 !important;
    color: #fff !important;
    font-weight: 600;
    box-shadow: 0 3px 10px rgba(59,130,246,.25);
}

/* ══ Submit ══ */
.fp-submit {
    display: block;
    width: calc(100% - 32px);
    margin: 14px 16px;
    padding: 11px;
    border-radius: 10px;
    border: none;
    background: #3b82f6;
    color: #fff;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    transition: .2s;
    box-shadow: 0 4px 14px rgba(59,130,246,.25);
}
.fp-submit:hover {
    background: #2563eb;
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(59,130,246,.35);
}
.fp-submit:active { transform: scale(.98); }

/* ══ Dark mode support ══ */
body.dark-mode .fp {
    background: #1e2235;
    border-color: rgba(255,255,255,0.06);
    box-shadow: none;
}
body.dark-mode .fp-head {
    background: #161828;
    color: #f1f5f9;
    border-color: rgba(255,255,255,0.06);
}
body.dark-mode .fp-group { border-color: rgba(255,255,255,0.05); }
body.dark-mode .fp-group-title { color: #94a3b8; }
body.dark-mode .fp-group-title:hover { color: #f1f5f9; background: rgba(255,255,255,0.03); }
body.dark-mode .fp-group-title.is-open { color: #f1f5f9; }
body.dark-mode .fb {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.08);
    color: #94a3b8;
}
body.dark-mode .fb:hover { background: #334155; border-color: #60a5fa; color: #eff6ff; }
body.dark-mode .fb.on { background: #3b82f6; border-color: #3b82f6; color: #fff; }
body.dark-mode .fp-btns--vc a {
    background: rgba(255,255,255,0.04) !important;
    border-color: rgba(255,255,255,0.08) !important;
    color: #94a3b8 !important;
}
body.dark-mode .fp-btns--vc a:hover { background: #334155 !important; color: #eff6ff !important; }
body.dark-mode .fp-btns--vc a.on { background: #3b82f6 !important; color: #fff !important; }
</style>

<script>
(function () {
    const params = new URLSearchParams(window.location.search);

    /* ══ Accordion ══ */
    document.querySelectorAll('.fp-group-title').forEach(title => {
        const body = document.getElementById(title.dataset.target);
        if (!body) return;

        /* Khởi tạo: nếu body đã có class open thì title cũng is-open */
        if (body.classList.contains('open')) title.classList.add('is-open');

        title.addEventListener('click', () => {
            const isOpen = body.classList.contains('open');
            body.classList.toggle('open', !isOpen);
            title.classList.toggle('is-open', !isOpen);
        });
    });

    /* ══ Single-select fbtn groups ══ */
    // document.querySelectorAll('.fp-btns[data-single]').forEach(group => {
    //     const key = group.dataset.single;
    //     group.querySelectorAll('.fb').forEach(btn => {
    //         btn.addEventListener('click', function () {
    //             const isOn = this.classList.contains('on');
    //             group.querySelectorAll('.fb').forEach(b => b.classList.remove('on'));
    //             if (isOn && key !== 'sort' && key !== 'minchap') {
    //                 params.delete(key);
    //             } else {
    //                 this.classList.add('on');
    //                 params.set(key, this.dataset.val);
    //             }
    //         });
    //     });
    // });
    document.querySelectorAll('.fp-btns[data-single]').forEach(group => {
    const key = group.dataset.single;

        group.querySelectorAll('.fb').forEach(btn => {
            btn.addEventListener('click', function () {

                const val = this.dataset.val;
                const isActive = this.classList.contains('on');

                // clear UI trước
                group.querySelectorAll('.fb').forEach(b => b.classList.remove('on'));

                if (isActive) {
                    // click lại để bỏ chọn
                    params.delete(key);
                } else {
                    // chọn mới
                    this.classList.add('on');
                    params.set(key, val);
                }
            });
        });
    });
    /* ══ vc:categories toggle ══ */
    document.querySelectorAll('.fp-btns--cat a').forEach(a => {
        const id = a.dataset.catId || '';
        if (id && params.get('category') === id) a.classList.add('on');
    
        a.addEventListener('click', e => {
            e.preventDefault();
            const isOn = a.classList.contains('on');
            document.querySelectorAll('.fp-btns--cat a').forEach(x => x.classList.remove('on'));
            if (!isOn) { 
                a.classList.add('on'); 
                params.set('category', id); 
            } else { 
                params.delete('category'); 
            }
        });
    });

        /* ══ vc:categories toggle ══ */
    document.querySelectorAll('.fp-btns--tag a').forEach(a => {
        const id = a.dataset.catId || '';
        if (id && params.get('tag') === id) a.classList.add('on');
    
        a.addEventListener('click', e => {
            e.preventDefault();
            const isOn = a.classList.contains('on');
            document.querySelectorAll('.fp-btns--tag a').forEach(x => x.classList.remove('on'));
            if (!isOn) { 
                a.classList.add('on'); 
                params.set('tag', id); 
            } else { 
                params.delete('tag'); 
            }
        });
    });

    /* ══ Apply filter ══ */
    document.getElementById('btnFilter')?.addEventListener('click', () => {
        params.delete('page');
        window.location.href = window.location.pathname + '?' + params.toString();
    });
})();
</script>