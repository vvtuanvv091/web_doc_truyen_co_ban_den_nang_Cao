@model IEnumerable<web_doc_truyen_Co_ban.Models.BaiVietModel>

@{
    Layout = "~/Views/Shared/_Layout_Customer.cshtml";
    ViewData["Title"] = "Thảo Luận";

    int page = (int)(ViewBag.Page ?? 1);
    int totalPages = (int)(ViewBag.TotalPages ?? 1);
    int total = (int)(ViewBag.Total ?? 0);
    string search = ViewData["Search"]?.ToString() ?? "";
    Guid? categoryId = ViewBag.CategoryId as Guid?;
    var currentCategory = ViewBag.CurrentCategory as web_doc_truyen_Co_ban.Models.ThaoLuanDanhMucModel;
    var categories = ViewBag.Categories as IEnumerable<web_doc_truyen_Co_ban.Models.ThaoLuanDanhMucModel>;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;500&display=swap');

    :root {
        --ink: #1a1208;
        --parchment: #fdf6e3;
        --parchment-dark: #f5e8c8;
        --red: #c0392b;
        --red-deep: #96261e;
        --gold: #d4a017;
        --gold-light: #f0c040;
        --jade: #2e7d6e;
        --border: #d9c49a;
        --muted: #8a7a5a;
        --thread-hover: #fef9ee;
       --paper: #faf8f5;


    }

    body { background: var(--paper) !important; }

    /* ── Page Wrapper ── */
    .forum-wrap {
        font-family: 'Noto Sans SC', sans-serif;
        background: var(--paper);
        background-image:
            url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c8a96e' fill-opacity='0.08'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        min-height: 100vh;
        padding: 24px 0 48px;
    }

    /* ── Hero Banner ── */
    .forum-hero {
        background: linear-gradient(135deg, #1a1208 0%, #2d1f0e 50%, #1a1208 100%);
        border-bottom: 3px solid var(--gold);
        padding: 28px 40px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
    }
    .forum-hero::before {
        position: absolute;
        right: 40px;
        top: 50%;
        transform: translateY(-50%);
        font-family: 'Noto Serif SC', serif;
        font-size: 72px;
        color: rgba(212,160,23,0.12);
        font-weight: 700;
        pointer-events: none;
        letter-spacing: 8px;
    }
    .forum-hero h1 {
        font-family: 'Noto Serif SC', serif;
        color: var(--gold-light);
        font-size: 1.9rem;
        font-weight: 700;
        margin: 0 0 6px;
        letter-spacing: 2px;
        text-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }
    .forum-hero .subtitle {
        color: rgba(240,192,64,0.6);
        font-size: 0.82rem;
        letter-spacing: 3px;
        text-transform: uppercase;
    }
    .forum-hero .btn-post {
        background: linear-gradient(135deg, var(--red), var(--red-deep));
        border: 1px solid #e05045;
        color: #fff;
        font-family: 'Noto Serif SC', serif;
        font-size: 0.88rem;
        letter-spacing: 1px;
        padding: 10px 22px;
        border-radius: 3px;
        text-decoration: none;
        transition: all .25s;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        box-shadow: 0 4px 12px rgba(192,57,43,0.4);
    }
    .forum-hero .btn-post:hover {
        background: linear-gradient(135deg, #e04535, #c0392b);
        box-shadow: 0 6px 20px rgba(192,57,43,0.55);
        transform: translateY(-1px);
        color: #fff;
    }

    /* ── Layout Grid ── */
    .forum-grid {
        display: grid;
        grid-template-columns: 1fr 260px;
        gap: 24px;
        margin: 0 auto;
        padding: 0 24px;
    }
    @@media (max-width: 900px) {
        .forum-grid { grid-template-columns: 1fr; }
        .forum-sidebar { display: none; }
    }

    /* ── Search Bar ── */
    .search-bar {
        background: var(--parchment);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 14px 18px;
        margin-bottom: 16px;
        display: flex;
        gap: 10px;
        align-items: center;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    }
    .search-bar input {
        flex: 1;
        border: 1px solid var(--border);
        background: #fff;
        border-radius: 3px;
        padding: 8px 14px;
        font-family: 'Noto Sans SC', sans-serif;
        font-size: 0.88rem;
        color: var(--ink);
        outline: none;
        transition: border-color .2s;
    }
    .search-bar input:focus { border-color: var(--gold); }
    .search-bar input::placeholder { color: #b0a080; }
    .search-bar .btn-search {
        background: var(--ink);
        color: var(--gold);
        border: 1px solid var(--gold);
        padding: 8px 18px;
        border-radius: 3px;
        font-size: 0.85rem;
        letter-spacing: 1px;
        cursor: pointer;
        font-family: 'Noto Sans SC', sans-serif;
        transition: all .2s;
    }
    .search-bar .btn-search:hover { background: var(--gold); color: var(--ink); }

    /* ── Thread List Panel ── */
    .thread-panel {
        background: var(--parchment);
        border: 1px solid var(--border);
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 3px 12px rgba(0,0,0,0.1);
    }
    .thread-panel-head {
        background: linear-gradient(90deg, #2d1f0e, #3d2a12);
        border-bottom: 2px solid var(--gold);
        padding: 12px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-family: 'Noto Serif SC', serif;
    }
    .thread-panel-head .title {
        color: var(--gold-light);
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: 2px;
    }
    .thread-panel-head .count {
        color: var(--muted);
        font-size: 0.78rem;
        letter-spacing: 1px;
    }

    /* ── Thread Row ── */
    .thread-row {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 20px;
        border-bottom: 1px solid var(--parchment-dark);
        transition: background .18s;
        position: relative;
    }
    .thread-row:last-child { border-bottom: none; }
    .thread-row:hover { background: var(--thread-hover); }
    .thread-row::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: transparent;
        transition: background .18s;
    }
    .thread-row:hover::before { background: var(--red); }

    /* Avatar */
    .thread-avatar {
        width: 42px; height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--red-deep), var(--red));
        color: var(--gold-light);
        display: flex; align-items: center; justify-content: center;
        font-family: 'Noto Serif SC', serif;
        font-size: 1rem;
        font-weight: 700;
        flex-shrink: 0;
        border: 2px solid var(--gold);
        box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    }

    /* Content */
    .thread-content { flex: 1; min-width: 0; }
    .thread-title {
        font-family: 'Noto Serif SC', serif;
        color: var(--ink);
        font-size: 0.96rem;
        font-weight: 600;
        text-decoration: none;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color .18s;
    }
    .thread-title:hover { color: var(--red); }
    .thread-meta {
        margin-top: 5px;
        font-size: 0.76rem;
        color: var(--muted);
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
    }
    .thread-meta i { font-size: 0.72rem; }

    /* Badges */
    .badge-pin {
        background: var(--gold);
        color: var(--ink);
        font-size: 0.68rem;
        padding: 2px 7px;
        border-radius: 2px;
        font-weight: 700;
        letter-spacing: 0.5px;
    }
    .badge-lock {
        background: var(--red);
        color: #fff;
        font-size: 0.68rem;
        padding: 2px 7px;
        border-radius: 2px;
        font-weight: 700;
    }
    .badge-cat {
        background: rgba(46,125,110,0.12);
        color: var(--jade);
        border: 1px solid rgba(46,125,110,0.25);
        font-size: 0.7rem;
        padding: 1px 8px;
        border-radius: 2px;
    }

    /* Stats */
    .thread-stats {
        text-align: right;
        font-size: 0.74rem;
        color: var(--muted);
        flex-shrink: 0;
        min-width: 52px;
    }
    .thread-stats div { line-height: 1.7; }

    /* Empty */
    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: var(--muted);
        font-family: 'Noto Serif SC', serif;
    }
    .empty-state .icon { font-size: 3rem; opacity: .35; margin-bottom: 14px; }
    .empty-state p { font-size: 0.9rem; letter-spacing: 1px; }

    /* ── Sidebar ── */
    .sidebar-card {
        background: var(--parchment);
        border: 1px solid var(--border);
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 3px 10px rgba(0,0,0,0.08);
        margin-bottom: 20px;

    }
    .sidebar-head {
        background: linear-gradient(90deg, #2d1f0e, #3d2a12);
        border-bottom: 2px solid var(--gold);
        padding: 11px 16px;
        font-family: 'Noto Serif SC', serif;
        color: var(--gold-light);
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 2px;
         min-width:430px;
        margin-right:10px;
    }
    .cat-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 16px;
        border-bottom: 1px solid var(--parchment-dark);
        text-decoration: none;
        color: var(--ink);
        font-size: 0.84rem;
        transition: all .18s;
        font-family: 'Noto Sans SC', sans-serif;
    }
    .cat-item:last-child { border-bottom: none; }
    .cat-item:hover, .cat-item.active {
        background: #f5e8c8;
        color: var(--red);
        padding-left: 22px;
    }
    .cat-item.active { color: var(--red); font-weight: 600; border-left: 3px solid var(--red); }
    .cat-count {
        background: rgba(0,0,0,0.07);
        color: var(--muted);
        font-size: 0.7rem;
        padding: 1px 8px;
        border-radius: 10px;
        min-width: 22px;
        text-align: center;
    }
    .sidebar-login {
        padding: 18px;
        text-align: center;
    }
    .sidebar-login p { font-size: 0.82rem; color: var(--muted); margin-bottom: 12px; font-family: 'Noto Serif SC', serif; letter-spacing: 1px; }
    .btn-login {
        display: block;
        background: linear-gradient(135deg, var(--red), var(--red-deep));
        color: #fff;
        text-decoration: none;
        padding: 9px 16px;
        border-radius: 3px;
        font-size: 0.85rem;
        letter-spacing: 1px;
        text-align: center;
        transition: all .2s;
    }
    .btn-login:hover { box-shadow: 0 4px 14px rgba(192,57,43,0.4); color: #fff; }

    /* ── Pagination ── */
    .paging {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-top: 22px;
    }
    .paging a, .paging span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px; height: 34px;
        border: 1px solid var(--border);
        border-radius: 3px;
        text-decoration: none;
        font-size: 0.82rem;
        color: var(--ink);
        background: var(--parchment);
        transition: all .18s;
        font-family: 'Noto Serif SC', serif;
    }
    .paging a:hover { background: var(--ink); color: var(--gold); border-color: var(--gold); }
    .paging .cur { background: var(--red); color: #fff; border-color: var(--red-deep); }
    .paging .disabled { opacity: .35; pointer-events: none; }
</style>

<div class="forum-wrap">

    <!-- Hero Banner -->
    <div class="forum-hero px-4">
        <div style="max-width:1200px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;">
            <div>
                <h1>
                    <i class="bi bi-chat-square-quote me-2" style="font-size:1.5rem;vertical-align:middle;"></i>
                    @(currentCategory != null ? currentCategory.Name : "Thảo Luận ")
                </h1>
                <div class="subtitle">— Diễn đàn trao đổi &amp; bình luận —</div>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="BaiViet" asp-action="Create" asp-route-categoryId="@categoryId" class="btn-post">
                    <i class="bi bi-brush"></i> Đăng Bài Mới
                </a>
            }
        </div>
    </div>

    <div class="forum-grid">

        <!-- MAIN -->
        <div>
            <!-- Search -->
            <form method="get" class="search-bar">
                @if (categoryId.HasValue) { <input type="hidden" name="categoryId" value="@categoryId" /> }
                <i class="bi bi-search" style="color:var(--muted);font-size:1rem;"></i>
                <input type="text" name="search" value="@search" placeholder="Tìm kiếm bài viết..." />
                <button type="submit" class="btn-search">Tìm Kiếm</button>
            </form>

            <!-- Thread Panel -->
            <div class="thread-panel">
                <div class="thread-panel-head">
                    <span class="title">⚔ Danh Sách Bài Viết</span>
                    <span class="count">@total bài</span>
                </div>

                @if (Model == null || !Model.Any())
                {
                    <div class="empty-state">
                        <div class="icon">📜</div>
                        <p>Chưa có bài viết nào trong mục này</p>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="BaiViet" asp-action="Create" asp-route-categoryId="@categoryId"
                               style="display:inline-block;margin-top:14px;padding:8px 20px;background:var(--red);color:#fff;text-decoration:none;border-radius:3px;font-size:0.85rem;letter-spacing:1px;">
                                Đăng bài đầu tiên
                            </a>
                        }
                    </div>
                }
                else
                {
                    @foreach (var t in Model)
                    {
                        <div class="thread-row">
                            <div class="thread-avatar">
                                
                                @{
                                    var avatarUrl = Context.Session.GetString("AvatarUrl");
                                }
                                <img src="@avatarUrl" style="width:36px;height:36px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                                @* @(!string.IsNullOrEmpty(t.User?.Username) ? t.User.Username[0].ToString().ToUpper() : "?") *@
                            </div>
                            <div class="thread-content">
                                <a asp-controller="BaiViet" asp-action="Detail" asp-route-id="@t.Id" class="thread-title">
                                    @if (t.IsPinned) { <span class="badge-pin me-1">📌 Ghim</span> }
                                    @if (t.IsLocked) { <span class="badge-lock me-1">🔒 Khóa</span> }
                                    @t.Title
                                </a>
                                <div class="thread-meta">
                                    <span><i class="bi bi-person-fill"></i> @(t.User?.Username ?? "Ẩn danh")</span>
                                    <span><i class="bi bi-clock"></i> @t.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                    @if (currentCategory == null)
                                    {
                                        <span class="badge-cat">@(t.ForumCategory?.Name ?? "Chung")</span>
                                    }
                                </div>
                            </div>
                            <div class="thread-stats">
                                <div><i class="bi bi-eye"></i> @t.ViewCount</div>
                                <div><i class="bi bi-chat-dots"></i> @t.ReplyCount</div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="paging">
                    @if (page > 1)
                    {
                        <a href="?page=@(page-1)&search=@search&categoryId=@categoryId"><i class="bi bi-chevron-left"></i></a>
                    }
                    else
                    {
                        <span class="disabled"><i class="bi bi-chevron-left"></i></span>
                    }

                    @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
                    {
                        <a href="?page=@i&search=@search&categoryId=@categoryId" class="@(i == page ? "cur" : "")">@i</a>
                    }

                    @if (page < totalPages)
                    {
                        <a href="?page=@(page+1)&search=@search&categoryId=@categoryId"><i class="bi bi-chevron-right"></i></a>
                    }
                    else
                    {
                        <span class="disabled"><i class="bi bi-chevron-right"></i></span>
                    }
                </div>
            }
        </div>

        <!-- SIDEBAR -->
        <aside class="forum-sidebar">
            <div class="sidebar-card">
                <div class="sidebar-head">📚 Danh Mục Chuyên Mục</div>
                <a asp-controller="BaiViet" asp-action="Index"
                   class="cat-item @(categoryId == null ? "active" : "")">
                    <span>📋 Tất Cả</span>
                </a>
                @if (categories != null)
                {
                    @foreach (var cat in categories)
                    {
                        <a asp-controller="BaiViet" asp-action="Index" asp-route-categoryId="@cat.Id"
                           class="cat-item @(categoryId == cat.Id ? "active" : "")">
                            <span>💬 @cat.Name</span>
                            <span class="cat-count">@(cat.Threads?.Count ?? 0)</span>
                        </a>
                    }
                }
            </div>

            @if (User.Identity?.IsAuthenticated != true)
            {
                <div class="sidebar-card">
                    <div class="sidebar-head">🔑 Thành Viên</div>
                    <div class="sidebar-login">
                        <p>Đăng nhập để tham gia thảo luận</p>
                        <a asp-controller="Account" asp-action="Login" class="btn-login">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Đăng Nhập
                        </a>
                    </div>
                </div>
            }
        </aside>

    </div>
</div>
