@model web_doc_truyen_Co_ban.Models.StoryModel
@{
    var hotStories = ViewBag.HotStories as List<StoryModel> ?? new();
    var newStories = ViewBag.NewStories as List<StoryModel> ?? new();
}

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
 :root {
    --header-h: 60px;
    --bg-deep: #f5f5fd;
    --bg-card: #ffffff;
    --bg-surface: #f8f8ff;
    --bg-hover: #ececff;
    --accent: #6c63ff;
    --accent-light: #8b84ff;
    --accent-glow: rgba(108, 99, 255, 0.15);
    --red: #e05252;
    --green: #4caf7d;
    --text-primary: #1f2330;
    --text-secondary: #5f6780;
    --text-muted: #8c93aa;
    --border: rgba(0, 0, 0, 0.08);
    --border-accent: rgba(108, 99, 255, 0.25);

    --rank-1: #f4b400;
    --rank-2: #9ba4b8;
    --rank-3: #c27b52;
}
  body {
    font-family: 'Be Vietnam Pro', sans-serif;
    background: var(--bg-deep);
    color: var(--text-primary);
    font-size: 14px;
    line-height: 1.6;
  }
  a { text-decoration: none; color: inherit; }
  img { display: block; }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg-deep); }
  ::-webkit-scrollbar-thumb { background: var(--bg-surface); border-radius: 3px; }

  /* ─── HEADER ─── */
  header {
    position: sticky; top: 0; z-index: 100;
    height: var(--header-h);
    background: rgba(13,15,20,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center;
  }
  .header-inner {
    max-width: 1280px; margin: 0 auto; width: 100%;
    padding: 0 24px;
    display: flex; align-items: center; gap: 32px;
  }
  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 22px; font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.5px;
    white-space: nowrap;
  }
  .logo span { color: var(--text-primary); }
  nav { display: flex; align-items: center; gap: 4px; flex: 1; }
  .nav-item {
    padding: 6px 14px; border-radius: 6px;
    font-size: 13.5px; font-weight: 500;
    color: var(--text-secondary);
    transition: all .2s; white-space: nowrap;
    display: flex; align-items: center; gap: 5px; cursor: pointer;
  }
  .nav-item:hover, .nav-item.active { color: var(--text-primary); background: var(--bg-surface); }
  .nav-item.active { color: var(--accent); }
  .nav-item svg { width: 14px; height: 14px; }
  .header-right { display: flex; align-items: center; gap: 10px; margin-left: auto; }
  .search-box {
    display: flex; align-items: center; gap: 8px;
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 6px 12px;
    width: 220px; transition: border-color .2s;
  }
  .search-box:focus-within { border-color: var(--border-accent); }
  .search-box input {
    background: none; border: none; outline: none;
    color: var(--text-primary); font-size: 13px; width: 100%;
    font-family: inherit;
  }
  .search-box input::placeholder { color: var(--text-muted); }
  .search-box svg { color: var(--text-muted); flex-shrink: 0; }
  .btn-login {
    padding: 7px 18px; border-radius: 7px;
    background: var(--accent); color: #0d0f14;
    font-size: 13px; font-weight: 600; cursor: pointer;
    border: none; transition: background .2s;
  }
  .btn-login:hover { background: var(--accent-light); }
  .avatar {
    width: 34px; height: 34px; border-radius: 50%;
    background: linear-gradient(135deg, #c9973a, #8b5e1a);
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 600; color: #0d0f14;
    cursor: pointer; border: 2px solid var(--border-accent);
  }

  /* ─── BANNER ─── */
  .banner-wrap {
    background: linear-gradient(180deg, #161b28 0%, var(--bg-deep) 100%);
    border-bottom: 1px solid var(--border);
    padding: 0;
  }
  .banner-inner {
    max-width: 1280px; margin: 0 auto;
    padding: 28px 24px 24px;
    display: grid; grid-template-columns: 1fr 340px; gap: 24px;
  }
  .featured-book {
    display: flex; gap: 24px; align-items: flex-start;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 14px; padding: 24px; overflow: hidden;
    position: relative;
  }
  .featured-book::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: linear-gradient(180deg, var(--accent), transparent);
  }
  .featured-cover {
    width: 120px; flex-shrink: 0; border-radius: 8px; overflow: hidden;
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
  }
  .featured-cover img { width: 100%; aspect-ratio: 2/3; object-fit: cover; }
  .cover-placeholder {
    width: 100%; aspect-ratio: 2/3;
    background: var(--bg-surface);
    display: flex; align-items: center; justify-content: center;
    font-size: 32px; border-radius: 8px;
  }
  .featured-info { flex: 1; }
  .badge-hot {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 10px; border-radius: 4px;
    background: rgba(224,82,82,0.15); color: var(--red);
    font-size: 11px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.5px; margin-bottom: 10px;
  }
  .featured-title {
    font-family: 'Playfair Display', serif;
    font-size: 20px; font-weight: 700; line-height: 1.3;
    margin-bottom: 8px; color: var(--text-primary);
  }
  .featured-author {
    font-size: 12.5px; color: var(--text-secondary); margin-bottom: 10px;
  }
  .featured-author span { color: var(--accent); }
  .featured-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; }
  .tag {
    padding: 3px 9px; border-radius: 4px;
    background: var(--bg-surface); color: var(--text-secondary);
    font-size: 11.5px; border: 1px solid var(--border);
  }
  .featured-desc {
    font-size: 13px; color: var(--text-secondary);
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
    line-height: 1.7; margin-bottom: 16px;
  }
  .featured-stats { display: flex; gap: 18px; margin-bottom: 16px; }
  .stat-item { display: flex; flex-direction: column; }
  .stat-num { font-size: 15px; font-weight: 600; color: var(--text-primary); }
  .stat-label { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
  .featured-actions { display: flex; gap: 10px; }
  .btn-read {
    padding: 9px 22px; border-radius: 8px;
    background: var(--accent); color: #0d0f14;
    font-size: 13px; font-weight: 600; cursor: pointer;
    border: none; transition: .2s;
  }
  .btn-read:hover { background: var(--accent-light); transform: translateY(-1px); }
  .btn-bookmark {
    padding: 9px 16px; border-radius: 8px;
    background: transparent; color: var(--text-secondary);
    font-size: 13px; font-weight: 500; cursor: pointer;
    border: 1px solid var(--border); transition: .2s;
  }
  .btn-bookmark:hover { border-color: var(--border-accent); color: var(--accent); }

  /* ─── RANKING SIDE ─── */
  .rank-panel {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 14px; overflow: hidden;
  }
  .rank-tabs { display: flex; border-bottom: 1px solid var(--border); }
  .rank-tab {
    flex: 1; padding: 12px; text-align: center;
    font-size: 12.5px; font-weight: 500; color: var(--text-muted);
    cursor: pointer; transition: .2s; border-bottom: 2px solid transparent;
  }
  .rank-tab.active { color: var(--accent); border-color: var(--accent); background: var(--accent-glow); }
  .rank-list { padding: 8px 0; }
  .rank-item {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 16px; transition: background .15s; cursor: pointer;
  }
  .rank-item:hover { background: var(--bg-hover); }
  .rank-num {
    width: 20px; text-align: center; font-size: 13px; font-weight: 700; flex-shrink: 0;
  }
  .rank-num.r1 { color: var(--rank-1); }
  .rank-num.r2 { color: var(--rank-2); }
  .rank-num.r3 { color: var(--rank-3); }
  .rank-num.rn { color: var(--text-muted); font-weight: 400; font-size: 12px; }
  .rank-cover {
    width: 36px; height: 50px; border-radius: 4px;
    background: var(--bg-surface); overflow: hidden; flex-shrink: 0;
  }
  .rank-cover img { width: 100%; height: 100%; object-fit: cover; }
  .rank-mini-cover {
    width: 36px; height: 50px; border-radius: 4px;
    background: var(--bg-surface); display: flex;
    align-items: center; justify-content: center; font-size: 18px;
  }
  .rank-info { flex: 1; min-width: 0; }
  .rank-title {
    font-size: 13px; font-weight: 500; color: var(--text-primary);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .rank-meta { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
  .rank-trend { font-size: 11px; font-weight: 600; flex-shrink: 0; }
  .trend-up { color: var(--green); }
  .trend-down { color: var(--red); }
</style>

<div class="container-fluid px-lg-5 px-3 py-4">

    <div class="row g-4 align-items-start">

        <!-- LEFT -->
        <div class="col-12 col-lg-9">
                        
                        <!-- FEATURED -->
                        <div class="featured-book">
                          <div class="featured-cover">
                            <div class="cover-placeholder">📖</div>
                          </div>
                          <div class="featured-info">
                            <div class="badge-hot">
                              <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c0 0-4.5 5.5-4.5 10a4.5 4.5 0 009 0C16.5 7.5 12 2 12 2z"/></svg>
                              Nổi bật hôm nay
                            </div>
                            <div class="featured-title">Tru Tiên — Hành Trình Bất Diệt</div>
                            <div class="featured-author">Tác giả: <span>Tiêu Đỉnh</span> &nbsp;·&nbsp; Cập nhật: Chương 1.842</div>
                            <div class="featured-tags">
                              <span class="tag">Tiên Hiệp</span>
                              <span class="tag">Tu Tiên</span>
                              <span class="tag">Phục Thù</span>
                              <span class="tag">Hoàn Thành</span>
                            </div>
                            <div class="featured-desc">Trương Tiểu Phàm, một chàng trai bình thường gia nhập môn phái Thanh Vân để tu luyện. Trên con đường tu tiên đầy gian nan, chàng gặp gỡ những người bạn đồng hành, trải qua biết bao thử thách và bí ẩn, dần dần khám phá ra sự thật đen tối ẩn sau thế giới tu tiên.</div>
                            <div class="featured-stats">
                              <div class="stat-item">
                                <span class="stat-num">12.4M</span>
                                <span class="stat-label">Lượt đọc</span>
                              </div>
                              <div class="stat-item">
                                <span class="stat-num">98.2%</span>
                                <span class="stat-label">Đánh giá</span>
                              </div>
                              <div class="stat-item">
                                <span class="stat-num">1.842</span>
                                <span class="stat-label">Chương</span>
                              </div>
                            </div>
                            <div class="featured-actions">
                              <button class="btn-read">Đọc Ngay</button>
                              <button class="btn-bookmark">+ Theo Dõi</button>
                            </div>
                          </div>

                       
             </div>

        </div>

        <!-- RIGHT -->
        <div class="col-12 col-lg-3">
            <!-- RANK PANEL -->
                <div class="rank-panel">
                  <div class="rank-tabs">
                    <div class="rank-tab active" onclick="switchTab(this,'hot')">🔥 Hot</div>
                    <div class="rank-tab" onclick="switchTab(this,'new')">🆕 Mới</div>
                    <div class="rank-tab" onclick="switchTab(this,'complete')">✅ Full</div>
                  </div>
                  <div class="rank-list" id="rankList">
                    @foreach (var item in Model.Select((story, index) => new { story, index }))
                    {
                        <div class="rank-item">
                            <div class="rank-num">@((item.index + 1))</div>
                            <div class="rank-title">@item.story.Title</div>
                        </div>
                    }
                  </div>
                </div>
              </div>
        </div>

    </div>

</div>

    
