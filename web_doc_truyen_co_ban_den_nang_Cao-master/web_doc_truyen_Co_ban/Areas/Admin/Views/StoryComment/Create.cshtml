@model web_doc_truyen_Co_ban.Models.StoryCommentModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm Bình Luận";
    ViewData["ActiveMenu"] = "StoryComment";
}

@section Styles {
<style>
    .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px}
    .page-title{font-size:1.25rem;font-weight:800;color:#1e293b;margin:0}
    .breadcrumb{font-size:.82rem;margin-bottom:20px}
    .card{background:#fff;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 4px rgba(0,0,0,.06);margin-bottom:24px}
    .card-header{padding:14px 20px;border-bottom:1px solid #e2e8f0;font-weight:700;font-size:.9rem;color:#1e293b;border-radius:12px 12px 0 0;background:#f8fafc;display:flex;align-items:center;gap:8px}
    .card-body{padding:24px}
    .form-label{font-size:.84rem;font-weight:700;color:#374151;margin-bottom:6px;display:block}
    .form-control{border:1px solid #e2e8f0;border-radius:8px;padding:9px 14px;font-size:.84rem;outline:none;transition:border .15s;width:100%}
    .form-control:focus{border-color:#2563eb;box-shadow:0 0 0 3px rgba(37,99,235,.08)}
    select.form-control{appearance:auto;cursor:pointer}
    .btn-primary{display:inline-flex;align-items:center;gap:6px;background:#2563eb;color:#fff;border:none;padding:9px 22px;border-radius:8px;font-weight:700;font-size:.84rem;cursor:pointer;transition:background .15s}
    .btn-primary:hover{background:#1d4ed8;color:#fff}
    .btn-secondary{display:inline-flex;align-items:center;gap:6px;background:#f1f5f9;color:#475569;border:1px solid #e2e8f0;padding:9px 22px;border-radius:8px;font-weight:700;font-size:.84rem;cursor:pointer;text-decoration:none;transition:all .15s}
    .btn-secondary:hover{background:#e2e8f0;color:#1e293b}
    .text-danger{color:#ef4444!important;font-size:.78rem}
    .alert-danger{border-radius:8px;font-size:.84rem;padding:10px 14px;background:#fef2f2;border:1px solid #fecaca;color:#dc2626}
    .hint{font-size:.76rem;color:#94a3b8;margin-top:4px}
    .reply-notice{background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:10px 14px;font-size:.82rem;color:#1d4ed8;display:flex;align-items:center;gap:8px;margin-bottom:16px}
</style>
}

<!-- Page Header -->
<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-chat-left-text me-2"></i>Thêm Bình Luận Mới
    </h1>
</div>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="StoryComment" asp-action="Index">Danh sách Bình Luận</a>
        </li>
        <li class="breadcrumb-item active">Thêm mới</li>
    </ol>
</nav>

<form asp-area="Admin"
      asp-controller="StoryComment"
      asp-action="Create"
      method="post"
      id="commentForm">

    @Html.AntiForgeryToken()

    <div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start">

        <!-- Cột trái: nội dung chính -->
        <div>
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-chat-quote"></i> Nội Dung Bình Luận
                </div>
                <div class="card-body">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" style="display:none"></div>

                    <!-- TRUYỆN -->
                    <div class="mb-4">
                        <label asp-for="StoryId" class="form-label">
                            Truyện <span class="text-danger">*</span>
                        </label>
                        <select asp-for="StoryId" class="form-control" id="storySelect">
                            <option value="">-- Chọn truyện --</option>
                            @foreach (var story in (IEnumerable<dynamic>)ViewBag.Stories)
                            {
                                <option value="@story.Id">@story.Title</option>
                            }
                        </select>
                        <span asp-validation-for="StoryId" class="text-danger"></span>
                    </div>

                    <!-- NGƯỜI DÙNG -->
                    <div class="mb-4">
                        <label asp-for="UserId" class="form-label">
                            Người Dùng <span class="text-danger">*</span>
                        </label>
                        <select asp-for="UserId" class="form-control">
                            <option value="">-- Chọn người dùng --</option>
                            @foreach (var user in (IEnumerable<dynamic>)ViewBag.Users)
                            {
                                <option value="@user.Id">@user.Username</option>
                            }
                        </select>
                        <span asp-validation-for="UserId" class="text-danger"></span>
                    </div>

                    <!-- PARENT COMMENT (reply) -->
                    <div class="mb-4">
                        <label asp-for="ParentId" class="form-label">Trả Lời Bình Luận (tùy chọn)</label>
                        <div class="reply-notice" id="replyNotice" style="display:none">
                            <i class="bi bi-reply-all"></i>
                            <span>Chọn truyện trước để xem danh sách bình luận có thể trả lời.</span>
                        </div>
                        <select asp-for="ParentId" class="form-control" id="parentSelect">
                            <option value="">-- Không có (bình luận gốc) --</option>
                        </select>
                        <p class="hint"><i class="bi bi-info-circle"></i> Để trống nếu đây là bình luận gốc</p>
                        <span asp-validation-for="ParentId" class="text-danger"></span>
                    </div>

                    <!-- NỘI DUNG -->
                    <div class="mb-2">
                        <label asp-for="Content" class="form-label">
                            Nội Dung <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="Content"
                                  class="form-control"
                                  rows="6"
                                  placeholder="Nhập nội dung bình luận..."></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                </div>
            </div>
        </div>

        <!-- Cột phải: tuỳ chọn -->
        <div>
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-gear"></i> Tuỳ Chọn
                </div>
                <div class="card-body">

                    <!-- TRẠNG THÁI -->
                    <div class="mb-4">
                        <label asp-for="Status" class="form-label">Trạng Thái</label>
                        <select asp-for="Status" class="form-control">
                            <option value="0">✅ Hiển thị</option>
                            <option value="1">🔕 Ẩn</option>
                        </select>
                        <p class="hint">Bình luận bị ẩn sẽ không hiển thị với người đọc</p>
                    </div>

                    <!-- LIKE COUNT -->
                    <div class="mb-2">
                        <label asp-for="LikeCount" class="form-label">Số Lượt Thích</label>
                        <input asp-for="LikeCount" type="number" class="form-control" min="0" value="0" />
                        <p class="hint">Mặc định là 0</p>
                    </div>

                </div>
            </div>

            <!-- Buttons -->
            <div style="display:flex;flex-direction:column;gap:10px">
                <button type="submit" class="btn-primary" style="justify-content:center;padding:11px">
                    <i class="bi bi-floppy"></i> Lưu Bình Luận
                </button>
                <a asp-area="Admin" asp-controller="StoryComment" asp-action="Index"
                   class="btn-secondary" style="justify-content:center;padding:11px">
                    <i class="bi bi-arrow-left"></i> Hủy / Quay lại
                </a>
            </div>
        </div>

    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // ── Load parent comments khi chọn truyện ─────────────────────
        const storySelect  = document.getElementById('storySelect');
        const parentSelect = document.getElementById('parentSelect');
        const replyNotice  = document.getElementById('replyNotice');

        storySelect.addEventListener('change', async function () {
            const storyId = this.value;
            parentSelect.innerHTML = '<option value="">-- Không có (bình luận gốc) --</option>';

            if (!storyId) return;

            replyNotice.style.display = 'flex';
            replyNotice.querySelector('span').textContent = 'Đang tải danh sách bình luận...';

            try {
                const res  = await fetch(`/Admin/StoryComment/GetRootComments?storyId=${storyId}`);
                const data = await res.json();

                data.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value       = c.id;
                    opt.textContent = `${c.userName}: ${c.content.substring(0, 60)}${c.content.length > 60 ? '…' : ''}`;
                    parentSelect.appendChild(opt);
                });

                replyNotice.querySelector('span').textContent =
                    data.length > 0
                        ? `Có ${data.length} bình luận gốc — chọn để trả lời.`
                        : 'Truyện này chưa có bình luận gốc nào.';
            } catch {
                replyNotice.querySelector('span').textContent = 'Không thể tải danh sách bình luận.';
            }
        });

        // ── Hiện validation-summary nếu có lỗi ─────────────────────
        const summary = document.querySelector('[data-valmsg-summary]');
        if (summary && summary.querySelector('li')) {
            summary.style.display = 'block';
        }
    </script>
}
