@model web_doc_truyen_Co_ban.Models.CategoryModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm Thể Loại";
    ViewData["ActiveMenu"] = "Category";
}

@section Styles {
<style>
    .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px}
    .page-title{font-size:1.25rem;font-weight:800;color:#1e293b;margin:0}
    .breadcrumb{font-size:.82rem;margin-bottom:20px}
    .card{background:#fff;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 4px rgba(0,0,0,.06);margin-bottom:24px}
    .card-header{padding:14px 20px;border-bottom:1px solid #e2e8f0;font-weight:700;font-size:.9rem;color:#1e293b;border-radius:12px 12px 0 0;background:#f8fafc;display:flex;align-items:center;gap:8px}
    .card-body{padding:24px}
    .form-label{font-size:.84rem;font-weight:700;color:#374151;margin-bottom:6px}
    .form-control{border:1px solid #e2e8f0;border-radius:8px;padding:9px 14px;font-size:.84rem;outline:none;transition:border .15s;width:100%}
    .form-control:focus{border-color:#2563eb;box-shadow:0 0 0 3px rgba(37,99,235,.08)}
    .form-check-input{width:40px;height:22px;cursor:pointer}
    .form-check-input:checked{background-color:#2563eb;border-color:#2563eb}
    .form-check-label{font-size:.84rem;font-weight:600;padding-left:6px}
    .btn-primary{display:inline-flex;align-items:center;gap:6px;background:#2563eb;color:#fff;border:none;padding:9px 22px;border-radius:8px;font-weight:700;font-size:.84rem;cursor:pointer;transition:background .15s}
    .btn-primary:hover{background:#1d4ed8;color:#fff}
    .btn-secondary{display:inline-flex;align-items:center;gap:6px;background:#f1f5f9;color:#475569;border:1px solid #e2e8f0;padding:9px 22px;border-radius:8px;font-weight:700;font-size:.84rem;cursor:pointer;text-decoration:none;transition:all .15s}
    .btn-secondary:hover{background:#e2e8f0;color:#1e293b}
    .text-danger{color:#ef4444!important;font-size:.78rem}
    .alert-danger{border-radius:8px;font-size:.84rem;padding:10px 14px}
    .slug-hint{font-size:.76rem;color:#94a3b8;margin-top:4px}
    .status-badge{display:inline-flex;align-items:center;gap:5px;font-size:.82rem;font-weight:700;padding:4px 12px;border-radius:20px}
    .status-active{background:#dcfce7;color:#16a34a}
    .status-inactive{background:#f1f5f9;color:#64748b}
    .tox-tinymce{border-radius:8px!important;border:1px solid #e2e8f0!important}
</style>
}

<!-- Page Header -->
<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-tags me-2"></i>Thêm Thể Loại Mới
    </h1>
</div>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="Category" asp-action="Index">Danh sách Thể Loại</a>
        </li>
        <li class="breadcrumb-item active">Thêm mới</li>
    </ol>
</nav>

<form asp-area="Admin"
      asp-controller="Category"
      asp-action="Create"
      method="post"
      id="categoryForm">

    @Html.AntiForgeryToken()

    <div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start">

        <!-- Cột trái: thông tin chính -->
        <div>
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-info-circle"></i> Thông Tin Thể Loại
                </div>
                <div class="card-body">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none"></div>

                    <!-- NAME -->
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label">
                            Tên Thể Loại <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control"
                               id="nameInput"
                               placeholder="VD: Tiên Hiệp, Ngôn Tình, Kinh Dị..." />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- SLUG -->
                    <div class="mb-4">
                        <label asp-for="Slug" class="form-label">
                            Slug <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Slug" class="form-control"
                               id="slugInput"
                               placeholder="vd: tien-hiep" />
                        <p class="slug-hint"><i class="bi bi-link-45deg"></i> Tự động tạo từ tên — có thể chỉnh tay</p>
                        <span asp-validation-for="Slug" class="text-danger"></span>
                    </div>

                    <!-- DESCRIPTION -->
                    <div class="mb-2">
                        <label asp-for="Description" class="form-label">Mô Tả</label>
                        <textarea asp-for="Description"
                                  id="contentEditor"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Nhập mô tả ngắn về thể loại này..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                </div>
            </div>
        </div>

        <!-- Cột phải: tuỳ chọn -->
        <div>
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-gear"></i> Tuỳ Chọn
                </div>
                <div class="card-body">

                    <!-- DISPLAY ORDER -->
                    <div class="mb-4">
                        <label asp-for="DisplayOrder" class="form-label">Thứ Tự Hiển Thị</label>
                        <input asp-for="DisplayOrder" type="number" class="form-control"
                               min="0" placeholder="0" />
                        <p class="slug-hint">Số nhỏ hơn hiển thị trước</p>
                    </div>

                    <!-- IS ACTIVE -->
                    <div class="mb-2">
                        <label class="form-label d-block">Trạng Thái</label>
                        <div class="form-check form-switch" style="display:flex;align-items:center;gap:10px">
                            <input asp-for="IsActive"
                                   class="form-check-input"
                                   type="checkbox"
                                   id="isActiveToggle"
                                   checked />
                            <span id="statusLabel" class="status-badge status-active">
                                <i class="bi bi-check-circle"></i> Hoạt động
                            </span>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Buttons -->
            <div style="display:flex;flex-direction:column;gap:10px">
                <button type="submit" class="btn-primary" style="justify-content:center;padding:11px">
                    <i class="bi bi-floppy"></i> Lưu Thể Loại
                </button>
                <a asp-area="Admin" asp-controller="Category" asp-action="Index"
                   class="btn-secondary" style="justify-content:center;padding:11px">
                    <i class="bi bi-arrow-left"></i> Hủy / Quay lại
                </a>
            </div>
        </div>

    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <!-- TinyMCE CDN (version ổn định, đúng path) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.4.2/tinymce.min.js"
            referrerpolicy="origin"></script>

    <script>
        // ── TinyMCE init ────────────────────────────────────────────
        tinymce.init({
            selector: '#contentEditor',
            height: 280,
            menubar: false,
            plugins: ['lists', 'link', 'code', 'fullscreen'],
            toolbar:
                'undo redo | bold italic underline strikethrough | ' +
                'alignleft aligncenter alignright | ' +
                'bullist numlist | link | code fullscreen',
            content_style: 'body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; font-size: 14px; }',
            branding: false,
            resize: true,
            setup: function (editor) {
                // Sync về textarea khi thay đổi để validation client hoạt động
                editor.on('change keyup', function () {
                    editor.save();
                });
            }
        });

        // ── Submit: đồng bộ TinyMCE → textarea ─────────────────────
        document.getElementById('categoryForm').addEventListener('submit', function () {
            tinymce.triggerSave();
        });

        // ── Auto Slug từ Name ───────────────────────────────────────
        const nameInput = document.getElementById('nameInput');
        const slugInput = document.getElementById('slugInput');
        let slugEdited = false;

        // Nếu user tự sửa slug → không auto-override nữa
        slugInput.addEventListener('input', function () {
            slugEdited = this.value.trim() !== '';
        });

        nameInput.addEventListener('input', function () {
            if (slugEdited) return;
            slugInput.value = toSlug(this.value);
        });

        function toSlug(str) {
            return str
                .toLowerCase()
                .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
                .replace(/đ/g, "d").replace(/Đ/g, "d")
                .replace(/[^a-z0-9\s-]/g, "")
                .trim()
                .replace(/\s+/g, "-")
                .replace(/-+/g, "-");
        }

        // ── Toggle trạng thái label ─────────────────────────────────
        const toggle = document.getElementById('isActiveToggle');
        const label  = document.getElementById('statusLabel');

        function updateStatusLabel() {
            if (toggle.checked) {
                label.className = 'status-badge status-active';
                label.innerHTML = '<i class="bi bi-check-circle"></i> Hoạt động';
            } else {
                label.className = 'status-badge status-inactive';
                label.innerHTML = '<i class="bi bi-dash-circle"></i> Ẩn';
            }
        }

        toggle.addEventListener('change', updateStatusLabel);
        updateStatusLabel(); // khởi tạo đúng trạng thái ban đầu

        // ── Hiện validation-summary nếu có lỗi ─────────────────────
        const summary = document.querySelector('[data-valmsg-summary]');
        if (summary && summary.querySelector('li')) {
            summary.style.display = 'block';
        }
    </script>
}
