@model web_doc_truyen_Co_ban.Models.RolesModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm Quyền";
    ViewData["ActiveMenu"] = "Roles";
}

@section Styles {
<style>
    .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px}
    .page-title{font-size:1.25rem;font-weight:800;color:#1e293b;margin:0}
    .breadcrumb{font-size:.82rem;margin-bottom:20px}
    .card{background:#fff;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 4px rgba(0,0,0,.06);margin-bottom:24px}
    .card-header{padding:14px 20px;border-bottom:1px solid #e2e8f0;font-weight:700;font-size:.9rem;color:#1e293b;border-radius:12px 12px 0 0;background:#f8fafc;display:flex;align-items:center;gap:8px}
    .card-body{padding:24px}
    .form-label{font-size:.84rem;font-weight:700;color:#374151;margin-bottom:6px}
    .form-control{border:1px solid #e2e8f0;border-radius:8px;padding:9px 14px;font-size:.84rem;outline:none;transition:border .15s;width:100%}
    .form-control:focus{border-color:#2563eb;box-shadow:0 0 0 3px rgba(37,99,235,.08)}
    .btn-primary{display:inline-flex;align-items:center;gap:6px;background:#2563eb;color:#fff;border:none;padding:9px 22px;border-radius:8px;font-weight:700;font-size:.84rem;cursor:pointer;transition:background .15s}
    .btn-primary:hover{background:#1d4ed8;color:#fff}
    .btn-secondary{display:inline-flex;align-items:center;gap:6px;background:#f1f5f9;color:#475569;border:1px solid #e2e8f0;padding:9px 22px;border-radius:8px;font-weight:700;font-size:.84rem;cursor:pointer;text-decoration:none;transition:all .15s}
    .btn-secondary:hover{background:#e2e8f0;color:#1e293b}
    .text-danger{color:#ef4444!important;font-size:.78rem}
    .alert-danger{border-radius:8px;font-size:.84rem;padding:10px 14px}
    .hint{font-size:.76rem;color:#94a3b8;margin-top:4px}
    .perm-wrap{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
    .perm-chip{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;background:#eff6ff;color:#2563eb;font-size:.76rem;font-weight:700;cursor:pointer;border:1px solid #bfdbfe;transition:all .15s;user-select:none}
    .perm-chip:hover{background:#dbeafe}
    .perm-chip.selected{background:#2563eb;color:#fff;border-color:#2563eb}
    .perm-chip i{font-size:.7rem}
</style>
}

<!-- Page Header -->
<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-shield-plus me-2"></i>Thêm Quyền Mới
    </h1>
</div>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="Roles" asp-action="Index">Danh sách Quyền</a>
        </li>
        <li class="breadcrumb-item active">Thêm mới</li>
    </ol>
</nav>

<form asp-area="Admin"
      asp-controller="Roles"
      asp-action="Create"
      method="post"
      id="rolesForm">

    @Html.AntiForgeryToken()

    <div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start">

        <!-- Cột trái -->
        <div>
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-shield-check"></i> Thông Tin Quyền
                </div>
                <div class="card-body">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none"></div>

                    <!-- NAME -->
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label">
                            Tên Quyền <span style="color:#ef4444">*</span>
                        </label>
                        <input asp-for="Name" class="form-control"
                               id="nameInput"
                               placeholder="VD: Admin, Editor, Moderator..." />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- PERMISSIONS -->
                    <div class="mb-2">
                        <label asp-for="Permissions" class="form-label">Quyền hạn / quyền truy cập</label>
                        <input asp-for="Permissions"
                               class="form-control"
                               id="permInput"
                               placeholder="VD: users.view, stories.edit, comments.delete" />
                        <p class="hint"><i class="bi bi-info-circle"></i> Phân cách bằng dấu phẩy — hoặc chọn nhanh bên dưới</p>
                        <span asp-validation-for="Permissions" class="text-danger"></span>

                        <!-- Quick pick chips -->
                        <div class="perm-wrap" id="permChips">
                            @foreach (var p in new[]{ "users.view","users.edit","users.delete","stories.view","stories.edit","stories.delete","chapters.view","chapters.edit","chapters.delete","comments.view","comments.delete","categories.manage","tags.manage","roles.manage","logs.view" })
                            {
                                <span class="perm-chip" data-perm="@p" onclick="togglePerm(this)">
                                    <i class="bi bi-plus-lg"></i> @p
                                </span>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Cột phải -->
        <div>
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-info-circle"></i> Lưu Ý
                </div>
                <div class="card-body">
                    <p style="font-size:.82rem;color:#64748b;line-height:1.6;margin:0">
                        Quyền sẽ được đồng bộ với <strong>ASP.NET Identity</strong> — tên quyền phân biệt hoa thường.<br><br>
                        Quyền hạn / quyền truy cập lưu dạng chuỗi phân cách bằng dấu phẩy, dùng để kiểm soát chi tiết trong code.<br><br>
                        Nếu Có Bất Kỳ Trục Trặc Nào , Liên Hệ Đến tongngoctuan09@gmail.com hỗ trợ.
                    </p>
                </div>
            </div>

            <!-- Buttons -->
            <div style="display:flex;flex-direction:column;gap:10px">
                <button type="submit" class="btn-primary" style="justify-content:center;padding:11px">
                    <i class="bi bi-floppy"></i> Lưu Quyền
                </button>
                <a asp-area="Admin" asp-controller="Roles" asp-action="Index"
                   class="btn-secondary" style="justify-content:center;padding:11px">
                    <i class="bi bi-arrow-left"></i> Hủy / Quay lại
                </a>
            </div>
        </div>

    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // ── Toggle permission chip ──────────────────────────────────
        function togglePerm(chip) {
            const perm  = chip.dataset.perm;
            const input = document.getElementById('permInput');
            let perms   = input.value.split(',').map(p => p.trim()).filter(Boolean);

            if (perms.includes(perm)) {
                perms = perms.filter(p => p !== perm);
                chip.classList.remove('selected');
                chip.querySelector('i').className = 'bi bi-plus-lg';
            } else {
                perms.push(perm);
                chip.classList.add('selected');
                chip.querySelector('i').className = 'bi bi-check-lg';
            }

            input.value = perms.join(', ');
        }

        // ── Sync chips khi user tự gõ vào input ────────────────────
        document.getElementById('permInput').addEventListener('input', function () {
            const perms = this.value.split(',').map(p => p.trim()).filter(Boolean);
            document.querySelectorAll('.perm-chip').forEach(chip => {
                if (perms.includes(chip.dataset.perm)) {
                    chip.classList.add('selected');
                    chip.querySelector('i').className = 'bi bi-check-lg';
                } else {
                    chip.classList.remove('selected');
                    chip.querySelector('i').className = 'bi bi-plus-lg';
                }
            });
        });

        // ── Hiện validation-summary nếu có lỗi ─────────────────────
        const summary = document.querySelector('[data-valmsg-summary]');
        if (summary && summary.querySelector('li')) {
            summary.style.display = 'block';
        }
    </script>
}
