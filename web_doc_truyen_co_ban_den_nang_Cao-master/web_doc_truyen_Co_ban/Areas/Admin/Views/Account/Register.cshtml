     <script>
        document.addEventListener("DOMContentLoaded", function () {

            // Toggle Password
            document.getElementById("passwordToggle").onclick = function() {
                var input = document.getElementById("passwordInput");
                var icon  = document.getElementById("eyeIcon");
                input.type = input.type === "password" ? "text" : "password";
                icon.textContent = input.type === "password" ? "👁" : "🙈";
            };

            // Toggle Confirm Password
            document.getElementById("confirmPasswordToggle").onclick = function() {
                var input = document.getElementById("confirmPasswordInput");
                var icon  = document.getElementById("confirmEyeIcon");
                input.type = input.type === "password" ? "text" : "password";
                icon.textContent = input.type === "password" ? "👁" : "🙈";
            };

            // ===== Submit Form via AJAX =====
            const form        = document.getElementById("loginForm");
            const btnText     = form.querySelector(".btn-text");
            const btnLoader   = form.querySelector(".btn-loader");
            const submitBtn   = form.querySelector(".gradient-button");

            form.addEventListener("submit", async function (e) {
                e.preventDefault();

                // Show loader
                btnText.classList.add("hidden");
                btnLoader.classList.add("active");
                submitBtn.disabled = true;

                // Clear lỗi cũ
                document.getElementById("usernameError").textContent  = "";
                document.getElementById("emailError").textContent     = "";
                document.getElementById("passwordError").textContent  = "";
                document.getElementById("confirmPasswordError").textContent = "";

                const formData = new FormData(form);

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: formData
                    });

                    const result = await response.json();

                    if (result.success) {
                        // Hiện overlay thành công
                        showSuccess();
                        setTimeout(() => {
                            window.location.href = result.redirectUrl;
                        }, 1500);
                    } else {
                        // Hiện lỗi đúng field
                        showError(result.message);
                    }
                } catch (err) {
                    showError("Có lỗi xảy ra, vui lòng thử lại.");
                } finally {
                    btnText.classList.remove("hidden");
                    btnLoader.classList.remove("active");
                    submitBtn.disabled = false;
                }
            });

            function showError(message) {
                const msg = message?.toLowerCase() ?? "";

                if (msg.includes("tên đăng nhập")) {
                    document.getElementById("usernameError").textContent = message;
                } else if (msg.includes("email")) {
                    document.getElementById("emailError").textContent = message;
                } else if (msg.includes("xác nhận")) {
                    document.getElementById("confirmPasswordError").textContent = message;
                } else if (msg.includes("mật khẩu")) {
                    document.getElementById("passwordError").textContent = message;
                } else {
                    document.getElementById("emailError").textContent = message;
                }
            }

            function showSuccess() {
                const overlay = document.getElementById("successOverlay");
                if (overlay) overlay.classList.add("active");
            }

        });
    </script>
    

</body>
</html>


