@model web_doc_truyen_Co_ban.Models.UsersModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Sửa Người Dùng";
    ViewData["ActiveMenu"] = "Users";
    var allRoles = ViewBag.AllRoles as List<web_doc_truyen_Co_ban.Models.RolesModel> ?? new();
}

@section Styles {
<style>
    .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px}
    .page-title{font-size:1.25rem;font-weight:800;color:#1e293b;margin:0}
    .breadcrumb{font-size:.82rem;margin-bottom:20px}
    .card{background:#fff;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 4px rgba(0,0,0,.06);margin-bottom:24px}
    .card-header{padding:14px 20px;border-bottom:1px solid #e2e8f0;font-weight:700;font-size:.9rem;color:#1e293b;border-radius:12px 12px 0 0;background:#f8fafc;display:flex;align-items:center;gap:8px}
    .card-body{padding:24px}
    .form-label{font-size:.84rem;font-weight:700;color:#374151;margin-bottom:6px}
    .form-control,.form-select{border:1px solid #e2e8f0;border-radius:8px;padding:9px 14px;font-size:.84rem;outline:none;transition:border .15s;width:100%}
    .form-control:focus,.form-select:focus{border-color:#2563eb;box-shadow:0 0 0 3px rgba(37,99,235,.08)}
    .form-control:disabled{background:#f8fafc;color:#94a3b8;cursor:not-allowed}
    .btn-primary{display:inline-flex;align-items:center;gap:6px;background:#2563eb;color:#fff;border:none;padding:9px 22px;border-radius:8px;font-weight:700;font-size:.84rem;cursor:pointer;transition:background .15s}
    .btn-primary:hover{background:#1d4ed8;color:#fff}
    .btn-secondary{display:inline-flex;align-items:center;gap:6px;background:#f1f5f9;color:#475569;border:1px solid #e2e8f0;padding:9px 22px;border-radius:8px;font-weight:700;font-size:.84rem;cursor:pointer;text-decoration:none;transition:all .15s}
    .btn-secondary:hover{background:#e2e8f0;color:#1e293b}
    .text-danger{color:#ef4444!important;font-size:.78rem}
    .alert-danger{border-radius:8px;font-size:.84rem;padding:10px 14px}
    .hint{font-size:.76rem;color:#94a3b8;margin-top:4px}
    .status-badge{display:inline-flex;align-items:center;gap:5px;font-size:.82rem;font-weight:700;padding:4px 12px;border-radius:20px}
    .status-active{background:#dcfce7;color:#16a34a}
    .status-locked{background:#fef9c3;color:#ca8a04}
    .status-banned{background:#fee2e2;color:#dc2626}
    .avatar-wrap{display:flex;align-items:center;gap:14px;margin-bottom:20px}
    .avatar-img{width:64px;height:64px;border-radius:50%;object-fit:cover;border:2px solid #e2e8f0}
    .avatar-placeholder{width:64px;height:64px;border-radius:50%;background:#e2e8f0;display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:#94a3b8}
    .info-row{display:flex;flex-direction:column;gap:2px}
    .info-label{font-size:.72rem;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:.6px}
    .info-value{font-size:.84rem;color:#1e293b;font-weight:600}
    .form-check-input{width:40px;height:22px;cursor:pointer}
    .form-check-input:checked{background-color:#2563eb;border-color:#2563eb}
</style>
}

<!-- Page Header -->
<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-person-gear me-2"></i>Sửa Người Dùng
    </h1>
</div>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="User" asp-action="Index">Danh sách Người Dùng</a>
        </li>
        <li class="breadcrumb-item active">Sửa Người Dùng</li>
    </ol>
</nav>

<form asp-area="Admin"
      asp-controller="User"
      asp-action="Edit"
      asp-route-id="@Model.Id"
      method="post"
      id="editUserForm">

    @Html.AntiForgeryToken()

    <div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start">

        <!-- Cột trái -->
        <div>
            <!-- Thông tin cơ bản -->
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-person-circle"></i> Thông Tin Người Dùng
                </div>
                <div class="card-body">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none"></div>

                    <!-- Avatar + tên -->
                    <div class="avatar-wrap">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" alt="avatar" class="avatar-img" />
                        }
                        else
                        {
                            <div class="avatar-placeholder"><i class="bi bi-person"></i></div>
                        }
                        <div class="info-row">
                            <span class="info-label">Tài khoản</span>
                            <span class="info-value">@Model.Username</span>
                            <span style="font-size:.78rem;color:#94a3b8;">@Model.Email</span>
                        </div>
                    </div>

                    <!-- USERNAME — readonly -->
                    <div class="mb-4">
                        <label class="form-label">Tên Đăng Nhập</label>
                        <input type="text" class="form-control" value="@Model.Username" disabled />
                        <p class="hint"><i class="bi bi-lock"></i> Không thể thay đổi tên đăng nhập</p>
                    </div>

                    <!-- EMAIL — readonly -->
                    <div class="mb-4">
                        <label class="form-label">Email</label>
                        <input type="text" class="form-control" value="@Model.Email" disabled />
                        <p class="hint"><i class="bi bi-lock"></i> Không thể thay đổi email</p>
                    </div>

                    <!-- DISPLAY NAME -->
                    <div class="mb-2">
                        <label class="form-label">
                            Tên Hiển Thị <span class="text-danger">*</span>
                        </label>
                        <input type="text"
                               name="DisplayName"
                               class="form-control"
                               value="@Model.DisplayName"
                               placeholder="Nhập tên hiển thị..." />
                    </div>

                </div>
            </div>
        </div>

        <!-- Cột phải -->
        <div>
            <!-- Phân quyền & trạng thái -->
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-shield-check"></i> Phân Quyền & Trạng Thái
                </div>
                <div class="card-body">

                    <!-- ROLE -->
                    <div class="mb-4">
                        <label class="form-label">Quyền Hạn</label>
                        <select name="RoleId" class="form-select">
                            <option value="">-- Không có quyền --</option>
                        @foreach (var r in allRoles)
                        {
                            @if (Model.RoleId == r.Id)
                            {
                                <option value="@r.Id" selected>@r.Name</option>
                            }
                            else
                            {
                                <option value="@r.Id">@r.Name</option>
                            }
                        }
                        </select>
                    </div>

                    <!-- THÔNG TIN THÊM -->
                    <div class="mb-4" style="display:flex;flex-direction:column;gap:10px">
                        <div class="info-row">
                            <span class="info-label">Ngày tạo</span>
                            <span class="info-value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        @if (Model.LastLoginAt.HasValue)
                        {
                            <div class="info-row">
                                <span class="info-label">Đăng nhập lần cuối</span>
                                <span class="info-value">@Model.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        }
                        <div class="info-row">
                            <span class="info-label">Xác minh Email</span>
                            <span class="info-value">
                                @if (Model.EmailVerified)
                                {
                                    <span style="color:#16a34a"><i class="bi bi-check-circle-fill"></i> Đã xác minh</span>
                                }
                                else
                                {
                                    <span style="color:#dc2626"><i class="bi bi-x-circle-fill"></i> Chưa xác minh</span>
                                }
                            </span>
                        </div>
                    </div>

                    <!-- TRẠNG THÁI hiện tại -->
                    <div class="mb-2">
                        <label class="form-label d-block">Trạng Thái Hiện Tại</label>
                        @{
                            var (badgeClass, badgeIcon, badgeText) = Model.Status switch
                            {
                                2 => ("status-locked", "bi-pause-circle", "Tạm khóa"),
                                3 => ("status-banned", "bi-ban", "Đã cấm"),
                                _ => ("status-active", "bi-check-circle", "Hoạt động")
                            };
                        }
                        <span class="status-badge @badgeClass">
                            <i class="bi @badgeIcon"></i> @badgeText
                        </span>
                        <p class="hint mt-2">Đổi trạng thái tại trang danh sách</p>
                    </div>

                </div>
            </div>

            <!-- Buttons -->
            <div style="display:flex;flex-direction:column;gap:10px">
                <button type="submit" class="btn-primary" style="justify-content:center;padding:11px">
                    <i class="bi bi-floppy"></i> Lưu Thay Đổi
                </button>
                <a asp-area="Admin" asp-controller="User" asp-action="Index"
                   class="btn-secondary" style="justify-content:center;padding:11px">
                    <i class="bi bi-arrow-left"></i> Hủy / Quay lại
                </a>
            </div>
        </div>

    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Hiện validation-summary nếu có lỗi
        const summary = document.querySelector('[data-valmsg-summary]');
        if (summary && summary.querySelector('li')) {
            summary.style.display = 'block';
        }

        // Toast thông báo sau submit (nếu dùng Ajax)
        document.getElementById('editUserForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const form = this;
            const data = new FormData(form);

            try {
                const res = await fetch(form.action, { method: 'POST', body: data });
                const json = await res.json();

                if (json.success) {
                    alert('✅ ' + (json.message ?? 'Cập nhật thành công!'));
                    window.location.href = '@Url.Action("Index", "User", new { area = "Admin" })';
                } else {
                    alert('❌ ' + (json.message ?? 'Có lỗi xảy ra.'));
                }
            } catch {
                alert('❌ Không thể kết nối máy chủ.');
            }
        });
    </script>
}
