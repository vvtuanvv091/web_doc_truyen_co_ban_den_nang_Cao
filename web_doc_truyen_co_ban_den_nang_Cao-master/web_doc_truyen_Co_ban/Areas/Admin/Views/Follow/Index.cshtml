@model IEnumerable<web_doc_truyen_Co_ban.Models.FollowModel>
@{
    ViewData["Title"] = "Quản lý theo dõi truyện";
    int page       = (int)ViewBag.Page;
    int totalPages = (int)ViewBag.TotalPages;
    int total      = (int)ViewBag.Total;
    string? search  = ViewData["Search"] as string;
    string? storyId = ViewData["StoryId"] as string;
    int? status     = ViewData["Status"] as int?;
}

@section Styles {
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<style>
    :root {
        --c-bg:        #f5f6fa;
        --c-card:      #ffffff;
        --c-border:    #e8eaf0;
        --c-text:      #1a1d2e;
        --c-muted:     #6b7280;
        --c-accent:    #4f63d2;
        --c-accent-lt: #eef0fd;
        --c-green:     #059669;
        --c-green-lt:  #ecfdf5;
        --c-amber:     #d97706;
        --c-amber-lt:  #fffbeb;
        --c-red:       #dc2626;
        --c-red-lt:    #fef2f2;
        --c-gray-lt:   #f3f4f6;
        --c-teal:      #0d9488;
        --c-teal-lt:   #f0fdfa;
        --radius:      10px;
        --radius-lg:   14px;
        --shadow:      0 1px 3px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.04);
        --shadow-md:   0 4px 12px rgba(0,0,0,.08);
    }

    .sc-wrap         { background: var(--c-bg); min-height: 100vh; padding: 28px 32px; font-family: 'Nunito','Segoe UI',sans-serif; color: var(--c-text); }

    /* breadcrumb */
    .sc-breadcrumb   { font-size: 12px; color: var(--c-muted); margin-bottom: 6px; }
    .sc-breadcrumb a { color: var(--c-accent); text-decoration: none; }
    .sc-topbar       { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .sc-topbar h1    { font-size: 22px; font-weight: 700; letter-spacing: -.4px; }

    /* metric cards */
    .sc-metrics      { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; margin-bottom: 24px; }
    .sc-mc           { background: var(--c-card); border-radius: var(--radius-lg); padding: 18px 20px; box-shadow: var(--shadow); display: flex; align-items: center; gap: 16px; }
    .sc-mc-icon      { width: 44px; height: 44px; border-radius: var(--radius); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .sc-mc-body label{ font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--c-muted); }
    .sc-mc-body .val { font-size: 26px; font-weight: 700; line-height: 1.1; margin-top: 2px; }
    .sc-mc-body .sub { font-size: 11px; margin-top: 3px; color: var(--c-muted); }

    /* charts row */
    .sc-charts       { display: grid; grid-template-columns: 2fr 1fr; gap: 14px; margin-bottom: 24px; }
    .sc-chart-card   { background: var(--c-card); border-radius: var(--radius-lg); padding: 18px 20px; box-shadow: var(--shadow); }
    .sc-chart-title  { font-size: 13px; font-weight: 700; color: var(--c-muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 14px; }

    /* hot list */
    .sc-hot          { background: var(--c-card); border-radius: var(--radius-lg); padding: 18px 20px; box-shadow: var(--shadow); }
    .sc-hot-item     { display: flex; gap: 10px; padding: 9px 0; border-bottom: 1px solid var(--c-border); align-items: center; }
    .sc-hot-item:last-child { border-bottom: none; padding-bottom: 0; }
    .sc-hot-rank     { font-size: 13px; font-weight: 700; color: var(--c-muted); min-width: 20px; }
    .sc-hot-rank.top { color: var(--c-amber); }
    .sc-hot-body     { flex: 1; min-width: 0; }
    .sc-hot-story    { font-size: 12px; color: var(--c-accent); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sc-hot-meta     { display: flex; align-items: center; gap: 6px; margin-top: 3px; font-size: 11px; color: var(--c-muted); }

    /* top-user list */
    .sc-user-item    { display: flex; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--c-border); align-items: center; }
    .sc-user-item:last-child { border-bottom: none; padding-bottom: 0; }

    /* filter bar */
    .sc-filterbar    { background: var(--c-card); border-radius: var(--radius-lg); padding: 14px 18px; box-shadow: var(--shadow); margin-bottom: 16px; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .sc-filterbar input,
    .sc-filterbar select { height: 36px; padding: 0 12px; font-size: 13px; border: 1.5px solid var(--c-border); border-radius: var(--radius); background: var(--c-bg); color: var(--c-text); outline: none; transition: border-color .15s; font-family: inherit; }
    .sc-filterbar input:focus,
    .sc-filterbar select:focus { border-color: var(--c-accent); }
    .sc-filterbar input  { width: 220px; }
    .sc-filterbar .ml-auto { margin-left: auto; }

    /* buttons */
    .btn-sc          { display: inline-flex; align-items: center; gap: 6px; height: 36px; padding: 0 16px; border-radius: var(--radius); border: 1.5px solid transparent; font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none; transition: all .15s; white-space: nowrap; font-family: inherit; }
    .btn-accent      { background: var(--c-accent); color: #fff; border-color: var(--c-accent); }
    .btn-accent:hover{ background: #3d50b8; border-color: #3d50b8; color: #fff; }
    .btn-outline     { background: transparent; color: var(--c-text); border-color: var(--c-border); }
    .btn-outline:hover{ background: var(--c-gray-lt); }
    .btn-sm          { height: 29px; padding: 0 10px; font-size: 12px; border-radius: 7px; }
    .btn-ghost-blue  { background: var(--c-accent-lt); color: var(--c-accent); border-color: var(--c-accent-lt); }
    .btn-ghost-blue:hover  { background: #dde1fa; }
    .btn-ghost-amber { background: var(--c-amber-lt); color: var(--c-amber); border-color: var(--c-amber-lt); }
    .btn-ghost-amber:hover { background: #fef3c7; }
    .btn-ghost-red   { background: var(--c-red-lt); color: var(--c-red); border-color: var(--c-red-lt); }
    .btn-ghost-red:hover   { background: #fee2e2; }
    .btn-ghost-green { background: var(--c-green-lt); color: var(--c-green); border-color: var(--c-green-lt); }
    .btn-ghost-green:hover { background: #d1fae5; }

    /* table card */
    .sc-table-card   { background: var(--c-card); border-radius: var(--radius-lg); box-shadow: var(--shadow); overflow: hidden; }
    .sc-table-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; border-bottom: 1px solid var(--c-border); }
    .sc-table-header h2  { font-size: 15px; font-weight: 700; }
    .sc-table-header .count { font-size: 12px; font-weight: 600; color: var(--c-muted); background: var(--c-gray-lt); padding: 3px 10px; border-radius: 20px; margin-left: 8px; }

    table.sc-table   { width: 100%; border-collapse: collapse; }
    .sc-table thead tr{ background: #fafbff; }
    .sc-table th     { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--c-muted); padding: 11px 14px; text-align: left; border-bottom: 1px solid var(--c-border); white-space: nowrap; }
    .sc-table td     { padding: 11px 14px; font-size: 13px; border-bottom: 1px solid var(--c-border); vertical-align: middle; }
    .sc-table tbody tr:last-child td { border-bottom: none; }
    .sc-table tbody tr:hover td { background: #fafbff; }

    /* avatar */
    .ava             { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; flex-shrink: 0; }
    .ava-blue        { background: #dbeafe; color: #1d4ed8; }
    .ava-green       { background: #d1fae5; color: #065f46; }
    .ava-amber       { background: #fef3c7; color: #92400e; }
    .ava-pink        { background: #fce7f3; color: #9d174d; }
    .ava-purple      { background: #ede9fe; color: #5b21b6; }
    .ava-teal        { background: #ccfbf1; color: #134e4a; }

    /* badges */
    .badge           { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 20px; white-space: nowrap; }
    .badge-show      { background: var(--c-green-lt); color: var(--c-green); }
    .badge-hide      { background: var(--c-amber-lt); color: var(--c-amber); }
    .badge-del       { background: var(--c-red-lt);   color: var(--c-red); }

    .actions         { display: flex; gap: 5px; }

    /* pagination */
    .sc-pagination   { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-top: 1px solid var(--c-border); }
    .sc-pag-info     { font-size: 13px; color: var(--c-muted); }
    .sc-pag-btns     { display: flex; gap: 4px; }
    .pag-btn         { height: 32px; min-width: 32px; padding: 0 8px; border-radius: 8px; border: 1.5px solid var(--c-border); background: transparent; color: var(--c-text); font-size: 13px; cursor: pointer; font-family: inherit; transition: all .12s; }
    .pag-btn:hover:not(:disabled):not(.active) { background: var(--c-gray-lt); }
    .pag-btn.active  { background: var(--c-accent); border-color: var(--c-accent); color: #fff; font-weight: 700; }
    .pag-btn:disabled{ opacity: .35; cursor: default; }

    /* toast */
    .sc-toast        { position: fixed; bottom: 28px; right: 28px; background: #1a1d2e; color: #fff; padding: 12px 20px; border-radius: var(--radius); font-size: 13px; font-weight: 600; box-shadow: var(--shadow-md); z-index: 9999; display: flex; align-items: center; gap: 10px; opacity: 0; transform: translateY(10px); transition: all .25s; pointer-events: none; }
    .sc-toast.show   { opacity: 1; transform: translateY(0); }
    .sc-toast.success{ border-left: 4px solid var(--c-green); }
    .sc-toast.error  { border-left: 4px solid var(--c-red); }

    /* empty */
    .sc-empty        { text-align: center; padding: 64px 0; color: var(--c-muted); }
    .sc-empty i      { font-size: 40px; margin-bottom: 12px; display: block; opacity: .35; }
    .sc-empty p      { font-size: 14px; }

    @@media (max-width: 900px) {
        .sc-metrics  { grid-template-columns: repeat(2,1fr); }
        .sc-charts   { grid-template-columns: 1fr; }
    }
</style>
}

<div class="sc-wrap">

    <div class="sc-breadcrumb">
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Tổng quan</a>
        &rsaquo; Theo dõi truyện
    </div>

    <div class="sc-topbar">
        <h1>
            <i class="bi bi-bookmark-heart-fill" style="color:var(--c-accent);font-size:20px;margin-right:8px"></i>
            Theo dõi truyện
        </h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div id="toastEl" class="sc-toast success show">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div id="toastEl" class="sc-toast error show">
            <i class="bi bi-x-circle-fill"></i> @TempData["Error"]
        </div>
    }
    <div class="sc-metrics">
        <div class="sc-mc">
            <div class="sc-mc-icon" style="background:#eef0fd;color:var(--c-accent)">
                <i class="bi bi-bookmark-heart-fill"></i>
            </div>
            <div class="sc-mc-body">
                <label>Tổng theo dõi</label>
                <div class="val">@ViewBag.TotalAll.ToString("N0")</div>
                <div class="sub">tất cả trạng thái</div>
            </div>
        </div>
        <div class="sc-mc">
            <div class="sc-mc-icon" style="background:var(--c-green-lt);color:var(--c-green)">
                <i class="bi bi-eye-fill"></i>
            </div>
            <div class="sc-mc-body">
                <label>Đang hiển thị</label>
                <div class="val" style="color:var(--c-green)">@ViewBag.TotalVisible.ToString("N0")</div>
                <div class="sub">
                    @if (ViewBag.TotalAll > 0)
                    {
                        @(((double)ViewBag.TotalVisible / (double)ViewBag.TotalAll * 100).ToString("0.#"))
                        <text>%</text>
                    }
                </div>
            </div>
        </div>
        <div class="sc-mc">
            <div class="sc-mc-icon" style="background:var(--c-amber-lt);color:var(--c-amber)">
                <i class="bi bi-eye-slash-fill"></i>
            </div>
            <div class="sc-mc-body">
                <label>Đã ẩn</label>
                <div class="val" style="color:var(--c-amber)">@ViewBag.TotalHidden.ToString("N0")</div>
                <div class="sub">chờ xét duyệt</div>
            </div>
        </div>
        <div class="sc-mc">
            <div class="sc-mc-icon" style="background:var(--c-red-lt);color:var(--c-red)">
                <i class="bi bi-trash3-fill"></i>
            </div>
            <div class="sc-mc-body">
                <label>Đã xóa</label>
                <div class="val" style="color:var(--c-red)">@ViewBag.TotalDeleted.ToString("N0")</div>
                <div class="sub">soft delete</div>
            </div>
        </div>
    </div>
    <div class="sc-charts">
        <div class="sc-chart-card">
            <div class="sc-chart-title">
                <i class="bi bi-bar-chart-fill" style="color:var(--c-accent)"></i> Theo dõi 7 ngày qua
            </div>
            <div style="position:relative;height:180px">
                <canvas id="chartWeek" role="img" aria-label="Biểu đồ theo dõi 7 ngày">Dữ liệu đang tải...</canvas>
            </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:14px">

            <div class="sc-hot">
                <div class="sc-chart-title">
                    <i class="bi bi-fire" style="color:var(--c-amber)"></i> Truyện được follow nhiều nhất
                </div>
                <div id="topStoriesEl">
                    <div style="text-align:center;padding:20px 0;color:var(--c-muted);font-size:13px">Đang tải...</div>
                </div>
            </div>
            <div class="sc-hot">
                <div class="sc-chart-title">
                    <i class="bi bi-person-fill" style="color:var(--c-teal)"></i> Người dùng follow nhiều nhất
                </div>
                <div id="topUsersEl">
                    <div style="text-align:center;padding:20px 0;color:var(--c-muted);font-size:13px">Đang tải...</div>
                </div>
            </div>

        </div>
    </div>
    <div class="sc-filterbar">
        <form method="get" asp-action="Index" style="display:contents">
            <i class="bi bi-search" style="color:var(--c-muted);font-size:14px"></i>
            <input type="text" name="search" value="@search" placeholder="Tìm tên truyện, tên user…">

            <select name="storyId">
                <option value="">Tất cả truyện</option>
                @foreach (var s in ViewBag.Stories)
                {
                    <option value="@s.Id" selected="@(storyId == s.Id.ToString())">
                        @s.Title
                    </option>
                }
            </select>

            <select name="status">
            <option value="0" selected="@(status == 0)">Hiển thị</option>
            <option value="1" selected="@(status == 1)">Đã ẩn</option>
            @* <option value="2" selected="@(status == 2)">Đã xóa</option> *@
            </select>

            <button type="submit" class="btn-sc btn-accent" style="height:36px">
                <i class="bi bi-funnel-fill"></i> Lọc
            </button>

            @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(storyId) || status.HasValue)
            {
                <a asp-action="Index" class="btn-sc btn-outline" style="height:36px">
                    <i class="bi bi-x-lg"></i> Xóa bộ lọc
                </a>
            }
        </form>

        <div class="ml-auto" style="font-size:12px;color:var(--c-muted)">
            <i class="bi bi-list-ul"></i> @total kết quả
        </div>
    </div>

    <div class="sc-table-card">
        <div class="sc-table-header">
            <div style="display:flex;align-items:center">
                <h2>Danh sách theo dõi</h2>
                <span class="count">@total</span>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="sc-empty">
                <i class="bi bi-bookmark-x"></i>
                <p>Không tìm thấy theo dõi nào.</p>
            </div>
        }
        else
        {
            <div style="overflow-x:auto">
                <table class="sc-table">
                    <thead>
                        <tr>
                            <th style="width:42px">#</th>
                            <th style="width:160px">Người dùng</th>
                            <th>Truyện</th>
                            <th style="width:100px">Trạng thái</th>
                            <th style="width:100px">Ngày theo dõi</th>
                            <th style="width:110px">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowNum = (page - 1) * (int)ViewBag.PageSize;
                            string[] avaColors = { "ava-blue","ava-green","ava-amber","ava-pink","ava-purple","ava-teal" };
                        }
                        @foreach (var f in Model)
                        {
                            rowNum++;
                            var ava      = avaColors[rowNum % avaColors.Length];
                            var username = f.User?.Username ?? "—";
                            var initials = string.Join("", username.Split(' ').TakeLast(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""));
                            <tr>
                                <td style="color:var(--c-muted);font-size:12px">@rowNum</td>

                                <td>
                                    <div style="display:flex;align-items:center;gap:8px">
                                        <div class="ava @ava">@initials</div>
                                        <span style="font-weight:600;font-size:12px;white-space:nowrap">@username</span>
                                    </div>
                                </td>

                                <td style="font-size:12px;max-width:240px">
                                    <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:600;color:var(--c-accent)">
                                        @(f.Story?.Title ?? "—")
                                    </div>
                                </td>

                                <td>
                                    @if (f.Status == 0)
                                    {
                                        <span class="badge badge-show"><i class="bi bi-circle-fill" style="font-size:6px"></i> Hiển Thị</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-hide"><i class="bi bi-circle-fill" style="font-size:6px"></i> Đã Ân</span>
                                    }

                                </td>

                                <td style="font-size:11px;color:var(--c-muted);white-space:nowrap">
                                    @f.CreatedAt.ToString("dd/MM/yyyy")<br />@f.CreatedAt.ToString("HH:mm")
                                </td>

                                <td>
                                    <div class="actions">
                                        <a asp-action="Edit" asp-route-id="@f.Id"
                                           class="btn-sc btn-sm btn-outline" title="Sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        @if (f.Status == 0)
                                        {
                                            <button type="button" class="btn-sc btn-sm btn-ghost-amber"
                                                    title="Ẩn theo dõi" onclick="toggleStatus('@f.Id', this)">
                                                <i class="bi bi-eye-slash"></i>
                                            </button>
                                        }
                                        else if (f.Status == 1)
                                        {
                                            <button type="button" class="btn-sc btn-sm btn-ghost-green"
                                                    title="Hiện theo dõi" onclick="toggleStatus('@f.Id', this)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        }

                                        <a asp-action="Delete" asp-route-id="@f.Id"
                                           class="btn-sc btn-sm btn-ghost-red" title="Xóa">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="sc-pagination">
                <span class="sc-pag-info">
                    Trang @@page / @totalPages &nbsp;·&nbsp; @total theo dõi
                </span>
                <div class="sc-pag-btns">
                    <button class="pag-btn" @(page <= 1 ? "disabled" : "") onclick="goPage(@(page-1))">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        if (p == 1 || p == totalPages || Math.Abs(p - page) <= 1)
                        {
                            <button class="pag-btn @(p == page ? "active" : "")" onclick="goPage(@p)">@p</button>
                        }
                        else if (Math.Abs(p - page) == 2)
                        {
                            <span style="padding:0 4px;color:var(--c-muted);line-height:32px">…</span>
                        }
                    }
                    <button class="pag-btn" @(page >= totalPages ? "disabled" : "") onclick="goPage(@(page+1))">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>

</div>

<div class="sc-toast" id="ajaxToast"></div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    // ── Pagination ─────────────────────────────────────────────────────
    function goPage(p) {
        const url = new URL(window.location.href);
        url.searchParams.set('page', p);
        window.location.href = url.toString();
    }

    // ── Toast ──────────────────────────────────────────────────────────
    const toastEl = document.getElementById('toastEl');
    if (toastEl) setTimeout(() => toastEl.classList.remove('show'), 3500);

    function showToast(msg, type = 'success') {
        const t = document.getElementById('ajaxToast');
        t.textContent = msg;
        t.className = 'sc-toast ' + type + ' show';
        setTimeout(() => t.classList.remove('show'), 3000);
    }

    // ── Toggle AJAX ────────────────────────────────────────────────────
    async function toggleStatus(id, btn) {
        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            const res = await fetch('@Url.Action("ToggleStatus", "Follow", new { area = "Admin" })', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': token
                },
                body: 'id=' + encodeURIComponent(id)
            });
            const data = await res.json();
            if (data.success) {
                showToast(data.newStatus === 0 ? 'Đã hiện theo dõi.' : 'Đã ẩn theo dõi.');
                setTimeout(() => location.reload(), 800);
            } else {
                showToast(data.message || 'Có lỗi xảy ra.', 'error');
            }
        } catch (e) {
            showToast('Không thể kết nối server.', 'error');
        }
    }

    // ── Weekly chart ───────────────────────────────────────────────────
    async function loadWeeklyChart() {
        try {
            const res  = await fetch('@Url.Action("ChartWeekly", "Follow", new { area = "Admin" })');
            const data = await res.json();
            new Chart(document.getElementById('chartWeek'), {
                type: 'bar',
                data: {
                    labels: data.map(d => d.date),
                    datasets: [{
                        label: 'Theo dõi',
                        data: data.map(d => d.count),
                        backgroundColor: '#c7cef7',
                        borderColor: '#4f63d2',
                        borderWidth: 2,
                        borderRadius: 6,
                        borderSkipped: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 11 } } },
                        y: { grid: { color: 'rgba(0,0,0,.05)' }, ticks: { font: { size: 11 }, maxTicksLimit: 5, precision: 0 }, beginAtZero: true }
                    }
                }
            });
        } catch (e) { console.warn('Chart load failed', e); }
    }

    // ── Top truyện được follow nhiều nhất ──────────────────────────────
    async function loadTopStories() {
        try {
            const res  = await fetch('@Url.Action("ChartTopStories", "Follow", new { area = "Admin" })');
            const data = await res.json();
            const el   = document.getElementById('topStoriesEl');
            if (!data.length) {
                el.innerHTML = '<p style="text-align:center;color:#6b7280;font-size:13px;padding:16px 0">Chưa có dữ liệu.</p>';
                return;
            }
            el.innerHTML = data.slice(0, 5).map((d, i) => `
                <div class="sc-hot-item">
                    <div class="sc-hot-rank ${i < 3 ? 'top' : ''}">${i + 1}</div>
                    <div class="sc-hot-body">
                        <div class="sc-hot-story">${d.title}</div>
                        <div class="sc-hot-meta">
                            <i class="bi bi-bookmark-heart" style="font-size:11px"></i> ${d.count} lượt theo dõi
                        </div>
                    </div>
                </div>`).join('');
        } catch (e) { console.warn('Top stories load failed', e); }
    }

    // ── Top người dùng follow nhiều nhất ──────────────────────────────
    async function loadTopUsers() {
        try {
            const res  = await fetch('@Url.Action("ChartTopUsers", "Follow", new { area = "Admin" })');
            const data = await res.json();
            const el   = document.getElementById('topUsersEl');
            if (!data.length) {
                el.innerHTML = '<p style="text-align:center;color:#6b7280;font-size:13px;padding:16px 0">Chưa có dữ liệu.</p>';
                return;
            }
            const avaList = ['ava-blue','ava-green','ava-amber','ava-pink','ava-purple','ava-teal'];
            el.innerHTML = data.slice(0, 5).map((d, i) => {
                const initials = d.username.split(' ').slice(-2).map(w => w[0]?.toUpperCase() ?? '').join('');
                const ava = avaList[i % avaList.length];
                return `
                <div class="sc-user-item">
                    <div class="sc-hot-rank ${i < 3 ? 'top' : ''}">${i + 1}</div>
                    <div class="ava ${ava}" style="width:28px;height:28px;font-size:10px">${initials}</div>
                    <div class="sc-hot-body">
                        <div style="font-size:12px;font-weight:600;color:var(--c-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${d.username}</div>
                        <div class="sc-hot-meta">
                            <i class="bi bi-bookmark-heart" style="font-size:11px;color:var(--c-teal)"></i> ${d.count} truyện đang theo dõi
                        </div>
                    </div>
                </div>`;
            }).join('');
        } catch (e) { console.warn('Top users load failed', e); }
    }

    loadWeeklyChart();
    loadTopStories();
    loadTopUsers();
</script>
}
