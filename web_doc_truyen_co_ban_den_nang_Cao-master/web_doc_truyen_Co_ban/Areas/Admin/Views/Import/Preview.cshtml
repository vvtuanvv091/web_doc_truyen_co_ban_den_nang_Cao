@model web_doc_truyen_Co_ban.Models.StoryModel
@{
    ViewData["Title"] = "Preview trước khi Import";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var apiTags = ViewBag.Tags as List<string> ?? new List<string>();   
    // ← Thêm dòng này
    var chapters = ViewBag.Chapters as List<web_doc_truyen_Co_ban.Models.ChapterModel> 
                   ?? new List<web_doc_truyen_Co_ban.Models.ChapterModel>();
}
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Xem trước truyện</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/Admin/Home">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Admin/Import">Import MangaDex</a></li>
        <li class="breadcrumb-item active">Preview</li>
    </ol>

    <div class="row g-4">
        <!-- Cột trái: ảnh bìa + thông tin API -->
        <div class="col-md-3">
            @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
            {
                <img src="@Model.CoverImageUrl"
                     class="img-fluid rounded shadow"
                     alt="@Model.Title"
                     onerror="this.src='/img/no-cover.png'" />
            }
            <div class="mt-3">
                <h5 class="fw-bold">@Model.Title</h5>
                <p class="text-muted mb-1"><i class="fas fa-user"></i> @(Model.OriginalAuthor ?? "—")</p>
                <p class="text-muted mb-1">
                    <i class="fas fa-circle-dot"></i> @(Model.Status switch
                    {
                        1 => "Đang tiến hành",
                        2 => "Hoàn thành",
                        3 => "Tạm dừng",
                        4 => "Đã hủy",
                        _ => "Không rõ"
                    })
                </p>
                @if (Model.Is18Plus)
                {
                    <span class="badge bg-danger">18+</span>
                }
            </div>

            @if (apiTags.Any())
            {
                <div class="mt-3">
                    <strong>Tags từ MangaDex:</strong>
                    <div class="mt-1 d-flex flex-wrap gap-1">
                        @foreach (var tag in apiTags)
                        {
                            <span class="badge bg-light text-dark border" style="font-size:0.75rem;">@tag</span>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Cột phải: form import -->
        <div class="col-md-9">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <i class="fas fa-file-import me-1"></i> Cấu hình Import
                </div>
                <div class="card-body">
                    <form method="post" action="/Admin/Import/DoImport">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="mangaDexId" value="@ViewBag.MangaDexId" />

                        <!-- Description (readonly, từ API) -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mô tả (từ MangaDex)</label>
                            <textarea class="form-control" rows="5" readonly>@Model.Description</textarea>
                            <div class="form-text">Bạn có thể chỉnh sửa sau trong mục Quản lý truyện.</div>
                        </div>

                        <!-- Source URL (readonly) -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nguồn</label>
                            <input type="text" class="form-control" value="@Model.Source" readonly />
                        </div>

                        <!-- Category (BẮT BUỘC admin chọn) -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Category <span class="text-danger">*</span>
                            </label>
                            <select name="categoryId" class="form-select" required>
                                <option value="">-- Chọn thể loại --</option>
                                @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Categories)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>

                        <!-- Tags (admin chọn từ DB của mình) -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tags hệ thống</label>
                            <select name="selectedTags" class="form-select" multiple size="6">
                                @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.MultiSelectList)ViewBag.AllTags)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                            <div class="form-text">Giữ Ctrl để chọn nhiều tag.</div>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="fas fa-file-import"></i> Import vào hệ thống
                            </button>
                            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-arrow-left"></i> Quay lại
                            </a>
                            <a href="@Model.Source" target="_blank" class="btn btn-outline-info btn-lg ms-auto">
                                <i class="fas fa-external-link-alt"></i> Xem trên MangaDex
                            </a>
                        </div>
                        <div class="card shadow-sm mt-4">
                            <div class="card-header bg-secondary text-white">
                                <i class="fas fa-list me-1"></i> Danh sách Chapters (@chapters.Count chương)
                            </div>
                            <div class="card-body p-0">
                                @if (!chapters.Any())
                                {
                                    <p class="text-muted p-3 mb-0">Không tìm thấy chapter nào.</p>
                                }
                                else
                                {
                                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                        <table class="table table-sm table-hover mb-0">
                                            <thead class="table-light sticky-top">
                                                <tr>
                                                    <th>Chapter</th>
                                                    <th>Tên chương</th>
                                                    <th>Số trang</th>
                                                    <th>Ngày đăng</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var ch in chapters)
                                                {
                                                    <tr>
                                                        <td><span class="badge bg-primary">@ch.ChapterNumber</span></td>
                                                        <td>@ch.Title</td>
                                                        <td>@ch.WordCount trang</td>
                                                        <td>@(ch.PublishedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
