@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

@model web_doc_truyen_Co_ban.DTO.RegisterDto

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Ký</title>

    <link rel="icon" type="image/svg+xml"
          href="data:image/svg+xml,
    <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'>
    <circle cx='50' cy='50' r='48' fill='%238b5cf6' />
    <text x='50' y='68' font-size='60' text-anchor='middle'
    fill='white' font-family='Arial'>L</text>
    </svg>">

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --bg1: #0f172a;
                --bg2: #1e1b4b;
                --bg3: #111827;
                --primary: #8b5cf6;
                --secondary: #ec4899;
                --info: #38bdf8;
                --text: #f8fafc;
                --muted: rgba(255,255,255,.68);
                --glass: rgba(255,255,255,.07);
                --glass-strong: rgba(255,255,255,.12);
                --border: rgba(255,255,255,.12);
                --radius: 26px;
                --radius-sm: 16px;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: 'Segoe UI',sans-serif;
                min-height: 100vh;
                background: linear-gradient(135deg,var(--bg1),var(--bg2),var(--bg3));
                color: var(--text);
                overflow-y: auto;
                overflow-x: hidden;
                position: relative;
                padding: 50px 20px;
            }

            /* =========================
                       Background
                    ==========================*/

            .bg {
                position: fixed;
                inset: 0;
                z-index: 0;
                overflow: hidden;
            }

            .blob {
                position: absolute;
                border-radius: 50%;
                filter: blur(70px);
                opacity: .30;
                animation: float 20s infinite linear;
            }

                .blob:nth-child(1) {
                    width: 520px;
                    height: 520px;
                    background: #8b5cf6;
                    top: -120px;
                    left: -120px;
                }

                .blob:nth-child(2) {
                    width: 420px;
                    height: 420px;
                    background: #ec4899;
                    top: 25%;
                    right: -100px;
                    animation-duration: 25s;
                }

                .blob:nth-child(3) {
                    width: 360px;
                    height: 360px;
                    background: #38bdf8;
                    bottom: -100px;
                    left: 30%;
                    animation-duration: 30s;
                }

            @@keyframes float {

                0% {
                    transform: translateY(0) rotate(0deg);
                }

                50% {
                    transform: translateY(-40px) rotate(180deg);
                }

                100% {
                    transform: translateY(0) rotate(360deg);
                }
            }

            /* =========================
                       Main Wrapper
                    ==========================*/

            .register-wrapper {
                width: 100%;
                max-width: 980px;
                margin: auto;
                position: relative;
                z-index: 2;
            }

            .register-card {
                display: flex;
                overflow: hidden;
                border-radius: var(--radius);
                background: rgba(15,23,42,.58);
                backdrop-filter: blur(28px);
                -webkit-backdrop-filter: blur(28px);
                border: 1px solid var(--border);
                box-shadow: 0 25px 80px rgba(0,0,0,.55), inset 0 1px 0 rgba(255,255,255,.08);
                animation: showCard .8s ease;
            }

            @@keyframes showCard {

                from {
                    opacity: 0;
                    transform: translateY(30px) scale(.96);
                }

                to {
                    opacity: 1;
                    transform: none;
                }
            }

            .left {
                flex: 1;
                padding: 55px 45px;
            }

            .right {
                width: 320px;
                padding: 50px 35px;
                background: rgba(255,255,255,.03);
                border-left: 1px solid rgba(255,255,255,.08);
                display: flex;
                flex-direction: column;
                justify-content: center;
                gap: 18px;
            }

            /* =========================
                       Header
                    ==========================*/

            .header {
                text-align: center;
                margin-bottom: 35px;
            }

            .logo {
                width: 78px;
                height: 78px;
                margin: auto auto 18px;
                border-radius: 22px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 34px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--primary), var(--secondary));
                box-shadow: 0 12px 40px rgba(139,92,246,.45);
            }

            .header h1 {
                font-size: 32px;
                margin-bottom: 8px;
            }

            .header p {
                color: var(--muted);
                font-size: 14px;
            }

            /* =========================
                       Form
                    ==========================*/

            .form-group {
                margin-bottom: 18px;
            }

            .input-box {
                position: relative;
            }

                .input-box input {
                    width: 100%;
                    padding: 20px 18px 18px 18px;
                    border: none;
                    outline: none;
                    background: var(--glass);
                    border: 1px solid var(--border);
                    border-radius: var(--radius-sm);
                    color: var(--text);
                    font-size: 15px;
                    transition: .3s;
                }

                    .input-box input:focus {
                        border-color: var(--primary);
                        box-shadow: 0 0 0 4px rgba(139,92,246,.15);
                    }

                .input-box label {
                    position: absolute;
                    left: 16px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: var(--muted);
                    pointer-events: none;
                    transition: .25s;
                    padding: 0 4px;
                }

                .input-box input:focus + label,
                .input-box input:not(:placeholder-shown) + label {
                    top: 0;
                    font-size: 12px;
                    background: #1b1c3f;
                    color: var(--primary);
                }

            .error {
                color: #fb7185;
                font-size: 12px;
                margin-top: 6px;
                padding-left: 5px;
                min-height: 18px;
            }

            /* =========================
                       Password Toggle
                    ==========================*/

            .toggle-password {
                position: absolute;
                right: 14px;
                top: 50%;
                transform: translateY(-50%);
                border: none;
                background: none;
                color: var(--muted);
                cursor: pointer;
                font-size: 18px;
            }

            /* =========================
                       Login Link
                    ==========================*/

            .login-link {
                margin-top: 10px;
                font-size: 14px;
                color: var(--muted);
            }

                .login-link a {
                    text-decoration: none;
                    color: var(--primary);
                    font-weight: 600;
                }

                    .login-link a:hover {
                        color: var(--secondary);
                    }

            /* =========================
                       Button
                    ==========================*/

            .btn-register {
                width: 100%;
                border: none;
                cursor: pointer;
                padding: 16px;
                border-radius: var(--radius-sm);
                background: linear-gradient(135deg, var(--primary), var(--secondary));
                color: white;
                font-size: 15px;
                font-weight: 600;
                transition: .3s;
                position: relative;
                overflow: hidden;
            }

                .btn-register:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 12px 35px rgba(139,92,246,.35);
                }

                .btn-register:disabled {
                    opacity: .7;
                    cursor: not-allowed;
                }

            .loader {
                display: none;
                gap: 5px;
                justify-content: center;
                align-items: center;
            }

                .loader.active {
                    display: flex;
                }

                .loader span {
                    width: 5px;
                    height: 15px;
                    border-radius: 10px;
                    background: white;
                    animation: loading .8s infinite;
                }

                    .loader span:nth-child(2) {
                        animation-delay: .15s;
                    }

                    .loader span:nth-child(3) {
                        animation-delay: .3s;
                    }

            @@keyframes loading {

                0%, 100% {
                    transform: scaleY(.4);
                    opacity: .5;
                }

                50% {
                    transform: scaleY(1);
                    opacity: 1;
                }
            }

            /* =========================
                       Right Panel
                    ==========================*/

            .right-title {
                text-align: center;
                margin-bottom: 8px;
            }

                .right-title h3 {
                    margin-bottom: 6px;
                }

                .right-title p {
                    color: var(--muted);
                    font-size: 13px;
                }

            .social-btn {
                width: 100%;
                border: none;
                cursor: pointer;
                padding: 14px 18px;
                border-radius: var(--radius-sm);
                background: var(--glass);
                border: 1px solid var(--border);
                color: white;
                display: flex;
                align-items: center;
                gap: 14px;
                transition: .25s;
            }

                .social-btn:hover {
                    transform: translateX(4px);
                    background: var(--glass-strong);
                }

                .social-btn svg {
                    width: 22px;
                    height: 22px;
                }

            /* =========================
                       Success Overlay
                    ==========================*/

            .success {
                position: absolute;
                inset: 0;
                display: none;
                align-items: center;
                justify-content: center;
                flex-direction: column;
                background: rgba(15,23,42,.88);
                backdrop-filter: blur(12px);
                z-index: 20;
            }

                .success.active {
                    display: flex;
                }

            .success-icon {
                width: 82px;
                height: 82px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 42px;
                margin-bottom: 20px;
                background: linear-gradient(135deg, var(--primary), var(--secondary));
                animation: bounce .6s ease;
            }

            @@keyframes bounce {

                from {
                    transform: scale(0);
                }

                to {
                    transform: scale(1);
                }
            }

            .success h2 {
                margin-bottom: 10px;
            }

            .success p {
                color: var(--muted);
            }

            /* =========================
                       Responsive
                    ==========================*/

            @@media(max-width:768px) {

                body {
                    padding: 30px 15px;
                }

                .register-card {
                    flex-direction: column;
                }

                .right {
                    width: 100%;
                    border-left: none;
                    border-top: 1px solid rgba(255,255,255,.08);
                }

                .left,
                .right {
                    padding: 35px 25px;
                }
            }
    </style>
</head>
<body>

    <!-- Background -->
    <div class="bg">
        <div class="blob"></div>
        <div class="blob"></div>
        <div class="blob"></div>
    </div>

    <div class="register-wrapper">

        <div class="register-card">

            <!-- LEFT -->
            <div class="left">

                <div class="header">

                    <div class="logo">
                        L
                    </div>

                    <h1>Đăng Ký</h1>

                    <p>
                        Tạo tài khoản để tiếp tục sử dụng hệ thống
                    </p>

                </div>

                <form asp-action="Register"
                      asp-controller="Account"
                      method="post"
                      id="registerForm">

                    @Html.AntiForgeryToken()

                    <!-- Username -->
                    <div class="form-group">

                        <div class="input-box">

                            <input asp-for="Username"
                                   id="username"
                                   placeholder=" "
                                   autocomplete="username"
                                   required>

                            <label for="username">
                                Tên người dùng
                            </label>

                        </div>

                        <div class="error" id="usernameError"></div>

                    </div>

                    <!-- Email -->
                    <div class="form-group">

                        <div class="input-box">

                            <input asp-for="Email"
                                   type="email"
                                   id="email"
                                   placeholder=" "
                                   autocomplete="email"
                                   required>

                            <label for="email">
                                Địa chỉ email
                            </label>

                        </div>

                        <div class="error" id="emailError"></div>

                    </div>

                    <!-- Password -->
                    <div class="form-group">

                        <div class="input-box">

                            <input asp-for="Password"
                                   type="password"
                                   id="password"
                                   placeholder=" "
                                   autocomplete="new-password"
                                   required>

                            <label for="password">
                                Mật khẩu
                            </label>

                            <button type="button"
                                    class="toggle-password"
                                    id="togglePassword">
                                👁
                            </button>

                        </div>

                        <div class="error" id="passwordError"></div>

                    </div>

                    <!-- Confirm Password -->
                    <div class="form-group">

                        <div class="input-box">

                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   id="confirmPassword"
                                   placeholder=" "
                                   autocomplete="new-password"
                                   required>

                            <label for="confirmPassword">
                                Xác nhận mật khẩu
                            </label>

                            <button type="button"
                                    class="toggle-password"
                                    id="toggleConfirmPassword">
                                👁
                            </button>

                        </div>

                        <div class="error" id="confirmPasswordError"></div>

                    </div>

                    <button type="submit"
                            class="btn-register"
                            id="submitBtn">

                        <span class="btn-text">
                            Đăng Ký
                        </span>

                        <div class="loader" id="loader">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>

                    </button>

                    <div class="login-link">
                        Đã có tài khoản?
                        <a asp-action="Login"
                           asp-controller="Account">
                            Đăng nhập
                        </a>
                    </div>

                </form>

            </div>

            <!-- RIGHT -->
            <div class="right">

                <div class="right-title">

                    <h3>Đăng ký nhanh</h3>

                    <p>
                        Tiếp tục bằng tài khoản khác
                    </p>

                </div>

                <!-- Google -->
                <button type="button" class="social-btn">

                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                    </svg>

                    Tiếp tục với Google

                </button>

                <!-- Facebook -->
                <button type="button" class="social-btn">

                    <svg viewBox="0 0 24 24" fill="#1877F2">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                    </svg>

                    Tiếp tục với Facebook

                </button>

                <!-- Apple -->
                <button type="button" class="social-btn">

                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83" />
                    </svg>

                    Tiếp tục với Apple

                </button>

            </div>

            <!-- SUCCESS -->
            <div class="success" id="successBox">

                <div class="success-icon">
                    ✓
                </div>

                <h2>Đăng ký thành công</h2>

                <p>
                    Đang chuyển hướng...
                </p>

            </div>

        </div>

    </div>

    <script>

            document.addEventListener("DOMContentLoaded", () => {

                // =========================
                // Toggle Password
                // =========================

                function setupToggle(buttonId, inputId){

                    const btn = document.getElementById(buttonId);
                    const input = document.getElementById(inputId);

                    btn.addEventListener("click", () => {

                        if(input.type === "password"){

                            input.type = "text";
                            btn.innerHTML = "🙈";

                        }else{

                            input.type = "password";
                            btn.innerHTML = "👁";

                        }

                    });

                }

                setupToggle("togglePassword", "password");
                setupToggle("toggleConfirmPassword", "confirmPassword");

                // =========================
                // AJAX REGISTER
                // =========================

                const form = document.getElementById("registerForm");

                const submitBtn = document.getElementById("submitBtn");

                const loader = document.getElementById("loader");

                const btnText = document.querySelector(".btn-text");

                form.addEventListener("submit", async (e) => {

                    e.preventDefault();

                    // reset errors
                    document.getElementById("usernameError").innerText = "";
                    document.getElementById("emailError").innerText = "";
                    document.getElementById("passwordError").innerText = "";
                    document.getElementById("confirmPasswordError").innerText = "";

                    submitBtn.disabled = true;

                    btnText.style.display = "none";

                    loader.classList.add("active");

                    try{

                        const response = await fetch(form.action, {

                            method:"POST",

                            body:new FormData(form)

                        });

                        const result = await response.json();

                        if(result.success){

                            document
                                .getElementById("successBox")
                                .classList.add("active");

                            setTimeout(() => {

                                window.location.href =
                                    result.redirectUrl || "/";

                            },1500);

                        }else{

                            showError(result.message);

                            resetButton();

                        }

                    }
                    catch(error){

                        document.getElementById("emailError")
                                .innerText = "Có lỗi xảy ra.";

                        resetButton();

                    }

                });

                function showError(message){

                    const msg = message.toLowerCase();

                    if(msg.includes("tên")){

                        document.getElementById("usernameError")
                                .innerText = message;

                    }
                    else if(msg.includes("email")){

                        document.getElementById("emailError")
                                .innerText = message;

                    }
                    else if(msg.includes("xác nhận")){

                        document.getElementById("confirmPasswordError")
                                .innerText = message;

                    }
                    else{

                        document.getElementById("passwordError")
                                .innerText = message;

                    }

                }

                function resetButton(){

                    submitBtn.disabled = false;

                    loader.classList.remove("active");

                    btnText.style.display = "inline";

                }

            });

    </script>

</body>
</html>