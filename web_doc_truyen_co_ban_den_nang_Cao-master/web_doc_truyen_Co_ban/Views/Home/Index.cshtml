@model List<web_doc_truyen_Co_ban.Models.StoryModel>

@{
    ViewData["Title"] = "Trang Chủ";

    var hotStories = ViewBag.HotStories as List<web_doc_truyen_Co_ban.Models.StoryModel> ?? new();
    var newStories = ViewBag.NewStories as List<web_doc_truyen_Co_ban.Models.StoryModel> ?? new();
    var completeStories = ViewBag.CompleteStories as List<web_doc_truyen_Co_ban.Models.StoryModel> ?? new();
    var readHistory = ViewBag.ReadHistory as List<web_doc_truyen_Co_ban.Models.ReadingHistoryModel> ?? new();
    var categories = ViewBag.Categories as List<web_doc_truyen_Co_ban.Models.CategoryModel> ?? new();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"]</title>

    <!-- FONT AWESOME -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>

            :root {
                --bg: #0f1221;
                --card: #181c30;
                --border: #2b3150;
                --text: #fff;
                --muted: #a9afc7;
                --accent: #4d7dff;
                --accent2: #e8541a;
                --radius: 16px;
                --shadow: 0 10px 30px rgba(0,0,0,.25);
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                background: #0b0d18;
                color: var(--text);
                font-family: Segoe UI, sans-serif;
                overflow-x: hidden;
            }

            a {
                text-decoration: none;
                color: inherit;
            }

            img {
                display: block;
            }

            .container {
                width: 100%;
                max-width: 1400px;
                margin: auto;
                padding: 20px;
            }

            /* =========================
                       MOBILE TOPBAR
                    ========================= */

            .mobile-topbar,
            .mobile-menu,
            .mobile-overlay {
                display: none;
            }

            @@media(max-width:768px) {

                .mobile-topbar {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    position: sticky;
                    top: 0;
                    z-index: 9999;
                    width: 100%;
                    height: 60px;
                    padding: 0 14px;
                    background: #101427;
                    border-bottom: 1px solid rgba(255,255,255,.08);
                }

                .mobile-menu-btn {
                    width: 42px;
                    height: 42px;
                    border: none;
                    border-radius: 12px;
                    background: rgba(255,255,255,.08);
                    color: #fff;
                    font-size: 18px;
                    cursor: pointer;
                }

                .mobile-logo {
                    font-size: 24px;
                    font-weight: 800;
                    color: var(--accent);
                }

                .mobile-right {
                    display: flex;
                    gap: 8px;
                }

                .mobile-icon-btn {
                    width: 40px;
                    height: 40px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    border-radius: 12px;
                    background: rgba(255,255,255,.08);
                    color: #fff;
                }

                .mobile-overlay {
                    display: block;
                    position: fixed;
                    inset: 0;
                    background: rgba(0,0,0,.45);
                    opacity: 0;
                    visibility: hidden;
                    transition: .3s;
                    z-index: 9998;
                }

                    .mobile-overlay.active {
                        opacity: 1;
                        visibility: visible;
                    }

                .mobile-menu {
                    display: block;
                    position: fixed;
                    top: 0;
                    left: -280px;
                    width: 280px;
                    height: 100vh;
                    background: #171b2f;
                    z-index: 9999;
                    transition: .35s ease;
                    overflow-y: auto;
                }

                    .mobile-menu.active {
                        left: 0;
                    }

                .mobile-user {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    padding: 22px 18px;
                    border-bottom: 1px solid rgba(255,255,255,.08);
                }

                .mobile-avatar {
                    width: 52px;
                    height: 52px;
                    border-radius: 50%;
                    background: var(--accent);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-weight: 700;
                    font-size: 20px;
                }

                .mobile-user-name {
                    font-size: 15px;
                    font-weight: 700;
                }

                .mobile-user-mail {
                    font-size: 12px;
                    color: #b8bfd9;
                    margin-top: 3px;
                }

                .mobile-links {
                    padding: 14px;
                }

                    .mobile-links a {
                        display: flex;
                        align-items: center;
                        gap: 12px;
                        padding: 14px;
                        margin-bottom: 10px;
                        border-radius: 14px;
                        background: rgba(255,255,255,.05);
                        transition: .2s;
                    }

                        .mobile-links a:hover {
                            background: var(--accent);
                        }
            }

            /* =========================
                       HERO
                    ========================= */

            .hero {
                position: relative;
                width: 100%;
                overflow: hidden;
                margin-bottom: 30px;
            }

            .hero-track {
                position: relative;
                height: 520px;
            }

            .hero-slide {
                position: absolute;
                inset: 0;
                opacity: 0;
                transition: .5s;
                background-size: cover;
                background-position: center;
                border-radius: 22px;
                overflow: hidden;
            }

                .hero-slide.active {
                    opacity: 1;
                }

            .hero-overlay {
                position: absolute;
                inset: 0;
                background: linear-gradient(to top, rgba(0,0,0,.88), rgba(0,0,0,.1));
            }

            .hero-content {
                position: absolute;
                left: 40px;
                bottom: 40px;
                z-index: 5;
            }

                .hero-content h2 {
                    font-size: 46px;
                    font-weight: 800;
                    margin-bottom: 10px;
                }

            .hero-tags {
                display: flex;
                gap: 10px;
                flex-wrap: wrap;
            }

                .hero-tags span {
                    padding: 8px 14px;
                    border-radius: 999px;
                    background: rgba(255,255,255,.12);
                    font-size: 13px;
                }

            @@media(max-width:768px) {

                .hero-track {
                    height: 380px;
                }

                .hero-content h2 {
                    font-size: 28px;
                }
            }

            /* =========================
                       SECTION
                    ========================= */

            .section {
                margin-bottom: 40px;
            }

            .section-head {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 20px;
            }

            .section-title {
                font-size: 24px;
                font-weight: 800;
            }

            .story-grid {
                display: grid;
                grid-template-columns: repeat(5,1fr);
                gap: 18px;
            }

            @@media(max-width:1100px) {
                .story-grid {
                    grid-template-columns: repeat(4,1fr);
                }
            }

            @@media(max-width:768px) {
                .story-grid {
                    grid-template-columns: repeat(2,1fr);
                }
            }

            .story-card {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 18px;
                overflow: hidden;
                transition: .25s;
                box-shadow: var(--shadow);
            }

                .story-card:hover {
                    transform: translateY(-6px);
                    border-color: var(--accent);
                }

            .story-cover {
                position: relative;
                width: 100%;
                padding-top: 140%;
                overflow: hidden;
            }

                .story-cover img {
                    position: absolute;
                    inset: 0;
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

            .badge {
                position: absolute;
                top: 10px;
                left: 10px;
                padding: 5px 10px;
                border-radius: 999px;
                font-size: 11px;
                font-weight: 700;
                background: #ff4d4f;
            }

            .story-info {
                padding: 14px;
            }

            .story-title {
                font-size: 15px;
                font-weight: 700;
                line-height: 1.5;
                min-height: 46px;
            }

            .story-meta {
                margin-top: 8px;
                color: var(--muted);
                font-size: 13px;
            }
    </style>
</head>
<body>

    <!-- MOBILE NAVBAR -->

    <div class="mobile-topbar">

        <button class="mobile-menu-btn" id="mobileMenuBtn">
            <i class="fa fa-bars"></i>
        </button>

        <a href="/" class="mobile-logo">
            HiNovels
        </a>

        <div class="mobile-right">

            <a href="/Search" class="mobile-icon-btn">
                <i class="fa fa-search"></i>
            </a>

            <a href="/Notification" class="mobile-icon-btn">
                <i class="fa fa-bell"></i>
            </a>

        </div>

    </div>

    <div class="mobile-overlay" id="mobileOverlay"></div>

    <div class="mobile-menu" id="mobileMenu">

        <div class="mobile-user">

            <div class="mobile-avatar">
                C
            </div>

            <div>
                <div class="mobile-user-name">
                    cathu012
                </div>

                <div class="mobile-user-mail">
                    Thành viên
                </div>
            </div>

        </div>

        <div class="mobile-links">

            <a href="/">
                <i class="fa fa-home"></i>
                Trang Chủ
            </a>

            <a href="/">
                <i class="fa fa-home"></i>
                Danh mục truyện
            </a>

            <a href="/">
                <i class="fa fa-home"></i>
                Diễn đàn
            </a>

            <a href="/">
                <i class="fa fa-home"></i>
                Hội viên 
            </a>


            <a asp-controller="History" asp-action="Index">
                <i class="fa fa-clock"></i>
                Lịch Sử
            </a>

            <a href="/Favorite">
                <i class="fa fa-heart"></i>
                Yêu Thích
            </a>

            <a href="/Account/Logout">
                <i class="fa fa-right-from-bracket"></i>
                Đăng xuất
            </a>

        </div>

    </div>

    <!-- CONTENT -->

    <div class="container">

        <!-- HERO -->

        <div class="hero">

            <div class="hero-track">

                <div class="hero-slide active"
                     style="background-image:url('/assets/img/avatar-Arya-nhin-nghieng-che-mat-day-ve-bi-an-quyen-ru.webp')">

                    <div class="hero-overlay"></div>

                    <div class="hero-content">
                        <h2>Arya</h2>

                        <div class="hero-tags">
                            <span>Fantasy</span>
                            <span>Hành Động</span>
                            <span>Tiên Hiệp</span>
                        </div>
                    </div>

                </div>

                <div class="hero-slide"
                     style="background-image:url('/assets/img/hinh-nen-Arya-anime-cam-ly-nuoc-uong-trong-rat-tu-nhien.webp')">

                    <div class="hero-overlay"></div>

                    <div class="hero-content">
                        <h2>Ánh Mắt Không Màu</h2>

                        <div class="hero-tags">
                            <span>Drama</span>
                            <span>Ngôn Tình</span>
                        </div>
                    </div>

                </div>

            </div>

        </div>

        <!-- HOT -->

        <div class="section">

            <div class="section-head">
                <div class="section-title">
                    🔥 Truyện Nổi Bật
                </div>
            </div>

            <div class="story-grid">

                @foreach (var s in hotStories.Take(10))
                {
                    <a href="/Story/Detail/@s.Id" class="story-card">

                        <div class="story-cover">

                            @if (!string.IsNullOrEmpty(s.CoverImageUrl))
                            {
                                <img src="@GetImage(s.CoverImageUrl)"
                                     alt="@s.Title" />
                            }
                            else
                            {
                                <img src="/img/cat1.jpg" />
                            }

                            <div class="badge">
                                HOT
                            </div>

                        </div>

                        <div class="story-info">

                            <div class="story-title">
                                @s.Title
                            </div>

                            <div class="story-meta">
                                <i class="fa fa-eye"></i>
                                @s.TotalViews.ToString("N0")
                            </div>

                        </div>

                    </a>
                }

            </div>

        </div>

        <!-- NEW -->

        <div class="section">

            <div class="section-head">
                <div class="section-title">
                    ⚡ Truyện Mới
                </div>
            </div>

            <div class="story-grid">

                @foreach (var s in newStories.Take(10))
                {
                    <a href="/Story/Detail/@s.Id" class="story-card">

                        <div class="story-cover">

                            @if (!string.IsNullOrEmpty(s.CoverImageUrl))
                            {
                                <img src="@GetImage(s.CoverImageUrl)"
                                     alt="@s.Title" />
                            }
                            else
                            {
                                <img src="/img/cat1.jpg" />
                            }

                            <div class="badge"
                                 style="background:#20c997;">
                                NEW
                            </div>

                        </div>

                        <div class="story-info">

                            <div class="story-title">
                                @s.Title
                            </div>

                            <div class="story-meta">
                                <i class="fa fa-calendar"></i>
                                @s.UpdatedAt.ToString("dd/MM/yyyy")
                            </div>

                        </div>

                    </a>
                }

            </div>

        </div>

    </div>

    <script>

            document.addEventListener("DOMContentLoaded", function(){

                // =========================
                // MOBILE MENU
                // =========================

                const mobileBtn = document.getElementById("mobileMenuBtn");
                const mobileMenu = document.getElementById("mobileMenu");
                const mobileOverlay = document.getElementById("mobileOverlay");

                if(mobileBtn){

                    mobileBtn.addEventListener("click", function(){

                        mobileMenu.classList.add("active");
                        mobileOverlay.classList.add("active");

                    });

                }

                if(mobileOverlay){

                    mobileOverlay.addEventListener("click", function(){

                        mobileMenu.classList.remove("active");
                        mobileOverlay.classList.remove("active");

                    });

                }

                // =========================
                // HERO SLIDER
                // =========================

                const slides = document.querySelectorAll(".hero-slide");

                let current = 0;

                function showSlide(index){

                    slides.forEach(slide => {
                        slide.classList.remove("active");
                    });

                    slides[index].classList.add("active");

                }

                setInterval(function(){

                    current++;

                    if(current >= slides.length){
                        current = 0;
                    }

                    showSlide(current);

                }, 4000);

            });

    </script>

</body>
</html>

@functions {

    public string GetImage(string? url)
    {
        if (string.IsNullOrEmpty(url))
            return Url.Content("~/img/cat1.jpg");

        if (url.StartsWith("http"))
            return url;

        if (url.StartsWith("/"))
            return url;

        return Url.Content("~/img/" + url);
    }

}