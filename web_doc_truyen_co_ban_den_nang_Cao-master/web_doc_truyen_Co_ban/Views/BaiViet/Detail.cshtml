@model web_doc_truyen_Co_ban.Models.BaiVietModel

@{
    Layout = "~/Views/Shared/_Layout_Customer.cshtml";
    ViewData["Title"] = Model.Title;

    bool isOwner = (bool)(ViewBag.IsOwner ?? false);
    bool isAdmin = (bool)(ViewBag.IsAdmin ?? false);
    bool canEdit = isOwner || isAdmin;
    Guid? currentUserId = ViewBag.CurrentUserId as Guid?;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;500&display=swap');

    :root {
        --ink: #1a1208;
        --parchment: #fdf6e3;
        --parchment-dark: #f5e8c8;
        --red: #c0392b;
        --red-deep: #96261e;
        --gold: #d4a017;
        --gold-light: #f0c040;
        --jade: #2e7d6e;
        --border: #d9c49a;
        --muted: #8a7a5a;
    }

    body { background: #f0e8d5 !important; }

    .detail-wrap {
        font-family: 'Noto Sans SC', sans-serif;
        background: #f0e8d5;
        background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c8a96e' fill-opacity='0.08'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        min-height: 100vh;
        padding: 30px 24px 60px;
    }

    .detail-container { max-width: 900px; margin: 0 auto; }

    /* Breadcrumb */
    .forum-breadcrumb {
        font-size: 0.8rem; color: var(--muted); margin-bottom: 20px;
        display: flex; align-items: center; gap: 8px;
        font-family: 'Noto Serif SC', serif;
    }
    .forum-breadcrumb a { color: var(--gold); text-decoration: none; }
    .forum-breadcrumb a:hover { color: var(--red); }

    /* ── Main Post ── */
    .post-card {
        background: var(--parchment);
        border: 1px solid var(--border);
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.12);
        margin-bottom: 24px;
    }

    /* Post Header */
    .post-header {
        background: linear-gradient(135deg, #1a1208, #2d1f0e);
        border-bottom: 2px solid var(--gold);
        padding: 22px 28px;
        position: relative;
        overflow: hidden;
    }
    .post-header::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--gold-light), transparent);
    }

    .post-badges { display: flex; gap: 7px; margin-bottom: 10px; flex-wrap: wrap; }
    .badge-cat {
        background: rgba(212,160,23,0.15);
        border: 1px solid rgba(212,160,23,0.35);
        color: var(--gold);
        font-size: 0.73rem;
        padding: 2px 10px;
        border-radius: 2px;
        font-family: 'Noto Serif SC', serif;
        letter-spacing: 0.5px;
    }
    .badge-pin {
        background: var(--gold);
        color: var(--ink);
        font-size: 0.72rem;
        padding: 2px 9px;
        border-radius: 2px;
        font-weight: 700;
    }
    .badge-lock {
        background: var(--red);
        color: #fff;
        font-size: 0.72rem;
        padding: 2px 9px;
        border-radius: 2px;
    }

    .post-title {
        font-family: 'Noto Serif SC', serif;
        color: var(--gold-light);
        font-size: 1.4rem;
        font-weight: 700;
        line-height: 1.5;
        margin: 0 0 14px;
        letter-spacing: 1px;
        text-shadow: 0 2px 6px rgba(0,0,0,0.4);
    }

    .post-author-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        justify-content: space-between;
        flex-wrap: wrap;
    }
    .author-info { display: flex; align-items: center; gap: 10px; }
    .author-avatar {
        width: 38px; height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--red-deep), var(--red));
        color: var(--gold-light);
        display: flex; align-items: center; justify-content: center;
        font-family: 'Noto Serif SC', serif;
        font-size: 1rem;
        font-weight: 700;
        border: 2px solid var(--gold);
        box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }
    .author-name {
        font-family: 'Noto Serif SC', serif;
        color: var(--gold);
        font-size: 0.88rem;
        font-weight: 600;
    }
    .author-date {
        font-size: 0.75rem;
        color: rgba(240,192,64,0.45);
        letter-spacing: 0.5px;
    }
    .post-stats {
        display: flex; gap: 16px; font-size: 0.76rem;
        color: rgba(240,192,64,0.4);
    }

    /* Post Body */
    .post-body {
        padding: 28px 32px;
        border-bottom: 1px solid var(--parchment-dark);
    }
    .post-body .content {
        font-family: 'Noto Serif SC', serif;
        font-size: 0.95rem;
        line-height: 2;
        color: #2d2010;
        white-space: pre-wrap;
        word-break: break-word;
    }

    /* Post Actions */
    .post-actions {
        padding: 16px 32px;
        display: flex;
        gap: 10px;
        align-items: center;
        background: rgba(212,160,23,0.04);
        flex-wrap: wrap;
    }
    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 16px;
        border-radius: 3px;
        font-size: 0.8rem;
        font-family: 'Noto Serif SC', serif;
        text-decoration: none;
        letter-spacing: 0.5px;
        transition: all .2s;
        border: 1px solid;
        cursor: pointer;
    }
    .btn-action-edit {
        color: var(--jade);
        border-color: rgba(46,125,110,0.3);
        background: rgba(46,125,110,0.05);
    }
    .btn-action-edit:hover {
        background: rgba(46,125,110,0.1);
        color: var(--jade);
    }
    .btn-action-delete {
        color: var(--red);
        border-color: rgba(192,57,43,0.3);
        background: rgba(192,57,43,0.05);
    }
    .btn-action-delete:hover {
        background: rgba(192,57,43,0.1);
        color: var(--red);
    }

    /* ── Reply Section ── */
    .replies-head {
        background: linear-gradient(90deg, #2d1f0e, #3d2a12);
        border: 1px solid var(--gold);
        border-bottom: none;
        border-radius: 4px 4px 0 0;
        padding: 12px 24px;
        font-family: 'Noto Serif SC', serif;
        color: var(--gold-light);
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 2px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .replies-list {
        background: var(--parchment);
        border: 1px solid var(--border);
        border-top: none;
        border-radius: 0 0 4px 4px;
        margin-bottom: 24px;
        overflow: hidden;
        box-shadow: 0 3px 12px rgba(0,0,0,0.08);
    }

    /* Reply Item */
    .reply-item {
        display: flex;
        gap: 0;
        border-bottom: 1px solid var(--parchment-dark);
        transition: background .15s;
    }
    .reply-item:last-child { border-bottom: none; }
    .reply-item:hover { background: #fef9ee; }

    .reply-sidebar {
        flex-shrink: 0;
        background: rgba(212,160,23,0.04);
        border-right: 1px solid var(--parchment-dark);
        padding: 18px 12px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }
    .reply-avatar {
        width: 44px; height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2d6b5e, var(--jade));
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-family: 'Noto Serif SC', serif;
        font-size: 1rem;
        font-weight: 700;
        border: 2px solid rgba(46,125,110,0.4);
    }
    .reply-author {
        font-family: 'Noto Serif SC', serif;
        font-size: 0.78rem;
        color: var(--ink);
        font-weight: 600;
        word-break: break-all;
    }
    .reply-label {
        font-size: 0.68rem;
        color: var(--muted);
        background: rgba(0,0,0,0.06);
        padding: 1px 8px;
        border-radius: 10px;
    }

    .reply-main {
        flex: 1;
        padding: 18px 24px;
    }
    .reply-meta {
        font-size: 0.73rem;
        color: var(--muted);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 6px;
    }
    .reply-number {
        font-family: 'Noto Serif SC', serif;
        background: var(--ink);
        color: var(--gold);
        font-size: 0.68rem;
        padding: 1px 8px;
        border-radius: 2px;
        letter-spacing: 0.5px;
    }
    .reply-content {
        font-size: 0.9rem;
        line-height: 1.85;
        color: #2d2010;
        white-space: pre-wrap;
        word-break: break-word;
    }

    /* ── Reply Form ── */
    .reply-form-wrap {
        background: var(--parchment);
        border: 1px solid var(--border);
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 3px 12px rgba(0,0,0,0.08);
    }
    .reply-form-head {
        background: linear-gradient(90deg, #2d1f0e, #3d2a12);
        border-bottom: 2px solid var(--gold);
        padding: 13px 24px;
        font-family: 'Noto Serif SC', serif;
        color: var(--gold-light);
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 2px;
    }
    .reply-form-body { padding: 24px; }

    .reply-textarea {
        width: 100%;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 3px;
        padding: 12px 16px;
        font-family: 'Noto Serif SC', serif;
        font-size: 0.88rem;
        color: var(--ink);
        min-height: 130px;
        resize: vertical;
        outline: none;
        transition: border-color .2s, box-shadow .2s;
        box-sizing: border-box;
        line-height: 1.8;
    }
    .reply-textarea:focus {
        border-color: var(--gold);
        box-shadow: 0 0 0 3px rgba(212,160,23,0.12);
    }
    .reply-textarea::placeholder { color: #b0a080; }

    .reply-locked {
        padding: 20px 24px;
        background: rgba(192,57,43,0.05);
        border-top: 1px solid rgba(192,57,43,0.12);
        text-align: center;
        color: var(--red);
        font-family: 'Noto Serif SC', serif;
        font-size: 0.85rem;
        letter-spacing: 1px;
    }

    .reply-login {
        padding: 22px 24px;
        text-align: center;
    }
    .reply-login p {
        font-family: 'Noto Serif SC', serif;
        color: var(--muted);
        font-size: 0.85rem;
        letter-spacing: 1px;
        margin-bottom: 14px;
    }
    .btn-login {
        display: inline-block;
        background: linear-gradient(135deg, var(--red), var(--red-deep));
        color: #fff;
        text-decoration: none;
        padding: 9px 24px;
        border-radius: 3px;
        font-size: 0.85rem;
        letter-spacing: 1px;
        font-family: 'Noto Serif SC', serif;
        transition: all .2s;
        box-shadow: 0 3px 10px rgba(192,57,43,0.3);
    }
    .btn-login:hover { box-shadow: 0 5px 16px rgba(192,57,43,0.45); color: #fff; }

    .btn-reply {
        background: linear-gradient(135deg, var(--red), var(--red-deep));
        color: #fff;
        border: 1px solid var(--red-deep);
        padding: 10px 28px;
        border-radius: 3px;
        font-family: 'Noto Serif SC', serif;
        font-size: 0.88rem;
        letter-spacing: 1.5px;
        cursor: pointer;
        margin-top: 14px;
        transition: all .22s;
        box-shadow: 0 3px 10px rgba(192,57,43,0.3);
    }
    .btn-reply:hover {
        box-shadow: 0 5px 16px rgba(192,57,43,0.45);
        transform: translateY(-1px);
    }

    /* Empty Replies */
    .empty-replies {
        padding: 40px 20px;
        text-align: center;
        color: var(--muted);
        font-family: 'Noto Serif SC', serif;
        font-size: 0.88rem;
        letter-spacing: 1px;
    }
    .empty-replies .icon { font-size: 2.2rem; margin-bottom: 10px; opacity: .35; }

    /* Back Button */
    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 8px 18px;
        border-radius: 3px;
        background: var(--parchment);
        border: 1px solid var(--border);
        color: var(--ink);
        text-decoration: none;
        font-size: 0.82rem;
        font-family: 'Noto Serif SC', serif;
        letter-spacing: 0.5px;
        margin-top: 28px;
        transition: all .2s;
    }
    .btn-back:hover { background: var(--parchment-dark); color: var(--red); }
    .reply-footer{
    margin-top:14px;
    display:flex;
    align-items:center;
    gap:10px;
    }

    .btn-like{
        border:none;
        background:rgba(212,160,23,0.08);
        border:1px solid rgba(212,160,23,0.25);
        color:#7a5a12;
        padding:6px 14px;
        border-radius:30px;
        font-size:0.78rem;
        font-family:'Noto Serif SC', serif;
        cursor:pointer;
        transition:all .2s;
    }

    .btn-like:hover{
        background:rgba(212,160,23,0.16);
        transform:translateY(-1px);
    }

    .btn-like.liked{
        background:rgba(192,57,43,0.12);
        border-color:rgba(192,57,43,0.3);
        color:var(--red);
        font-weight:700;
    }
</style>

<div class="detail-wrap">
    <div class="detail-container">

        <!-- Breadcrumb -->
        <div class="forum-breadcrumb">
            <a asp-controller="BaiViet" asp-action="Index">
                <i class="bi bi-house-door me-1"></i>Thảo Luận
            </a>
            <span>›</span>
            @if (Model.ForumCategory != null)
            {
                <a asp-controller="BaiViet" asp-action="Index" asp-route-categoryId="@Model.ForumCategoryId">
                    @Model.ForumCategory.Name
                </a>
                <span>›</span>
            }
            <span style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@Model.Title</span>
        </div>

        <!-- ── Main Post ── -->
        <div class="post-card">

            <!-- Header -->
            <div class="post-header">
                <div class="post-badges">
                    @if (Model.ForumCategory != null)
                    {
                        <span class="badge-cat">📚 @Model.ForumCategory.Name</span>
                    }
                    @if (Model.IsPinned) { <span class="badge-pin">📌 Ghim</span> }
                    @if (Model.IsLocked) { <span class="badge-lock">🔒 Đã Khóa</span> }
                </div>

                <h1 class="post-title">@Model.Title</h1>

                <div class="post-author-bar">
                    <div class="author-info">
                        <div class="author-avatar">
                            @(!string.IsNullOrEmpty(Model.User?.Username) ? Model.User.Username[0].ToString().ToUpper() : "?")
                        </div>
                        <div>
                            <div class="author-name">@(Model.User?.Username ?? "Ẩn danh")</div>
                            <div class="author-date">
                                <i class="bi bi-clock me-1"></i>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                    </div>
                    <div class="post-stats">
                        <span><i class="bi bi-eye me-1"></i>@Model.ViewCount</span>
                        <span><i class="bi bi-chat-dots me-1"></i>@Model.ReplyCount</span>
                    </div>
                </div>
            </div>

            <!-- Body -->
            <div class="post-body">
                <div class="content">@Html.Raw(Model.Content)</div>
            </div>

            <!-- Actions -->
            @if (canEdit)
            {
                <div class="post-actions">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-action btn-action-edit">
                        <i class="bi bi-pencil-fill"></i> Chỉnh Sửa
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:inline;"
                          onsubmit="return confirm('Xác nhận xóa bài viết này?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-action btn-action-delete">
                            <i class="bi bi-trash3-fill"></i> Xóa Bài
                        </button>
                    </form>
                </div>
            }
        </div>
        <!-- ── Replies ── -->
        <div style="padding:0 0 32px;">

            <!-- Header -->
            <div style="display:flex;align-items:center;justify-content:space-between;
                        margin-bottom:20px;padding-bottom:14px;border-bottom:2px solid #f1f5f9;">
                <h5 style="margin:0;font-weight:700;color:#1e293b;font-size:1rem;">
                    💬 Bình Luận & Thảo Luận
                </h5>
                <span style="background:#6c63ff;color:#fff;border-radius:20px;
                             padding:3px 12px;font-size:12px;font-weight:600;">
                    @Model.ReplyCount bình luận
                </span>
            </div>

            <!-- Danh sách -->
            <div>
                @if (Model.Replies == null || !Model.Replies.Any())
                {
                    <div style="text-align:center;padding:48px 0;color:#94a3b8;">
                        <div style="font-size:40px;margin-bottom:12px;">💭</div>
                        <p style="font-size:14px;margin:0;">Chưa có bình luận nào. Hãy là người đầu tiên!</p>
                    </div>
                }
                else
                {
                    int replyNum = 1;
                    @foreach (var r in Model.Replies)
                    {
                        bool isMyReply = currentUserId.HasValue && r.UserId == currentUserId.Value;
                        bool liked = ViewBag.LikedReplies != null &&
                                     ((List<Guid>)ViewBag.LikedReplies).Contains(r.Id);

                        <div style="display:flex;gap:14px;padding:18px 0;
                                    border-bottom:1px solid #f1f5f9;">
                            <!-- Avatar -->
                            <div style="flex-shrink:0;text-align:center;">
                                <div style="width:44px;height:44px;border-radius:50%;
                                            background:linear-gradient(135deg,#6c63ff,#a78bfa);
                                            display:flex;align-items:center;justify-content:center;
                                            color:#fff;font-weight:700;font-size:17px;margin-bottom:4px;">
                                    @(!string.IsNullOrEmpty(r.User?.Username) ? r.User.Username[0].ToString().ToUpper() : "?")
                                </div>
                                <div style="font-size:11px;font-weight:600;color:#475569;
                                            max-width:52px;overflow:hidden;text-overflow:ellipsis;
                                            white-space:nowrap;text-align:center;">
                                    @(r.User?.Username ?? "Ẩn danh")
                                </div>
                                @if (isMyReply)
                                {
                                    <span style="font-size:9px;background:#dbeafe;color:#3b82f6;
                                                 border-radius:4px;padding:1px 5px;font-weight:600;">
                                        Bạn
                                    </span>
                                }
                            </div>

                            <!-- Nội dung -->
                            <div style="flex:1;min-width:0;">
                                <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                                    <span style="font-size:11px;font-weight:700;color:#6c63ff;
                                                 background:#f0f0ff;border-radius:4px;padding:1px 7px;">
                                        #@replyNum
                                    </span>
                                    <span style="font-size:11px;color:#94a3b8;">
                                        <i class="bi bi-clock me-1"></i>@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                </div>

                                <div style="font-size:14px;color:#334155;line-height:1.7;
                                            word-break:break-word;margin-bottom:10px;">
                                    @r.Content
                                </div>

                                <!-- Like -->
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <form asp-controller="Like" asp-action="Toggle"
                                          asp-route-replyId="@r.Id" method="post"
                                          style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                style="border:1px solid @(liked ? "#fca5a5" : "#e2e8f0");
                                                       background:@(liked ? "#fff5f5" : "#f8fafc");
                                                       color:@(liked ? "#e74c3c" : "#64748b");
                                                       font-size:12px;padding:4px 14px;border-radius:20px;
                                                       cursor:pointer;display:inline-flex;
                                                       align-items:center;gap:5px;font-weight:500;
                                                       transition:all .2s;">
                                            @(liked ? "💖 Đã thích" : "🤍 Thích")
                                            <strong>@r.LikeCount</strong>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span style="border:1px solid #fecdd3;background:#fff5f5;
                                                 color:#e74c3c;font-size:12px;padding:4px 14px;
                                                 border-radius:20px;display:inline-flex;
                                                 align-items:center;gap:5px;">
                                        ❤️ @r.LikeCount
                                    </span>
                                }
                            </div>
                        </div>
                        replyNum++;
                    }
                }
            </div>

            <!-- Form viết bình luận -->
            <div style="margin-top:28px;background:#f8fafc;border-radius:14px;
                        border:1px solid #e2e8f0;overflow:hidden;">
                <div style="padding:14px 18px;background:#f1f5f9;border-bottom:1px solid #e2e8f0;
                            font-weight:700;font-size:14px;color:#1e293b;">
                    ✍️ Viết Bình Luận
                </div>

                @if (Model.IsLocked)
                {
                    <div style="padding:20px 18px;text-align:center;color:#94a3b8;font-size:14px;">
                        🔒 Bài viết này đã bị khóa, không thể bình luận thêm.
                    </div>
                }
                else if (User.Identity?.IsAuthenticated == true)
                {
                    <div style="padding:18px;">
                        <form asp-controller="TraLoiBaiVietModel" asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="threadId" value="@Model.Id" />

                            <textarea name="content" required
                                      placeholder="Chia sẻ suy nghĩ của bạn..."
                                      style="width:100%;padding:12px 16px;border:1px solid #e2e8f0;
                                             border-radius:10px;font-size:14px;resize:vertical;
                                             min-height:100px;font-family:inherit;outline:none;
                                             background:#fff;color:#1e293b;transition:border-color .2s;"
                                      onfocus="this.style.borderColor='#6c63ff'"
                                      onblur="this.style.borderColor='#e2e8f0'">
                            </textarea>

                            <div style="text-align:right;margin-top:10px;">
                                <button type="submit"
                                        style="background:linear-gradient(135deg,#6c63ff,#8b5cf6);
                                               color:#fff;border:none;padding:10px 22px;
                                               border-radius:10px;font-size:14px;font-weight:600;
                                               cursor:pointer;display:inline-flex;align-items:center;
                                               gap:8px;transition:opacity .2s;"
                                        onmouseover="this.style.opacity='.85'"
                                        onmouseout="this.style.opacity='1'">
                                    <i class="bi bi-send"></i> Gửi Bình Luận
                                </button>
                            </div>
                        </form>
                    </div>
                }
                else
                {
                    <div style="padding:28px;text-align:center;">
                        <i class="bi bi-lock" style="font-size:28px;color:#cbd5e1;
                                                      display:block;margin-bottom:10px;"></i>
                        <p style="margin:0 0 14px;font-size:14px;color:#64748b;">
                            Đăng nhập để tham gia bình luận
                        </p>
                        <a asp-controller="Account" asp-action="Login"
                           style="background:linear-gradient(135deg,#6c63ff,#8b5cf6);
                                  color:#fff;text-decoration:none;padding:9px 22px;
                                  border-radius:10px;font-size:14px;font-weight:600;
                                  display:inline-flex;align-items:center;gap:8px;">
                            <i class="bi bi-box-arrow-in-right"></i> Đăng Nhập
                        </a>
                    </div>
                }
            </div>

        </div>

        <!-- Back -->
        <a asp-controller="BaiViet" asp-action="Index"
           asp-route-categoryId="@Model.ForumCategoryId" class="btn-back">
            <i class="bi bi-arrow-left"></i> Quay Lại Danh Sách
        </a>

    </div>
</div>
