@model web_doc_truyen_Co_ban.Models.MembershipOrder

@{
    ViewData["Title"] = "Thanh toán thành công";
}

@* Load Google Fonts – same as Index *@
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">

<style>
/* ── Reset ───────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
    --ink:      #1a1714;
    --ink-mid:  #5a5550;
    --ink-lt:   #9a9490;
    --paper:    #faf8f5;
    --line:     #e8e4de;
    --green:    #1e7a4a;
    --green-bg: #eaf6f0;
    --gold:     #b07a10;
    --gold-bg:  #fff8e6;
    --radius:   18px;
}

body { background: var(--paper) !important; font-family: 'DM Sans', sans-serif; color: var(--ink); }

/* ── Page Wrapper ────────────────────────────────────── */
.suc-page {
    max-width: 1160px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 5rem;
}

/* ── Breadcrumb-ish back link ────────────────────────── */
.suc-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--ink-mid);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color .15s;
}
.suc-back:hover { color: var(--ink); }
.suc-back svg { width: 16px; height: 16px; }

/* ── Two-column layout ───────────────────────────────── */
.suc-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 28px;
    align-items: start;
}

@@media (max-width: 820px) {
    .suc-grid { grid-template-columns: 1fr; }
}

/* ── Left: Hero block ────────────────────────────────── */
.suc-hero {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 3rem 2.5rem 2.5rem;
    position: relative;
    overflow: hidden;
}

/* watermark star */
.suc-hero::before {
    position: absolute;
    font-size: 16rem;
    color: var(--line);
    top: -4rem;
    right: -3rem;
    pointer-events: none;
    user-select: none;
    line-height: 1;
    z-index: 0;
}

.suc-hero-inner { position: relative; z-index: 1; }

.suc-check {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--green-bg);
    border: 2px solid var(--green);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 30px;
    color: var(--green);
    margin-bottom: 1.6rem;
    animation: popIn .45s cubic-bezier(.175,.885,.32,1.275) both;
}

@@keyframes popIn {
    from { transform: scale(0); opacity: 0; }
    to   { transform: scale(1); opacity: 1; }
}

.suc-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--green);
    background: var(--green-bg);
    border: 1px solid rgba(30,122,74,.18);
    padding: 4px 13px;
    border-radius: 99px;
    margin-bottom: 1rem;
}

.suc-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 900;
    color: var(--ink);
    line-height: 1.12;
    margin-bottom: .9rem;
}

.suc-subtitle {
    font-size: 14.5px;
    color: var(--ink-mid);
    line-height: 1.65;
    max-width: 440px;
    margin-bottom: 2rem;
}

/* plan highlight pill */
.suc-plan-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--gold-bg);
    border: 1px solid rgba(176,122,16,.22);
    border-radius: 99px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    color: var(--gold);
}

.suc-plan-pill .pill-icon { font-size: 17px; }

/* ── CTA Buttons ─────────────────────────────────────── */
.suc-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 2rem;
}

.suc-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 13px 26px;
    border-radius: 99px;
    font-size: 13.5px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: .02em;
    transition: opacity .15s, transform .12s;
    cursor: pointer;
    border: none;
}
.suc-btn:hover { opacity: .82; transform: scale(.97); text-decoration: none; }

.suc-btn-primary {
    background: var(--ink);
    color: #fff;
}

.suc-btn-ghost {
    background: transparent;
    color: var(--ink-mid);
    border: 1.5px solid var(--line);
}
.suc-btn-ghost:hover { color: var(--ink); }

/* ── Right: Receipt card ─────────────────────────────── */
.suc-receipt {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    position: sticky;
    top: 24px;
}

.suc-receipt-head {
    padding: 1.4rem 1.6rem;
    border-bottom: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.receipt-title {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
}

.receipt-paid {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11.5px;
    font-weight: 600;
    color: var(--green);
    background: var(--green-bg);
    border: 1px solid rgba(30,122,74,.18);
    padding: 4px 11px;
    border-radius: 99px;
}

.receipt-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
}

.suc-receipt-body { padding: 0 1.6rem; }

.receipt-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 0;
    border-bottom: 1px solid #f2f0ec;
    font-size: 13.5px;
}
.receipt-row:last-child { border-bottom: none; }

.receipt-label { color: var(--ink-mid); }

.receipt-val {
    font-weight: 600;
    color: var(--ink);
    text-align: right;
}

.receipt-val.amount {
    font-size: 1.1rem;
    color: var(--gold);
}

.order-code-chip {
    font-family: 'Courier New', monospace;
    font-size: 12px;
    background: #f0ede8;
    padding: 3px 9px;
    border-radius: 7px;
    color: var(--ink-mid);
    letter-spacing: .04em;
}

/* ── Confetti strip ──────────────────────────────────── */
.suc-confetti {
    height: 5px;
    background: repeating-linear-gradient(
        90deg,
        #C9B99A 0px, #C9B99A 20px,
        #7DBFAA 20px, #7DBFAA 40px,
        #F0B860 40px, #F0B860 60px,
        #8B95E0 60px, #8B95E0 80px
    );
    animation: slideIn .6s ease both;
}

@@keyframes slideIn {
    from { transform: scaleX(0); transform-origin: left; }
    to   { transform: scaleX(1); }
}

/* ── Fade-up animation ───────────────────────────────── */
.fade-up {
    animation: fadeUp .5s ease both;
}
.fade-up-2 { animation-delay: .1s; }
.fade-up-3 { animation-delay: .2s; }

@@keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
}
</style>

<div class="suc-page">

    <a href="/MembershipPlan" class="suc-back">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10 12L6 8l4-4"/>
        </svg>
        Quay lại Hội viên
    </a>

    <div class="suc-grid">

        @* ── LEFT ── *@
        <div class="suc-hero fade-up">
            <div class="suc-confetti"></div>

            <div class="suc-hero-inner" style="padding-top:2rem">
                <div class="suc-check">✓</div>

                <div class="suc-eyebrow">Xác nhận thanh toán</div>

                <h1 class="suc-title">
                    Chào mừng bạn<br>đến với hội viên!
                </h1>

                <p class="suc-subtitle">
                    Gói hội viên của bạn đã được kích hoạt ngay lập tức.
                    Tận hưởng toàn bộ đặc quyền dành riêng cho hội viên ngay bây giờ.
                </p>

                <div class="suc-plan-pill">
                    <span class="pill-icon">✦</span>
                    @Model.Plan?.Name đã kích hoạt
                </div>

                <div class="suc-actions">
                    <a asp-controller="Home" asp-action="Index" class="suc-btn suc-btn-primary">
                        Bắt đầu đọc truyện →
                    </a>
                    <a asp-action="Index" asp-controller="MembershipPlan" class="suc-btn suc-btn-ghost">
                        Xem gói hội viên
                    </a>
                </div>
            </div>
        </div>

        @* ── RIGHT ── *@
        <div class="suc-receipt fade-up fade-up-2">
            <div class="suc-receipt-head">
                <span class="receipt-title">Chi tiết đơn hàng</span>
                <span class="receipt-paid">
                    <span class="receipt-dot"></span>
                    Đã thanh toán
                </span>
            </div>

            <div class="suc-receipt-body">
                <div class="receipt-row">
                    <span class="receipt-label">Mã đơn</span>
                    <span class="receipt-val">
                        <span class="order-code-chip">#@Model.OrderCode</span>
                    </span>
                </div>

                <div class="receipt-row">
                    <span class="receipt-label">Gói hội viên</span>
                    <span class="receipt-val">@Model.Plan?.Name</span>
                </div>

                <div class="receipt-row">
                    <span class="receipt-label">Thời hạn</span>
                    <span class="receipt-val">@(Model.Plan?.DurationDays) ngày</span>
                </div>

                <div class="receipt-row">
                    <span class="receipt-label">Số tiền</span>
                    <span class="receipt-val amount">@Model.Amount.ToString("N0") đ</span>
                </div>

                <div class="receipt-row">
                    <span class="receipt-label">Thanh toán lúc</span>
                    <span class="receipt-val" style="font-size:13px;">
                        @(Model.PaidAt?.ToString("HH:mm — dd/MM/yyyy"))
                    </span>
                </div>
            </div>
        </div>

    </div>
</div>
