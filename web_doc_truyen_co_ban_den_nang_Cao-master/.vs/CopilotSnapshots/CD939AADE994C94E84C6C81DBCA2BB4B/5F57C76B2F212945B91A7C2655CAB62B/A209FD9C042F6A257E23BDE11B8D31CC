@model IEnumerable<web_doc_truyen_Co_ban.Models.ErrorLogAdminViewModel>

@{
    ViewData["Title"] = "Nhật ký lỗi";
    int currentpage       = (int)ViewBag.Page;
    int totalPages = (int)ViewBag.TotalPages;
    int total      = (int)ViewBag.Total;

    string? search     = ViewData["Search"]     as string;
    string? action     = ViewData["Action"]     as string;
    string? entityType = ViewData["EntityType"] as string;
    string? status     = ViewData["Status"]     as string;
    string? from       = ViewData["From"]       as string;
    string? to         = ViewData["To"]         as string;
}

@section Styles{
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
    :root {
        --bg: #f0f2f8;
        --card: #fff;
        --border: #e8ecf4;
        --text: #1a202c;
        --muted: #718096;
        --blue: #4f63d2;
        --blue-light: #eef2ff;
        --blue-dim: rgba(79,99,210,.12);
        --green: #059669;
        --green-light: #ecfdf5;
        --green-dim: rgba(5,150,105,.12);
        --amber: #d97706;
        --amber-light: #fffbeb;
        --amber-dim: rgba(217,119,6,.12);
        --red: #dc2626;
        --red-light: #fef2f2;
        --red-dim: rgba(220,38,38,.12);
        --purple: #7c3aed;
        --purple-dim: rgba(124,58,237,.12);
        --radius: 12px;
        --shadow: 0 1px 4px rgba(0,0,0,.06);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); font-family: 'Segoe UI', system-ui, sans-serif; color: var(--text); }

    /* ── WRAP ── */
    .el-wrap { padding: 20px 24px; min-height: 100vh; }

    /* ── TITLE ── */
    .el-title {
        font-size: 20px; font-weight: 700; color: var(--text);
        display: flex; align-items: center; gap: 8px; margin-bottom: 4px;
    }
    .el-sub { font-size: 13px; color: var(--muted); margin-bottom: 18px; display: flex; align-items: center; justify-content: space-between; }
    .el-sub-actions { display: flex; gap: 8px; }

    /* ── BUTTONS ── */
    .hbtn {
        height: 34px; padding: 0 14px; border-radius: 7px; border: 1px solid var(--border);
        background: var(--card); color: var(--text); font-size: 12px; font-weight: 600;
        cursor: pointer; display: inline-flex; align-items: center; gap: 6px;
        text-decoration: none; transition: background .15s; box-shadow: var(--shadow);
    }
    .hbtn:hover { background: var(--border); }
    .hbtn.danger { border-color: var(--red); color: var(--red); }
    .hbtn.danger:hover { background: var(--red-dim); }

    /* ── STAT BAR ── */
    .stat-bar {
        display: grid; grid-template-columns: repeat(4,1fr);
        background: var(--card); border-radius: var(--radius);
        box-shadow: var(--shadow); overflow: hidden; margin-bottom: 16px;
    }
    .stat-cell {
        padding: 14px 18px; border-right: 1px solid var(--border);
        display: flex; align-items: center; gap: 12px;
    }
    .stat-cell:last-child { border-right: none; }
    .sbc-icon {
        width: 42px; height: 42px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; flex-shrink: 0;
    }
    .sbc-val { font-size: 22px; font-weight: 700; color: var(--text); line-height: 1; }
    .sbc-lbl { font-size: 11px; color: var(--muted); margin-top: 3px; text-transform: uppercase; letter-spacing: .04em; }

    /* ── MAIN GRID ── */
    .main-grid {
        display: grid; grid-template-columns: 1fr 260px;
        gap: 16px; margin-bottom: 16px;
    }

    /* ── CARD ── */
    .card {
        background: var(--card); border-radius: var(--radius);
        box-shadow: var(--shadow); padding: 18px 20px;
    }
    .card-title {
        font-size: 13px; font-weight: 700; color: var(--text);
        display: flex; align-items: center; gap: 6px; margin-bottom: 14px;
    }

    /* ── RIGHT COLUMN ── */
    .right-col { display: flex; flex-direction: column; gap: 16px; }
    .panel-red {
        background: var(--red); border-radius: var(--radius);
        padding: 16px 18px; display: flex; align-items: center; gap: 14px; color: #fff;
    }
    .panel-blue {
        background: var(--blue); border-radius: var(--radius);
        padding: 16px 18px; display: flex; align-items: center; gap: 14px; color: #fff;
    }
    .panel-icon {
        width: 44px; height: 44px; border-radius: 10px;
        background: rgba(255,255,255,.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; flex-shrink: 0;
    }
    .panel-big { font-size: 24px; font-weight: 700; line-height: 1; }
    .panel-sub { font-size: 12px; opacity: .85; margin-top: 3px; }

    .mini-stats {
        background: var(--card); border-radius: var(--radius);
        box-shadow: var(--shadow); overflow: hidden; flex: 1;
    }
    .mini-stat-row {
        display: grid; grid-template-columns: 1fr 1fr;
        border-bottom: 1px solid var(--border);
    }
    .mini-stat-row:last-child { border-bottom: none; }
    .mini-cell { padding: 12px 14px; border-right: 1px solid var(--border); }
    .mini-cell:last-child { border-right: none; }
    .mc-lbl { font-size: 11px; color: var(--muted); }
    .mc-val { font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 4px; margin-top: 2px; }
    .mc-val .up { color: var(--green); font-size: 12px; }
    .mc-val .dn { color: var(--red); font-size: 12px; }
    .mc-sub { font-size: 10px; color: var(--muted); margin-top: 2px; }

    /* ── CHART ROW 2 ── */
    .chart-row2 { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 16px; }

    /* ── PROGRESS ROW ── */
    .prog-row {
        display: grid; grid-template-columns: repeat(4,1fr);
        background: var(--card); border-radius: var(--radius);
        box-shadow: var(--shadow); overflow: hidden; margin-bottom: 16px;
    }
    .prog-cell { padding: 14px 18px; border-right: 1px solid var(--border); }
    .prog-cell:last-child { border-right: none; }
    .pc-lbl { font-size: 11px; color: var(--muted); margin-bottom: 4px; }
    .pc-val { font-size: 18px; font-weight: 700; color: var(--text); }
    .prog-bar { height: 5px; background: var(--border); border-radius: 99px; margin-top: 10px; }
    .prog-fill { height: 100%; border-radius: 99px; position: relative; }
    .prog-fill::after {
        content: ''; position: absolute; right: -1px; top: 50%;
        transform: translateY(-50%); width: 10px; height: 10px;
        border-radius: 50%; background: inherit;
    }

    /* ── BODY: sidebar + log list ── */
    .lv-body { display: grid; grid-template-columns: 210px 1fr 310px; gap: 16px; }

    /* ── SIDEBAR ── */
    .lv-sidebar {
        background: var(--card); border-radius: var(--radius);
        box-shadow: var(--shadow); padding: 16px 14px;
        align-self: start;
    }
    .sidebar-title {
        font-size: 11px; font-weight: 700; color: var(--muted);
        text-transform: uppercase; letter-spacing: .07em; margin-bottom: 12px;
        display: flex; align-items: center; gap: 6px;
    }
    .filter-group { margin-bottom: 16px; }
    .filter-group-title {
        font-size: 12px; font-weight: 700; color: var(--text);
        margin-bottom: 7px; display: flex; align-items: center; justify-content: space-between;
    }
    .filter-group-title i { font-size: 10px; color: var(--muted); }
    .filter-input {
        width: 100%; height: 32px; background: #f8fafc;
        border: 1px solid var(--border); border-radius: 7px;
        padding: 0 10px; color: var(--text); font-size: 12px; outline: none;
    }
    .filter-input:focus { border-color: var(--blue); }
    .filter-check {
        display: flex; align-items: center;
        padding: 4px 2px; border-radius: 6px; cursor: pointer; font-size: 12px;
        transition: background .12s;
    }
    .filter-check:hover { background: #f8fafc; }
    .filter-check input[type=checkbox],
    .filter-check input[type=radio] { accent-color: var(--blue); margin-right: 6px; }
    .btn-apply {
        width: 100%; height: 34px; border-radius: 8px; border: none;
        background: var(--blue); color: #fff; font-size: 12px; font-weight: 700;
        cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px;
        margin-top: 6px;
    }
    .btn-apply:hover { opacity: .9; }
    .btn-clear {
        width: 100%; height: 34px; border-radius: 8px;
        border: 1px solid var(--border); background: transparent;
        color: var(--muted); font-size: 12px; cursor: pointer; margin-top: 6px;
        display: flex; align-items: center; justify-content: center; text-decoration: none;
        transition: color .15s, border-color .15s;
    }
    .btn-clear:hover { color: var(--text); border-color: var(--text); }

    /* ── LOG LIST ── */
    .lv-list {
        background: var(--card); border-radius: var(--radius);
        box-shadow: var(--shadow); overflow: hidden;
    }
    .list-toolbar {
        padding: 12px 14px; border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 10px;
    }
    .search-wrap { position: relative; flex: 1; }
    .search-wrap i { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 13px; }
    .search-box {
        width: 100%; height: 34px; background: #f8fafc;
        border: 1px solid var(--border); border-radius: 7px;
        padding: 0 10px 0 32px; color: var(--text); font-size: 12px; outline: none;
    }
    .search-box:focus { border-color: var(--blue); }
    .sort-btn {
        height: 34px; padding: 0 12px; border-radius: 7px;
        border: 1px solid var(--border); background: #f8fafc;
        color: var(--text); font-size: 12px; cursor: pointer;
        display: flex; align-items: center; gap: 5px; white-space: nowrap;
    }
    .sort-btn:hover { background: var(--border); }
    .list-count { font-size: 11px; color: var(--muted); white-space: nowrap; }

    /* log row */
    .log-row {
        padding: 11px 14px; border-bottom: 1px solid var(--border);
        cursor: pointer; transition: background .1s;
        display: grid; grid-template-columns: 68px 1fr;
        gap: 10px; align-items: start;
    }
    .log-row:hover { background: #fafcff; }
    .log-row.active { background: var(--blue-dim); border-left: 3px solid var(--blue); }
    .log-date { font-size: 11px; color: var(--muted); line-height: 1.6; }
    .log-date strong { font-size: 12px; color: var(--text); display: block; }
    .log-body .log-title { font-size: 13px; font-weight: 700; color: var(--blue); margin-bottom: 2px; }
    .log-body .log-desc {
        font-size: 12px; color: var(--muted);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 420px;
    }
    .log-tags { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 5px; }

    /* tags */
    .tag {
        font-size: 10px; font-weight: 700; padding: 2px 8px;
        border-radius: 999px; display: inline-flex; align-items: center; gap: 3px;
    }
    .tag-blue   { background: var(--blue-dim);   color: var(--blue);   }
    .tag-green  { background: var(--green-dim);  color: var(--green);  }
    .tag-red    { background: var(--red-dim);    color: var(--red);    }
    .tag-amber  { background: var(--amber-dim);  color: var(--amber);  }
    .tag-purple { background: var(--purple-dim); color: var(--purple); }

    /* list pagination */
    .list-pagination {
        padding: 12px 14px; border-top: 1px solid var(--border);
        display: flex; justify-content: space-between; align-items: center;
    }
    .pag-btns { display: flex; gap: 4px; flex-wrap: wrap; }
    .p-btn {
        min-width: 30px; height: 30px; border-radius: 6px;
        border: 1px solid var(--border); background: #fff;
        color: var(--text); font-size: 12px; cursor: pointer;
    }
    .p-btn.active { background: var(--blue); border-color: var(--blue); color: #fff; font-weight: 700; }
    .p-btn:hover:not(.active) { background: var(--blue-light); }

    /* ── DETAIL PANEL ── */
    .lv-detail {
        background: var(--card); border-radius: var(--radius);
        box-shadow: var(--shadow); overflow: hidden; align-self: start;
    }
    .detail-header {
        padding: 14px 18px; border-bottom: 1px solid var(--border);
        font-size: 13px; font-weight: 700; color: var(--text);
        display: flex; align-items: center; gap: 8px;
    }
    .detail-empty {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        padding: 48px 20px; color: var(--muted); font-size: 13px; gap: 10px;
    }
    .detail-empty i { font-size: 36px; }
    .detail-body { padding: 18px; }
    .detail-ts { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 16px; }
    .detail-section { margin-bottom: 18px; }
    .detail-section-title {
        font-size: 11px; font-weight: 700; color: var(--muted);
        text-transform: uppercase; letter-spacing: .07em; margin-bottom: 8px;
    }
    .detail-row {
        display: grid; grid-template-columns: 110px 1fr;
        gap: 6px; padding: 6px 0; border-bottom: 1px solid var(--border); font-size: 12px;
    }
    .detail-row:last-child { border-bottom: none; }
    .detail-row .dk { color: var(--muted); }
    .detail-row .dv { color: var(--text); font-weight: 600; word-break: break-all; }
    .detail-error-box {
        background: var(--red-dim); border: 1px solid rgba(220,38,38,.25);
        border-radius: 8px; padding: 12px; font-size: 12px; color: var(--red);
        line-height: 1.6; margin-top: 8px;
    }
    .detail-del-btn {
        width: 100%; height: 36px; border-radius: 8px;
        border: 1px solid var(--red); background: transparent;
        color: var(--red); font-size: 12px; font-weight: 700;
        cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px;
        margin-top: 16px; transition: background .15s;
    }
    .detail-del-btn:hover { background: var(--red-dim); }

    /* ── AVATAR ── */
    .avatar {
        width: 38px; height: 38px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 13px; flex-shrink: 0; overflow: hidden;
    }
    .avatar img { width: 100%; height: 100%; object-fit: cover; }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }

    @@media (max-width: 1280px) {
        .lv-body { grid-template-columns: 200px 1fr; }
        .lv-detail { display: none; }
        .main-grid { grid-template-columns: 1fr; }
        .chart-row2 { grid-template-columns: 1fr; }
    }
    @@media (max-width: 900px) {
        .stat-bar { grid-template-columns: repeat(2,1fr); }
        .prog-row { grid-template-columns: repeat(2,1fr); }
    }
    @@media (max-width: 768px) {
        .lv-body { grid-template-columns: 1fr; }
        .lv-sidebar { display: none; }
        /* Mobile overlay with fade + slide animation */
        .lv-detail {
            position: fixed; inset: 0; display: flex; align-items: center; justify-content: center;
            background: rgba(0,0,0,0.45); z-index: 1200;
            opacity: 0; pointer-events: none; transition: opacity .28s ease;
        }
        .lv-detail .detail-body {
            background: var(--card); border-radius: var(--radius);
            max-height: 86vh; overflow: auto; padding: 16px; box-shadow: var(--shadow);
            width: calc(100% - 32px); transform: translateY(18px) scale(.98); opacity: 0;
            transition: transform .32s cubic-bezier(.2,.8,.2,1), opacity .28s ease;
        }
        .lv-detail.open { opacity: 1; pointer-events: auto; }
        .lv-detail.open .detail-body { transform: translateY(0) scale(1); opacity: 1; }
        .lv-detail .detail-header { position: relative; display:flex; align-items:center; gap:8px; }
        .detail-header .close-btn { margin-left: auto; background: transparent; border: none; color: var(--muted); cursor: pointer; font-size: 16px; display: inline-flex; align-items: center; gap:6px; }
    }
</style>
}

<div class="el-wrap">

    <!-- ── TITLE ── -->
    <div class="el-title">
        <i class="bi bi-journal-x" style="color:var(--red)"></i>
        Nhật ký hoạt động
    </div>
    <div class="el-sub">
        <span>Theo dõi toàn bộ hành động người dùng · @total bản ghi</span>
        <div class="el-sub-actions">
            <a href="/Admin/ErrorLog/Export" class="hbtn">
                <i class="bi bi-download"></i> Export CSV
            </a>
            <form method="post" asp-action="DeleteOld" style="display:inline"
                  onsubmit="return confirm('Xóa toàn bộ log cũ hơn 30 ngày?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="hbtn danger">
                    <i class="bi bi-trash3-fill"></i> Xóa log cũ
                </button>
            </form>
        </div>
    </div>

    <!-- ── STAT BAR ── -->
    <div class="stat-bar">
        <div class="stat-cell">
            <div class="sbc-icon" style="background:var(--blue-dim);color:var(--blue)">
                <i class="bi bi-activity"></i>
            </div>
            <div>
                <div class="sbc-val">@ViewBag.TotalLogs</div>
                <div class="sbc-lbl">Tổng log</div>
            </div>
        </div>
        <div class="stat-cell">
            <div class="sbc-icon" style="background:var(--red-dim);color:var(--red)">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div>
                <div class="sbc-val">@ViewBag.TotalErrors</div>
                <div class="sbc-lbl">Tổng lỗi</div>
            </div>
        </div>
        <div class="stat-cell">
            <div class="sbc-icon" style="background:var(--green-dim);color:var(--green)">
                <i class="bi bi-people-fill"></i>
            </div>
            <div>
                <div class="sbc-val">@ViewBag.TotalUsers</div>
                <div class="sbc-lbl">User hoạt động</div>
            </div>
        </div>
        <div class="stat-cell">
            <div class="sbc-icon" style="background:var(--amber-dim);color:var(--amber)">
                <i class="bi bi-calendar-day-fill"></i>
            </div>
            <div>
                <div class="sbc-val">@ViewBag.TodayLogs</div>
                <div class="sbc-lbl">Hôm nay</div>
            </div>
        </div>
    </div>

    <!-- ── MAIN GRID: trend chart + right col ── -->
    <div class="main-grid">

        <div class="card">
            <div class="card-title">
                <i class="bi bi-graph-up-arrow"></i>
                Hoạt động 30 ngày gần nhất
            </div>
            <div style="position:relative;height:180px">
                <canvas id="trendChart"></canvas>
            </div>
        </div>

        <div class="right-col">
            <div class="panel-red">
                <div class="panel-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                <div>
                    <div class="panel-big">@ViewBag.TotalErrors</div>
                    <div class="panel-sub">Tổng lỗi ghi nhận</div>
                </div>
            </div>
            <div class="panel-blue">
                <div class="panel-icon"><i class="bi bi-people-fill"></i></div>
                <div>
                    <div class="panel-big">@ViewBag.TotalUsers</div>
                    <div class="panel-sub">User hoạt động</div>
                </div>
            </div>
            <div class="mini-stats">
                <div class="mini-stat-row">
                    <div class="mini-cell">
                        <div class="mc-lbl">Hôm nay</div>
                        <div class="mc-val"><i class="bi bi-arrow-up up"></i>@ViewBag.TodayLogs</div>
                        <div class="mc-sub">Lượt hoạt động</div>
                    </div>
                    <div class="mini-cell">
                        <div class="mc-lbl">Lỗi hôm nay</div>
                        <div class="mc-val" style="color:var(--red)">@ViewBag.TodayErrors</div>
                        <div class="mc-sub">Cần xử lý</div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- ── CHART ROW 2 ── -->
    <div class="chart-row2">
        <div class="card">
            <div class="card-title">
                <i class="bi bi-lightning-fill"></i>
                Top hành động
            </div>
            <div style="position:relative;height:200px">
                <canvas id="actionChart"></canvas>
            </div>
        </div>
        <div class="card">
            <div class="card-title">
                <i class="bi bi-pie-chart-fill"></i>
                Tỷ lệ thành công / lỗi
            </div>
            <div style="position:relative;height:200px">
                <canvas id="statusChart"></canvas>
            </div>
        </div>
    </div>

    <!-- ── PROGRESS ROW ── -->
    <div class="prog-row">
        <div class="prog-cell">
            <div class="pc-lbl">Tổng log</div>
            <div class="pc-val">@ViewBag.TotalLogs</div>
            <div class="prog-bar"><div class="prog-fill" style="width:72%;background:var(--blue)"></div></div>
        </div>
        <div class="prog-cell">
            <div class="pc-lbl">Tổng lỗi</div>
            <div class="pc-val">@ViewBag.TotalErrors</div>
            <div class="prog-bar"><div class="prog-fill" style="width:20%;background:var(--red)"></div></div>
        </div>
        <div class="prog-cell">
            <div class="pc-lbl">User hoạt động</div>
            <div class="pc-val">@ViewBag.TotalUsers</div>
            <div class="prog-bar"><div class="prog-fill" style="width:60%;background:var(--green)"></div></div>
        </div>
        <div class="prog-cell">
            <div class="pc-lbl">Hôm nay</div>
            <div class="pc-val">@ViewBag.TodayLogs</div>
            <div class="prog-bar"><div class="prog-fill" style="width:40%;background:var(--amber)"></div></div>
        </div>
    </div>

    <!-- ── BODY: sidebar + list + detail ── -->
    <div class="lv-body">

        <!-- SIDEBAR -->
        <div class="lv-sidebar">
            <div class="sidebar-title"><i class="bi bi-funnel-fill"></i> Bộ lọc</div>
            <form method="get" asp-action="Index" id="filterForm">

                <div class="filter-group">
                    <div class="filter-group-title">Username <i class="bi bi-chevron-down"></i></div>
                    <input class="filter-input" type="text" name="search"
                           value="@search" placeholder="Nhập username..." />
                </div>

                <div class="filter-group">
                    <div class="filter-group-title">Trạng thái <i class="bi bi-chevron-down"></i></div>
                    <div class="filter-check">
                        <label style="display:flex;align-items:center;gap:6px;cursor:pointer">
                            <input type="radio" name="status" value="" @(string.IsNullOrEmpty(status) ? "checked" : "") /> Tất cả
                        </label>
                    </div>
                    <div class="filter-check">
                        <label style="display:flex;align-items:center;gap:6px;cursor:pointer">
                            <input type="radio" name="status" value="success" @(status == "success" ? "checked" : "") />
                            <span style="color:var(--green)"><i class="bi bi-check-circle-fill"></i> Thành công</span>
                        </label>
                    </div>
                    <div class="filter-check">
                        <label style="display:flex;align-items:center;gap:6px;cursor:pointer">
                            <input type="radio" name="status" value="error" @(status == "error" ? "checked" : "") />
                            <span style="color:var(--red)"><i class="bi bi-x-circle-fill"></i> Thất bại</span>
                        </label>
                    </div>
                </div>

                <div class="filter-group">
                    <div class="filter-group-title">Hành động <i class="bi bi-chevron-down"></i></div>
                    @foreach (var a in ViewBag.Actions)
                    {
                        <div class="filter-check">
                            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;flex:1">
                                <input type="checkbox" name="action" value="@a" @(action == a ? "checked" : "") /> @a
                            </label>
                        </div>
                    }
                </div>

                <div class="filter-group">
                    <div class="filter-group-title">Model <i class="bi bi-chevron-down"></i></div>
                    @foreach (var e in ViewBag.EntityTypes)
                    {
                        <div class="filter-check">
                            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;flex:1">
                                <input type="checkbox" name="entityType" value="@e" @(entityType == e ? "checked" : "") /> @e
                            </label>
                        </div>
                    }
                </div>

                <div class="filter-group">
                    <div class="filter-group-title">Từ ngày <i class="bi bi-chevron-down"></i></div>
                    <input class="filter-input" type="date" name="from" value="@from" />
                </div>
                <div class="filter-group">
                    <div class="filter-group-title">Đến ngày <i class="bi bi-chevron-down"></i></div>
                    <input class="filter-input" type="date" name="to" value="@to" />
                </div>

                <button type="submit" class="btn-apply">
                    <i class="bi bi-funnel-fill"></i> Áp dụng
                </button>
                <a href="@Url.Action("Index")" class="btn-clear">Xóa bộ lọc</a>
            </form>
        </div>

        <!-- LOG LIST -->
        <div class="lv-list">
            <div class="list-toolbar">
                <div class="search-wrap">
                    <i class="bi bi-search"></i>
                    <input class="search-box" type="text" id="quickSearch" placeholder="Tìm nhanh trong trang..." />
                </div>
                <button class="sort-btn" onclick="sortByDate()">
                    <i class="bi bi-arrow-down-up"></i> DateTime
                </button>
                <span class="list-count">@total bản ghi</span>
            </div>

            <div id="logRows">
            @{
                int row = (currentpage - 1) * 20;
                var avatarColors = new[] {
                    ("dbeafe","1e40af"), ("fce7f3","9d174d"),
                    ("fef3c7","92400e"), ("d1fae5","065f46"), ("ede9fe","5b21b6")
                };
            }
            @foreach (var item in Model)
            {
                row++;
                var uname    = item.User?.Username ?? "Khách";
                var uemail   = item.User?.Email    ?? "—";
                var avatarUrl= item.User?.AvatarUrl;
                var initials = uname.Split(' ').TakeLast(2).Select(x => x[0].ToString().ToUpper()).Aggregate("", (a, b) => a + b);
                var ac       = avatarColors[Math.Abs(uname.GetHashCode()) % avatarColors.Length];

                var statusTag = item.IsSuccess
                    ? "<span class='tag tag-green'><i class='bi bi-check-circle-fill'></i> Thành công</span>"
                    : "<span class='tag tag-red'><i class='bi bi-x-circle-fill'></i> Thất bại</span>";
                var actionTag = $"<span class='tag tag-blue'><i class='bi bi-lightning-fill'></i> {item.Action}</span>";
                var entityTag = item.EntityType != null ? $"<span class='tag tag-amber'>{item.EntityType}</span>" : "";

                var errMsg  = (item.ErrorMessage ?? "").Replace("\"","&quot;").Replace("'","&#39;");
                var entityId= item.EntityId.HasValue ? item.EntityId.Value.ToString() : "—";
                var ip      = item.IpAddress ?? "—";
                var ua      = (item.UserAgent ?? "—").Replace("\"","&quot;");
                var ts      = item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss");

                <div class="log-row"
                     onclick="showDetail(this)"
                     data-id="@item.Id"
                     data-ts="@ts"
                     data-user="@uname"
                     data-email="@uemail"
                     data-action="@item.Action"
                     data-entity="@(item.EntityType ?? "—")"
                     data-entityid="@entityId"
                     data-success="@item.IsSuccess.ToString().ToLower()"
                     data-errmsg="@errMsg"
                     data-ip="@ip"
                     data-ua="@ua"
                     data-avatar="@(avatarUrl ?? "")"
                     data-initials="@initials"
                     data-abg="@ac.Item1"
                     data-acl="@ac.Item2">

                    <div class="log-date">
                        <strong>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</strong>
                        @item.CreatedAt.ToLocalTime().ToString("HH:mm:ss")
                    </div>
                    <div class="log-body">
                        <div class="log-title">@uname</div>
                        <div class="log-desc">
                            @if (!string.IsNullOrEmpty(item.ErrorMessage)) { @item.ErrorMessage }
                            else { @($"{item.Action} · {item.EntityType ?? "—"} · {ip}") }
                        </div>
                        <div class="log-tags">
                            @Html.Raw(statusTag)
                            @Html.Raw(actionTag)
                            @Html.Raw(entityTag)
                        </div>
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <div style="padding:60px;text-align:center;color:var(--muted)">
                    <i class="bi bi-inbox" style="font-size:40px;display:block;margin-bottom:10px"></i>
                    Không có log nào
                </div>
            }
            </div>

            <div class="list-pagination">
                <span style="font-size:12px;color:var(--muted)">Trang @currentpage / @totalPages</span>
                <div class="pag-btns">
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        <button class="p-btn @(p == currentpage ? "active" : "")" onclick="goPage(@p)">@p</button>
                    }
                </div>
            </div>
        </div>

        <!-- DETAIL PANEL -->
        <div class="lv-detail" id="detailPanel">
            <div class="detail-header">
                <i class="bi bi-card-text" style="color:var(--blue)"></i>
                Entry Details
                <button type="button" class="close-btn" id="detailCloseBtn" onclick="closeDetail()" style="display:none"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="detail-empty" id="detailEmpty">
                <i class="bi bi-cursor-text"></i>
                <span>Chọn một dòng để xem chi tiết</span>
            </div>
            <div class="detail-body" id="detailBody" style="display:none">
                <div class="detail-ts" id="dTs"></div>

                <div class="detail-section">
                    <div class="detail-section-title">Người dùng</div>
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
                        <div class="avatar" id="dAvatar"></div>
                        <div>
                            <div id="dUser" style="font-weight:700;font-size:14px"></div>
                            <div id="dEmail" style="font-size:12px;color:var(--muted)"></div>
                        </div>
                    </div>
                </div>

                <div class="detail-section">
                    <div class="detail-section-title">Thông tin hành động</div>
                    <div class="detail-row"><span class="dk">Hành động</span> <span class="dv" id="dAction"></span></div>
                    <div class="detail-row"><span class="dk">Model</span>     <span class="dv" id="dEntity"></span></div>
                    <div class="detail-row"><span class="dk">Entity ID</span> <span class="dv" id="dEntityId" style="font-size:11px"></span></div>
                    <div class="detail-row"><span class="dk">Trạng thái</span><span class="dv" id="dStatus"></span></div>
                </div>

                <div class="detail-section" id="dErrSection" style="display:none">
                    <div class="detail-section-title">Chi tiết lỗi</div>
                    <div class="detail-error-box" id="dErrMsg"></div>
                </div>

                <div class="detail-section">
                    <div class="detail-section-title">Thiết bị</div>
                    <div class="detail-row"><span class="dk">IP Address</span><span class="dv" id="dIp"></span></div>
                    <div class="detail-row"><span class="dk">User Agent</span><span class="dv" id="dUa" style="font-size:11px"></span></div>
                </div>

                <form method="post" asp-action="Delete" id="dDelForm"
                      onsubmit="return confirm('Xóa log này?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="dDelId" />
                    <button type="submit" class="detail-del-btn">
                        <i class="bi bi-trash3-fill"></i> Xóa log này
                    </button>
                </form>
            </div>
        </div>

    </div><!-- /lv-body -->

</div><!-- /el-wrap -->

@section Scripts{
<script>
    const COLORS = ['#4f63d2','#059669','#d97706','#dc2626','#8b5cf6','#0891b2','#db2777'];
    const GRID   = 'rgba(0,0,0,0.06)';
    const TICK   = '#718096';
    const baseOpts = {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { color: GRID }, ticks: { color: TICK, font: { size: 10 } }, border: { display: false } },
            y: { grid: { color: GRID }, ticks: { color: TICK, font: { size: 10 }, maxTicksLimit: 5 }, border: { display: false } }
        }
    };

    /* ── TREND ── */
    async function loadTrend() {
        const res  = await fetch('/Admin/ErrorLog/ChartTrend');
        const data = await res.json();
        const labels = data.map(x => {
            const d = new Date(x.date);
            return `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}`;
        });
        const values = data.map(x => x.count);
        new Chart(document.getElementById('trendChart'), {
            type: 'bar',
            data: { labels, datasets: [{
                data: values,
                backgroundColor: 'rgba(79,99,210,.45)',
                borderColor: 'rgba(79,99,210,1)',
                borderWidth: 1, borderRadius: 3
            }]},
            options: { ...baseOpts }
        });
    }

    /* ── ACTION CHART ── */
    async function loadActionChart() {
        const res  = await fetch('/Admin/ErrorLog/ChartTopActions');
        const data = await res.json();
        new Chart(document.getElementById('actionChart'), {
            type: 'bar',
            data: {
                labels: data.map(x => x.action),
                datasets: [{
                    data: data.map(x => x.count),
                    backgroundColor: COLORS.map(c => c + 'cc'),
                    borderColor: COLORS,
                    borderWidth: 1, borderRadius: 6
                }]
            },
            options: { ...baseOpts }
        });
    }

    /* ── STATUS DONUT ── */
    async function loadStatusChart() {
        const res  = await fetch('/Admin/ErrorLog/ChartSuccessRate');
        const data = await res.json();
        new Chart(document.getElementById('statusChart'), {
            type: 'doughnut',
            data: {
                labels: ['Thành công', 'Thất bại'],
                datasets: [{
                    data: [data.success, data.error],
                    backgroundColor: ['#059669','#dc2626'],
                    borderWidth: 2, hoverOffset: 8
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false, cutout: '65%',
                plugins: { legend: { display: true, position: 'bottom',
                    labels: { color: TICK, font: { size: 11 }, boxWidth: 10, padding: 8 }
                }}
            }
        });
    }

    loadTrend();
    loadActionChart();
    loadStatusChart();

    /* ── DETAIL PANEL ── */
    let activeRow = null;
    function showDetail(el) {
        if (activeRow) activeRow.classList.remove('active');
        el.classList.add('active');
        activeRow = el;
        const d = el.dataset;

        document.getElementById('detailEmpty').style.display = 'none';
        document.getElementById('detailBody').style.display  = 'block';
        // If on small screens, open overlay
        const detail = document.getElementById('detailPanel');
        if (window.matchMedia('(max-width:768px)').matches) {
            detail.classList.add('open');
            document.getElementById('detailCloseBtn').style.display = 'inline-flex';
        }

        document.getElementById('dTs').textContent      = d.ts;
        document.getElementById('dUser').textContent    = d.user;
        document.getElementById('dEmail').textContent   = d.email;
        document.getElementById('dAction').textContent  = d.action;
        document.getElementById('dEntity').textContent  = d.entity;
        document.getElementById('dEntityId').textContent= d.entityid;
        document.getElementById('dIp').textContent      = d.ip;
        document.getElementById('dUa').textContent      = d.ua;
        document.getElementById('dDelId').value         = d.id;

        const av = document.getElementById('dAvatar');
        av.style.background = '#' + d.abg;
        av.style.color = '#' + d.acl;
        av.innerHTML = d.avatar
            ? `<img src="${d.avatar}" style="width:100%;height:100%;object-fit:cover"/>`
            : d.initials;

        const st = document.getElementById('dStatus');
        st.innerHTML = d.success === 'true'
            ? `<span class="tag tag-green"><i class="bi bi-check-circle-fill"></i> Thành công</span>`
            : `<span class="tag tag-red"><i class="bi bi-x-circle-fill"></i> Thất bại</span>`;

        const errSection = document.getElementById('dErrSection');
        if (d.errmsg && d.errmsg.trim()) {
            document.getElementById('dErrMsg').textContent = d.errmsg;
            errSection.style.display = 'block';
        } else {
            errSection.style.display = 'none';
        }

    function closeDetail() {
        const detail = document.getElementById('detailPanel');
        detail.classList.remove('open');
        document.getElementById('detailEmpty').style.display = 'flex';
        document.getElementById('detailBody').style.display  = 'none';
        document.getElementById('detailCloseBtn').style.display = 'none';
        if (activeRow) { activeRow.classList.remove('active'); activeRow = null; }
    }
    }

    /* ── QUICK SEARCH ── */
    document.getElementById('quickSearch').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.log-row').forEach(r => {
            r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });

    /* ── SORT ── */
    let sortAsc = false;
    function sortByDate() {
        sortAsc = !sortAsc;
        const c = document.getElementById('logRows');
        [...c.querySelectorAll('.log-row')]
            .sort((a,b) => {
                const parse = s => {
                    const [date, time] = s.split(' ');
                    const [d,m,y] = date.split('/');
                    return new Date(`${y}-${m}-${d}T${time}`);
                };
                return sortAsc ? parse(a.dataset.ts) - parse(b.dataset.ts)
                               : parse(b.dataset.ts) - parse(a.dataset.ts);
            })
            .forEach(r => c.appendChild(r));
    }

    /* ── PAGINATION ── */
    function goPage(p) {
        const url = new URL(window.location.href);
        url.searchParams.set('page', p);
        window.location.href = url.toString();
    }
</script>
}
